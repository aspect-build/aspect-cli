# Pre-serialized protobuf blobs for Command and Action: /bin/sh -c "echo it worked!"
#
# Recompute with:
#   python3 -c "
#   import hashlib
#   def v(n):
#       o=[]
#       while True:
#           b=n&0x7f;n>>=7;o.append(b|0x80 if n else b)
#           if not n:break
#       return bytes(o)
#   def fl(fn,d):
#       if isinstance(d,str):d=d.encode()
#       return v((fn<<3)|2)+v(len(d))+d
#   args=['/bin/sh','-c','echo it worked!']
#   cmd=b''.join(fl(1,a) for a in args)
#   ch=hashlib.sha256(cmd).hexdigest();cs=len(cmd)
#   eh=hashlib.sha256(b'').hexdigest()
#   def dp(h,s):
#       d=fl(1,h)
#       if s:d+=v((2<<3)|0)+v(s)
#       return d
#   act=fl(1,dp(ch,cs))+fl(2,dp(eh,0))+v((7<<3)|0)+v(1)
#   ah=hashlib.sha256(act).hexdigest();acs=len(act)
#   print('CMD:', ch, cs, cmd.hex())
#   print('ACT:', ah, acs, act.hex())
#   "

_CMD_HASH  = "53ddf04cefcb5d352bb879c7e200faf0fe24e3b046efc39f8295a69555164994"
_CMD_SIZE  = 31
_ACT_HASH  = "e505ffe8041e134179c7c6a331590ab4bc77ee22605ee89f8deb257fa6617165"
_ACT_SIZE  = 140
_EMPTY_HASH = "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

_CMD_BYTES = bytes("0a072f62696e2f73680a022d630a106563686f20697420776f726b65645c21")
_ACT_BYTES = bytes("0a440a4035336464663034636566636235643335326262383739633765323030666166306665323465336230343665666333396638323935613639353535313634393934101f12420a40653362306334343239386663316331343961666266346338393936666239323432376165343165343634396239333463613439353939316237383532623835353801")

RemoteRunConfig = fragment(
    uri           = attr(str, "grpc://localhost:8980"),
    instance_name = attr(str, ""),
)

def _impl(ctx):
    cfg = ctx.fragments[RemoteRunConfig]

    # ── CAS: upload Command and Action blobs ──────────────────────────────
    cas = remote.execution.ContentAddressableStorage(uri=cfg.uri, headers={})
    cas.connect(ctx)

    upload_resp = cas.BatchUpdateBlobs(
        remote.execution.v2.BatchUpdateBlobsRequest(
            instance_name = cfg.instance_name,
            requests = [
                remote.execution.v2.batch_update_blobs_request.Request(
                    digest = remote.execution.v2.Digest(hash=_CMD_HASH, size_bytes=_CMD_SIZE),
                    data   = _CMD_BYTES,
                ),
                remote.execution.v2.batch_update_blobs_request.Request(
                    digest = remote.execution.v2.Digest(hash=_ACT_HASH, size_bytes=_ACT_SIZE),
                    data   = _ACT_BYTES,
                ),
            ],
        ),
    )
    print("uploaded:", upload_resp)

    # ── Execution: submit and stream operations ───────────────────────────
    exec_svc = remote.execution.Execution(uri=cfg.uri, headers={})
    exec_svc.connect(ctx)

    stream = exec_svc.Execute(
        remote.execution.v2.ExecuteRequest(
            instance_name     = cfg.instance_name,
            action_digest     = remote.execution.v2.Digest(hash=_ACT_HASH, size_bytes=_ACT_SIZE),
            skip_cache_lookup = True,
        ),
    )

    for op in stream:
        print("operation:", op.name, "  done:", op.done)

    return 0

remote_run = task(
    name           = "remote-run",
    group          = ["remote"],
    implementation = _impl,
    fragments      = [RemoteRunConfig],
    args           = {},
)
