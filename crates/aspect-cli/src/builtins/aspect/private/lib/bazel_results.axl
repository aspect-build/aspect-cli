def _bucket_header(bucket, count):
    """Build the 'N <Thing>(s)' header string for a bucket."""
    raw = _BUCKET_HEADERS.get(bucket, "")
    plural = "s" if count != 1 else ""
    return str(count) + " " + raw.replace("{s}", plural)

def _is_test_kind(kind):
    """True when a Bazel rule kind is a test (convention: ends in `_test`)."""
    return kind.endswith("_test") if kind else False

def _pad_right(s, width):
    """Pad s with trailing spaces to at least `width` characters. No truncation."""
    n = width - len(s)
    if n <= 0:
        return s
    return s + " " * n

# Column header strings for target-list tables in <pre> blocks.
_TABLE_HDR_LABEL = "Label"
_TABLE_HDR_KIND = "Target Type"
_TABLE_HDR_DURATION = "Duration"
_TABLE_HDR_ARTIFACTS = "Artifacts"
_TABLE_HDR_MNEMONIC = "Mnemonic"

# Task-timing columns. Same `<pre>`-aligned shape as target/test tables.
_TT_HDR_PHASE = "Phase"
_TT_HDR_DESCRIPTION = "Description"
_TT_HDR_DURATION = "Duration"

# Max label length in target lists; longer labels truncate to exactly this with
# a `...` suffix (the 3 dots included) so <pre> columns stay readable.
_LABEL_MAX_LEN = 90

def _truncate_label(s):
    """Cap a target label at _LABEL_MAX_LEN with a `...` suffix when longer."""
    if not s or len(s) <= _LABEL_MAX_LEN:
        return s
    return s[:_LABEL_MAX_LEN - 3] + "..."

def _artifact_anchors(entry):
    """Build a test entry's Artifacts cell. Returns (html, visible_width).

    html is the <pre> string (HTML <a> tags or ""); visible_width is the rendered
    width (e.g. "log xml" = 7) for column alignment, ignoring the <a> markup.
    """
    parts_html = []
    parts_visible = []
    if entry.get("log_url"):
        parts_html.append('<a href="' + entry["log_url"] + '">log</a>')
        parts_visible.append("log")
    if entry.get("xml_url"):
        parts_html.append('<a href="' + entry["xml_url"] + '">xml</a>')
        parts_visible.append("xml")
    html = " ".join(parts_html)
    visible = " ".join(parts_visible)
    return html, len(visible)

def _align_for_pre(entries, has_duration = True, has_mnemonic = False):
    """Build a column-aligned table for <pre> rendering.

    Columns: label, kind (always); duration (has_duration); artifacts (auto from
    log_url/xml_url); mnemonic (has_mnemonic, build failures). Returns
    {rows, header, separator} where rows carry aligned_* fields per present
    column. Columns pad to max(header, widest value); the artifacts column uses
    *visible* anchor width (not raw HTML) so <pre> alignment survives link rendering.
    """
    if not entries:
        return {"rows": [], "header": "", "separator": ""}

    label_w = len(_TABLE_HDR_LABEL)
    kind_w = len(_TABLE_HDR_KIND)
    dur_w = len(_TABLE_HDR_DURATION) if has_duration else 0
    mnemonic_w = len(_TABLE_HDR_MNEMONIC) if has_mnemonic else 0
    artifacts_w = 0

    # Pre-build artifact cells to use their visible width for alignment.
    artifact_cells = []
    for e in entries:
        html, vis_w = _artifact_anchors(e)
        artifact_cells.append((html, vis_w))
        if vis_w > artifacts_w:
            artifacts_w = vis_w

    has_artifacts = artifacts_w > 0
    if has_artifacts and artifacts_w < len(_TABLE_HDR_ARTIFACTS):
        artifacts_w = len(_TABLE_HDR_ARTIFACTS)

    for e in entries:
        lbl = e.get("label", "") or ""
        knd = e.get("kind", "") or ""
        if len(lbl) > label_w:
            label_w = len(lbl)
        if len(knd) > kind_w:
            kind_w = len(knd)
        if has_duration:
            dur = e.get("duration", "") or ""
            if len(dur) > dur_w:
                dur_w = len(dur)
        if has_mnemonic:
            mn = e.get("mnemonic", "") or ""
            if len(mn) > mnemonic_w:
                mnemonic_w = len(mn)

    hdr_cells = [_pad_right(_TABLE_HDR_LABEL, label_w), _pad_right(_TABLE_HDR_KIND, kind_w)]
    if has_duration:
        hdr_cells.append(_pad_right(_TABLE_HDR_DURATION, dur_w))
    if has_mnemonic:
        hdr_cells.append(_pad_right(_TABLE_HDR_MNEMONIC, mnemonic_w))
    if has_artifacts:
        hdr_cells.append(_pad_right(_TABLE_HDR_ARTIFACTS, artifacts_w))
    header = " | ".join(hdr_cells)

    # `-+-` join so `+` lands under each `|` in the data rows.
    sep_cells = ["-" * label_w, "-" * kind_w]
    if has_duration:
        sep_cells.append("-" * dur_w)
    if has_mnemonic:
        sep_cells.append("-" * mnemonic_w)
    if has_artifacts:
        sep_cells.append("-" * artifacts_w)
    separator = "-+-".join(sep_cells)

    rows = []
    for i in range(len(entries)):
        e = entries[i]
        row = dict(e)
        row["aligned_label"] = _pad_right(e.get("label", "") or "", label_w)
        row["aligned_kind"] = _pad_right(e.get("kind", "") or "", kind_w)
        if has_duration:
            row["aligned_duration"] = _pad_right(e.get("duration", "") or "", dur_w)
        if has_mnemonic:
            row["aligned_mnemonic"] = _pad_right(e.get("mnemonic", "") or "", mnemonic_w)
        if has_artifacts:
            html, vis_w = artifact_cells[i]

            # Pad on visible width (not the raw HTML length).
            pad = " " * (artifacts_w - vis_w) if artifacts_w > vis_w else ""
            row["aligned_artifacts"] = html + pad
        rows.append(row)
    return {"rows": rows, "header": header, "separator": separator, "has_artifacts": has_artifacts}

def _align_task_timing_for_pre(entries, total_duration = ""):
    """Build a column-aligned <pre> table for the Task timing section.

    Columns: Phase | Description | Duration (same shape as `_align_for_pre`).
    `total_duration` (formatted ctx.task.elapsed_ms), when set, adds an aligned
    `Total` row mirroring the header strip's `⏱` total.

    Returns {rows ({aligned_name, aligned_description, aligned_duration}),
    header, separator, total_separator (between phase rows and Total; "" when no
    total), total_line ("" when no total)}.
    """
    if not entries:
        return {
            "rows": [],
            "header": "",
            "separator": "",
            "total_separator": "",
            "total_line": "",
        }

    # `-> ` marks the active row's Phase cell. Only reserved when an `is_active`
    # entry exists (live emits); terminal renders flush with no prefix column.
    _ACTIVE_PREFIX = "-> "
    _BLANK_PREFIX = " " * len(_ACTIVE_PREFIX)
    has_active = any([e.get("is_active") for e in entries])
    prefix_w = len(_ACTIVE_PREFIX) if has_active else 0
    inactive_prefix = _BLANK_PREFIX if has_active else ""

    name_w = prefix_w + len(_TT_HDR_PHASE)
    desc_w = len(_TT_HDR_DESCRIPTION)
    dur_w = len(_TT_HDR_DURATION)

    # Include total in width calc so the Total row aligns.
    total_label = "Total"
    if prefix_w + len(total_label) > name_w:
        name_w = prefix_w + len(total_label)
    if total_duration and len(total_duration) > dur_w:
        dur_w = len(total_duration)

    for e in entries:
        n = e.get("name", "") or ""
        d = e.get("description", "") or ""
        dur = e.get("duration", "") or ""
        row_prefix_len = prefix_w if (has_active and not e.get("is_active")) else (len(_ACTIVE_PREFIX) if e.get("is_active") else 0)
        if row_prefix_len + len(n) > name_w:
            name_w = row_prefix_len + len(n)
        if len(d) > desc_w:
            desc_w = len(d)
        if len(dur) > dur_w:
            dur_w = len(dur)

    header = " | ".join([
        _pad_right(inactive_prefix + _TT_HDR_PHASE, name_w),
        _pad_right(_TT_HDR_DESCRIPTION, desc_w),
        _pad_right(_TT_HDR_DURATION, dur_w),
    ])
    separator = "-+-".join(["-" * name_w, "-" * desc_w, "-" * dur_w])

    rows = []
    for e in entries:
        if e.get("is_active"):
            prefix = _ACTIVE_PREFIX
        elif has_active:
            prefix = _BLANK_PREFIX
        else:
            prefix = ""
        rows.append({
            "aligned_name": _pad_right(prefix + (e.get("name", "") or ""), name_w),
            "aligned_description": _pad_right(e.get("description", "") or "", desc_w),
            "aligned_duration": _pad_right(e.get("duration", "") or "", dur_w),
        })

    total_line = ""
    total_separator = ""
    if total_duration:
        # Delimiter so the Total row stands apart from the phase rows.
        total_separator = separator
        total_line = " | ".join([
            _pad_right(inactive_prefix + total_label, name_w),
            _pad_right("", desc_w),
            _pad_right(total_duration, dur_w),
        ])

    return {
        "rows": rows,
        "header": header,
        "separator": separator,
        "total_separator": total_separator,
        "total_line": total_line,
    }

def _render_counter_pre(counter, name_col, name_display = None, count_col = "Count", pct_col = "%", limit = 15):
    """Render a {name -> count} dict as a column-aligned <pre> body string.

    Sorted by count desc then name asc; at most `limit` rows plus a "…N more"
    footer. Each row shows comma-formatted count + percent of total.
    `name_display` is an optional name -> display fn. Returns "" when empty
    (no wrapping <pre> tags).
    """
    if not counter:
        return ""
    items = sorted(
        [(k, counter[k]) for k in counter],
        key = lambda x: (-x[1], x[0]),
    )
    total = 0
    for (_, c) in items:
        total += c
    shown = items[:limit]
    more_count = len(items) - len(shown)
    more_tally = 0
    for i in range(len(shown), len(items)):
        more_tally += items[i][1]

    name_w = len(name_col)
    count_w = len(count_col)
    pct_w = len(pct_col)

    formatted = []
    for (name, count) in shown:
        display = name_display(name) if name_display else name
        pct_tenths = (count * 1000) // total if total > 0 else 0
        pct_str = str(pct_tenths // 10) + "." + str(pct_tenths % 10) + "%"
        c_str = format_int_comma(count)
        formatted.append({"name": display, "count": c_str, "pct": pct_str})
        if len(display) > name_w:
            name_w = len(display)
        if len(c_str) > count_w:
            count_w = len(c_str)
        if len(pct_str) > pct_w:
            pct_w = len(pct_str)

    header = _pad_right(name_col, name_w) + " | " + _pad_right(count_col, count_w) + " | " + _pad_right(pct_col, pct_w)
    sep = "-" * name_w + "-+-" + "-" * count_w + "-+-" + "-" * pct_w
    lines = [header, sep]
    for r in formatted:
        lines.append(_pad_right(r["name"], name_w) + " | " + _pad_right(r["count"], count_w) + " | " + _pad_right(r["pct"], pct_w))
    if more_count > 0:
        lines.append("…" + str(more_count) + " more (" + format_int_comma(more_tally) + " actions)")
    return "\n".join(lines)

def _failed_action_labels(data):
    """Unique target labels whose actions failed.

    Uses the process_event-populated list; falls back to deriving from
    failed_actions (test fixtures that bypass the event pipeline).
    """
    labels = data["bazel"].get("failed_action_labels", [])
    if labels:
        return list(labels)
    seen = {}
    for a in data["bazel"].get("failed_actions", []):
        lbl = a.get("label", "")
        if lbl:
            seen[lbl] = True
    return list(seen.keys())

def _compute_bucket_counts(data):
    """Count targets per bucket. Returns dict[bucket -> int].

    Sources: failed_actions/failed_targets → FAILED_TO_BUILD; failed_tests by
    .status → TEST_FAILED/TIMEOUT/FAILED_TO_BUILD; flaky_tests → TEST_FLAKY;
    passed_tests by .cached → TEST_PASSED/_CACHED; skipped_targets → SKIPPED;
    non-test built_targets → SUCCESSFUL_BUILD; aborted flag → ABORTED_STATE.
    """
    counts = {b: 0 for b in _BUCKET_DISPLAY_ORDER}
    if data["bazel"].get("aborted", False):
        counts[_BUCKET_ABORTED_STATE] = 1

    # Count root failures only (own action failed), not derived dep-broken ones.
    # failed_actions is authoritative; fall back to failed_targets (mid-stream / older BES).
    _root_action_labels = _failed_action_labels(data)
    if _root_action_labels:
        counts[_BUCKET_FAILED_TO_BUILD] = len(_root_action_labels)
    else:
        counts[_BUCKET_FAILED_TO_BUILD] = len(data["bazel"].get("failed_targets", []))
    for t in data["bazel"].get("failed_tests", []):
        s = t.get("status", "failed")
        if s == "timeout":
            counts[_BUCKET_TEST_TIMEOUT] += 1
        elif s == "failed_to_build":
            counts[_BUCKET_FAILED_TO_BUILD] += 1
        else:
            counts[_BUCKET_TEST_FAILED] += 1
    counts[_BUCKET_TEST_FLAKY] = data["bazel"].get("flaky_test_total", 0)
    passed_cached = data["bazel"].get("cached_test_total", 0)
    passed_total = data["bazel"].get("passed_test_total", 0)
    counts[_BUCKET_TEST_PASSED_CACHED] = passed_cached
    counts[_BUCKET_TEST_PASSED] = passed_total - passed_cached if passed_total > passed_cached else 0

    # Uncapped (the list is capped at MAX_BUILT_TARGETS).
    skipped_total = data["bazel"].get("skipped_targets_total", 0)
    counts[_BUCKET_SKIPPED] = skipped_total

    # successful = targets_total − failed − skipped − tests (counted via *_TEST_*).
    # Aggregates only; the capped built_targets sample would under-count.
    successful_target_count = (data["bazel"].get("targets_total", 0) -
                               len(data["bazel"].get("failed_targets", [])) -
                               skipped_total)
    if successful_target_count < 0:
        successful_target_count = 0
    test_target_count = passed_total + data["bazel"].get("failed_test_total", 0) + data["bazel"].get("flaky_test_total", 0)
    non_test_built = successful_target_count - test_target_count if successful_target_count > test_target_count else 0
    counts[_BUCKET_SUCCESSFUL_BUILD] = non_test_built
    return counts

# Buckets that can label a failed invocation, in priority order. ABORTED is
# handled separately; FLAKY doesn't fail the build.
_FAILURE_BUCKETS = [
    _BUCKET_FAILED_TO_BUILD,
    _BUCKET_TEST_FAILED,
    _BUCKET_TEST_TIMEOUT,
]

def compute_invocation_state(data, status):
    """Return the invocation-state label for the title.

    Walks priority groups top-down; first group with a non-empty bucket wins
    (in-group order is the tiebreaker). "Running..." while in progress (partial
    data isn't authoritative). When status == "failed", restricts to
    `_FAILURE_BUCKETS` and falls back to "Failed to build" — else an
    analysis-phase failure (no failed_action/target) would read "Successful build".
    """

    # Aborted: fixed label regardless of what else ran.
    if data["bazel"].get("aborted", False):
        return _BUCKET_INVOCATION_LABELS[_BUCKET_ABORTED_STATE]

    # In-progress: always Running... regardless of mid-stream failures.
    if status in ("running", "failing"):
        return _BUCKET_INVOCATION_LABELS[_BUCKET_PENDING]
    counts = _compute_bucket_counts(data)

    if status == "failed":
        for bucket in _FAILURE_BUCKETS:
            if counts.get(bucket, 0) > 0:
                return _BUCKET_INVOCATION_LABELS[bucket]
        return _BUCKET_INVOCATION_LABELS[_BUCKET_FAILED_TO_BUILD]

    for group in _BUCKET_PRIORITY_GROUPS:
        for bucket in group:
            if counts.get(bucket, 0) > 0:
                return _BUCKET_INVOCATION_LABELS[bucket]
    return ""

_REDACTED = "<REDACTED>"

# Bazel flags whose values are gRPC/HTTP headers — always redacted (carry
# bearer tokens, API keys, cookies).
_HEADER_OPTION_NAMES = [
    "remote_header",
    "remote_cache_header",
    "remote_exec_header",
    "remote_downloader_header",
    "bes_header",
]

# Bazel `--foo=KEY=VALUE` env-passthrough flags. VALUE is redacted unless KEY is
# on the ALLOW_ENV allowlist. `common_env` deliberately omitted (not standard).
_ENV_VAR_OPTION_NAMES = [
    "action_env",
    "client_env",
    "host_action_env",
    "repo_env",
    "test_env",
]

# Env vars expected to hold a git repo URL: stay visible but any user:password
# prefix is scrubbed. Common CI-provided git-url vars.
_KNOWN_GIT_REPO_URL_KEYS = [
    "REPO_URL",
    "GIT_URL",
    "TRAVIS_REPO_SLUG",
    "BUILDKITE_REPO",
    "GIT_REPOSITORY_URL",
    "CIRCLE_REPOSITORY_URL",
    "GITHUB_REPOSITORY",
    "CI_REPOSITORY_URL",
]

# Default ALLOW_ENV: CI/VCS identifiers publicly safe to surface (commit SHA,
# branch, PR number, run ID, repo URL). Unrecognized vars are redacted by
# default. Override via `--build_metadata=ALLOW_ENV=MY_VAR,OTHER_*`.
_DEFAULT_ALLOW_ENV = [
    # Who ran the build.
    "USER",
    "GITHUB_ACTOR",
    "BUILDKITE_BUILD_CREATOR",
    "GITLAB_USER_NAME",
    "CIRCLE_USERNAME",
    # Repo URLs (creds stripped separately, see _KNOWN_GIT_REPO_URL_KEYS).
    "GITHUB_REPOSITORY",
    "BUILDKITE_REPO",
    "TRAVIS_REPO_SLUG",
    "GIT_URL",
    "GIT_REPOSITORY_URL",
    "CI_REPOSITORY_URL",
    "REPO_URL",
    "CIRCLE_REPOSITORY_URL",
    # Commit SHAs.
    "GITHUB_SHA",
    "CIRCLE_SHA1",
    "BUILDKITE_COMMIT",
    "TRAVIS_COMMIT",
    "BITRISE_GIT_COMMIT",
    "GIT_COMMIT",
    "VOLATILE_GIT_COMMIT",
    "CI_COMMIT_SHA",
    "COMMIT_SHA",
    # Run identifiers + URLs.
    "GITHUB_RUN_ID",
    "BUILDKITE_BUILD_URL",
    "BUILDKITE_JOB_ID",
    # Branches / refs.
    "GITHUB_HEAD_REF",
    "GITHUB_REF",
    "CIRCLE_BRANCH",
    "BUILDKITE_BRANCH",
    "TRAVIS_BRANCH",
    "BITRISE_GIT_BRANCH",
    "GIT_BRANCH",
    "CI_COMMIT_BRANCH",
    "CI_MERGE_REQUEST_SOURCE_BRANCH_NAME",
    # Generic CI flags.
    "CI",
    "CI_RUNNER",
]

# Env values always safe regardless of allowlist (no-op markers + booleans,
# never secrets). Boolean comparison is case-insensitive.
_SAFE_ENV_VALUES_LITERAL = ["", "0", "1"]
_SAFE_ENV_VALUES_BOOL = ["true", "false"]

def _allow_env_patterns(metadata):
    """Resolve ALLOW_ENV glob patterns from --build_metadata=ALLOW_ENV=...

    Comma-separated globs; falls back to _DEFAULT_ALLOW_ENV. A single `*` allows
    everything.
    """
    raw = (metadata or {}).get("ALLOW_ENV", "")
    if not raw:
        return _DEFAULT_ALLOW_ENV
    return [p.strip() for p in raw.split(",") if p.strip()]

def _is_allowed_env(key, allow_env):
    """True when KEY is on the allowlist (case-insensitive, globs supported).

    Lowercases both sides and delegates to path_glob.match_path; ALLOW_ENV globs
    have no `/`, so the path-aware matcher behaves identically.
    """
    key_lc = key.lower()
    for pat in allow_env:
        if pat == "*" or match_path(pat.lower(), key_lc):
            return True
    return False

def _is_safe_env_value(value):
    """True for values always safe regardless of allowlist: empty, `0`, `1`,
    `true`/`false` (case-insensitive) — booleanish flags carry no secret.
    """
    if value in _SAFE_ENV_VALUES_LITERAL:
        return True
    lowered = value.lower()
    for b in _SAFE_ENV_VALUES_BOOL:
        if lowered == b:
            return True
    return False

def _strip_url_creds(s):
    """Redact the user:password prefix in any embedded URL in `s`.

    `scheme://user:password@host` → `scheme://user:<REDACTED>@host`. Scheme must
    start with a letter then scheme-legal chars (alnum, `+-.`). Handles ~10 URLs
    per string.
    """
    if "://" not in s:
        return s
    result = s
    cursor = 0
    for _ in range(10):
        idx = result.find("://", cursor)
        if idx < 0:
            break

        # Walk back to scheme start; require ≥1 alpha char.
        scheme_start = idx
        i = idx - 1
        for _ in range(64):
            if i < 0:
                break
            c = result[i]
            is_alpha = (c >= "a" and c <= "z") or (c >= "A" and c <= "Z")
            is_digit = c >= "0" and c <= "9"
            if is_alpha or is_digit or c == "+" or c == "-" or c == ".":
                scheme_start = i
                i -= 1
            else:
                break

        # Scheme must start with a letter.
        first = result[scheme_start]
        is_first_alpha = (first >= "a" and first <= "z") or (first >= "A" and first <= "Z")
        if not is_first_alpha or scheme_start == idx:
            cursor = idx + 3
            continue

        # `:` separating user from password (before `@`/whitespace/end).
        colon = -1
        for j in range(idx + 3, len(result)):
            c = result[j]
            if c == ":":
                colon = j
                break
            if c == "@" or c == " " or c == "\t" or c == "\r" or c == "\n":
                break
        if colon < 0:
            cursor = idx + 3
            continue

        # Find the `@` that closes the userinfo.
        at = -1
        for j in range(colon + 1, len(result)):
            c = result[j]
            if c == "@":
                at = j
                break
            if c == " " or c == "\t" or c == "\r" or c == "\n":
                break
        if at < 0:
            cursor = idx + 3
            continue

        # Redact the password slot.
        result = result[:colon + 1] + _REDACTED + result[at:]
        cursor = colon + 1 + len(_REDACTED) + 1
    return result

def _split_combined_form(arg):
    """Split `--flag=value` into (`--flag`, `value`) on the first `=`; empty
    value when no `=`.
    """
    eq = arg.find("=")
    if eq < 0:
        return (arg, "")
    return (arg[:eq], arg[eq + 1:])

def _is_header_option(name):
    """True when `name` (bare flag name, no leading `--`) is a header option."""
    for h in _HEADER_OPTION_NAMES:
        if name == h:
            return True
    return False

def _is_env_option(name):
    """True when `name` (bare flag name, no leading `--`) is an env-passthrough."""
    for e in _ENV_VAR_OPTION_NAMES:
        if name == e:
            return True
    return False

def _redact_env_value(value, allow_env):
    """Redact the value of an env-passthrough flag (`VAR=stuff`).

    Preserves wrapping `"`/`'` quotes. No `=` (e.g. `--action_env=FOO` inherit)
    → as-is. Known git-URL vars keep the URL but strip creds. Safe values
    (""/0/1/true/false) never redacted. Else redact when not allowlisted.
    """
    if not value:
        return value

    first = value[0]
    last = value[-1] if len(value) > 0 else ""
    if (first == "\"" or first == "'") and last == first and len(value) >= 2:
        inner = value[1:-1]
        return first + _redact_env_value(inner, allow_env) + first

    eq = value.find("=")
    if eq < 0:
        return value
    var_name = value[:eq]
    var_value = value[eq + 1:]

    if _is_safe_env_value(var_value):
        return var_name + "=" + var_value

    # Known git-URL vars: keep URL, strip creds.
    upper_name = var_name.upper()
    for key in _KNOWN_GIT_REPO_URL_KEYS:
        if upper_name == key:
            return var_name + "=" + _strip_url_creds(var_value)

    # Allowlisted → show value (creds stripped as belt-and-suspenders).
    if _is_allowed_env(var_name, allow_env):
        return var_name + "=" + _strip_url_creds(var_value)
    return var_name + "=" + _REDACTED

def _redact_header_value(value):
    """Redact a request-header flag value, keeping the header name. Bazel accepts
    `Name=Value` and `Name: Value`, so split on the first `=` or `:`:
      `X-Aspect=tok` -> `X-Aspect=<REDACTED>`
      `Authorization: Bearer t` -> `Authorization:<REDACTED>`
    No separator → fully redacted.
    """
    eq = value.find("=")
    colon = value.find(":")
    seps = [i for i in [eq, colon] if i >= 0]
    if not seps:
        return _REDACTED
    i = min(seps)
    return value[:i + 1] + _REDACTED

def _redact_arg(arg, allow_env):
    """Redact one command-line token:

      1. Header flags → name kept, value <REDACTED> (`_redact_header_value`).
      2. Env-passthrough → value per allowlist/safe/git-URL (`_redact_env_value`).
      3. Other flag values → URL creds stripped.

    Non-flag tokens pass through (subcommands, target patterns).
    """
    if not arg.startswith("--"):
        return _strip_url_creds(arg)
    name, value = _split_combined_form(arg)

    bare = name[2:] if name.startswith("--") else name
    if _is_header_option(bare):
        return name + "=" + _redact_header_value(value)
    if _is_env_option(bare):
        return name + "=" + _redact_env_value(value, allow_env)

    # Generic flag — URL credential stripping only.
    if value:
        return name + "=" + _strip_url_creds(value)
    return arg

def _redact_args(args, allow_env):
    """Apply _redact_arg to each element of a list."""
    return [_redact_arg(a, allow_env) for a in args]

# Chars safe to leave unquoted in a shell token; anything else triggers quoting.
_SHELL_SAFE_CHARS = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_=./:@,+%"

def _shell_quote(s):
    """Single-quote s if it has whitespace/unsafe chars. Embedded `'` escaped via
    the POSIX `'\\''` idiom; empty → `''`; all-safe tokens returned untouched.
    """
    if not s:
        return "''"
    for i in range(len(s)):
        if s[i] not in _SHELL_SAFE_CHARS:
            return "'" + s.replace("'", "'\\''") + "'"
    return s

def _is_shell_safe(s):
    """True when s contains only characters that need no shell escaping."""
    if not s:
        return True
    for i in range(len(s)):
        if s[i] not in _SHELL_SAFE_CHARS:
            return False
    return True

def _quote_flag(token):
    """Shell-quote a flag for a copy-pasteable command.

    For `--flag=value` the quote starts after `=` so the name stays readable
    (`--build_metadata=KEY=hello world` → `--build_metadata='KEY=hello world'`).
    Tokens without `=` (incl. space-separated "flag value" forms Bazel emits as
    one string) fall back to whole-token quoting, as do non-flag tokens.
    """
    if not token:
        return "''"

    # Value-only quoting requires a shell-safe `--name=` prefix; an unsafe flag
    # name would slip past a value-quoted token.
    if token.startswith("--") and "=" in token:
        idx = token.index("=")
        flag_part = token[:idx + 1]  # includes `=`
        value = token[idx + 1:]
        if _is_shell_safe(flag_part):
            return flag_part + _shell_quote(value)
    return _shell_quote(token)

def _format_shell_command(head, flags, targets):
    """Format a reproducer as a multi-line backslash-continued shell command,
    one flag per line, targets last after a bare `--` (the Bazel/Unix idiom).
    Tokens must be pre-quoted by the caller.
    """
    if not head:
        return ""
    lines = [head]
    for f in flags:
        lines.append("  " + f)
    if targets:
        # `--` only matters with flags to disambiguate from; skip it otherwise.
        if flags:
            lines.append("  --")
        for t in targets:
            lines.append("  " + t)
    return " \\\n".join(lines)

# Max length for the one-line <details> summary preview; longer gets ellipsized.
_EXPLICIT_SHORT_MAX = 120

def _assemble_explicit_command(build_command, target_pattern, explicit_cmd_line, allow_env):
    """Build both explicit-command forms for the details:
        {"short": "bazel test //foo:bar",  # <details> summary
         "long":  "bazel test \\\n  --flag=val \\\n  -- \\\n  //foo:bar"}
    Each token is redacted then shell-quoted only if needed. Empty strings when
    no build_command.
    """
    if not build_command:
        return {"short": "", "long": ""}

    redacted = _redact_args(explicit_cmd_line or [], allow_env)
    flags = [_quote_flag(a) for a in redacted]

    # One target per line in `long`.
    target_tokens = []
    if target_pattern:
        for t in target_pattern.split(" "):
            if t:
                target_tokens.append(_shell_quote(t))

    head = "bazel " + build_command

    # Short form skips flags.
    short_parts = [head]
    short_parts.extend(target_tokens)
    short = " ".join(short_parts)
    if len(short) > _EXPLICIT_SHORT_MAX:
        short = short[:_EXPLICIT_SHORT_MAX - 1] + "…"

    long_form = _format_shell_command(head, flags, target_tokens)
    return {"short": short, "long": long_form}

def _sorted_dedup(args, allow_env):
    """Redact + sort + dedup + shell-quote, for browseable option lists. Sort is
    on the pre-quote form so quoted/unquoted variants don't end up adjacent.
    """
    redacted = _redact_args(args or [], allow_env)
    unique = sorted(set(redacted))
    return [_quote_flag(a) for a in unique]

def render_bes_url(data: dict) -> str:
    """Full BES results URL from `data["bazel"]`, or "" when unavailable.

    Keyed on Bazel's own `invocation_id` (the --bes_results_url backend only
    sees that UUID). BES counterpart to `aspect_web_ui_url`, which keys on
    sink_invocation_id.
    """
    base = data["bazel"].get("bes_results_url", "")
    inv = data["bazel"].get("invocation_id", "")
    if not base or not inv:
        return ""
    return _join_url(base, inv)

def format_run_date(ctx, epoch_ms):
    """Format an epoch-ms timestamp as a human-readable date (e.g.
    `Sun May 10 07:16:05 UTC 2026`). Single source of truth across all status
    surfaces.

    Shells out to `date` cross-platform via `sh -c "macOS form || Linux form"`
    (`date -r <s>` / `date -d @<s>`). No `-u`: `date` honors `$TZ` then
    /etc/localtime, so workflows can set TZ to render in local time; `%Z` keeps
    the render honest about the clock. Returns "" on bad input or failure.
    """
    if not epoch_ms or epoch_ms <= 0:
        return ""
    epoch_s = str(epoch_ms // 1000)
    result = ctx.std.process.command("sh").args([
        "-c",
        "date -r " + epoch_s + " 2>/dev/null || date -d '@" + epoch_s + "'",
    ]).stdout("piped").stderr("piped").spawn().wait_with_output()
    if result.status.code == 0:
        val = result.stdout.strip()
        if val:
            return val
    return ""

# Must cover every status the task lifecycle emits — a missing key falls back to
# 🔄/"Running", leaving a finished task stuck on "Running" (e.g. a `warning`
# delivery). Icons mirror lib/result_text.axl.
STATUS_ICONS = {
    "passed": "✅",
    "failed": "❌",
    "failing": "⚠️",
    "warning": "⚠️",
    "aborted": "🔥",
    "running": "🔄",
}

STATUS_LABELS = {
    "passed": "Succeeded",
    "failed": "Failed",
    "failing": "Failing...",
    "warning": "Flagged",
    "aborted": "Aborted",
    "running": "Running...",
}

def ci_link_item(ctx, links):
    """Build the CI-host link item for the summary row. Prefers
    `links["ci_url"]` (may be a job-scoped deep link); falls back to
    `resolve_build_url`.
    """
    host = detect_ci_host(ctx.std.env)
    if not host:
        return None
    url = (links or {}).get("ci_url", "") or resolve_build_url(ctx)
    if not url:
        return None
    return {"icon": host["icon"], "value": "[%s](%s)" % (host["label"], url)}

def _titlecase(s):
    """Title-case the first char and turn `_` into spaces (e.g. `bazel_query` →
    `Bazel query`). Subsequent words stay lowercase — it's an identifier, not a
    sentence. Callers needing a richer label set `Phase.display_name`.
    """
    if not s:
        return s
    return s[0].upper() + s[1:].replace("_", " ")

# Hide the synthetic `init` phase (Aspect startup + trait setup before the first
# `phase()` mark) from the strip below this duration; above it, surface it.
# Caller-named phases are never hidden, even at 0ms. Matches Rust-side
# INIT_PHASE_HIDE_THRESHOLD_MS.
_INIT_PHASE_HIDE_THRESHOLD_MS = 50

def format_elapsed_with_phases(ctx, status):
    """Render the `⏱` item content for the surface header.

    Total leads; completed phases follow in chronological order. The "highlight"
    slot (between total and history, after ` | `) carries the attention phase:
    the active phase while running/failing, or the interrupted phase on terminal
    failure. With no highlight, history follows total after an em-dash.

    Shapes:
      No phases:                "12.4s"
      Running:                  "4m13s · 🔨 Build 4m11s | 🔧 Setup 1.7s · 🔍 Detect 1.2s"
      Failing:                  "4m13s · 🔨 Build (failing 4m11s) | 🔧 Setup 1.7s · 🔍 Detect 1.2s"
      Passed (terminal):        "46.8s — 🔧 Setup 1.7s · 🔍 Detect 1.2s · 🔨 Build 45.3s"
      Failed-during-phase:      "1m 15s · 🔨 Build (failed after 1m 12s) | 🌱 Init 2.3s"
      Failed-after-phase-bound: "1m 15s — 🌱 Init 2.3s · 🔨 Build 1m 12s"

    Phase emoji comes from `Phase(emoji=...)` on the snapshot (p.emoji /
    current.emoji). The active running phase drops `(active …)` (leading slot
    implies it); failure riders stay (triage info). `ctx.task.elapsed_ms`
    refreshes on read and the active phase auto-closes, so terminal snapshots
    show all phases completed. The synthetic init phase is hidden under
    `_INIT_PHASE_HIDE_THRESHOLD_MS`.
    """
    elapsed_ms = ctx.task.elapsed_ms
    if elapsed_ms <= 0:
        return ""

    text = format_duration_ms(elapsed_ms)
    phases = ctx.task.phases()
    current = ctx.task.current_phase()

    # Drop the negligible synthetic init phase.
    visible_phases = [
        p
        for p in phases
        if not (p.name == "init" and p.duration_ms < _INIT_PHASE_HIDE_THRESHOLD_MS)
    ]

    if not visible_phases and not current:
        return text

    is_failed = status == "failed"
    history = []
    highlight = ""
    for p in visible_phases:
        name_t = _phase_label(p.name, p.emoji, p.display_name)
        dur = format_duration_ms(p.duration_ms)
        if is_failed and p.interrupted and not highlight:
            # Phase active at the non-zero exit (auto-closed interrupted=True).
            highlight = "%s (failed after %s)" % (name_t, dur)
        else:
            history.append("%s %s" % (name_t, dur))
    if current:
        cur_dur = format_duration_ms(current.duration_ms)
        name_t = _phase_label(current.name, current.emoji, current.display_name)
        if status == "failed":
            # current_phase still set — render fires from inside `_impl` before auto-close.
            highlight = "%s (failed after %s)" % (name_t, cur_dur)
        elif status == "passed":
            # No highlight on terminal success — render in order.
            history.append("%s %s" % (name_t, cur_dur))
        elif status == "failing":
            highlight = "%s (failing %s)" % (name_t, cur_dur)
        else:  # running / unknown non-terminal
            highlight = "%s %s" % (name_t, cur_dur)

    if highlight and history:
        return "%s · %s | %s" % (text, highlight, " · ".join(history))
    if highlight:
        return "%s · %s" % (text, highlight)
    return "%s — %s" % (text, " · ".join(history))

def _phase_label(phase, emoji, display_name):
    """`<emoji> <Display name>` for the header phase strip. `emoji` (from
    `Phase(emoji=...)`) is omitted when empty. `display_name` (from
    `Phase(display_name=...)`) is used verbatim, else `_titlecase(phase)`.
    """
    name_t = display_name or _titlecase(phase)
    if emoji:
        return emoji + " " + name_t
    return name_t

def build_invocation_rows(ctx, data, render_ctx, status, links = None, run_date = "", extra_meta = None):
    """Build the summary rows for SUMMARY_TEMPLATE.

    Up to 7 rows, each a list of {icon, value}; empty rows excluded. See
    `DEVELOPMENT.md → Summary header rows` for the grouping rationale.

        Row 1 (status & timing):  status · date · elapsed
        Row 2 (actor & toolchain): user · host · CLI version
        Row 3 (VCS context):       repo · PR · branch · commit · trigger
        Row 4 (build content):     targets · actions · tests · tool · CPU · mode
        Row 5 (Workflows runner):  runner version · cloud · AZ · instance · ID
                                   (only on an Aspect Workflows runner)
        Row 6 (tags & custom):     custom links · tags
        Row 7 (external links):    Aspect Workflows · CI host
    """
    meta = merged_meta(data)
    vcs = vcs_info(meta)

    def _item(icon, value):
        return {"icon": icon, "value": value}

    # Row 1: status · date · elapsed.
    row1 = [_item(STATUS_ICONS.get(status, "🔄"), STATUS_LABELS.get(status, "Running"))]

    if run_date:
        row1.append(_item("📅", run_date))

    elapsed_text = format_elapsed_with_phases(ctx, status)
    if elapsed_text:
        row1.append(_item("⏱", elapsed_text))

    # Row 2: user · host · CLI version.
    row2 = []

    # Prefer a name, omit email — GFM autolinks `user@host.tld` into mailto: and
    # HTML-entity tricks don't help (GitHub decodes before the autolink scan).
    # Full "Name <email>" still appears in Build Metadata.
    commit_author_name = meta.get("COMMIT_AUTHOR_NAME", "")
    commit_author = meta.get("COMMIT_AUTHOR", "")
    commit_author_email = meta.get("COMMIT_AUTHOR_EMAIL", "")
    if commit_author_name:
        user_display = commit_author_name
    elif commit_author:
        # COMMIT_AUTHOR is "Name <email>"; strip the "<…>" tail.
        lt = commit_author.find(" <")
        user_display = commit_author[:lt] if lt > 0 else commit_author
    elif meta.get("USER", ""):
        user_display = meta["USER"]
    elif meta.get("BUILD_USER", ""):
        user_display = meta["BUILD_USER"]
    elif commit_author_email:
        # Backticks so GFM can't autolink the `@`.
        user_display = "`" + commit_author_email + "`"
    else:
        user_display = ""
    if user_display:
        row2.append(_item("👤", html_escape(user_display)))

    build_host = meta.get("BUILD_HOST", "")
    if build_host:
        row2.append(_item("🖥", html_escape(build_host)))

    # Use a Unicode `💎` (renders on every surface); a BK shortcode like
    # `:aspect:` would show as literal text on GHSC.
    cli_version = ctx.std.env.aspect_cli_version() if ctx else ""
    if cli_version:
        row2.append(_item("💎", "aspect-cli v" + cli_version))

    # Row 3: repo · PR · branch · commit · trigger.
    row3 = []
    if vcs:
        # Link text is repo name only — the icon tells the host.
        link_text = vcs["repo_name"] if vcs["repo_name"] else vcs["display_name"]
        row3.append(_item(vcs["icon"], "[" + link_text + "](" + vcs["repo_url"] + ")"))

        pr_id = meta.get("PR_ID", "")
        pr_number = meta.get("PR_NUMBER", "")
        if pr_id and pr_number:
            pr_url = vcs["repo_url"] + vcs["pr_path"] + "/" + pr_id
            row3.append(_item(":twisted_rightwards_arrows:", "[#" + pr_number + "](" + pr_url + ")"))
        elif pr_number:
            # No PR_ID for a deep link — show the number unlinked.
            row3.append(_item(":twisted_rightwards_arrows:", "#" + pr_number))

        branch = meta.get("BRANCH_NAME", "")
        if branch:
            branch_url = vcs["repo_url"] + vcs["tree_path"] + "/" + branch
            row3.append(_item("⎇", "[" + html_escape(branch) + "](" + branch_url + ")"))

        sha = meta.get("COMMIT_SHA", "")
        if sha:
            short_sha = sha[:7]
            commit_msg = meta.get("COMMIT_MESSAGE", "")
            if len(commit_msg) > 60:
                commit_msg = commit_msg[:60] + "…"
            display = short_sha + (" - " + html_escape(commit_msg) if commit_msg else "")
            commit_url = vcs["repo_url"] + vcs["commit_path"] + "/" + sha
            row3.append(_item("✏️", "[" + display + "](" + commit_url + ")"))
    else:
        # No VCS info — unlinked branch/commit.
        branch = meta.get("BRANCH_NAME", "")
        if branch:
            row3.append(_item("⎇", html_escape(branch)))
        sha = meta.get("COMMIT_SHA", "")
        if sha:
            short_sha = sha[:7] if len(sha) > 7 else sha
            commit_msg = meta.get("COMMIT_MESSAGE", "")
            if len(commit_msg) > 60:
                commit_msg = commit_msg[:60] + "…"
            display = short_sha + (" - " + html_escape(commit_msg) if commit_msg else "")
            row3.append(_item("✏️", display))

    trigger = _trigger_label(meta.get("RUN_TYPE", ""))
    if trigger:
        row3.append(_item("🏃", trigger))

    # Row 4: targets · actions · tests · tool · CPU · mode.
    row4 = []

    # Just the completed count; "configured" numbers live in Performance.
    targets_total = data["bazel"].get("targets_total", 0)
    if targets_total > 0:
        row4.append(_item("📦", pluralize(targets_total, "target")))

    # "N of M actions executed (X% cached)". Remote cache hits reclassified as
    # cached (see `_effective_action_cache_counts`). When executed==0, drop the
    # "0 of"/"executed" — "100% cached" says nothing ran.
    actions_executed_raw = data["bazel"].get("actions_executed", 0)
    actions_executed, cached, actions_total = _effective_action_cache_counts(data)
    if actions_total > 0:
        pct = (cached * 100) // actions_total
        if actions_executed == 0:
            row4.append(_item(
                "⚡",
                pluralize(actions_total, "action") + " (" + str(pct) + "% cached)",
            ))
        else:
            row4.append(_item(
                "⚡",
                format_int_comma(actions_executed) + " of " + format_int_comma(actions_total) + " actions executed (" + str(pct) + "% cached)",
            ))
    elif actions_executed_raw > 0:
        row4.append(_item("⚡", pluralize(actions_executed_raw, "action")))

    # Mirrors the actions format; same executed==0 collapse.
    pass_t = data["bazel"].get("passed_test_total", 0)
    fail_t = data["bazel"].get("failed_test_total", 0)
    flaky_t = data["bazel"].get("flaky_test_total", 0)
    total_tests = pass_t + fail_t + flaky_t
    if total_tests > 0:
        cached_t = data["bazel"].get("cached_test_total", 0)
        exec_t = total_tests - cached_t if total_tests > cached_t else 0
        pct = (cached_t * 100) // total_tests if total_tests > 0 else 0
        if exec_t == 0:
            row4.append(_item(
                ":test_tube:",
                pluralize(total_tests, "test") + " (" + str(pct) + "% cached)",
            ))
        else:
            row4.append(_item(
                ":test_tube:",
                format_int_comma(exec_t) + " of " + format_int_comma(total_tests) + " tests executed (" + str(pct) + "% cached)",
            ))

    tool_version = data["bazel"].get("build_tool_version", "")
    build_cmd = data["bazel"].get("build_command", "")
    if tool_version or build_cmd:
        tool_str = "bazel"
        if tool_version:
            tool_str += " v" + tool_version
        if build_cmd:
            tool_str += " " + build_cmd
        row4.append(_item("🔧", tool_str))

    # Invocation ID omitted here (long UUID, low at-a-glance value); it's in
    # the Invocation details section.

    cpu_arch = data["bazel"].get("cpu_arch", "")
    if cpu_arch:
        # 🎯 plays on `TARGET_CPU` — no chip emoji renders in GitHub check runs.
        row4.append(_item("🎯", cpu_arch))

    mode = data["bazel"].get("compilation_mode", "")
    if mode:
        row4.append(_item("⚙️", mode))

    # Row 5: Workflows runner hardware (only on a runner). Compact; full set is
    # in the `### Runner metadata` details section.
    row5 = []
    env = ctx.std.env
    if is_aspect_workflows_runner(env):
        version = env.var("ASPECT_WORKFLOWS_RUNNER_VERSION") or ""
        cloud = env.var("ASPECT_WORKFLOWS_RUNNER_CLOUD_PROVIDER") or ""
        az = env.var("ASPECT_WORKFLOWS_RUNNER_AZ") or ""
        itype = env.var("ASPECT_WORKFLOWS_RUNNER_INSTANCE_TYPE") or ""
        iid = env.var("ASPECT_WORKFLOWS_RUNNER_INSTANCE_ID") or ""
        if version:
            row5.append(_item("🚀", "Workflows runner v" + version))
        if cloud:
            row5.append(_item("☁️", display_cloud_provider(cloud)))
        if az:
            row5.append(_item("📍", az))
        if itype:
            row5.append(_item("💠", itype))
        if iid:
            row5.append(_item("🤖", iid))

    # Row 6: custom links · tags · pinned metadata. 🏷 = TAGS/TAG_*; 📌 =
    # operator-selected `--build_metadata=K=V` via the GHSC `metadata_keys` arg.
    row6 = []
    for lnk in parse_workflows_links(meta):
        row6.append(_item("🔗", "[" + lnk["text"] + "](" + lnk["url"] + ")"))
    for tag in parse_tags(meta):
        row6.append(_item("🏷", tag))
    for entry in (extra_meta or []):
        row6.append(_item("📌", entry["key"] + " = " + entry["value"]))

    # Row 7: external links (Aspect Workflows · CI host).
    row7 = []

    # Keyed on sink_invocation_id (resolve_aspect_url).
    aspect_url = (links or {}).get("aspect_url", "") or ""
    if aspect_url:
        row7.append(_item("✨", "[Aspect](" + aspect_url + ")"))

    # Keyed on Bazel's invocation_id; complementary to Aspect (distinct backend +
    # UUID), shown alongside when both configured.
    bes_url = (links or {}).get("bes_url", "") or render_bes_url(data)
    if bes_url and bes_url != aspect_url:
        row7.append(_item("🔗", "[BES](" + bes_url + ")"))
    ci_item = ci_link_item(ctx, links)
    if ci_item:
        row7.append(ci_item)

    rows = []
    for row in [row1, row2, row3, row4, row5, row6, row7]:
        if row:
            rows.append(row)
    return rows

# Shared tips block spliced into every surface template (lint/format/gazelle/
# delivery/bazel-results) for consistency: one blockquote per tip,
# severity-emoji + label + title header, `> `-prefixed body (from
# `decorate_tip`), optional silence-hint footer. Each tip is preceded by
# `<div class="border-top my3"></div>` (visible on both GitHub and BK dark mode,
# where a Markdown `---` reads faint).
TIPS_BLOCK = """{% if tips %}{% for tip in tips %}

<div class="border-top my3"></div>

> {{ tip.severity_emoji }} **{{ tip.severity_label|upper }}: {{ tip.title }}**
>
{{ tip.body_quoted }}{% if tip.silence_hint %}
>
> {{ tip.silence_hint }}{% endif %}
{% endfor %}{% endif %}"""

SUMMARY_TEMPLATE = """{% if detail_rows %}{% for row in detail_rows %}
{% for item in row %}{{ item.icon }} {{ item.value }}{% if not loop.last %} · {% endif %}{% endfor %}{% if not loop.last %}  {% endif %}
{%- endfor %}{% endif %}
{% if config_items %}
:gear: {% for item in config_items %}**{{ item.key }}:** `{{ item.value }}`{% if not loop.last %} · {% endif %}{% endfor %}{% if last_update %}  {% endif %}{% endif %}{% if last_update %}
:speech_balloon: **Last update:** `{{ last_update }}`{% endif %}""" + TIPS_BLOCK

# Reusable Jinja snippets: iterate producer-authored repro_commands/fix_commands
# into one fenced code block per entry + optional italic description. Headings
# use the same emojis (🔁 / 🛠️) as the PR-comment aggregator.
REPRO_COMMANDS_BLOCK = """{%- if repro_commands %}
### 🔁 Reproduce
{% for c in repro_commands %}
```
{% if c.description %}# {{ c.description }}
{% endif %}{{ c.command }}
```
{% endfor %}
""" + ASPECT_CLI_INSTALL_HINT_MARKDOWN + """

{% endif %}"""

FIX_COMMANDS_BLOCK = """{%- if fix_commands %}
### 🛠️ Fix
{% for c in fix_commands %}
```
{% if c.description %}# {{ c.description }}
{% endif %}{{ c.command }}
```
{% endfor %}
""" + ASPECT_CLI_INSTALL_HINT_MARKDOWN + """

{% endif %}"""

# Per-row inline failure snippets: a collapsed code block under a failure table,
# one per row carrying a `snippet` (attached in build_details_data, budget-gated).
# Rendered as a Jinja2 macro so each bucket reuses the same markup.
# Renders a row's failure header (always) + its code block (when `snippet` is
# still set). The trim ladder can pop `snippet` under the size cap to shed the
# heavy log while keeping the one-line header visible.
SNIPPET_MACRO = """{% macro failure_snippets(rows) %}
{%- for t in rows %}
❌ {{ t.kind }} `{{ t.label }}` {{ t.snippet_verb }}:
{%- if t.snippet %}
{{ t.snippet_fence }}text
{% if t.snippet_trunc_head %}…
{% endif %}{{ t.snippet }}
{% if t.snippet_trunc_tail %}…
{% endif %}{{ t.snippet_fence }}
{% endif %}
{%- if t.repros %}
Reproduce with:
{% for r in t.repros %}
```
{% if r.description %}# {{ r.description }}
{% endif %}{{ r.command }}
```
{%- endfor %}
{% endif %}{%- endfor %}
{%- endmacro %}"""

# Bazel-targets detail block: build failures (root + dep-broken),
# failed/timeout/flaky tests, optional repro/fix (gated by
# render_repro_in_targets), built-targets / cached-tests tables. Split out of
# SHARED so build/test render it as slot 1 while non-bazel tasks render it as
# slot 4 (via the `include_bazel_targets` flag in SHARED).
BAZEL_TARGETS_TEMPLATE = """### 🎯 Bazel targets ({{ total_targets }})

{% if no_targets_info %}
{%- if not aborted %}
:hourglass_flowing_sand: **Build in progress** — target data will appear here as Bazel reports them.
{% endif %}
{%- else %}
{%- if build_failures or build_failures_snippets or derived_failures %}
<details open>
<summary>{{ build_failures_icon }} {{ build_failures_header }}</summary>
{{ failure_snippets(build_failures_snippets) }}
{% if build_failures_snippet_overflow %}_+ {{ build_failures_snippet_overflow }} more failure{{ build_failures_snippet_overflow_plural }} — output not shown._

{% endif %}
{%- if build_failures %}<pre>
{{- build_failures_table_head }}
{{ build_failures_table_sep }}
{%- for t in build_failures %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_mnemonic }}
{%- endfor %}
{% if build_failures_overflow %}_{{ build_failures_overflow }} more root failure(s) not shown._{% endif %}</pre>
{% endif %}
{% if derived_failures %}
<details><summary>{{ derived_failures_count }} more target{{ derived_failures_plural }} blocked by a failed dependency</summary>

<pre>
{{- derived_failures_table_head }}
{{ derived_failures_table_sep }}
{%- for t in derived_failures %}
{{ t.aligned_label }} | {{ t.aligned_kind }}
{%- endfor %}
{% if derived_failures_overflow %}_{{ derived_failures_overflow }} more not shown._{% endif %}</pre>
</details>
{% endif %}
</details>

{% endif %}
{%- if failed_tests or failed_tests_snippets %}
<details open>
<summary>{{ failed_tests_icon }} {{ failed_tests_header }}</summary>
{{ failure_snippets(failed_tests_snippets) }}
{% if failed_tests_snippet_overflow %}_+ {{ failed_tests_snippet_overflow }} more failure{{ failed_tests_snippet_overflow_plural }} — output not shown._

{% endif %}
{%- if failed_tests %}<pre>
{{- failed_tests_table_head }}
{{ failed_tests_table_sep }}
{%- for t in failed_tests %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_duration }}{% if failed_tests_has_artifacts %} | {{ t.aligned_artifacts }}{% endif %}
{%- endfor %}</pre>
{% endif %}
</details>

{% endif %}
{%- if timeout_tests or timeout_tests_snippets %}
<details open>
<summary>{{ timeout_tests_icon }} {{ timeout_tests_header }}</summary>
{{ failure_snippets(timeout_tests_snippets) }}
{% if timeout_tests_snippet_overflow %}_+ {{ timeout_tests_snippet_overflow }} more failure{{ timeout_tests_snippet_overflow_plural }} — output not shown._

{% endif %}
{%- if timeout_tests %}<pre>
{{- timeout_tests_table_head }}
{{ timeout_tests_table_sep }}
{%- for t in timeout_tests %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_duration }}{% if timeout_tests_has_artifacts %} | {{ t.aligned_artifacts }}{% endif %}
{%- endfor %}</pre>
{% endif %}
</details>

{% endif %}
{%- if flaky_tests %}
<details open>
<summary>{{ flaky_tests_icon }} {{ flaky_tests_header }}</summary>

<pre>
{{- flaky_tests_table_head }}
{{ flaky_tests_table_sep }}
{%- for t in flaky_tests %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_duration }}{% if flaky_tests_has_artifacts %} | {{ t.aligned_artifacts }}{% endif %}
{%- endfor %}</pre>
</details>

{% endif %}
{%- if passed_tests %}
<details>
<summary>✅ {{ passed_tests_header }}</summary>

<pre>
{{- passed_tests_table_head }}
{{ passed_tests_table_sep }}
{%- for t in passed_tests %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_duration }}{% if passed_tests_has_artifacts %} | {{ t.aligned_artifacts }}{% endif %}
{%- endfor %}
{% if passed_tests_overflow %}_{{ passed_tests_overflow }} more not shown._{% endif %}</pre>
</details>

{% endif %}
{%- if cached_tests %}
<details>
<summary>⚡ {{ cached_tests_header }}</summary>

<pre>
{{- cached_tests_table_head }}
{{ cached_tests_table_sep }}
{%- for t in cached_tests %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_duration }}{% if cached_tests_has_artifacts %} | {{ t.aligned_artifacts }}{% endif %}
{%- endfor %}
</pre>
</details>

{% endif %}
{%- if built_targets_any %}
<details>
<summary>✅ {{ built_targets_header }}</summary>

<pre>
{%- if built_targets %}
{{- built_targets_table_head }}
{{ built_targets_table_sep }}
{%- for t in built_targets %}
{{ t.aligned_label }} | {{ t.aligned_kind }}
{%- endfor %}
{%- endif %}
{% if built_targets_overflow %}_{{ built_targets_overflow }} more not shown._{% endif %}</pre>
</details>

{% endif %}
{%- if skipped_targets_any %}
<details>
<summary>{{ skipped_targets_icon }} {{ skipped_targets_header }}</summary>

<pre>
{%- if skipped_targets %}
{{- skipped_targets_table_head }}
{{ skipped_targets_table_sep }}
{%- for t in skipped_targets %}
{{ t.aligned_label }} | {{ t.aligned_kind }}
{%- endfor %}
{%- endif %}
{% if skipped_targets_overflow %}_{{ skipped_targets_overflow }} more not shown._{% endif %}</pre>
</details>

{% endif %}
{% endif %}
{% if render_repro_in_targets %}""" + FIX_COMMANDS_BLOCK + REPRO_COMMANDS_BLOCK + """{% endif %}
"""

# Section block every task renders below its primary data, in order:
# Artifacts; Task timing (when phases used); Bazel targets (when not hoisted);
# Bazel details (umbrella: command line, invocation, metrics, workspace status,
# build metadata, options); Runner metadata (Aspect Workflows only); footer.
# Mirrors the Aspect UI tabs (Bazel targets ↔ Targets, Bazel details ↔ Details).
# `include_bazel_targets` is True for non-bazel tasks; False for build/test
# (which hoist Bazel targets to slot 1).
#
# Leads with SNIPPET_MACRO so `failure_snippets(...)` — used by the embedded
# BAZEL_TARGETS_TEMPLATE — is in scope wherever SHARED is composed into a
# details template. Non-bazel surfaces (lint, format, gazelle, delivery,
# warming) embed SHARED with include_bazel_targets=True but don't hoist their
# own copy of BAZEL_TARGETS_TEMPLATE, so this is their only macro definition.
# Redefining it (build/test also prepend SNIPPET_MACRO for their hoisted slot)
# is harmless in minijinja: last definition wins and macro blocks emit nothing.
SHARED_DETAILS_BODY_TEMPLATE = SNIPPET_MACRO + """{% if artifacts_browse_url or artifact_links %}
### 📎 Artifacts

{% if artifacts_browse_url %}[Artifacts]({{ artifacts_browse_url }}){% endif %}{% if artifact_links %}{% if artifacts_browse_url %} · {% endif %}{% for a in artifact_links %}[{{ a.label }}]({{ a.url }}){% if not loop.last %} · {% endif %}{% endfor %}{% endif %}

{% endif %}
{% if task_timing_rows %}
### ⏱️ Task timing

<pre>
{{- task_timing_table_head }}
{{ task_timing_table_sep }}
{%- for p in task_timing_rows %}
{{ p.aligned_name }} | {{ p.aligned_description }} | {{ p.aligned_duration }}
{%- endfor %}
{%- if task_timing_total_line %}
{{ task_timing_total_separator }}
{{ task_timing_total_line }}
{%- endif %}</pre>

{% endif %}
{% if include_bazel_targets %}
""" + BAZEL_TARGETS_TEMPLATE + """
{% endif %}
{% if explicit_command_line or invocation_rows or invocation_stats or workspace_status_rows or build_metadata_rows or startup_options or cmd_line_options or retry_attempt_rows %}
### 🧮 Bazel details

{% if retry_attempt_rows -%}
<details open>
<summary>🔁 Retry attempts ({{ retry_attempt_rows|length }})</summary>

{% for a in retry_attempt_rows -%}
- Attempt {{ a.attempt }} ({{ a.outcome }}){% if a.aspect_url %} — [Aspect]({{ a.aspect_url }}){% endif %}
{% endfor %}
</details>

{% endif -%}
{% if explicit_command_line -%}
<details>
<summary>📟 Command line · <code>{{ explicit_command_line_short | e }}</code></summary>

<pre>{{ explicit_command_line | e }}</pre>
</details>

{% endif -%}
{% if invocation_rows -%}
<details>
<summary>ℹ️ Invocation details</summary>

{% for r in invocation_rows -%}
- **{{ r.key }}:** `{{ r.value }}`
{% endfor %}
</details>

{% endif -%}
{% if invocation_stats -%}
{% if invocation_stats.analysis_time or invocation_stats.execution_time or invocation_stats.elapsed_time or invocation_stats.critical_path or invocation_stats.bazel_server_time or invocation_stats.executed_tests_time or invocation_stats.cached_tests_time_saved -%}
<details>
<summary>⏱ Timing</summary>

{% if invocation_stats.elapsed_time -%}
- Elapsed time: `{{ invocation_stats.elapsed_time }}`
{% endif -%}
{% if invocation_stats.analysis_time -%}
- Analysis time: `{{ invocation_stats.analysis_time }}`
{% endif -%}
{% if invocation_stats.execution_time -%}
- Execution time: `{{ invocation_stats.execution_time }}`
{% endif -%}
{% if invocation_stats.critical_path -%}
- Critical path: `{{ invocation_stats.critical_path }}`
{% endif -%}
{% if invocation_stats.bazel_server_time -%}
- Bazel server time: `{{ invocation_stats.bazel_server_time }}`
{% endif -%}
{% if invocation_stats.executed_tests_time -%}
- Executed Tests Time: `{{ invocation_stats.executed_tests_time }}`
{% endif -%}
{% if invocation_stats.cached_tests_time_saved -%}
