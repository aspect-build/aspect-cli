# VCS helpers — mirror the Aspect Web UI (silo kilgore/app/layout/header/
# ExecutionContext.tsx) for matching link shapes across surfaces.
# Per-VCS URL shape; display_name + icon used in the summary line.
_VCS_CONFIG = {
    "GITHUB": {
        "domain": "github.com",
        "tree_path": "/tree",
        "commit_path": "/commit",
        "pr_path": "/pull",
        "display_name": "GitHub",
        "icon": ":octocat:",
    },
    "GITLAB": {
        "domain": "gitlab.com",
        "tree_path": "/-/tree",
        "commit_path": "/-/commit",
        "pr_path": "/-/merge_requests",
        "display_name": "GitLab",
        "icon": "🦊",
    },
    "BITBUCKET": {
        "domain": "bitbucket.org",
        "tree_path": "/src",
        "commit_path": "/commits",
        "pr_path": "/pull-requests",
        "display_name": "Bitbucket",
        "icon": "🪣",
    },
}

def merged_meta(data):
    """Merge build_metadata over workspace_status (build_metadata wins on key
    clash — matches Aspect Web UI getBuildMetadataValue(), silo
    kilgore/app/util/buildMetadata.ts). Empty values skipped so a blank entry
    doesn't shadow a populated one.
    """
    merged = {}
    for k, v in (data["bazel"].get("workspace_status", {}) or {}).items():
        if k and v:
            merged[k] = v
    for k, v in (data["bazel"].get("metadata", {}) or {}).items():
        if k and v:
            merged[k] = v
    return merged

def _owner_repo_from_url(url):
    """Extract (owner, repo) from https://host/owner/repo, else ("", "").

    Strips trailing slash and ".git". Repo = last segment (GitLab nested-group
    semantics).
    """
    if not url:
        return ("", "")
    rest = url
    scheme_end = rest.find("://")
    if scheme_end >= 0:
        rest = rest[scheme_end + 3:]

    slash = rest.find("/")
    if slash < 0:
        return ("", "")
    path = rest[slash + 1:]
    if path.endswith("/"):
        path = path[:-1]
    if path.endswith(".git"):
        path = path[:-len(".git")]
    parts = path.split("/")
    if len(parts) < 2:
        return ("", "")
    return (parts[0], parts[-1])

def vcs_info(meta):
    """Return VCS link info for the summary, or None when unknown.

    Requires VCS plus either REPO_URL (preferred — supports self-hosted hosts)
    or REPO_OWNER + REPO_NAME (legacy, hardcodes the public domain). When
    REPO_URL is set, owner/repo are parsed from it so it's self-consistent.
    """
    vcs = (meta.get("VCS") or "").upper()
    if not vcs or vcs not in _VCS_CONFIG:
        return None
    c = _VCS_CONFIG[vcs]
    repo_url = meta.get("REPO_URL", "")
    repo_owner = ""
    repo_name = ""
    if repo_url:
        (repo_owner, repo_name) = _owner_repo_from_url(repo_url)
    if not repo_owner or not repo_name:
        repo_owner = meta.get("REPO_OWNER") or repo_owner
        repo_name = meta.get("REPO_NAME") or repo_name
    if not repo_url:
        if not repo_owner or not repo_name:
            return None
        repo_url = "https://" + c["domain"] + "/" + repo_owner + "/" + repo_name
    if repo_url.endswith("/"):
        repo_url = repo_url[:-1]
    return {
        "repo_url": repo_url,
        "repo_owner": repo_owner,
        "repo_name": repo_name,
        "tree_path": c["tree_path"],
        "commit_path": c["commit_path"],
        "pr_path": c["pr_path"],
        "display_name": c["display_name"],
        "icon": c["icon"],
    }

_TRIGGER_LABELS = {
    "BRANCH_PUSH": "Branch push run",
    "PULL_REQUEST": "Pull request run",
    "TAG": "Tag push run",
    "SCHEDULED": "Scheduled run",
    "MANUAL": "Manual run",
}

def _trigger_label(run_type):
    """Human-readable label for a RUN_TYPE metadata value."""
    return _TRIGGER_LABELS.get(run_type or "", "")

def parse_tags(meta):
    """Collect display tags from TAGS (comma-separated) and TAG_* keys.

    Each TAG_X=Y → "X=Y" (or "X" when Y empty). Sorted for stable ordering.
    """
    out = []
    seen = {}
    raw = meta.get("TAGS", "") or ""
    if raw:
        for t in raw.split(","):
            t = t.strip()
            if t and t not in seen:
                seen[t] = True
                out.append(t)
    for k in sorted(meta.keys()):
        if k.startswith("TAG_") and k != "TAGS":
            name = k[len("TAG_"):]
            val = meta[k]
            if name:
                display = name + "=" + val if val else name
                if display not in seen:
                    seen[display] = True
                    out.append(display)
    return out

def parse_workflows_links(meta):
    """Parse ASPECT_WORKFLOWS_LINKS as a list of {text, url}.

    Format:
        [text one](https://a.example),[text two](https://b.example)
    Entries are comma-separated at the top level. Only http:// and https://
    URLs are accepted; malformed entries are silently skipped.
    """
    raw = meta.get("ASPECT_WORKFLOWS_LINKS", "") or ""
    if not raw:
        return []
    out = []
    for part in raw.split(","):
        part = part.strip()
        if not part.startswith("[") or "](" not in part or not part.endswith(")"):
            continue
        rb = part.find("]")
        if rb <= 1:
            continue
        text = part[1:rb]
        if not part[rb + 1:].startswith("("):
            continue
        url = part[rb + 2:-1]
        if text and (url.startswith("http://") or url.startswith("https://")):
            out.append({"text": text, "url": url})
    return out

