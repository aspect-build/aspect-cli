{% if last_updated_at or api_usage %}<sub>{% if last_updated_at %}⏱ Last updated {{ last_updated_at }}{% endif %}{% if last_updated_at and api_usage %} · {% endif %}{% if api_usage %}{{ api_usage }}{% endif %}</sub><br>
{%- endif %}<sub>🚀 Powered by [Aspect CLI](https://github.com/aspect-build/aspect-cli){% if cli_version %} (v{{ cli_version }}){% endif %} &nbsp;|&nbsp; [Aspect Build](https://aspect.build/) · [X](https://twitter.com/aspect_build) · [LinkedIn](https://www.linkedin.com/company/aspect-dev/) · [YouTube](http://www.youtube.com/@aspectbuild)</sub>
"""

# Build/test detail template: aborted prelude, hoisted Bazel targets as the
# primary slot, then SHARED (which skips its own Bazel targets via
# include_bazel_targets=False).
# SNIPPET_MACRO is prepended so `failure_snippets(...)` is in scope for the
# hoisted BAZEL_TARGETS_TEMPLATE, which precedes SHARED. (SHARED prepends its
# own copy too; the redefinition is harmless — see the note there.)
DETAILS_TEMPLATE = SNIPPET_MACRO + """
{% if aborted %}
> :warning: **Build aborted**{% if abort_reason %} (`{{ abort_reason }}`){% endif %}{% if abort_description %}: {{ abort_description }}{% endif %}

{% endif %}
""" + BAZEL_TARGETS_TEMPLATE + SHARED_DETAILS_BODY_TEMPLATE

_RENDER_LOG = feature_logger("Status render")

# Fallback body when a details template fails to render (either a built-in
# template or a user-supplied override). Rendered with `try_jinja2` (macro-free,
# no data refs beyond `error`/`surface`) so it cannot itself fail. Keeps the
# check updating with the correct status/title (both computed outside the
# template) while surfacing the render error to reviewers.
_DETAILS_FALLBACK_TEMPLATE = """> ⚠️ **Details unavailable** — the {{ surface }} status body failed to render. The task status above is still accurate.
>
> ```
> {{ error }}
> ```
"""

# Fallback for a summary render failure. The status/title/conclusion are all
# computed in AXL outside the template, so the check state stays correct; only
# this one-line body is degraded. Deliberately terse — the summary is the first
# thing reviewers read, so we don't dump a stack trace into it (the WARNING and
# the details fallback carry the message).
_SUMMARY_FALLBACK_TEMPLATE = """⚠️ Status summary unavailable — the {{ surface }} summary body failed to render (see task log)."""

def _render_or_fallback(ctx, template, data, fallback_template, surface):
    """Shared try/warn/fallback for a status body. On render error, logs a
    WARNING to CLI output with the message and renders `fallback_template`
    (macro-free, so it can't itself fail).

    Returns (text, ok): `ok` is False when the fallback was used.
    """
    ok, text = ctx.template.try_jinja2(template, data = data)
    if ok:
        return (text, True)
    _RENDER_LOG.warn(ctx.std, "%s body failed to render: %s" % (surface, text))
    fallback = ctx.template.jinja2(fallback_template, data = {"surface": surface, "error": text})
    return (fallback, False)

def render_details_or_fallback(ctx, template, data, surface = "check"):
    """Render a details body, degrading to a fallback instead of crashing.

    A template bug in one status surface must not abort the whole invocation
    (see anchor: SNIPPET_MACRO / failure_snippets). On render error this logs a
    WARNING to CLI output with the error and returns a minimal fallback body
    embedding the same message; the caller keeps the correct status/title. The
    fallback body is far under _DETAILS_LIMIT, so the caller's size-trim cascade
    is a no-op on it.

    Returns (text, ok); ok is False when the fallback was used.
    """
    return _render_or_fallback(ctx, template, data, _DETAILS_FALLBACK_TEMPLATE, surface + " details")

def render_summary_or_fallback(ctx, template, data, surface = "check"):
    """Render a summary body, degrading to a one-line fallback instead of
    crashing. Summary templates carry no macros today, so this is
    defense-in-depth against future edits — see render_details_or_fallback.

    Returns (text, ok); ok is False when the fallback was used.
    """
    return _render_or_fallback(ctx, template, data, _SUMMARY_FALLBACK_TEMPLATE, surface + " summary")

def build_summary_data(ctx, data, status, render_ctx, links, metadata_keys, run_date = "", config_items = None, complete_suffix = ""):
    """Build Jinja2 template data for SUMMARY_TEMPLATE.

    render_ctx keys (feature-provided, not from BES): triggered_by, targets,
    started_ms, ended_ms, progress (last task_update.progress message).

    `config_items` ([{key, value}]) surfaces a config row below "Last update"
    (e.g. lint Strategy, delivery Mode); None for build/test skips the row.

    `complete_suffix` decorates the terminal "<Task> complete" line on passed
    status (e.g. "Format complete · 42 files checked"); ignored otherwise.
    """

    # "Last update" terminal handling: passed/warning → "<task> complete"
    # (keeps row rhythm; title carries the outcome). failed → keep last
    # in-flight progress (tells reviewers where it broke).
    if status in ("running", "failing", "failed"):
        last_update = render_ctx.get("progress", "") or ""
    elif status in ("passed", "warning"):
        kind = render_ctx.get("task_kind", "") or "task"

        # "<kind> task complete" not "<kind> complete": "test complete" reads as
        # "the test passed", but "test task complete" means the task finished.
        # `warning` joins `passed` (terminal, non-fatal) so the row isn't blank.
        last_update = kind + " task complete"
        if complete_suffix:
            last_update = last_update + " · " + complete_suffix
    elif status == "aborted":
        kind = render_ctx.get("task_kind", "") or "task"
        last_update = kind + " task aborted"
    else:
        last_update = ""

    meta = data["bazel"].get("metadata", {})
    sha = meta.get("COMMIT_SHA", "")
    commit_msg = meta.get("COMMIT_MESSAGE", "")
    if len(commit_msg) > 72:
        commit_msg = commit_msg[:72] + "…"

    # Escape both halves — key and value are user-controlled. See `html_escape`.
    extra_meta = []
    keys = metadata_keys or []
    show_all = keys == ["*"]
    for k, v in meta.items():
        if k in RENDER_META_STANDARD_KEYS:
            continue

        # TAGS / TAG_* render as 🏷 chips via parse_tags; skip so 📌 doesn't dup.
        if k == "TAGS" or k.startswith("TAG_"):
            continue
        if show_all or k in keys:
            extra_meta.append({"key": html_escape(k), "value": html_escape(v)})

    return {
        "last_update": last_update,
        "config_items": config_items or [],
        "target_pattern": render_ctx.get("subject", "") if render_ctx else "",
        "branch": html_escape(meta.get("BRANCH_NAME", "")),
        "tag": html_escape(meta.get("TAG", "")),
        "short_sha": sha[:7] if sha else "",
        "commit_msg": html_escape(commit_msg),
        "detail_rows": build_invocation_rows(ctx, data, render_ctx, status, links = links, run_date = run_date, extra_meta = extra_meta),
        "tips": [decorate_tip(t) for t in (render_ctx.get("tips") if render_ctx else None) or []],
    }

def build_kv_rows(kv):
    """Convert key->value dict into sorted [{key, value}] rows; values coerced to
    str, empty ones dropped so the template never renders blank lines.
    """
    if not kv:
        return []
    out = []
    for key in sorted(kv.keys()):
        val = kv[key]
        if val == None:
            continue
        s = str(val) if type(val) != "string" else val
        if s:
            out.append({"key": key, "value": s})
    return out

def build_invocation_detail_rows(data, start_date, finish_date):
    """Build [{key, value}] rows for the Invocation section; empty values skipped
    so rows like "**Server PID:** 0" never render.
    """
    rows = []

    def _maybe_add(key, value):
        if value:
            rows.append({"key": key, "value": str(value)})

    _maybe_add("Invocation ID", data["bazel"].get("invocation_id", ""))
    _maybe_add("Command", data["bazel"].get("build_command", ""))
    _maybe_add("Bazel version", data["bazel"].get("build_tool_version", ""))
    _maybe_add("Start time", start_date)
    _maybe_add("End time", finish_date)

    # BUILD_USER / BUILD_HOST = where the build physically ran (workspace_status
    # script). Distinct from the summary "user", which prefers commit author.
    ws = data["bazel"].get("workspace_status", {}) or {}
    _maybe_add("User", ws.get("BUILD_USER", ""))
    _maybe_add("Host name", ws.get("BUILD_HOST", ""))
    _maybe_add("CPU Target", data["bazel"].get("cpu_arch", ""))
    _maybe_add("Mode", data["bazel"].get("compilation_mode", ""))
    _maybe_add("Working directory", data["bazel"].get("working_directory", ""))
    _maybe_add("Workspace directory", data["bazel"].get("workspace_directory", ""))
    pid = data["bazel"].get("server_pid", 0)
    if pid and pid > 0:
        rows.append({"key": "Server PID", "value": str(pid)})
    return rows

def _remote_cache_hit_count(data):
    """Count of actions on the `remote cache hit` runner.

    Bazel tallies these as `actions_executed` though they didn't execute; the
    cache-rate display reclassifies them as cached. `runner_counts` keys are
    `<runner_name> · <exec_kind>` (or bare name); see the build_metrics handler.
    """
    rc = data["bazel"].get("runner_counts", {}) or {}
    total = 0
    for key, count in rc.items():
        if key == "remote cache hit" or key.startswith("remote cache hit · "):
            total += count
    return total

def _effective_action_cache_counts(data):
    """Return (executed, cached, total) for the cache-rate display.

    Reclassifies remote cache hits as cached; caps cached at total. When
    actions_total is 0 (incremental with a partial build_metrics picture),
    preserves the raw executed count so "X action(s)" callers still render.
    """
    total = data["bazel"].get("actions_total", 0) or 0
    executed_raw = data["bazel"].get("actions_executed", 0) or 0
    if total <= 0:
        return (executed_raw, 0, 0)
    cached_raw = total - executed_raw if total > executed_raw else 0
    cached = cached_raw + _remote_cache_hit_count(data)
    if cached > total:
        cached = total
    executed = total - cached
    return (executed, cached, total)

def _cache_actions_line(data):
    """Return 'N of M cached (P%)' for actions, or '' when no actions."""
    _executed, cached, total = _effective_action_cache_counts(data)
    if total <= 0:
        return ""
    pct = (cached * 100) // total
    return format_int_comma(cached) + " of " + format_int_comma(total) + " cached (" + str(pct) + "%)"

def _cache_tests_line(data):
    """Return 'N of M cached (P%)' for tests, or '' when no tests ran."""
    pass_t = data["bazel"].get("passed_test_total", 0) or 0
    fail_t = data["bazel"].get("failed_test_total", 0) or 0
    flaky_t = data["bazel"].get("flaky_test_total", 0) or 0
    total = pass_t + fail_t + flaky_t
    if total <= 0:
        return ""
    cached = data["bazel"].get("cached_test_total", 0) or 0
    pct = (cached * 100) // total
    return format_int_comma(cached) + " of " + format_int_comma(total) + " cached (" + str(pct) + "%)"

def archive_bazel_attempt(data, human_attempt, exit_code):
    """Append a snapshot of `data["bazel"]` + `sink_invocation_id` to
    `data["bazel_attempts"]` under the 1-indexed attempt, returning the list.

    For the `🔁 Retry attempts` section (bazel_runner.run_bazel_task,
    delivery._get_output_shas). Holds the `bazel` sub-dict by reference, so the
    caller MUST swap in a fresh dict before the next iteration's events mutate it.
    """
    attempts = list(data.get("bazel_attempts", []) or [])
    attempts.append({
        "attempt": human_attempt,
        "exit_code": exit_code,
        "sink_invocation_id": data.get("sink_invocation_id", "") or "",
        "bazel": data["bazel"],
    })
    data["bazel_attempts"] = attempts
    return attempts

def _build_retry_attempt_rows(data, links):
    """Build per-attempt rows for the `🔁 Retry attempts` section; `[]` on the
    single-attempt path (template skips it). Each row {attempt (1-indexed),
    outcome ("passed"/"failed"), aspect_url (per-attempt sink_invocation_id vs
    links.results_base_url; "" when no sink → link suppressed)}.
    """
    attempts = data.get("bazel_attempts", []) or []
    if not attempts:
        return []
    base = (links or {}).get("results_base_url", "") if links else ""
    rows = []
    for a in attempts:
        sink_id = a.get("sink_invocation_id", "") or ""
        url = _join_url(base, sink_id) if (base and sink_id) else ""
        rows.append({
            "attempt": a.get("attempt", 0),
            "outcome": "passed" if a.get("exit_code", 1) == 0 else "failed",
            "aspect_url": url,
        })
    return rows

def _build_invocation_stats(data):
    """Build the Performance section payload; None pre-build_metrics (template
    skips the section).
    """
    wall_ms = data["bazel"].get("wall_time_ms", 0) or 0
    server_cpu_ms = data["bazel"].get("cpu_time_ms", 0) or 0
    analysis_ms = data["bazel"].get("analysis_phase_time_ms", 0) or 0
    execution_ms = data["bazel"].get("execution_phase_time_ms", 0) or 0
    critical_ms = data["bazel"].get("critical_path_ms", 0) or 0
    cached_tests_ms = data["bazel"].get("cached_duration_ms", 0) or 0
    executed_tests_ms = data["bazel"].get("executed_duration_ms", 0) or 0

    actions_executed = data["bazel"].get("actions_executed", 0) or 0
    actions_created = data["bazel"].get("actions_total", 0) or 0

    targets_completed = data["bazel"].get("targets_total", 0) or 0
    targets_configured = data["bazel"].get("targets_configured", 0) or 0

    # Fall back to our target_configured tally when build_metrics reports 0
    # (cached/incremental: no re-analysis, but per-target events still emitted).
    if targets_configured == 0:
        targets_configured = data["bazel"].get("targets_configured_counted", 0) or 0

    # Split "X configured, Y aspects" only when both fields are populated — a 0
    # in _not_including_aspects means Bazel didn't emit it, not 0 rule targets.
    targets_conf_plain = data["bazel"].get("targets_configured_not_including_aspects", 0) or 0
    aspect_applications = 0
    if targets_conf_plain > 0 and targets_configured > targets_conf_plain:
        aspect_applications = targets_configured - targets_conf_plain
    packages_loaded = data["bazel"].get("packages_loaded", 0) or 0

    cache_stats = data["bazel"].get("action_cache_stats", {}) or {}
    local_hits = cache_stats.get("hits", 0) or 0
    local_misses = cache_stats.get("misses", 0) or 0

    action_mnemonics = data["bazel"].get("action_mnemonics", {}) or {}
    mnemonic_pre = _render_counter_pre(action_mnemonics, "Mnemonic")

    runner_counts = data["bazel"].get("runner_counts", {}) or {}
    runner_pre = _render_counter_pre(runner_counts, "Runner")

    # Miss reasons: [{reason, count}] → counter for the shared renderer.
    miss_details = cache_stats.get("miss_details", []) or []
    miss_counter = {}
    for md in miss_details:
        r = md.get("reason", "")
        c = md.get("count", 0) or 0
        if r and c > 0:
            miss_counter[r] = c
    miss_reasons_pre = _render_counter_pre(miss_counter, "Reason", name_display = _miss_reason_display)

    if (wall_ms == 0 and server_cpu_ms == 0 and analysis_ms == 0 and execution_ms == 0 and
        critical_ms == 0 and cached_tests_ms == 0 and executed_tests_ms == 0 and
        actions_created == 0 and actions_executed == 0 and
        targets_configured == 0 and targets_completed == 0 and
        packages_loaded == 0 and local_hits == 0 and local_misses == 0 and
        not mnemonic_pre and not runner_pre and not miss_reasons_pre):
        return None

    # Mirror Bazel's CLI wording (e.g. "Analyzed 141 targets (735 packages
    # loaded, 134094 targets configured, 133 aspect applications)"). Incrementals
    # report zeros but still name the fields, as a "nothing re-analyzed" baseline.
    targets_line = ""
    if targets_completed > 0 or targets_configured > 0:
        parts = []
        if targets_configured > 0 or targets_completed > 0:
            count_cfg = targets_conf_plain if targets_conf_plain > 0 else targets_configured
            parts.append(format_int_comma(count_cfg) + " configured")
            if aspect_applications > 0:
                parts.append(pluralize(aspect_applications, "aspect application"))
        if targets_completed > 0:
            base = pluralize(targets_completed, "target")
        else:
            base = pluralize(targets_configured, "target")
        targets_line = base + (" (" + ", ".join(parts) + ")" if parts else "")

    # Reclassify remote cache hits as cached so actions_line and
    # cache_actions_line stay consistent ("X actions" == total - cached).
    actions_line = ""
    if actions_executed > 0 or actions_created > 0:
        actions_executed_eff, _cached_eff, _total_eff = _effective_action_cache_counts(data)
        base = pluralize(actions_executed_eff, "action")
        if actions_created > 0 and actions_created != actions_executed_eff:
            actions_line = base + " (" + format_int_comma(actions_created) + " created)"
        else:
            actions_line = base

    packages_line = ""
    if packages_loaded >= 0 and (packages_loaded > 0 or targets_completed > 0):
        # Show even at 0 (matches Bazel; makes "fully incremental" obvious).
        packages_line = pluralize(packages_loaded, "package") + " loaded"

    return {
        # Timing
        "analysis_time": format_duration_ms(analysis_ms) if analysis_ms > 0 else "",
        "execution_time": format_duration_ms(execution_ms) if execution_ms > 0 else "",
        "elapsed_time": format_duration_ms(wall_ms) if wall_ms > 0 else "",
        "critical_path": format_duration_ms(critical_ms) if critical_ms > 0 else "",
        "bazel_server_time": _format_cpu_seconds(server_cpu_ms) if server_cpu_ms > 0 else "",
        "executed_tests_time": _format_cpu_seconds(executed_tests_ms) if executed_tests_ms > 0 else "",
        "cached_tests_time_saved": _format_cpu_seconds(cached_tests_ms) if cached_tests_ms > 0 else "",

        # Bazel-style one-liners (`Analyzed N targets (…)`).
        "targets_line": targets_line,
        "actions_line": actions_line,
        "packages_line": packages_line,

        # Cache stats (counts + pct). Dup the summary row so this section is
        # self-contained.
        "cache_actions_line": _cache_actions_line(data),
        "cache_tests_line": _cache_tests_line(data),

        # Local action cache.
        "local_cache_hits": format_int_comma(local_hits) if local_hits > 0 else "",
        "local_cache_misses": format_int_comma(local_misses) if local_misses > 0 else "",

        # Distribution tables.
        "mnemonic_table": mnemonic_pre,
        "mnemonic_count": len(action_mnemonics),
        "runner_table": runner_pre,
        "runner_count": len(runner_counts),
        "miss_reasons_table": miss_reasons_pre,
    }

def build_details_data(data, links, render_ctx = None, status = "", start_date = "", finish_date = "", std = None, task_phases = None, task_active = None, task_elapsed_ms = 0, include_bazel_targets = True, render_repro_in_targets = False, snippet_options = None, max_snippets = 0):
    """Build Jinja2 template data for DETAILS_TEMPLATE.

    start_date / finish_date are pre-formatted by the caller (format_run_date
    shells out to `date` and needs ctx, unavailable here).

    Args:
      task_phases:             closed `TaskPhase`s from `ctx.task.phases()`.
      task_active:             the active `TaskPhase` or None — trailing Task
                               timing row with a status-aware verb.
      task_elapsed_ms:         `ctx.task.elapsed_ms`; the Task timing Total row.
      include_bazel_targets:   True for non-bazel tasks; False for build/test
                               (which hoist Bazel targets above SHARED).
      render_repro_in_targets: True for build/test (Reproduce/Fix render atop
                               the primary Bazel targets slot); False otherwise
                               (per-task templates render their own).
      snippet_options:         `SnippetOptions` (per-surface line/byte budget) for
                               inline failure snippets, or None to disable.
      max_snippets:            Max failure rows (shared across build-failure and
                               test-failure buckets, in render order) that get an
                               inline snippet. 0 disables. Requires `std`.
    """

    # Command-line views from options_parsed (not structured_command_line).
    # ALLOW_ENV from --build_metadata=ALLOW_ENV=... (defaults when unset). See _redact_arg.
    allow_env = _allow_env_patterns(data["bazel"].get("metadata", {}))
    opts_parsed = data["bazel"].get("options_parsed", {}) or {}
    target_pattern_for_cmd = (render_ctx or {}).get("subject", "") if render_ctx else ""
    _explicit_cmd = _assemble_explicit_command(
        data["bazel"].get("build_command", ""),
        target_pattern_for_cmd,
        opts_parsed.get("explicit_cmd_line", []),
        allow_env,
    )
    _startup_opts_redacted = _sorted_dedup(opts_parsed.get("startup_options", []), allow_env)
    _cmd_line_redacted = _sorted_dedup(opts_parsed.get("cmd_line", []), allow_env)

    target_kinds_map = data["bazel"].get("target_kinds") or {}

    def _prep_action(a):
        """Pre-process a failed build action: add kind, join mnemonics, truncate label."""
        entry = dict(a)
        mnemonics = a.get("mnemonics", []) or []
        entry["mnemonics_joined"] = ", ".join(mnemonics)
        original_label = a.get("label", "")
        entry["kind"] = target_kinds_map.get(original_label, "")
        entry["label"] = _truncate_label(original_label)
        return entry

    testlogs_label_urls = links.get("testlogs_label_urls", {})
    artifact_urls = links.get("artifact_urls", {}) or {}

    # Per-kind download links, stable order; only rendered when the URL is
    # populated (artifacts.by_kind via apply_artifact_links), so unproduced kinds
    # are omitted. Kinds mirror lib/artifacts.axl + the per-task patch uploaders.
    artifact_links = []
    for kind, alabel in [
        ("testlogs", "Test logs"),
        ("build_logs", "Build logs"),
        ("profile", "Profile"),
        ("execlog", "Execlog"),
        ("bep", "BEP"),
        ("format_diff", "Format Patch"),
        ("gazelle_diff", "Gazelle Patch"),
        ("lint_diff", "Lint Patch"),
    ]:
        u = artifact_urls.get(kind, "")
        if u:
            artifact_links.append({"label": alabel, "url": u})

    # Delivery manifest uploads may be multi-file; label each by filename.
    for a in links.get("manifest_artifacts", []) or []:
        artifact_links.append({"label": a["name"], "url": a["url"]})

    def _with_duration(tests):
        """Add formatted duration, per-file artifact URLs, and kind to each test.

        Looks up URLs/kind by the ORIGINAL label, then sets entry["label"] to
        the truncated form. Per-file URLs only on file-upload CIs (CircleCI);
        tar-based CIs leave log_url/xml_url empty so the column drops.
        """
        out = []
        for t in tests:
            entry = dict(t)
            ms = t.get("duration_ms", 0)
            entry["duration"] = format_duration_ms(ms) if ms > 0 else ""
            original_label = t.get("label", "")
            file_urls = testlogs_label_urls.get(original_label, {}) or {}
            entry["log_url"] = file_urls.get("test.log", "")
            entry["xml_url"] = file_urls.get("test.xml", "")

            # Backfill kind from the map (fixtures may omit it).
            if not entry.get("kind"):
                entry["kind"] = target_kinds_map.get(original_label, "")
            entry["label"] = _truncate_label(original_label)

            # Untruncated label, for correlating per-failure repro commands.
            entry["_orig_label"] = original_label
            out.append(entry)
        return out

    # Split failed_tests by .status into TEST_FAILED / TEST_TIMEOUT /
    # FAILED_TO_BUILD (test-level, distinct from action-level failed_actions).
    raw_failed = data["bazel"].get("failed_tests", [])
    failed_by_status = {"failed": [], "timeout": [], "failed_to_build": []}
    for t in raw_failed:
        s = t.get("status", "failed")
        if s in failed_by_status:
            failed_by_status[s].append(t)
        else:
            failed_by_status["failed"].append(t)

    # Split passed_tests by .cached. Aggregate counts are authoritative, so only
    # populate a bucket when its count is non-zero (else a stray sample could
    # render a "0 Tests Passed" header).
    raw_passed = sorted(data["bazel"].get("passed_tests", []), key = lambda t: t.get("label", ""))
    _has_executed = data["bazel"].get("passed_test_total", 0) > data["bazel"].get("cached_test_total", 0)
    _has_cached = data["bazel"].get("cached_test_total", 0) > 0
    passed_executed = [t for t in raw_passed if not t.get("cached")] if _has_executed else []
    passed_cached = [t for t in raw_passed if t.get("cached")] if _has_cached else []

    # Exclude tests from built_targets so SUCCESSFUL_BUILD = non-test built.
    # Primary signal: kind ends in `_test`; fallback (fixtures w/o kinds): label set.
    test_labels_fallback = {}
    for t in (data["bazel"].get("passed_tests", []) + data["bazel"].get("flaky_tests", []) + raw_failed):
        lbl = t.get("label", "")
        if lbl:
            test_labels_fallback[lbl] = True

    def _is_test_entry(t):
        if _is_test_kind(t.get("kind", "")):
            return True

        # Kind missing — check the label set.
        return t.get("label", "") in test_labels_fallback

    # Sort on the full label before truncating (stable when prefixes collide).
    built_non_test = [
        {"label": _truncate_label(t.get("label", "")), "kind": t.get("kind", "")}
        for t in sorted(
            [t for t in data["bazel"].get("built_targets", []) if not _is_test_entry(t)],
            key = lambda t: t.get("label", ""),
        )
    ]

    # Skipped targets — own section (neither built nor failed).
    skipped_for_table = [
        {"label": _truncate_label(t.get("label", "")), "kind": t.get("kind", "")}
        for t in sorted(
            data["bazel"].get("skipped_targets", []),
            key = lambda t: t.get("label", ""),
        )
    ]

    # Partition failed_targets into root (own action failed) vs derived (dep
    # broke). Same "Broken by" UX as the Aspect Web UI without the rdeps graph.
    failed_action_labels_set = {l: True for l in _failed_action_labels(data)}

    derived_failures = [
        {"label": _truncate_label(t["label"]), "kind": t.get("kind", "")}
        for t in sorted(
            [
                {"label": t.get("label", ""), "kind": t.get("kind", "")}
                for t in data["bazel"].get("failed_targets", [])
                if t.get("label", "") and t.get("label", "") not in failed_action_labels_set
            ],
            key = lambda t: t["label"],
        )
    ]

    # Cap at MAX_BUILT_TARGETS so cascade failures don't blow up details_text.
    derived_failures_count = len(derived_failures)
    if len(derived_failures) > MAX_BUILT_TARGETS:
        derived_failures = derived_failures[:MAX_BUILT_TARGETS]

    bucket_counts = _compute_bucket_counts(data)
    build_failure_count = bucket_counts.get(_BUCKET_FAILED_TO_BUILD, 0)
    failed_test_count = len(failed_by_status["failed"])
    timeout_test_count = len(failed_by_status["timeout"])
    flaky_test_count = data["bazel"].get("flaky_test_total", 0)
    passed_test_count = data["bazel"].get("passed_test_total", 0) - data["bazel"].get("cached_test_total", 0)
    if passed_test_count < 0:
        passed_test_count = 0
    cached_test_count = data["bazel"].get("cached_test_total", 0)
    built_non_test_count = bucket_counts.get(_BUCKET_SUCCESSFUL_BUILD, 0)
    skipped_count = bucket_counts.get(_BUCKET_SKIPPED, 0)

    # Overflow = total unique failing labels minus what fit in the capped list.
    failed_actions_overflow = len(_failed_action_labels(data)) - len(data["bazel"].get("failed_actions", []))
    passed_overflow = data["bazel"].get("passed_test_total", 0) - len(raw_passed)
    built_overflow = built_non_test_count - len(built_non_test)
    derived_failures_overflow = derived_failures_count - len(derived_failures)
    skipped_overflow = skipped_count - len(skipped_for_table)

    # Inline failure snippets. One shared budget (`_snippet_budget[0]`) across all
    # failure buckets, consumed in render order (build failures → failed tests →
    # timeouts) so the most-relevant failures get output first. Each attach
    # mutates `entry["snippet"]`/`["snippet_truncated"]` in place; rows beyond the
    # budget render plain (the template emits a "more — output not shown" line).
    _snippets_enabled = std != None and max_snippets > 0 and snippet_options != None
    _snippet_budget = [max_snippets if _snippets_enabled else 0]

    def _apply_snippet(entry, res):
        """Set the snippet render fields on a table row from a SnippetResult.
        `snippet_fence` is sized past any backtick run so log content can't close
        the code block early; `snippet_trunc_head`/`_tail` drive the `…` markers."""
        entry["snippet"] = res.text
        entry["snippet_truncated"] = res.truncated
        entry["snippet_trunc_head"] = res.trunc_head
        entry["snippet_trunc_tail"] = res.trunc_tail
        entry["snippet_fence"] = code_fence_for(res.text)
        _snippet_budget[0] -= 1

    def _attach_test_snippet(entry):
        """Read a failed test's snippet, preferring JUnit test.xml over test.log."""
        if _snippet_budget[0] <= 0:
            return
        detail = data["bazel"].get("test_details", {}).get(entry.get("label", ""), {}) or {}
        res = extract_junit_failure(std, detail.get("xml_path", ""), snippet_options)
        if not has_snippet(res):
            res = extract_snippet(std, detail.get("log_path", ""), snippet_options)
        if not has_snippet(res):
            return
        _apply_snippet(entry, res)

    def _attach_action_snippet(action, entry):
        """Read a failed action's stderr snippet (by path) onto the table row."""
        if _snippet_budget[0] <= 0:
            return
        res = extract_snippet(std, action.get("stderr_path", ""), snippet_options)
        if not has_snippet(res):
            return
        _apply_snippet(entry, res)

    def _without_snippet(rows):
        """Rows that did NOT get an inline snippet — these go in the <pre> table;
        the rows that DID are rendered as snippet blocks instead (no duplicate)."""
        return [r for r in rows if not r.get("snippet")]

    def _with_snippet(rows):
        """Rows that got an inline snippet (rendered by the snippet macro)."""
        return [r for r in rows if r.get("snippet")]

    # Failures table: Label | Target Type | Mnemonic (comma-joined when a target
    # failed multiple actions). Build-failure snippets are attached first so they
    # win the shared budget over test failures.
    _build_failures_rows = []
    for a in data["bazel"].get("failed_actions", []):
        original_label = a.get("label", "")
        mnemonics = a.get("mnemonics", []) or []
        row = {
            "label": _truncate_label(original_label),
            # Untruncated label, for correlating per-failure repro commands.
            "_orig_label": original_label,
            "kind": target_kinds_map.get(original_label, ""),
            "mnemonic": ", ".join(mnemonics),
        }
        if _snippets_enabled:
            _attach_action_snippet(a, row)
        _build_failures_rows.append(row)

    # Snippet rows render as blocks; the table lists only the rest.
    _build_failures_snippets = _with_snippet(_build_failures_rows)
    _build_failures_table = _align_for_pre(
        _without_snippet(_build_failures_rows),
        has_duration = False,
        has_mnemonic = True,
    )

    def _failed_with_snippets(tests):
        """`_with_duration` + a snippet on each row (budget permitting)."""
        rows = _with_duration(tests)
        if _snippets_enabled:
            for row in rows:
                _attach_test_snippet(row)
        return rows

    # Column-aligned <pre> tables.
    _passed_table = _align_for_pre(_with_duration(passed_executed), has_duration = True)
    _cached_table = _align_for_pre(_with_duration(passed_cached), has_duration = True)
    _built_table = _align_for_pre(built_non_test, has_duration = False)
    _derived_table = _align_for_pre(derived_failures, has_duration = False)
    _skipped_table = _align_for_pre(skipped_for_table, has_duration = False)

    # Failed/timeout buckets: rows with a snippet render as blocks, the rest fill
    # the aligned <pre> table (no duplication). Flaky is transient noise — table
    # only, no snippets.
    _failed_rows = _failed_with_snippets(failed_by_status["failed"])
    _timeout_rows = _failed_with_snippets(failed_by_status["timeout"])
    _failed_snippets = _with_snippet(_failed_rows)
    _timeout_snippets = _with_snippet(_timeout_rows)
    _failed_table = _align_for_pre(_without_snippet(_failed_rows), has_duration = True)
    _timeout_table = _align_for_pre(_without_snippet(_timeout_rows), has_duration = True)
    _flaky_table = _align_for_pre(_with_duration(data["bazel"].get("flaky_tests", [])), has_duration = True)

    # Header verb for inline snippet blocks (consistent with the PR comment):
    # "failed to build" / "failed [in <dur>]" / "timed out [after <dur>]". `dur`
    # is the pre-formatted duration string ("" when unknown, e.g. build actions).
    def _decorate_snippet_verb(rows, base, dur_word):
        for r in rows:
            dur = r.get("duration", "")
            r["snippet_verb"] = (base + " " + dur_word + " " + dur) if (dur_word and dur) else base

    _decorate_snippet_verb(_build_failures_snippets, "failed to build", "")
    _decorate_snippet_verb(_failed_snippets, "failed", "in")
    _decorate_snippet_verb(_timeout_snippets, "timed out", "after")

    # Attach each failure's per-failure repro commands to its snippet row (keyed
    # by untruncated label); they render inline beneath the snippet.
    _repro_by_target = repro_by_target(data.get("repro_commands", []))

    def _attach_repros(rows):
        for r in rows:
            r["repros"] = _repro_by_target.get(r.get("_orig_label", ""), [])

    _attach_repros(_build_failures_snippets)
    _attach_repros(_failed_snippets)
    _attach_repros(_timeout_snippets)

    # Per-bucket "more output not shown" note. A failure with a rendered snippet
    # is dropped from its bucket's <pre> table, so the table rows ARE the
    # snippet-less failures — each bucket's overflow is just its table row count.
    # Only framed as "output not shown" once snippets are on AND at least one
    # rendered (otherwise the table is the normal full listing, not an overflow).
    _snippets_shown = (max_snippets - _snippet_budget[0]) if _snippets_enabled else 0
    _overflow_active = _snippets_shown > 0

    def _bucket_overflow(table):
        n = len(table["rows"])
        return n if (_overflow_active and n > 0) else 0

    _build_failures_overflow_snip = _bucket_overflow(_build_failures_table)
    _failed_tests_overflow_snip = _bucket_overflow(_failed_table)
    _timeout_tests_overflow_snip = _bucket_overflow(_timeout_table)

    # Task timing: aligned <pre> (Phase | Description | Duration).
    _task_timing_rows_data = _build_task_timing_rows(task_phases, task_active, status)
    _task_timing_total_str = format_duration_ms(task_elapsed_ms) if task_elapsed_ms > 0 else ""
    _task_timing_table = _align_task_timing_for_pre(
        _task_timing_rows_data,
        total_duration = _task_timing_total_str,
    )

    # True when any target bucket has data. False (and not aborted) → template
    # shows a "waiting for data" placeholder instead of a blank section.
    _has_targets_info = (
        build_failure_count > 0 or
        failed_test_count > 0 or
        timeout_test_count > 0 or
        flaky_test_count > 0 or
        passed_test_count > 0 or
        cached_test_count > 0 or
        built_non_test_count > 0 or
        derived_failures_count > 0 or
        skipped_count > 0
    )

    actions_total = data["bazel"].get("actions_total", 0)
    if build_failure_count > 0:
        build_badge_url = "https://img.shields.io/badge/build-failed-red"
    elif actions_total > 0:
        build_badge_url = "https://img.shields.io/badge/build-" + str(actions_total) + "%20actions-blue"
    else:
        build_badge_url = "https://img.shields.io/badge/build-passed-brightgreen"

    pass_t_total = data["bazel"].get("passed_test_total", 0)
    if failed_test_count + timeout_test_count > 0:
        test_badge_url = ("https://img.shields.io/badge/tests-" +
                          str(pass_t_total) + "%20passed%2C%20" +
                          str(failed_test_count + timeout_test_count) + "%20failed-red")
    elif flaky_test_count > 0:
        test_badge_url = ("https://img.shields.io/badge/tests-" +
                          str(pass_t_total) + "%20passed%2C%20" +
                          str(flaky_test_count) + "%20flaky-yellow")
    elif pass_t_total > 0:
        test_badge_url = "https://img.shields.io/badge/tests-" + str(pass_t_total) + "%20passed-brightgreen"
    else:
        test_badge_url = ""

    return {
        "aborted": data["bazel"].get("aborted", False),
        "abort_reason": data["bazel"].get("abort_reason", ""),
        "abort_description": data["bazel"].get("abort_description", ""),
        # "" (falsy) when any bucket has data; "1" → template shows a
        # "waiting for data" placeholder.
        "no_targets_info": "" if _has_targets_info else "1",
        # "## Targets (N)" header; aggregate target_completed count (success + failure).
        "total_targets": str(data["bazel"].get("targets_total", 0)),

        # Bucket sections. Each *_header is "{count} {plural}"; empty lists let
        # template conditionals skip the section.
        "build_failures": _build_failures_table["rows"],
        "build_failures_table_head": _build_failures_table["header"],
        "build_failures_table_sep": _build_failures_table["separator"],
        # Rows that got an inline snippet — rendered as blocks, NOT in the table.
        "build_failures_snippets": _build_failures_snippets,
        "build_failures_count": build_failure_count,
        "build_failures_header": _bucket_header(_BUCKET_FAILED_TO_BUILD, build_failure_count),
        "build_failures_overflow": str(failed_actions_overflow) if failed_actions_overflow > 0 else "",
        "build_failures_icon": _BUCKET_ICONS[_BUCKET_FAILED_TO_BUILD],
        # Per-bucket inline-snippet overflow: failures in this bucket past the
        # shared snippet budget (shown as table rows, output not inlined). The
        # note renders inside the bucket, above its table. "" when none.
        "build_failures_snippet_overflow": str(_build_failures_overflow_snip) if _build_failures_overflow_snip > 0 else "",
        "build_failures_snippet_overflow_plural": "s" if _build_failures_overflow_snip != 1 else "",
        "failed_tests_snippet_overflow": str(_failed_tests_overflow_snip) if _failed_tests_overflow_snip > 0 else "",
        "failed_tests_snippet_overflow_plural": "s" if _failed_tests_overflow_snip != 1 else "",
        "timeout_tests_snippet_overflow": str(_timeout_tests_overflow_snip) if _timeout_tests_overflow_snip > 0 else "",
        "timeout_tests_snippet_overflow_plural": "s" if _timeout_tests_overflow_snip != 1 else "",
        # Producer-authored repro/fix lists (lib/repro_commands.axl); template
        # emits the "🔁 Reproduce" / "🛠️ Fix" sections. Per-failure entries
        # (target != "") render inline beneath their snippet, so the combined
        # sections show only whole-run (target == "") commands.
        "repro_commands": [c for c in (data.get("repro_commands", []) or []) if not _cmd_field(c, "target")],
        "fix_commands": [c for c in (data.get("fix_commands", []) or []) if not _cmd_field(c, "target")],
        # Derived failures (dep broke, no own action error); collapsed list under
        # Build Failures. Count stringified (Jinja2 can't compare AXL ints).
        "derived_failures": _derived_table["rows"],
        "derived_failures_table_head": _derived_table["header"],
        "derived_failures_table_sep": _derived_table["separator"],
        "derived_failures_count": str(derived_failures_count),
        "derived_failures_plural": "s" if derived_failures_count != 1 else "",
        "derived_failures_overflow": str(derived_failures_overflow) if derived_failures_overflow > 0 else "",
        "failed_tests": _failed_table["rows"],
        "failed_tests_table_head": _failed_table["header"],
        "failed_tests_table_sep": _failed_table["separator"],
        "failed_tests_has_artifacts": _failed_table.get("has_artifacts", False),
        "failed_tests_snippets": _failed_snippets,
        "failed_tests_header": _bucket_header(_BUCKET_TEST_FAILED, failed_test_count),
        "failed_tests_icon": _BUCKET_ICONS[_BUCKET_TEST_FAILED],
        "timeout_tests": _timeout_table["rows"],
        "timeout_tests_table_head": _timeout_table["header"],
        "timeout_tests_table_sep": _timeout_table["separator"],
        "timeout_tests_has_artifacts": _timeout_table.get("has_artifacts", False),
        "timeout_tests_snippets": _timeout_snippets,
        "timeout_tests_header": _bucket_header(_BUCKET_TEST_TIMEOUT, timeout_test_count),
        "timeout_tests_icon": _BUCKET_ICONS[_BUCKET_TEST_TIMEOUT],
        "flaky_tests": _flaky_table["rows"],
        "flaky_tests_table_head": _flaky_table["header"],
        "flaky_tests_table_sep": _flaky_table["separator"],
        "flaky_tests_has_artifacts": _flaky_table.get("has_artifacts", False),
        "flaky_tests_header": _bucket_header(_BUCKET_TEST_FLAKY, flaky_test_count),
        "flaky_tests_icon": _BUCKET_ICONS[_BUCKET_TEST_FLAKY],

        # Passed-test table: label | kind | duration [| artifacts]. Artifacts
        # column only when per-file URLs exist (driven by passed_tests_has_artifacts).
        "passed_tests": _passed_table["rows"],
        "passed_tests_table_head": _passed_table["header"],
        "passed_tests_table_sep": _passed_table["separator"],
        "passed_tests_has_artifacts": _passed_table.get("has_artifacts", False),
        "passed_tests_count": passed_test_count,
        "passed_tests_header": _bucket_header(_BUCKET_TEST_PASSED, passed_test_count),
        "cached_tests": _cached_table["rows"],
        "cached_tests_table_head": _cached_table["header"],
        "cached_tests_table_sep": _cached_table["separator"],
        "cached_tests_has_artifacts": _cached_table.get("has_artifacts", False),
        "cached_tests_count": cached_test_count,
        "cached_tests_header": _bucket_header(_BUCKET_TEST_PASSED_CACHED, cached_test_count),

        # Built-targets table: label | kind.
        "built_targets": _built_table["rows"],
        "built_targets_table_head": _built_table["header"],
        "built_targets_table_sep": _built_table["separator"],
        "built_targets_count": built_non_test_count,
        # Render whenever count > 0 even if the sample is empty (cap + test-heavy
        # filtering can leave nothing visible).
        "built_targets_any": "1" if built_non_test_count > 0 else "",
        "built_targets_header": _bucket_header(_BUCKET_SUCCESSFUL_BUILD, built_non_test_count),
        "built_targets_overflow": str(built_overflow) if built_overflow > 0 else "",
        "passed_tests_overflow": str(passed_overflow) if passed_overflow > 0 else "",

        # Skipped-targets table: label | kind. Header uses the uncapped count;
        # skipped_targets_overflow drives "N more not shown".
        "skipped_targets": _skipped_table["rows"],
        "skipped_targets_table_head": _skipped_table["header"],
        "skipped_targets_table_sep": _skipped_table["separator"],
        "skipped_targets_count": skipped_count,
        "skipped_targets_any": "1" if skipped_count > 0 else "",
        "skipped_targets_header": _bucket_header(_BUCKET_SKIPPED, skipped_count),
        "skipped_targets_icon": _BUCKET_ICONS[_BUCKET_SKIPPED],
        "skipped_targets_overflow": str(skipped_overflow) if skipped_overflow > 0 else "",

        # Command-line views (options_parsed, redacted). long: multi-line
        # reproducer; short: <details> summary.
        "explicit_command_line": _explicit_cmd["long"],
        "explicit_command_line_short": _explicit_cmd["short"],
        "startup_options": _startup_opts_redacted,
        "cmd_line_options": _cmd_line_redacted,

        # Badges, links, artifacts.
        "build_badge_url": build_badge_url,
        "test_badge_url": test_badge_url,
        "bes_invocation_url": render_bes_url(data),
        "ci_label": links.get("ci_label", ""),
        "ci_url": links.get("ci_url", ""),
        "aspect_url": links.get("aspect_url", ""),
        "artifacts_browse_url": links.get("artifacts_browse_url", ""),
        "artifact_links": artifact_links,

        # Invocation / Runner / Workspace Status / Build Metadata / Performance:
        # [{key, value}] rows (empty values filtered); template emits non-empty
        # sections only.
        "invocation_rows": build_invocation_detail_rows(data, start_date, finish_date),
        "aspect_runner_rows": build_aspect_runner_rows(std) if std else [],
        "workspace_status_rows": build_kv_rows(data["bazel"].get("workspace_status", {})),
        "build_metadata_rows": build_kv_rows(data["bazel"].get("metadata", {})),
        "invocation_stats": _build_invocation_stats(data),
        # Empty on the single-attempt path (template hides "🔁 Retry attempts").
        "retry_attempt_rows": _build_retry_attempt_rows(data, links),

        # Task timing (when the task opened phases); empty → template skips.
        "task_timing_table_head": _task_timing_table["header"],
        "task_timing_table_sep": _task_timing_table["separator"],
        "task_timing_rows": _task_timing_table["rows"],
        "task_timing_total_separator": _task_timing_table["total_separator"],
        "task_timing_total_line": _task_timing_table["total_line"],

        # SHARED renders Bazel targets unless build/test hoisted it (see DETAILS_TEMPLATE).
        "include_bazel_targets": include_bazel_targets,
        # Reproduce/Fix render atop Bazel targets only when it's the primary slot.
        "render_repro_in_targets": render_repro_in_targets,

        # "⏱ Last updated … · 📊 API quota …" line above `Powered by`; "" in
        # snapshot/direct-render sites (template gates).
        "api_usage": (render_ctx.get("api_usage") if render_ctx else "") or "",
        "last_updated_at": (render_ctx.get("last_updated_at") if render_ctx else "") or "",

        # Footer version suffix; "" when no `std` (template gates).
        "cli_version": std.env.aspect_cli_version() if std else "",
    }

def active_phase_data(ctx):
    """Active `Phase` snapshot or None. Thin pass-through to
    `ctx.task.current_phase()`, named so result libs can forward it via
    `render_check_output(task_active=...)`. duration_ms is live elapsed; the
    renderer adds status-aware description suffixes.
    """
    return ctx.task.current_phase()

def _build_task_timing_rows(phases, active, status):
    """Task-timing table rows.

    Hides the synthetic init phase under `_INIT_PHASE_HIDE_THRESHOLD_MS`;
    caller-named phases always render. The Phase column is bare names (no
    emoji): variable emoji widths break `_pad_right` alignment in a fixed-width
    column (the header strip keeps emoji as a single inline run).

    The active phase (non-terminal) is the trailing row with a status-aware
    Description suffix ("(active)"/"(failing)"); on terminal `failed`, an
    interrupted entry shows "(failed during this phase)".
    """

    def _name(name, display_name):
        return display_name or _titlecase(name)

    rows = []
    if phases:
        for p in phases:
            if p.name == "init" and p.duration_ms < _INIT_PHASE_HIDE_THRESHOLD_MS:
                continue
            desc = p.description or "—"
            if status == "failed" and p.interrupted:
                desc = desc + " (failed during this phase)"
            rows.append({
                "name": _name(p.name, p.display_name),
                "description": desc,
                "duration": format_duration_ms(p.duration_ms),
                "is_active": False,
            })
    if active:
        # Status-aware suffix on the active row (mirrors the header strip);
        # is_active drives the leading-arrow marker on live surfaces.
        verb_suffix = {
            "failed": " (failed during this phase)",
            "passed": "",
            "failing": " (failing)",
        }.get(status, " (active)")
        rows.append({
            "name": _name(active.name, active.display_name),
            "description": (active.description or "—") + verb_suffix,
            "duration": format_duration_ms(active.duration_ms),
            # Live-only — no "active" row at terminal.
            "is_active": status not in ("passed", "failed", "aborted"),
        })
    return rows

def extract_failure_snippets(std, data, snippet_options, max_per_task):
    """Extract up to `max_per_task` inline failure snippets from a frozen
    bazel_results `data`, for the PR-summary-comment producer.

    A snippet can only be read by the job that ran the failure (it owns the
    local test.log / action-stderr paths); sibling jobs can't. So each job
    extracts its own here on its terminal update and ships the result in its
    status artifact. Build-action failures take precedence over test failures,
    matching the check-surface order.

    Returns a list of plain dicts (JSON-round-trippable through the artifact):
    `[{label, kind, bucket, snippet, truncated, trunc_head, trunc_tail,
    duration_ms, repros}]` (bucket is "build" | "test" | "timeout"; duration_ms
    is the test wall time, 0 for build actions; repros is the per-failure repro
    commands `[{command, description}]` for that label), capped at `max_per_task`.
    Empty when off (max_per_task <= 0 / no options). The writer dedupes identical
    failures across tasks and computes overflow from what it drops at render.
    """
    bz = data.get("bazel", {})
    if max_per_task <= 0 or snippet_options == None or std == None:
        return []

    target_kinds = bz.get("target_kinds", {}) or {}
    test_details = bz.get("test_details", {}) or {}

    # Per-failure repro commands keyed by label, shipped with each snippet so the
    # PR-comment writer renders them inline.
    _repros = repro_by_target(data.get("repro_commands", []))

    out = []

    def _take(label, kind, bucket, res, duration_ms = 0):
        if not has_snippet(res):
            return
        out.append({
            "label": label,
            "kind": kind,
            "bucket": bucket,
            "snippet": res.text,
            "truncated": res.truncated,
            "trunc_head": res.trunc_head,
            "trunc_tail": res.trunc_tail,
            # Test wall time (ms); 0 for build actions (BES action timing is
            # unreliable and not captured). Rendered as "failed in <dur>".
            "duration_ms": duration_ms or 0,
            "repros": _repros.get(label, []),
        })

    # Build-action stderr first (precedence), then failed tests, then timeouts.
    for a in bz.get("failed_actions", []):
        if len(out) >= max_per_task:
            break
        label = a.get("label", "")
        _take(
            label,
            target_kinds.get(label, ""),
            "build",
            extract_snippet(std, a.get("stderr_path", ""), snippet_options),
        )

    for t in bz.get("failed_tests", []):
        if len(out) >= max_per_task:
            break
        s = t.get("status", "failed")
        bucket = "timeout" if s == "timeout" else "test"
        label = t.get("label", "")
        detail = test_details.get(label, {}) or {}
        res = extract_junit_failure(std, detail.get("xml_path", ""), snippet_options)
        if not has_snippet(res):
            res = extract_snippet(std, detail.get("log_path", ""), snippet_options)
        _take(
            label,
            t.get("kind", "") or target_kinds.get(label, ""),
            bucket,
            res,
            duration_ms = t.get("duration_ms", 0) or detail.get("duration_ms", 0),
        )

    return out

def render_check_output(ctx, data, status, render_ctx, links, templates = None, metadata_keys = None, snippet_options = None, max_snippets = 0):
    """Render {title, summary, text} for a GitHub check run output field.

    Public entry point for the "bazel_results" task_update kind; features call it
    from their task_update handler.

    Args:
        ctx:             TaskContext
        data:            dict from init_data(), updated by process_event
        status:          "running" | "failing" | "passed" | "failed"
        render_ctx:      feature display context — see build_summary_data
        links:           dict with ci_label, ci_url, aspect_url
        templates:       optional "summary"/"details" Jinja2 overrides
        metadata_keys:   extra BES metadata keys to surface; ["*"] = all
        snippet_options: `SnippetOptions` line/byte budget for inline failure
                         snippets, or None to disable (per-surface, see callers).
        max_snippets:    max failure rows (shared across build/test buckets) to
                         show inline output for; 0 disables.
    """

    # Render-debug gated on `_ASPECT_DEBUG_STATUS_RENDER_CHECK` (surfaces
    # re-render dozens of times per task — too noisy for the standard stream).
    debug_render = bool(ctx.std.env.var("_ASPECT_DEBUG_STATUS_RENDER_CHECK"))
    if debug_render:
        trace.log("debug [render_check_output] status=" + status)
        trace.log("debug [render_check_output]   invocation_id=" + (data["bazel"].get("invocation_id") or ""))
        trace.log("debug [render_check_output]   wall_time_ms=" + str(data["bazel"].get("wall_time_ms", 0)))
        trace.log("debug [render_check_output]   targets_total=" + str(data["bazel"].get("targets_total", 0)))
        trace.log("debug [render_check_output]   built_targets=" + str(len(data["bazel"].get("built_targets", []))))
        trace.log("debug [render_check_output]   passed_test_total=" + str(data["bazel"].get("passed_test_total", 0)))
        trace.log("debug [render_check_output]   passed_tests=" + str(len(data["bazel"].get("passed_tests", []))))
        trace.log("debug [render_check_output]   failed_test_total=" + str(data["bazel"].get("failed_test_total", 0)))
        trace.log("debug [render_check_output]   flaky_test_total=" + str(data["bazel"].get("flaky_test_total", 0)))
        trace.log("debug [render_check_output]   actions_total=" + str(data["bazel"].get("actions_total", 0)))
        op = data["bazel"].get("options_parsed") or {}
        trace.log("debug [render_check_output]   options_parsed explicit=" + str(len(op.get("explicit_cmd_line", []))) +
                  " startup=" + str(len(op.get("startup_options", []))) +
                  " cmd=" + str(len(op.get("cmd_line", []))))
        ws = data["bazel"].get("workspace_status") or {}
        if ws:
            trace.log("debug [render_check_output]   workspace_status=" + str(ws))
        meta = data["bazel"].get("metadata") or {}
        if meta:
            trace.log("debug [render_check_output]   metadata=" + str(meta))
        passed = data["bazel"].get("passed_tests") or []
        if passed:
            sample = [t.get("label", "") for t in passed[:5]]
            trace.log("debug [render_check_output]   passed_tests sample=" + str(sample))
        built = data["bazel"].get("built_targets") or []
        if built:
            sample = [t.get("label", "") for t in built[:3]]
            trace.log("debug [render_check_output]   built_targets sample=" + str(sample))

    # GitHub hard limit for check run output.text is 65535 bytes; 65000 leaves
    # encoding headroom.
    _DETAILS_LIMIT = 65000

    t = templates or {}
    run_date = format_run_date(ctx, data.get("start_time_ms", 0))
    finish_date = format_run_date(ctx, data.get("finish_time_ms", 0))
    summary_data = build_summary_data(ctx, data, status, render_ctx, links, metadata_keys, run_date = run_date)
    details_data = build_details_data(
        data,
        links,
        render_ctx = render_ctx,
        status = status,
        start_date = run_date,
        finish_date = finish_date,
        std = ctx.std,
        task_phases = ctx.task.phases(),
        task_active = active_phase_data(ctx),
        task_elapsed_ms = ctx.task.elapsed_ms,
        # Build/test hoist Bazel targets above SHARED, so SHARED skips it.
        include_bazel_targets = False,
        # Bazel targets is the primary slot, so Reproduce/Fix render at its top.
        render_repro_in_targets = True,
        snippet_options = snippet_options,
        max_snippets = max_snippets,
    )

    if debug_render:
        trace.log("debug [render_check_output]   summary target_pattern=" + summary_data.get("target_pattern", ""))
        trace.log("debug [render_check_output]   summary branch=" + summary_data.get("branch", ""))
        trace.log("debug [render_check_output]   summary short_sha=" + summary_data.get("short_sha", ""))
        trace.log("debug [render_check_output]   summary detail_rows count=" + str(len(summary_data.get("detail_rows", []))))
        trace.log("debug [render_check_output]   details startup_options=" + str(len(details_data.get("startup_options", []))) +
                  " cmd_line_options=" + str(len(details_data.get("cmd_line_options", []))) +
                  " explicit=" + str(bool(details_data.get("explicit_command_line", ""))))
        trace.log("debug [render_check_output]   run_date=" + run_date)
        trace.log("debug [render_check_output]   cpu_arch=" + str(data["bazel"].get("cpu_arch", "")))
        trace.log("debug [render_check_output]   compilation_mode=" + str(data["bazel"].get("compilation_mode", "")))
        trace.log("debug [render_check_output]   build_tool_version=" + str(data["bazel"].get("build_tool_version", "")))
        trace.log("debug [render_check_output]   targets_configured=" + str(data["bazel"].get("targets_configured", 0)))
        trace.log("debug [render_check_output]   packages_loaded=" + str(data["bazel"].get("packages_loaded", 0)))

    details_tmpl = t.get("details") or DETAILS_TEMPLATE
    (summary_text, _summary_ok) = render_summary_or_fallback(ctx, t.get("summary") or SUMMARY_TEMPLATE, summary_data, surface = "build/test")

    # Re-render the details body after a trim step, degrading to the fallback on
    # any render error. Trimming mutates details_data, so a template that only
    # errors on a trimmed shape must still fall back rather than abort — and the
    # fallback is far under _DETAILS_LIMIT, so the remaining trim guards go false
    # and the cascade stops on its own.
    def _render_details():
        (text, _ok) = render_details_or_fallback(ctx, details_tmpl, details_data, surface = "build/test")
        return text

    details_text = _render_details()

    # Fit details within the GitHub limit; each step re-renders only if still
    # over. Inline snippets are extra (not the data users primarily came for), so
    # they shed FIRST — secondary buckets, then all of them — before any of the
    # established trims below. Reference sections (redundant with Aspect Web UI)
    # go next, before the failure/target lists themselves:
    #   0a. snippets in secondary buckets  0b. all snippets
    #   1. Build Metadata  2. Workspace Status  3. Invocation  4. Performance
    #   5. parsed-options lists  6. halve built_targets  7. halve passed_tests
    #   8. drop cached_tests (last resort)
    # Shed the heavy log body but keep each failure's one-line header (the macro
    # renders the header whenever the row is present; the code block only when
    # `snippet` is still set).
    def _drop_snippets(rows):
        for r in rows:
            if "snippet" in r:
                r.pop("snippet")

    if len(details_text) > _DETAILS_LIMIT and max_snippets > 0:
        if debug_render:
            trace.log("debug [render_check_output]   OVER LIMIT (" + str(len(details_text)) +
                      "), dropping inline snippet bodies from secondary failure buckets")
        _drop_snippets(details_data.get("failed_tests_snippets", []))
        _drop_snippets(details_data.get("timeout_tests_snippets", []))
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT and max_snippets > 0:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping all inline snippet bodies")
        _drop_snippets(details_data.get("build_failures_snippets", []))
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   OVER LIMIT (" + str(len(details_text)) +
                      "), dropping build_metadata sub-block from Bazel details")
        details_data["build_metadata_rows"] = []
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping workspace_status sub-block from Bazel details")
        details_data["workspace_status_rows"] = []
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping invocation sub-block from Bazel details")
        details_data["invocation_rows"] = []
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping Runner metadata section")
        details_data["aspect_runner_rows"] = []
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping Performance")
        details_data["invocation_stats"] = None
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping parsed-options lists")
        details_data["startup_options"] = []
        details_data["cmd_line_options"] = []
        details_text = _render_details()

    if len(details_text) > _DETAILS_LIMIT:
        built = details_data.get("built_targets", [])
        built_total = details_data.get("built_targets_count", 0)

        # Halve up to 10 times (handles 1024× overage).
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(built) == 0:
                break
            built = built[:len(built) // 2]
            overflow = built_total - len(built)
            details_data["built_targets"] = built
            details_data["built_targets_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = _render_details()
        if debug_render:
            trace.log("debug [render_check_output]   after target trim: details len=" + str(len(details_text)) +
                      " built_targets=" + str(len(built)))

    if len(details_text) > _DETAILS_LIMIT:
        passed = details_data.get("passed_tests", [])
        passed_total = details_data.get("passed_tests_count", 0)
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(passed) == 0:
                break
            passed = passed[:len(passed) // 2]
            overflow = passed_total - len(passed)
            details_data["passed_tests"] = passed
            details_data["passed_tests_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = _render_details()
        if debug_render:
            trace.log("debug [render_check_output]   after test trim: details len=" + str(len(details_text)) +
                      " passed_tests=" + str(len(passed)))

    if len(details_text) > _DETAILS_LIMIT:
        skipped = details_data.get("skipped_targets", [])
        skipped_total = details_data.get("skipped_targets_count", 0)
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(skipped) == 0:
                break
            skipped = skipped[:len(skipped) // 2]
            overflow = skipped_total - len(skipped)
            details_data["skipped_targets"] = skipped
            details_data["skipped_targets_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = _render_details()
        if debug_render:
            trace.log("debug [render_check_output]   after skipped trim: details len=" + str(len(details_text)) +
                      " skipped_targets=" + str(len(skipped)))

    if len(details_text) > _DETAILS_LIMIT:
        # Last resort.
        details_data["cached_tests"] = []
        details_text = _render_details()

    if debug_render:
        trace.log("debug [render_check_output]   summary len=" + str(len(summary_text)))
        trace.log("debug [render_check_output]   details len=" + str(len(details_text)))
        trace.log("debug [render_check_output] --- summary ---")
        trace.log(summary_text)
        trace.log("debug [render_check_output] --- details (first 5000 chars) ---")
        trace.log(details_text[:5000])

    target_pattern = render_ctx.get("subject", "") if render_ctx else ""
    task_kind = render_ctx.get("task_kind", "") if render_ctx else ""
    return {
        "title": summary_title(
            data,
            status,
            target_pattern = target_pattern,
            task_kind = task_kind,
        ),
        "summary": summary_text,
        "text": details_text,
    }

# ─── The `results` handle: BES accumulation + status surfaces ─────────────────
#
# `results.build(ctx)` / `results.test(ctx)` wrap `phases.new(ctx, init_data())`
# and own every surface interaction a bazel build/test task makes: the live
# progress emit gate, per-attempt phase rows + retry archiving, the terminal
# emit, and repro-command production. A task that wants none of this simply
# doesn't construct a handle — the `bazel.build(ctx)` invocation handle runs
# fine without it. The status/progress text helpers below moved here verbatim
# from the old `bazel_runner.axl` (they were always results logic).

# BES event kinds `process_event` consumes. Passed as `kinds=` to the results
# iterator so the send-side filter drops the noisy unconsumed kinds (`progress`,
# `named_set_of_files`, …) before they are cloned into this subscriber's buffer.
# MUST stay in sync with the `process_event` switch — `bazel_run_test.axl` has a
# drift test asserting both directions.
RESULTS_KINDS = [
    "build_started",
    "structured_command_line",
    "options_parsed",
    "build_metadata",
    "workspace_status",
    "action_completed",
    "target_configured",
    "target_completed",
    "test_result",
    "test_summary",
    "build_metrics",
    "build_finished",
    "configuration",
    "aborted",
]

def _pick_status(command, data, had_failure, terminal):
    """Lifecycle status from accumulated BES counters. `command` is
    "build"/"test"; `had_failure` folds failed actions/tests. Aborted wins;
    a flaky-only test outcome flips to `warning`."""
    if data.get("bazel", {}).get("aborted"):
        return "aborted"
    if had_failure:
        return "failed" if terminal else "failing"
    if command == "test" and data.get("bazel", {}).get("flaky_test_total", 0) > 0:
        return "warning"
    return "passed" if terminal else "running"

def _passed_text(command, bz):
    if command == "test":
        passed = bz.get("passed_test_total", 0)
        failed = bz.get("failed_test_total", 0)
        flaky = bz.get("flaky_test_total", 0)
        cached = bz.get("cached_test_total", 0)
        total = passed + failed
        if total == 0:
            return "no tests"
        text = "%d/%d passed" % (passed, total)
        extras = []
        if flaky > 0:
            extras.append("%d flaky" % flaky)
        if cached > 0:
            extras.append("%d cached" % cached)
        if extras:
            text = text + " · " + " · ".join(extras)
        return text
    n = bz.get("targets_total", 0)
    return ("%d built" % n) if n > 0 else "ok"

def _compact_text(command, status, data):
    """Compact Result-cell text (PR-comment surface)."""
    bz = data.get("bazel", {}) or {}
    if status == "running":
        if command == "test":
            ran = bz.get("passed_test_total", 0) + bz.get("failed_test_total", 0)
            total = bz.get("targets_total", 0)
            if total > 0 and ran > 0:
                return "%d/%d tests run" % (ran, total)
        elif command == "build":
            n = bz.get("targets_total", 0)
            if n > 0:
                return "%d targets" % n
        return ""
    if status == "warning" or status == "passed":
        return _passed_text(command, bz)
    if status == "failing" or status == "failed":
        if command == "test":
            f = bz.get("failed_test_total", 0)
            if f > 0:
                return "%d test%s failed" % (f, "s" if f != 1 else "")
        return ""
    return ""

_TERMINAL_VERB = {
    "passed": "complete",
    "warning": "complete",
    "failed": "failed",
    "failing": "failing",
    "aborted": "aborted",
}

def _live_progress(data, command, status):
    """Compose the "Last update" `ProgressStyles` from the latest BES counters
    (see the old bazel_runner for the phrasing examples). `stream` stays empty —
    the bazel UI prints its own streaming progress."""
    base = "Bazel " + command
    if status == "running" or status == "":
        running_detail = ""
        if command == "test":
            passed = data["bazel"].get("passed_test_total", 0) or 0
            failed = data["bazel"].get("failed_test_total", 0) or 0
            flaky = data["bazel"].get("flaky_test_total", 0) or 0
            total = passed + failed + flaky
            if total > 0:
                expected = data["bazel"].get("test_targets_configured", 0) or 0
                if expected >= total:
                    running_detail = format_int_comma(total) + " of " + pluralize(expected, "test") + " run"
                else:
                    running_detail = pluralize(total, "test") + " run"
                if failed > 0:
                    running_detail = running_detail + " · " + pluralize(failed, "failed", plural = "failed")
        if not running_detail:
            targets = data["bazel"].get("targets_total", 0) or 0
            if targets > 0:
                running_detail = pluralize(targets, "target") + " built"
            else:
                actions = data["bazel"].get("actions_executed", 0) or 0
                if actions > 0:
                    running_detail = pluralize(actions, "action") + " executed"
        head = base + " running..."
        body = head + (" (" + running_detail + ")") if running_detail else head
    else:
        verb = _TERMINAL_VERB.get(status, status)
        body = base + " " + verb
        tail = _compact_text(command, status, data)
        if tail:
            body = body + " (" + tail + ")"

    return phases.ProgressStyles(body = body, stream = "")

# ms since the last live emit before a heartbeat is forced (matches
# MIN_HEARTBEAT_INTERVAL_MS); measured off the monotonic clock.
def _elapsed_ms(since_monotonic):
    return int((time.monotonic() - since_monotonic) * 1000)

def _results_new(ctx, command):
    """Shared constructor for `results.build` / `results.test`. Owns
    `phases.new(ctx, init_data())`, a small heartbeat/attempt state cell, and a
    deferred abort guard so a fatal error still concludes the surface."""
    ph = phases.new(ctx, init_data())
    data = ph.data
    # first: next emit bypasses the surface throttle (priority).
    # last_monotonic: monotonic seconds at the last emit (0 → first tick emits).
    # attempts: count of spawned attempts (human-numbered). label: current
    # spawn-phase body, reused by `invocation()`'s link re-emit.
    # concluded: set by conclude(); the abort guard stands down when True.
    m = {"first": True, "last_monotonic": 0.0, "attempts": 0, "label": "", "concluded": False}

    def _emit(status, priority):
        ph.dispatch(phases.Update(
            kind = "bazel_results",
            status = status,
            progress = _live_progress(data, command, status),
            priority = priority,
            data = data,
        ))
        m["first"] = False
        m["last_monotonic"] = time.monotonic()

    def setup(targets, rc):
        # `rc` is the live run command the invocation handle already registered
        # (`use_rc`); the health checks in setup_surface read it via ctx.bazel.
        _ = rc
        ph.setup_surface(" ".join(targets), "bazel_results")

    def attempt(index, prior = None):
        m["attempts"] = index + 1
        if index == 0:
            phase_id = command
            m["label"] = "Spawning bazel " + command + "..."
            phase_cli = "Spawning bazel " + command
            phase_desc = "Run bazel tests" if command == "test" else "Build bazel targets"
        else:
            # Archive the just-finished (failed) attempt BEFORE resetting `data`
            # (archive holds the `bazel` sub-dict by reference). Iter `index-1`
            # ran human attempt `index`.
            prior_code = prior.code if prior != None else 1
            prior_attempts = archive_bazel_attempt(data, index, prior_code)
            ph.reset(init_data())
            data["bazel_attempts"] = prior_attempts
            m["first"] = True
            phase_id = command + "_retry_" + str(index + 1)
            m["label"] = "Retrying bazel " + command + "... (attempt " + str(index + 1) + ")"
            phase_cli = "Retrying bazel " + command + " (attempt " + str(index + 1) + ")"
            phase_desc = "Retry attempt — " + ("Run bazel tests" if command == "test" else "Build bazel targets")

        ph.update(
            _pick_status(command, data, had_failure = False, terminal = False),
            phases.ProgressStyles(body = m["label"], stream = phase_cli),
            kind = "bazel_results",
            phase = phases.Phase(
                name = phase_id,
                description = phase_desc,
                emoji = "🧪" if command == "test" else "🔨",
            ),
        )

    def invocation(inv):
        data["sink_invocation_id"] = inv.sink_invocation_id
        # Surface the Aspect Workflows link now rather than on the next
        # heartbeat. Body only (no CLI re-print).
        if inv.sink_invocation_id:
            ph.update(
                _pick_status(command, data, had_failure = False, terminal = False),
                phases.ProgressStyles(body = m["label"]),
                kind = "bazel_results",
            )

    def process(event):
        # `event` is a BuildEvent, or None on a quiet heartbeat tick.
        interesting = process_event(data, event) if event != None else False
        heartbeat = _elapsed_ms(m["last_monotonic"]) >= MIN_HEARTBEAT_INTERVAL_MS
        if not (interesting or heartbeat):
            return
        had_failure = (
            data["bazel"]["failed_actions_total"] > 0 or
            data["bazel"]["failed_test_total"] > 0
        )
        _emit(_pick_status(command, data, had_failure = had_failure, terminal = False), priority = m["first"])

    def conclude(w, targets):
        m["concluded"] = True

        # BuildStatus.code is Option<i32> (None on abnormal exit); key the
        # verdict off the reliable `success` bool and coerce a numeric code.
        code = 0 if w.success else (w.code if w.code != None else 1)

        # If retries occurred, append the final attempt so `bazel_attempts` holds
        # the full ordered history (failed priors + final).
        if data.get("bazel_attempts"):
            archive_bazel_attempt(data, m["attempts"], code)

        final_status = _pick_status(command, data, had_failure = not w.success, terminal = True)

        # Per-subcommand + per-failure repro commands, flavor-gated. Keyed by the
        # subcommand that REPRODUCES each failure (a test that failed to build
        # reruns via `bazel build`). Moved verbatim from bazel_runner.
        flavors = ctx.args.repro_flavors if hasattr(ctx.args, "repro_flavors") else []
        prefix = repro_prefix(ctx)
        by_sub = failed_labels_by_subcommand(data)

        def _add(cmd, slug, description = "", target = ""):
            if cmd and flavor_allows(flavors, slug):
                data["repro_commands"].append(phases.ReproFixCommand(
                    command = cmd, description = description, slug = slug, target = target,
                ))

        def _add_pair(subcommand, labels, target = ""):
            if not labels:
                return
            _add(prefix + build_aspect_command(subcommand, [], labels), subcommand + "-repro-aspect", target = target)
            _add(prefix + build_bazel_command(subcommand, labels), subcommand + "-repro-vanilla-bazel", description = "vanilla bazel", target = target)

        for sub in ("build", "test"):
            if by_sub[sub]:
                _add_pair(sub, collapse_repro_targets(by_sub[sub], targets))
        for sub in ("build", "test"):
            for label in by_sub[sub]:
                _add_pair(sub, [label], target = label)

        ph.suggest_fixes(
            "bazel_results",
            final_status,
            exit_code = w.code,
            bazel_subcommand = command,
            targets = targets,
            failed_targets = failed_labels(data),
        )

        bookend = conclusion(final_status, data)
        ph.dispatch(phases.Update(
            kind = "bazel_results",
            status = final_status,
            final = True,
            conclusion = bookend,
            data = data,
            progress = _live_progress(data, command, final_status),
        ))
        print_repro_and_fix(ctx.std, data, final_status)
        return TaskConclusion(exit_code = code, text = bookend, flagged = final_status == "warning")

    def _abort_guard():
        # Fatal error / interrupt before conclude(): flip the surface off
        # "running" so it doesn't stick. ctx.defer runs even on a Starlark error.
        if m["concluded"]:
            return
        ph.dispatch(phases.Update(
            kind = "bazel_results",
            status = "aborted",
            final = True,
            conclusion = conclusion("aborted", data),
            data = data,
            progress = _live_progress(data, command, "aborted"),
        ))

    ctx.defer(_abort_guard)

    return struct(
        ph = ph,
        data = data,
        # Emit BES events only when a status surface is listening — mirrors the
        # old `need_bes` gate (no surfaces → bazel runs with no BEP fifo).
        live = bool(ctx.traits[Phases].task_update),
        setup = setup,
        attempt = attempt,
        invocation = invocation,
        process = process,
        conclude = conclude,
    )

results = namespace(
    build = lambda ctx: _results_new(ctx, "build"),
    test = lambda ctx: _results_new(ctx, "test"),
    KINDS = RESULTS_KINDS,
)
