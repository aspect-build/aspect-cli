"""Bazel build event result accumulation and Markdown rendering.

Processes the BES event stream into failed actions/targets and test outcomes,
then renders a Markdown summary for GitHub check run bodies. Reusable by any
surface reporting Bazel data (GitHub status checks, Buildkite annotations).

Event kinds consumed:
  "build_started"            — resets all state; captures invocation UUID, tool version, command, start time
  "structured_command_line"  — captures bes_results_url and reconstructs full command line strings
  "build_metadata"           — captures --build_metadata / --bes_metadata key=value pairs
  "workspace_status"         — captures workspace_status key=value pairs (BUILD_USER, etc.)
  "configuration"            — captures cpu arch and compilation_mode (target config only)
  "action_completed"         — accumulates failed build actions (up to MAX_FAILED_ACTIONS)
  "target_configured"        — caches rule kind per label; counts configured targets (incl. test targets, the live progress denominator)
  "target_completed"         — accumulates failed build targets
  "test_result"              — captures per-attempt test.log + test.xml paths and duration (keyed by label)
  "test_summary"             — buckets tests into failed / flaky / passed; tracks duration
  "build_metrics"            — captures action/target/package counts and timing
  "aborted"                  — captures build abort reason and description

Payload fields used:
  BuildStarted.uuid, .build_tool_version, .command, .start_time_millis
  CommandLine.command_line_label, .sections[].section_type (ChunkList|OptionList oneof)
  BuildMetadata.metadata             — dict[str,str] of --build_metadata/--bes_metadata pairs
  WorkspaceStatus.item               — repeated list of {key, value} structs (proto field is "item")
  Configuration.cpu, .compilation_mode, .is_tool_configuration
  ActionExecuted.success, .type, .stderr (File — uri only, never .contents)
  TargetComplete.success
  TestResult.test_action_output (File list), .test_attempt_duration_millis
  TestSummary.overall_status, .total_num_cached, .total_run_duration_millis (split by cached/executed)
  BuildMetrics.action_summary.{actions_executed, actions_created}
  BuildMetrics.timing_metrics.{wall_time_in_ms, cpu_time_in_ms}
  BuildMetrics.target_metrics.targets_configured
  BuildMetrics.package_metrics.packages_loaded
  BuildMetrics.cumulative_metrics.{num_analyses, num_builds}
  Aborted.abort_reason, .description
  event.id.label       — target label for all event types

stderr CONTENTS are deliberately not held on the Starlark heap: BES can inline
action stderr via the File.contents oneof (observed 40+ MB in the wild). We read
only the File.uri and resolve it to a local path (failed_actions[].stderr_path),
exactly as test.log is. The path is materialized on demand by lib/log_snippet
(bounded read) at render time for the inline failure snippet; the raw bytes are
never copied into a Starlark value here. When no snippet is rendered, the
surface still shows the failing label + action mnemonics + the CI link.
"""

load("@std//time.axl", "time")
load("./ci.axl", "detect_ci_host", "resolve_build_url")
load(
    "./environment.axl",
    "build_aspect_runner_rows",
    "display_cloud_provider",
    "feature_logger",
    "is_aspect_workflows_runner",
)
load("./lifecycle.axl", "Phases", "phases")
load("./log_snippet.axl", "SnippetOptions", "code_fence_for", "extract_junit_failure", "extract_snippet", "has_snippet")
load("./path_glob.axl", "match_path")
load(
    "./repro_commands.axl",
    "ASPECT_CLI_INSTALL_HINT_MARKDOWN",
    "build_aspect_command",
    "build_bazel_command",
    "flavor_allows",
    "print_repro_and_fix",
    "repro_prefix",
)
load("./result_text.axl", "emoji_for_status")
load("./text.axl", "SUBJECT_TITLE_MAX", "format_int_comma", "pluralize", "truncate_for_title")
load("./tips.axl", "decorate_tip")

# Max unique failed-target labels to keep detail for (entries are small).
MAX_FAILED_ACTIONS = 25

# Matches Marvin's MAX_TEST_TARGETS.
MAX_TEST_TARGETS = 100

# Matches Marvin's MAX_REPRO_COMMAND_RUNES.
MAX_REPRO_CHARS = 1000

MAX_BUILT_TARGETS = 250

# Heartbeat floor for live surface updates: force a refresh if this many ms
# elapsed since the last emit, so the `⏱` timer / counters don't stall during
# quiet stretches. 5s matches platform refresh cadence (BK throttles annotation
# updates ~4s server-side; GHSC is similarly slow).
MIN_HEARTBEAT_INTERVAL_MS = 5000

# Sleep between BES drain passes (drain try_pop, emit at most once, check
# events.done). 250ms = 4 wake-ups/sec; short enough that event-quiet stretches
# don't stall the loop.
BES_DRAIN_TICK_MS = 250

# bb_clientd FUSE mount root for resolving bytestream:// URIs on Aspect
# Workflows runners. lib/artifacts.axl loads `file_uri_to_path` from here, so
# both files resolve the same CAS blobs off this one root.
_BB_CLIENTD_ROOT = "/mnt/ephemeral/buildbarn/bb_clientd"

# TestSummary overall_status values from BlazeTestStatus proto enum. starbuf_derive
# lowercases CamelCase to snake_case: Failed → "failed", FailedToBuild → "failed_to_build".
_TEST_STATUS_PASSED = "passed"
_TEST_STATUS_FLAKY = "flaky"
_TEST_STATUS_FAILED = "failed"
_TEST_STATUS_TIMEOUT = "timeout"
_TEST_STATUS_NO_STATUS = "no_status"
_TEST_STATUS_FAILED_TO_BUILD = "failed_to_build"
_TEST_STATUS_INCOMPLETE = "incomplete"
_TEST_STATUS_REMOTE_FAILURE = "remote_failure"
_TEST_STATUS_BLAZE_HALTED_BEFORE_TESTING = "blaze_halted_before_testing"

# Non-pass terminal statuses. REMOTE_FAILURE / BLAZE_HALTED_BEFORE_TESTING are
# genuine failures and must not be counted as passes.
_FAILED_STATUSES = [
    _TEST_STATUS_FAILED,
    _TEST_STATUS_TIMEOUT,
    _TEST_STATUS_FAILED_TO_BUILD,
    _TEST_STATUS_REMOTE_FAILURE,
    _TEST_STATUS_BLAZE_HALTED_BEFORE_TESTING,
]

def html_escape(s):
    """Escape HTML special characters so user-provided text renders safely.

    Apply to every user-controlled string entering the markdown (commit message,
    branch, tag, metadata keys/values, link display text, code spans) — both BK
    (single HTML body) and GHSC (markdown permits raw HTML) would otherwise
    interpret e.g. a "<hr>" in a commit message as a real element. Only URL
    components and our own template literals stay unescaped.

    `&` MUST be replaced first, else we double-escape the `&` we introduce.
    """
    return s.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")

def format_duration_ms(ms):
    """Format a duration in milliseconds as a human-readable string.

    Regimes: <1s → "5ms"/"500ms"; <1m → "1.5s" (tenths); ≥1m → "1m 5s".
    Mirrors the runtime's `format_duration` (multi_phase.rs) so the surface
    header and the runtime's "→ Completed" line read the same.
    """
    if ms <= 0:
        return "0ms"
    if ms < 1000:
        return str(ms) + "ms"
    total_s = ms // 1000
    frac_s = (ms % 1000) // 100
    if total_s < 60:
        if frac_s > 0:
            return str(total_s) + "." + str(frac_s) + "s"
        return str(total_s) + "s"
    minutes = total_s // 60
    seconds = total_s % 60
    if seconds > 0:
        return str(minutes) + "m " + str(seconds) + "s"
    return str(minutes) + "m"

def _format_cpu_seconds(ms):
    """Format an aggregate CPU-time duration with an explicit "cpu-" unit prefix.

    Scales seconds → minutes → hours like `format_duration_ms`, but keeps the
    "cpu-" prefix so the reader knows this is CPU (summed across threads), not
    wall. E.g. 2300 → "2.3 cpu-seconds", 98000 → "1.6 cpu-minutes", 3660000 →
    "1 cpu-hour".
    """
    if ms <= 0:
        return ""
    total_s = ms // 1000

    if total_s < 60:
        tenths = (ms % 1000) // 100
        base = format_int_comma(total_s)
        if tenths > 0:
            base = base + "." + str(tenths)
        return base + " cpu-seconds"

    if total_s < 3600:
        whole = total_s // 60
        tenths = ((total_s % 60) * 10) // 60
        if tenths > 0:
            return format_int_comma(whole) + "." + str(tenths) + " cpu-minutes"
        return pluralize(whole, "cpu-minute")

    whole = total_s // 3600
    tenths = ((total_s % 3600) * 10) // 3600
    if tenths > 0:
        return format_int_comma(whole) + "." + str(tenths) + " cpu-hours"
    return pluralize(whole, "cpu-hour")

def _miss_reason_display(reason):
    """Pretty-print a Bazel MissReason enum string.

    "DIFFERENT_FILES" → "Different files"
    "DIGEST_MISMATCH" → "Digest mismatch"
    Unknown/empty returns the input unchanged.
    """
    if not reason:
        return reason
    s = reason.lower().replace("_", " ")
    return s[0].upper() + s[1:] if s else s

def bes_get(obj, field, default = None):
    """Safely getattr on a BES event object; default if obj is None or the field
    is absent (schema mismatch). Guards against AttributeError on malformed
    events. For chained access call it twice:
        uri = bes_get(bes_get(payload, "stderr"), "file", "")
    """
    if obj == None:
        return default
    return getattr(obj, field, default)

def file_uri_to_path(uri):
    """Convert a file:// or bytestream:// URI to a local filesystem path.

    `file://` (disk-cache / local outputs) is returned verbatim; `bytestream://`
    (remote cache) is resolved via the bb_clientd FUSE mount:
      bytestream://host:port/blobs/<hash>/<size>
      -> {_BB_CLIENTD_ROOT}/cas/{host}/blobs/sha256/file/{hash}-{size}

    Returns "" for a non-string `uri` — the BES `File.file` oneof yields bytes
    when contents are inlined (not a URI), which we can't turn into a path.
    """
    if type(uri) != "string" or not uri:
        return ""
    if uri.startswith("file://"):
        return uri[len("file://"):]
    if uri.startswith("bytestream://"):
        rest = uri[len("bytestream://"):]
        parts = rest.split("/")
        host_port = parts[0]
        host = host_port.split(":")[0]
        blob_hash = parts[2]
        blob_size = parts[3]
        return _BB_CLIENTD_ROOT + "/cas/" + host + "/blobs/sha256/file/" + blob_hash + "-" + blob_size
    return uri

def _repro_with_prefix(prefix, labels, max_chars):
    """Build a '<prefix> <labels>' repro command, truncating the label list to
    stay within max_chars. Returns (cmd, n_included); cmd is "" if no label fits.
    """
    base = prefix + " "
    included = []
    used = len(base)
    for label in labels:
        needed = len(label) + 1  # separating space
        if used + needed > max_chars:
            break
        included.append(label)
        used += needed
    if not included:
        return ("", 0)
    return (base + " ".join(included), len(included))

def init_data():
    """Create a fresh data accumulator.

    Two-tier: task-managed scalars at the root, BES-derived state under
    `["bazel"]`. The rendered "Bazel details" reads `data["bazel"][...]`;
    root scalars stay at the root so non-bazel tasks can populate them too.
    See `crates/aspect-cli/src/builtins/aspect/DEVELOPMENT.md` for the schema.
    """
    return {
        # start/finish ms since epoch. build/test: from BES (process_event).
        # Non-bazel tasks stamp them with `now_ms(ctx)`.
        "start_time_ms": 0,
        "finish_time_ms": 0,
        # Space-joined target pattern from the task's args; set by the task impl.
        "target_pattern": "",
        # Invocation ID minted by the gRPC BES sinks (Aspect Web UI key). Set by
        # bazel_runner.axl after Build::spawn; "" when no sinks. Differs from
        # build_started.uuid (Bazel's server-side UUID).
        "sink_invocation_id": "",
        # Producer-authored at terminal-emit time. Each entry {command, description};
        # see lib/repro_commands.axl.
        "repro_commands": [],
        "fix_commands": [],
        # Per-attempt history on retry; "" on the single-attempt path. Gates the
        # "🔁 Retry attempts" section. Each entry: {attempt (1-indexed), exit_code,
        # sink_invocation_id, bazel (full sub-dict snapshot)}. Populated by
        # archive_bazel_attempt (bazel_runner.run_bazel_task, delivery._get_output_shas).
        "bazel_attempts": [],

        # BES-derived state, populated by process_event. Non-bazel tasks leave
        # this at defaults; the renderer skips empty sub-blocks.
        "bazel": {
            # Failed non-test build targets: [{label}].
            "failed_targets": [],
            # Skipped targets — target_completed with an Aborted payload
            # (--build_tag_filters, target_compatible_with, incompatible toolchains).
            # [{label, kind, reason}], capped at MAX_BUILT_TARGETS; uncapped count
            # in skipped_targets_total.
            "skipped_targets": [],
            "skipped_targets_total": 0,
            # Failed actions grouped by label: [{label, mnemonics, stderr_path}]
            # (deduped). Capped at MAX_FAILED_ACTIONS labels. stderr_path is the
            # local path resolved from the BES stderr File.uri ("" when absent),
            # read on demand for the inline snippet — never the raw bytes.
            "failed_actions": [],
            # May exceed len(failed_actions) due to cap.
            "failed_actions_total": 0,
            # Uncapped dedup of labels with ≥1 failed action. Partitions
            # failed_targets into root (own action failed) vs derived (dep broke).
            "failed_action_labels": [],

            # Test outcomes: [{label, cached, duration_ms}]; duration_ms from
            # test_summary.total_run_duration_millis.
            "failed_tests": [],
            "flaky_tests": [],
            "passed_tests": [],
            "passed_test_total": 0,
            "failed_test_total": 0,
            "flaky_test_total": 0,
            "cached_test_total": 0,
            "executed_test_total": 0,
            # Executed-test wall time (ms), from total_run_duration_millis.
            "executed_duration_ms": 0,
            # Cached-test wall time (ms) — time saved by the cache.
            "cached_duration_ms": 0,
            # Per-test detail from test_result (keyed by label, last attempt wins):
            # {label -> {log_path, xml_path, duration_ms}}. log_path/xml_path are
            # local (resolved from the BES URI), or "" if remote / unavailable.
            # Read on demand at render time for the inline failure snippet.
            "test_details": {},

            # label -> rule kind (e.g. "cc_library", "py_test") from
            # target_configured. Detects tests and displays the kind.
            "target_kinds": {},
            # Count of configured targets whose kind is a test (`*_test`),
            # from target_configured. The expected-test denominator for the
            # live "N of M tests run" progress narrative.
            "test_targets_configured": 0,
            # All built labels (test + non-test), capped at MAX_BUILT_TARGETS.
            "built_targets": [],
            # Targets that completed (success + failure), counting target_completed
            # events. Distinct from targets_configured.
            "targets_total": 0,
            # From build_metrics.target_metrics.
            "targets_configured": 0,
            "targets_configured_not_including_aspects": 0,
            "targets_configured_counted": 0,
            "actions_executed": 0,
            "actions_cached": 0,
            "actions_total": 0,
            # Per-mnemonic counts. Preferred source is
            # build_metrics.action_summary.action_data (authoritative, includes
            # cached actions on incrementals); falls back to our action_completed
            # counter until build_metrics arrives.
            "action_mnemonics": {},
            # From build_metrics.action_summary.runner_count; empty when absent
            # (older Bazel, partial output).
            "runner_counts": {},
            # Local (disk) cache only, from build_metrics.action_cache_statistics.
            # Distinct from the combined summary rate — misses here may still hit remote.
            "action_cache_stats": {
                "hits": 0,
                "misses": 0,
                # [{reason, count}] for local cache misses.
                "miss_details": [],
            },

            # From build_metrics.timing_metrics; 0 until build_metrics arrives.
            "wall_time_ms": 0,  # bazel wall (excludes CLI overhead)
            "cpu_time_ms": 0,
            "analysis_phase_time_ms": 0,
            "execution_phase_time_ms": 0,
            # Longest action chain (floor on parallelism). From
            # critical_path_duration_millis (Bazel 7+) or critical_path_in_ms (older).
            "critical_path_ms": 0,

            # From build_metrics.package_metrics.
            "packages_loaded": 0,
            # From build_metrics.cumulative_metrics (analysis cache age).
            "num_analyses": 0,
            "num_builds": 0,

            # Bazel invocation UUID from build_started.
            "invocation_id": "",
            # BES viewer base URL from structured_command_line's --bes_results_url.
            # Append invocation_id for the full URL; "" when flag unset.
            "bes_results_url": "",
            # From build_started (e.g. "9.0.1", "test").
            "build_tool_version": "",
            "build_command": "",

            # From the configuration event.
            "cpu_arch": "",
            "compilation_mode": "",
            # From build_started; display-only, skip empty rows.
            "workspace_directory": "",
            "working_directory": "",
            "server_pid": 0,

            # From the build_metadata event (--build_metadata / --bes_metadata).
            # Standard keys (build_metadata.axl): BRANCH, COMMIT_SHA, COMMIT_MESSAGE,
            # COMMIT_AUTHOR, COMMIT_TIMESTAMP, USER, CI, VCS, REPO, REPO_OWNER, TAG.
            # Plus arbitrary --bes_metadata=MY_KEY=value.
            "metadata": {},
            # From the workspace_status event. Standard: BUILD_USER, BUILD_HOST,
            # BUILD_TIMESTAMP. Plus whatever the workspace_status script emits.
            "workspace_status": {},

            # From the options_parsed event (NOT structured_command_line, which
            # dumps every .bazelrc default override). One assembled "explicit"
            # command plus browseable startup/cmd_line lists, à la Aspect Web UI.
            "options_parsed": {
                # User-specified flags only (pre-bazelrc/config). With build_command
                # + target pattern, assembles the copy-pasteable "explicit" command.
                "explicit_cmd_line": [],
                # Fully-resolved (post-bazelrc).
                "startup_options": [],
                # Fully-resolved (post-bazelrc, post-config).
                "cmd_line": [],
            },

            # From the aborted event.
            "aborted": False,
            "abort_reason": "",  # snake_case proto enum, e.g. "interrupted"
            "abort_description": "",
        },
    }

def process_event(data, event):
    """Update data in-place from a single build event.

    All field access goes through bes_get() (guards AttributeError on schema
    mismatch). Missing-field warnings go through `trace` (ASPECT_DEBUG / OTel only).

    Args:
        data:  dict from init_data(), mutated in place
        event: BuildEvent from BazelTrait.build_event hook

    Returns:
        True when the change warrants a status check update.
    """
    kind = event.kind

    if kind == "build_started":
        # Reset state for the new stream (handles retries). Preserve the
        # task-managed sink_invocation_id (set before this event) — wiping it
        # would drop the Aspect Workflows link from every annotation.
        preserved_sink_id = data.get("sink_invocation_id", "") or ""
        fresh = init_data()
        for k in fresh:
            data[k] = fresh[k]
        data["sink_invocation_id"] = preserved_sink_id

        payload = event.payload
        uuid = bes_get(payload, "uuid", "") or ""
        if not uuid:
            trace.log("warning: BES build_started event missing expected field 'uuid'")
        data["bazel"]["invocation_id"] = uuid
        data["bazel"]["build_tool_version"] = bes_get(payload, "build_tool_version", "") or ""
        data["bazel"]["build_command"] = bes_get(payload, "command", "") or ""
        data["start_time_ms"] = bes_get(payload, "start_time_millis", 0) or 0
        data["bazel"]["workspace_directory"] = bes_get(payload, "workspace_directory", "") or ""
        data["bazel"]["working_directory"] = bes_get(payload, "working_directory", "") or ""
        data["bazel"]["server_pid"] = bes_get(payload, "server_pid", 0) or 0

        # True so the first metadata burst surfaces immediately, not only once
        # the first target_completed lands (several seconds in).
        return True

    elif kind == "structured_command_line":
        # Only need bes_results_url here ("View invocation" link); full command
        # comes from the cleaner options_parsed event below.
        payload = event.payload
        if payload:
            for section in (bes_get(payload, "sections", None) or []):
                sec_type = bes_get(section, "section_type", None)
                if sec_type:
                    for opt in (bes_get(sec_type, "option", None) or []):
                        if bes_get(opt, "option_name", "") == "bes_results_url":
                            val = bes_get(opt, "option_value", "") or ""
                            if val:
                                data["bazel"]["bes_results_url"] = val
                                trace.log("debug: captured bes_results_url=" + val)
                            break
        return False

    elif kind == "options_parsed":
        # Authoritative source for the command-line views (assembled "Explicit"
        # command + browseable startup/cmd_line lists). Avoids the noisy raw
        # structured_command_line form.
        payload = event.payload
        if payload:
            data["bazel"]["options_parsed"]["explicit_cmd_line"] = list(bes_get(payload, "explicit_cmd_line", None) or [])
            data["bazel"]["options_parsed"]["startup_options"] = list(bes_get(payload, "startup_options", None) or [])
            data["bazel"]["options_parsed"]["cmd_line"] = list(bes_get(payload, "cmd_line", None) or [])

            # Fallback for bes_results_url if structured_command_line is late/absent.
            if not data["bazel"].get("bes_results_url"):
                for arg in data["bazel"]["options_parsed"]["cmd_line"]:
                    if arg.startswith("--bes_results_url="):
                        data["bazel"]["bes_results_url"] = arg[len("--bes_results_url="):]
                        break
            trace.log("debug: options_parsed explicit=" + str(len(data["bazel"]["options_parsed"]["explicit_cmd_line"])) +
                      " startup=" + str(len(data["bazel"]["options_parsed"]["startup_options"])) +
                      " cmd=" + str(len(data["bazel"]["options_parsed"]["cmd_line"])))

        # Live update — command-line detail blocks come entirely from this event.
        return True

    elif kind == "build_metadata":
        # Merge --build_metadata / --bes_metadata pairs (once per invocation, early).
        payload = event.payload
        if payload:
            payload_meta = bes_get(payload, "metadata", None)
            if payload_meta:
                for k, v in payload_meta.items():
                    if k and v:
                        data["bazel"]["metadata"][k] = v

        # Live update — row 2 + Build Metadata block come from this event.
        return True

    elif kind == "workspace_status":
        # Proto field is `item` — a repeated list of {key, value} structs.
        payload = event.payload
        if payload:
            for ws_item in (bes_get(payload, "item", None) or []):
                if ws_item:
                    key = bes_get(ws_item, "key", "") or ""
                    val = bes_get(ws_item, "value", "") or ""
                    if key and val:
                        data["bazel"]["workspace_status"][key] = val

        # Live update — row 1 user/host + Workspace Status block come from here.
        return True

    elif kind == "action_completed":
        payload = event.payload
        success = bes_get(payload, "success", None)
        label = bes_get(event.id, "label", "") or ""

        # Mnemonic is small. Build-wide per-mnemonic totals come authoritatively
        # from build_metrics — counting here would under-report cached actions on
        # incrementals.
        mnemonic = bes_get(payload, "type", "") or ""
        if success == None:
            trace.log("warning: BES action_completed event missing expected field 'success' (label=" + label + ")")
        if not success:
            data["bazel"]["failed_actions_total"] += 1

            # Track root-failure labels (own action failed); used to classify
            # derived failures later.
            if label and label not in data["bazel"]["failed_action_labels"]:
                data["bazel"]["failed_action_labels"].append(label)

            # Resolve the stderr File.uri to a local path only (never .contents):
            # read on demand for the inline snippet, kept off the Starlark heap.
            stderr_uri = bes_get(bes_get(payload, "stderr", None), "file", "") or ""
            stderr_path = file_uri_to_path(stderr_uri)

            # One entry per label, deduped mnemonics (a target can fail multiple
            # actions, e.g. CppCompile + CppLink). First action's stderr_path
            # wins (typically the primary failure, e.g. CppCompile before Link).
            entry = None
            for a in data["bazel"]["failed_actions"]:
                if a.get("label", "") == label:
                    entry = a
                    break
            if entry:
                if mnemonic and mnemonic not in entry["mnemonics"]:
                    entry["mnemonics"].append(mnemonic)
                if not entry.get("stderr_path") and stderr_path:
                    entry["stderr_path"] = stderr_path
            elif len(data["bazel"]["failed_actions"]) < MAX_FAILED_ACTIONS:
                data["bazel"]["failed_actions"].append({
                    "label": label,
                    "mnemonics": [mnemonic] if mnemonic else [],
                    "stderr_path": stderr_path,
                })
                return True
        return False

    elif kind == "target_configured":
        # Carries the rule kind (target_completed does not); cache it in
        # target_kinds for later handlers + test detection. Bazel suffixes
        # " rule" (e.g. "cc_test rule") — strip it for clean display.
        #
        # Also bump targets_configured_counted: Bazel emits this for every
        # in-scope target (incl. skyframe-resolved on incrementals), so the
        # tally stays accurate when build_metrics reports zero newly-configured.
        payload = event.payload
        label = bes_get(event.id, "label", "") or ""
        target_kind = bes_get(payload, "target_kind", "") or ""
        if target_kind.endswith(" rule"):
            target_kind = target_kind[:-len(" rule")]
        if label and target_kind:
            # Aspects that apply to a test target emit extra target_configured
            # events for the same label (distinct `aspect` field) while
            # test_summary still reports the test once. Count each test label
            # a single time — first-seen — so the "N of M tests run"
            # denominator matches the run count and doesn't overshoot.
            first_seen = label not in data["bazel"]["target_kinds"]
            data["bazel"]["target_kinds"][label] = target_kind
            if first_seen and _is_test_kind(target_kind):
                data["bazel"]["test_targets_configured"] += 1
        data["bazel"]["targets_configured_counted"] += 1
        return False

    elif kind == "target_completed":
        data["bazel"]["targets_total"] += 1
        payload = event.payload
        label = bes_get(event.id, "label", "") or ""

        target_kind = data["bazel"]["target_kinds"].get(label, "") if label else ""

        # Skipped targets arrive as target_completed with an Aborted payload
        # (has `reason`+`description`; TargetComplete has `success`). Presence
        # of `reason` is the cleanest payload-shape probe.
        abort_reason = bes_get(payload, "reason", None)
        if abort_reason != None:
            data["bazel"]["skipped_targets_total"] += 1
            if len(data["bazel"]["skipped_targets"]) < MAX_BUILT_TARGETS:
                data["bazel"]["skipped_targets"].append({
                    "label": label,
                    "kind": target_kind,
                    "reason": abort_reason,
                })
            return True

        success = bes_get(payload, "success", None)
        if success == None:
            trace.log("warning: BES target_completed event missing expected field 'success' (label=" + label + ")")
        if not success:
            data["bazel"]["failed_targets"].append({"label": label, "kind": target_kind})
            return True
        elif label and len(data["bazel"]["built_targets"]) < MAX_BUILT_TARGETS:
            data["bazel"]["built_targets"].append({"label": label, "kind": target_kind})
        return False

    elif kind == "test_result":
        # Fires once per shard/run/attempt; last write wins. test_summary gives
        # the authoritative final outcome.
        label = bes_get(event.id, "label", "") or ""
        payload = event.payload
        log_uri = ""
        xml_uri = ""
        if payload:
            for output in (bes_get(payload, "test_action_output", None) or []):
                if not output:
                    continue
                name = bes_get(output, "name", "")
                if name == "test.log":
                    log_uri = bes_get(output, "file", "") or ""
                elif name == "test.xml":
                    xml_uri = bes_get(output, "file", "") or ""
        duration_ms = (bes_get(payload, "test_attempt_duration_millis", 0) or 0) if payload else 0
        data["bazel"]["test_details"][label] = {
            "log_path": file_uri_to_path(log_uri),
            # JUnit XML, when present: lets the snippet prefer structured
            # <failure>/<error> output over scraping the raw test.log.
            "xml_path": file_uri_to_path(xml_uri),
            "duration_ms": duration_ms,
        }

        # No update — test_summary is the authoritative signal.
        return False

    elif kind == "test_summary":
        payload = event.payload
        status = bes_get(payload, "overall_status", "") or ""
        label = bes_get(event.id, "label", "") or ""
        num_cached = bes_get(payload, "total_num_cached", 0) or 0

        # total_run_duration_millis is deprecated but still populated. Bucket by
        # whether the test ran or was served from cache.
        duration_ms = bes_get(payload, "total_run_duration_millis", 0) or 0
        if not status:
            trace.log("warning: BES test_summary event missing expected field 'overall_status' (label=" + label + ")")
        if not label:
            trace.log("warning: BES test_summary event missing expected field 'id.label'")
        cached = num_cached > 0
        if cached:
            if duration_ms:
                data["bazel"]["cached_duration_ms"] += duration_ms
        else:
            data["bazel"]["executed_test_total"] += 1
            if duration_ms:
                data["bazel"]["executed_duration_ms"] += duration_ms

        # Buckets capped independently: a shared cap let passed_tests crowd out
        # failed_tests, breaking repro narrowing and the failure list.
        if status in _FAILED_STATUSES:
            data["bazel"]["failed_test_total"] += 1
            if len(data["bazel"]["failed_tests"]) < MAX_TEST_TARGETS:
                data["bazel"]["failed_tests"].append({
                    "label": label,
                    "cached": cached,
                    "duration_ms": duration_ms,
                    "kind": data["bazel"]["target_kinds"].get(label, ""),
                    # Raw BES status; downstream splits into TEST_FAILED /
                    # TEST_TIMEOUT / FAILED_TO_BUILD buckets.
                    "status": status,
                })
            return True
        elif status == _TEST_STATUS_FLAKY:
            data["bazel"]["flaky_test_total"] += 1
            if len(data["bazel"]["flaky_tests"]) < MAX_TEST_TARGETS:
                data["bazel"]["flaky_tests"].append({
                    "label": label,
                    "cached": cached,
                    "duration_ms": duration_ms,
                    "kind": data["bazel"]["target_kinds"].get(label, ""),
                })
            return True
        else:
            # PASSED (common); NO_STATUS / INCOMPLETE also land here — not strict
            # passes, but rare and have no dedicated bucket, so lumping in beats
            # calling them failures.
            data["bazel"]["passed_test_total"] += 1
            if cached:
                data["bazel"]["cached_test_total"] += 1
            if label and len(data["bazel"]["passed_tests"]) < MAX_TEST_TARGETS:
                data["bazel"]["passed_tests"].append({
                    "label": label,
                    "cached": cached,
                    "duration_ms": duration_ms,
                    "kind": data["bazel"]["target_kinds"].get(label, ""),
                })
        return False

    elif kind == "build_metrics":
        payload = event.payload
        action_summary = bes_get(payload, "action_summary", None)
        if action_summary:
            executed = bes_get(action_summary, "actions_executed", 0) or 0

            # total - executed (not deprecated remote_cache_hits) captures local
            # cache hits too.
            total = bes_get(action_summary, "actions_created", 0) or 0
            data["bazel"]["actions_executed"] = executed
            data["bazel"]["actions_cached"] = total - executed if total > executed else 0
            data["bazel"]["actions_total"] = total

            # Prefer Bazel's per-mnemonic action_data over our event counter —
            # on incrementals Bazel skips action_completed for cached actions, so
            # the counter under-reports. Also sum per-mnemonic actions_created:
            # Bazel leaves top-level actions_created at 0 on incrementals but
            # still fills per-mnemonic, so summing recovers the "Actions (N created)" total.
            per_mnemonic = {}
            per_mnemonic_sum_created = 0
            for ad in (bes_get(action_summary, "action_data", None) or []):
                if ad:
                    m = bes_get(ad, "mnemonic", "") or ""
                    c = bes_get(ad, "actions_executed", 0) or 0
                    if m and c > 0:
                        per_mnemonic[m] = per_mnemonic.get(m, 0) + c
                    created = bes_get(ad, "actions_created", 0) or 0
                    if created > 0:
                        per_mnemonic_sum_created += created
            if per_mnemonic:
                data["bazel"]["action_mnemonics"] = per_mnemonic

            # Fall back to the per-mnemonic created sum when top-level is 0.
            if data["bazel"]["actions_total"] == 0 and per_mnemonic_sum_created > 0:
                data["bazel"]["actions_total"] = per_mnemonic_sum_created

            # Per-runner counts. Skip Bazel's synthetic "total" entry — it sums
            # the rest, so including it would double-count (percentages → 200%).
            per_runner = {}
            for rc in (bes_get(action_summary, "runner_count", None) or []):
                if rc:
                    name = bes_get(rc, "name", "") or ""
                    count = bes_get(rc, "count", 0) or 0
                    exec_kind = bes_get(rc, "exec_kind", "") or ""
                    if name == "total":
                        continue
                    if name and count > 0:
                        # exec_kind keeps the Remote/Local distinction visible
                        # ("remote cache hit · Remote").
                        display = name + (" · " + exec_kind if exec_kind else "")
                        per_runner[display] = per_runner.get(display, 0) + count
            if per_runner:
                data["bazel"]["runner_counts"] = per_runner
        else:
            trace.log("warning: BES build_metrics event missing expected field 'action_summary'")
        timing_metrics = bes_get(payload, "timing_metrics", None)
        if timing_metrics:
            wall_time = bes_get(timing_metrics, "wall_time_in_ms", 0) or 0
            if wall_time > 0:
                data["bazel"]["wall_time_ms"] = wall_time
            cpu_time = bes_get(timing_metrics, "cpu_time_in_ms", 0) or 0
            if cpu_time > 0:
                data["bazel"]["cpu_time_ms"] = cpu_time
            analysis_time = bes_get(timing_metrics, "analysis_phase_time_in_ms", 0) or 0
            if analysis_time > 0:
                data["bazel"]["analysis_phase_time_ms"] = analysis_time
            execution_time = bes_get(timing_metrics, "execution_phase_time_in_ms", 0) or 0
            if execution_time > 0:
                data["bazel"]["execution_phase_time_ms"] = execution_time

            # Critical path (floor on parallelism). Bazel 7+ emits a
            # google.protobuf.Duration {seconds, nanos}; older Bazel used int-ms
            # fields. Check both shapes.
            cp_field = bes_get(timing_metrics, "critical_path_time", None)
            cp_ms = 0
            if cp_field != None:
                cp_secs = bes_get(cp_field, "seconds", 0) or 0
                cp_nanos = bes_get(cp_field, "nanos", 0) or 0
                cp_ms = cp_secs * 1000 + cp_nanos // 1000000
            if cp_ms == 0:
                cp_ms = (bes_get(timing_metrics, "critical_path_duration_millis", 0) or
                         bes_get(timing_metrics, "critical_path_in_ms", 0) or 0)
            if cp_ms > 0:
                data["bazel"]["critical_path_ms"] = cp_ms
        target_metrics = bes_get(payload, "target_metrics", None)
        if target_metrics:
            configured = bes_get(target_metrics, "targets_configured", 0) or 0
            if configured > 0:
                data["bazel"]["targets_configured"] = configured

            # Keep both targets_configured (rule + aspect) and
            # _not_including_aspects (rule only) so Build graph can split them:
            # "134,094 configured, 133 aspect applications".
            without_aspects = bes_get(target_metrics, "targets_configured_not_including_aspects", 0) or 0
            if without_aspects > 0:
                data["bazel"]["targets_configured_not_including_aspects"] = without_aspects
        package_metrics = bes_get(payload, "package_metrics", None)
        if package_metrics:
            loaded = bes_get(package_metrics, "packages_loaded", 0) or 0
            if loaded > 0:
                data["bazel"]["packages_loaded"] = loaded
        cumulative_metrics = bes_get(payload, "cumulative_metrics", None)
        if cumulative_metrics:
            num_analyses = bes_get(cumulative_metrics, "num_analyses", 0) or 0
            num_builds = bes_get(cumulative_metrics, "num_builds", 0) or 0
            if num_analyses > 0:
                data["bazel"]["num_analyses"] = num_analyses
            if num_builds > 0:
                data["bazel"]["num_builds"] = num_builds

        # Local action cache: hits/misses + miss reasons.
        action_cache = bes_get(payload, "action_cache_statistics", None)
        if action_cache:
            hits = bes_get(action_cache, "hits", 0) or 0
            misses = bes_get(action_cache, "misses", 0) or 0
            data["bazel"]["action_cache_stats"]["hits"] = hits
            data["bazel"]["action_cache_stats"]["misses"] = misses
            md_list = []
            for md in (bes_get(action_cache, "miss_details", None) or []):
                if md:
                    reason = bes_get(md, "reason", "") or ""
                    count = bes_get(md, "count", 0) or 0
                    if reason and count > 0:
                        md_list.append({"reason": reason, "count": count})
            if md_list:
                data["bazel"]["action_cache_stats"]["miss_details"] = md_list
        trace.log("debug: build_metrics wall_time_ms=" + str(data["bazel"]["wall_time_ms"]) +
                  " cpu_time_ms=" + str(data["bazel"]["cpu_time_ms"]) +
                  " targets_configured=" + str(data["bazel"]["targets_configured"]) +
                  " packages_loaded=" + str(data["bazel"]["packages_loaded"]))
        return True

    elif kind == "build_finished":
        payload = event.payload
        if payload:
            finish_ms = bes_get(payload, "finish_time_millis", 0) or 0
            if finish_ms > 0:
                data["finish_time_ms"] = finish_ms
        return False

    elif kind == "configuration":
        # Fires once per config (exec/tool/target/transitions). Skip the sentinel
        # id == "none". Last-writer-wins (target config usually arrives last).
        # Read make_variable.TARGET_CPU / COMPILATION_MODE — idiomatic names
        # ("aarch64", "fastbuild"); top-level `cpu` is the internal platform name
        # ("darwin_arm64") which reads poorly.
        id_config = bes_get(event.id, "configuration", None)
        config_id = bes_get(id_config, "id", "") or ""
        if config_id == "none":
            return False
        payload = event.payload
        cpu_or_mode_changed = False
        if payload:
            make_vars = bes_get(payload, "make_variable", None)
            cpu = ""
            mode = ""
            if make_vars:
                cpu = make_vars.get("TARGET_CPU", "") or ""
                mode = make_vars.get("COMPILATION_MODE", "") or ""

            # Fallback to top-level fields for older Bazel without make_variable.
            if not cpu:
                cpu = bes_get(payload, "cpu", "") or ""
            if not mode:
                mode = bes_get(payload, "compilation_mode", "") or ""
            if cpu:
                data["bazel"]["cpu_arch"] = cpu
                cpu_or_mode_changed = True
            if mode:
                data["bazel"]["compilation_mode"] = mode
                cpu_or_mode_changed = True

        return cpu_or_mode_changed

    elif kind == "aborted":
        data["bazel"]["aborted"] = True
        payload = event.payload
        if payload:
            # Proto fields are `reason`/`description`; data-dict key stays
            # `abort_reason` to avoid renaming the template variable.
            data["bazel"]["abort_reason"] = bes_get(payload, "reason", "") or ""
            data["bazel"]["abort_description"] = bes_get(payload, "description", "") or ""
        return True

    return False

def _join_url(base, id):
    """Join base URL + invocation id with exactly one slash (tolerates a trailing
    slash on `base`)."""
    return (base if base.endswith("/") else base + "/") + id

def resolve_aspect_url(links, data):
    """Return the Aspect Web UI URL for an invocation, or "" if unavailable.

    Keyed on `sink_invocation_id`, NOT Bazel's `invocation_id`: the Aspect Web
    UI indexes by the UUID the gRPC sink (`stream_sink.rs`) mints up-front when
    spawning BES subscribers — that's the stream-level id the backend sees;
    Bazel's own UUID is unknown to the backend (would 404).

    Tasks with sinks active set `data["sink_invocation_id"]` from
    `build.sink_invocation_id` right after `ctx.bazel.build(...)` (the runtime
    mints it inside `Build::spawn`). The `results` handle's `invocation()` sets
    it (see below). Without sinks the field is empty and we suppress the link.

    `links["results_base_url"]` (from `WorkflowsEnvironment.build_events.results_url`)
    is the prefix, joined as `{base}/{id}` (no `/invocations/` segment). Typical:
        ASPECT_WORKFLOWS_BES_RESULTS_URL=https://app.oss.aspect.build
    """
    base = links.get("results_base_url", "") if links else ""
    if not base:
        return ""
    inv_id = data.get("sink_invocation_id", "") or ""
    if not inv_id:
        return ""
    return _join_url(base, inv_id)

def aspect_web_ui_url(env: std.Env, data: dict) -> str:
    """Aspect Web UI invocation URL, or "" when unavailable. Joins
    `ASPECT_WORKFLOWS_BES_RESULTS_URL` (`env`=`ctx.std.env`) with
    `data["sink_invocation_id"]` (the UUID the Aspect backend indexes by)."""
    base = env.var("ASPECT_WORKFLOWS_BES_RESULTS_URL") or ""
    return resolve_aspect_url({"results_base_url": base}, data)

def failed_labels(data):
    """Deduplicated failed target labels from `data["bazel"]`, insertion-order.

    Merges action-level (preferred — has stderr), target-level (derived
    breakage), and failed-test labels. Used to narrow a CI rerun to broken
    labels. Pure — does NOT mutate `data`.
    """
    seen = {}
    labels = []

    for a in data["bazel"].get("failed_actions", []):
        lbl = a.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            labels.append(lbl)

    for t in data["bazel"].get("failed_targets", []):
        lbl = t.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            labels.append(lbl)

    for t in data["bazel"].get("failed_tests", []):
        lbl = t.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            labels.append(lbl)

    return labels

def _cmd_field(c, name):
    """Read a ReproFixCommand field whether `c` is a record (producer/live) or a
    dict (snapshot fixtures / JSON round-trip), defaulting to ""."""
    if type(c) == "dict":
        return c.get(name, "") or ""
    return getattr(c, name, "") or ""

def repro_by_target(repro_commands):
    """Map untruncated failure label -> its per-failure repro commands
    (`[{command, description}]`), built from the `target`-set entries in
    `data["repro_commands"]`. Whole-run entries (`target == ""`) are skipped —
    they render in the combined Reproduce section, not inline under a snippet.
    """
    out = {}
    for c in repro_commands or []:
        tgt = _cmd_field(c, "target")
        if tgt:
            out.setdefault(tgt, []).append({"command": _cmd_field(c, "command"), "description": _cmd_field(c, "description")})
    return out

# Above this many failing labels, collapse to a common-root pattern rather than
# listing each. Tuned to stay under build_aspect_command's ~100-char soft wrap.
_REPRO_INLINE_MAX = 10

def common_label_root(labels):
    """Return a Bazel target pattern that covers every label in `labels`.

    - All labels in the same package -> `//<pkg>:all`
    - Labels sharing a package-path prefix -> `//<prefix>/...`
    - No useful prefix (root-package labels, mixed-repo labels, etc.) -> ``""``

    Skips external-repo labels (`@foo//...`) — collapsing them into a
    workspace-relative pattern would be wrong. Pure function.
    """
    if not labels:
        return ""

    packages = []
    for lbl in labels:
        if not lbl.startswith("//"):
            # External / non-workspace form (`@foo//...`, `@@`): no safe collapse.
            return ""
        pkg = lbl[2:]
        if ":" in pkg:
            pkg, _, _ = pkg.partition(":")
        packages.append(pkg)

    distinct = {pkg: True for pkg in packages}
    if len(distinct) == 1:
        pkg = packages[0]
        return "//" + pkg + ":all" if pkg else ""

    split = [pkg.split("/") for pkg in packages]
    min_depth = min([len(s) for s in split])
    shared = []
    for i in range(min_depth):
        head = split[0][i]
        if all([s[i] == head for s in split]):
            shared.append(head)
        else:
            break
    if not shared or shared == [""]:
        return ""
    return "//" + "/".join(shared) + "/..."

def _is_explicit_label(target):
    """True when `target` names a single rule (no wildcard).

    Detects user-named labels that must survive a `//pkg/...` / `//pkg:all`
    collapse: wildcard test patterns skip `tags=["manual"]` rules, so an
    explicit manual test would otherwise vanish from the repro.
    """
    if "..." in target:
        return False
    if not (target.startswith("//") or target.startswith("@")):
        # Negation (`-//foo:bar`) or other non-label form.
        return False
    _, sep, name = target.partition(":")
    if not sep or not name:
        return False  # `//pkg` shorthand with no `:name`
    if name in ("all", "*", "all-targets"):
        return False
    return True

def _dedup_preserve_order(items):
    """Order-preserving dedup of a list of strings."""
    seen = {}
    out = []
    for x in items:
        if x not in seen:
            seen[x] = True
            out.append(x)
    return out

def collapse_repro_targets(failed, original_targets):
    """Collapse a failed-label list to a copy-pasteable target list for a repro.

    Small sets (≤ `_REPRO_INLINE_MAX`) pass through verbatim. Larger sets
    collapse to a common-root pattern when one exists, keeping any labels the
    user named explicitly (wildcard patterns skip manual-tagged rules, so
    explicit failures must not be lost). No labels → `original_targets`; no
    usable collapse → `original_targets`. Always order-preserving deduped.
    """
    if not failed:
        return _dedup_preserve_order(original_targets)
    if len(failed) <= _REPRO_INLINE_MAX:
        return failed
    root = common_label_root(failed)
    if not root:
        return _dedup_preserve_order(original_targets)

    explicit_in_original = {t: True for t in original_targets if _is_explicit_label(t)}
    explicit_failed = [l for l in failed if l in explicit_in_original]
    return explicit_failed + [root]

def repro_targets(data, original_targets):
    """Target list for a failing task's whole-run repro, over all failed labels
    (action + target-level + failed-test). See `collapse_repro_targets`."""
    return collapse_repro_targets(failed_labels(data), original_targets)

def failed_labels_by_subcommand(data):
    """Partition failed labels by the bazel subcommand that reproduces them:

      "test"  — tests that built and then failed/timed out at test time.
                `bazel test //x` reruns them.
      "build" — build-action / target failures AND tests that failed to BUILD.
                `bazel test //x` on these errors ("no test targets found" or a
                build error with nothing to test), so they rerun with
                `bazel build //x`.

    Returns `{"build": [labels], "test": [labels]}`, each order-preserving
    deduped. A label that both failed to build and is a test lands in "build"
    (build-first precedence — you can't test what won't build)."""
    build = []
    test = []
    build_seen = {}

    def _add_build(lbl):
        if lbl and lbl not in build_seen:
            build_seen[lbl] = True
            build.append(lbl)

    for a in data["bazel"].get("failed_actions", []):
        _add_build(a.get("label", ""))
    for t in data["bazel"].get("failed_targets", []):
        _add_build(t.get("label", ""))
    for t in data["bazel"].get("failed_tests", []):
        if t.get("status", "") == _TEST_STATUS_FAILED_TO_BUILD:
            _add_build(t.get("label", ""))

    test_seen = {}
    for t in data["bazel"].get("failed_tests", []):
        lbl = t.get("label", "")

        # A test that failed to build is a build failure (above); a test also
        # listed as a failed action/target likewise reruns via build.
        if (t.get("status", "") != _TEST_STATUS_FAILED_TO_BUILD and
            lbl and lbl not in build_seen and lbl not in test_seen):
            test_seen[lbl] = True
            test.append(lbl)

    return {"build": build, "test": test}

def compute_reproducer_command(data, task_kind, max_chars = MAX_REPRO_CHARS):
    """Legacy helper preserved for test fixtures. New code should append
    `{"command", "description"}` entries to `data["repro_commands"]`
    directly via `private/lib/repro_commands.axl::build_aspect_command`.

    Returns `(command, total)` from the deduped failure-label set.
    """
    labels = failed_labels(data)
    cmd, _ = _repro_with_prefix("aspect " + task_kind, labels, max_chars)
    return (cmd, len(labels))

# GitHub check-run title cap. Subject within is capped tighter at SUBJECT_TITLE_MAX.
_TITLE_MAX_LEN = 160

def summary_title(data, status, target_pattern = "", task_kind = ""):
    """Build the check run title in the form '<status_emoji> <task_kind> <subject> · <state>'.

    Mirrors Aspect Web UI conventions — see _BUCKET_INVOCATION_LABELS
    for the state vocabulary and compute_invocation_state for priority rules.

    Examples:
        "🔄 test //... · Running..."
        "✅ test //... · Tests passed (cached)"
        "❌ build //... · Failed to build"
        "🔥 deploy production · Invocation disconnected"

    Args:
        data:           dict from init_data()
        status:         "running" | "failing" | "passed" | "failed" | "warning" | "aborted"
        target_pattern: subject (e.g. "//..." for a build/test task)
        task_kind:      the task kind (`ctx.task.kind`) — the lowercase
                        string declared on `task(kind=...)`.

    Returns:
        str — max 160 chars (GitHub check title limit)
    """
    subject = truncate_for_title(target_pattern, SUBJECT_TITLE_MAX) if target_pattern else ""
    state = compute_invocation_state(data, status)
    icon = emoji_for_status(status)

    # `{icon} {task} {subject}` is the "what"; state clause follows after `·`.
    front_parts = []
    if task_kind:
        front_parts.append(icon + " " + task_kind)
    else:
        front_parts.append(icon)
    if subject:
        front_parts.append(subject)
    front = " ".join(front_parts)

    if front and state:
        title = front + " · " + state
    elif front:
        title = front
    else:
        title = state
    return truncate_for_title(title, _TITLE_MAX_LEN)

def conclusion(status, data):
    """Bazel build/test task's terminal bookend conclusion. Delegates
    to `compute_invocation_state(data, status)` so the bookend reads
    the same bucket-derived state label as `summary_title()`.
    """
    if status in ("running", "failing"):
        return ""
    state = compute_invocation_state(data, status)

    # Defensive: empty if no bucket matched (running already excluded above).
    return state or ""

def now_ms(ctx):
    """Current time in ms since epoch (for rate-limiting status updates).

    Backed by the runtime clock (`time.now_ms()`); the `ctx` parameter is kept
    for call-site compatibility but unused. Was a `date '+%s000'` subprocess per
    call — millisecond-accurate now and free of the ~4-forks/sec cost during a
    build's status-update loop.
    """
    _ = ctx
    return time.now_ms()

# Check run rendering — Jinja2 templates + data builders for the
