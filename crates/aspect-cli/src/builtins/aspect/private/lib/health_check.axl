"""HealthCheckTrait and the Workflows runner-agent health check.

`HealthCheckTrait` lets features register `health_check` hooks that run
during the task's Setup phase (via `lib/lifecycle.axl::setup_phase`); a
hook returning a non-None message fails the task. `agent_health_check`
is the Workflows-registered hook that:

  1. Waits for runner cache warming to complete.
  2. Displays the last runner health check.
  3. Verifies `ctx.bazel.startup_flags` targets the project-specific
     Bazel server (`assert_ctx_bazel_ready_for_health_check`).
  4. Runs `ctx.bazel.health_check()` and displays the result.
  5. Signals the agent if the Bazel server is unhealthy.

The `assert_ctx_bazel_ready_for_health_check` guard is exported so
custom tasks composing `BazelTrait` + `HealthCheckTrait` get the same
fail-loud contract enforcement â€” see `bazel.axl` for the
canonical helpers that satisfy it.
"""

load("@std//time.axl", "time")
load("./ansi.axl", "ansi")
load("./environment.axl", "AWS_LOG_GROUP", "get_workflows_environment", "is_warming_complete", "is_warming_observable", "warn")

def _url_encode(s):
    """Percent-encode a string for use in URLs."""
    result = ""
    for c in s.elems():
        if c == " ":
            result += "%20"
        elif c == "\"":
            result += "%22"
        elif c == "\n":
            result += "%0A"
        elif c == "=":
            result += "%3D"
        elif c == "/":
            result += "%2F"
        else:
            result += c
    return result

def _bootstrap_log_url(environment):
    """
    Construct the bootstrap log URL based on the cloud provider.

    Returns the URL string, or None if the provider cannot be determined.
    """
    if environment.cloud_provider == "aws":
        return _aws_bootstrap_log_url(environment)
    elif environment.cloud_provider == "gcp":
        return _gcp_bootstrap_log_url(environment)
    return None

def _aws_bootstrap_log_url(environment):
    """Construct AWS CloudWatch Logs URL for bootstrap logs."""
    region = environment.region
    instance_id = environment.instance_id

    # URL-encode the log group: replace "/" with "%252F" (double-encoded)
    escaped_log_group = AWS_LOG_GROUP.replace("/", "%252F")

    return (
        "https://" + region + ".console.aws.amazon.com/cloudwatch/home" +
        "?region=" + region +
        "#logsV2:log-groups/log-group/" + escaped_log_group +
        "/log-events/" + instance_id
    )

def _gcp_bootstrap_log_url(environment):
    """Construct GCP Cloud Logging URL for bootstrap logs."""
    instance_id = environment.instance_id
    project_id = environment.account

    query = (
        'resource.type="gce_instance"\n' +
        "resource.labels.instance_id=" + instance_id + "\n" +
        'log_name="projects/' + project_id + '/logs/google_metadata_script_runner"'
    )

    return (
        "https://console.cloud.google.com/logs/query" +
        ";query=" + _url_encode(query) +
        ";duration=P30D" +
        "?referrer=search&project=" + project_id
    )

def _wait_for_warming(std, environment):
    """
    Block until warming completes (or return immediately if warming isn't
    configured / already done). Side-effect only: re-reads the environment
    so the caller sees `warming_complete` / `warming_current_cache` set.

    If the runner enables warming without publishing the completion marker
    path, completion can never be observed â€” warn and skip the wait rather
    than spin forever.

    Display is intentionally separate (`_display_warming`): the saved
    Runner Health output from the previous job should render *first*, then
    per-section sub-blocks (Warming, Bazel Health) underneath.
    """
    if not environment.runner.warming_enabled:
        return environment

    # If warming hasn't completed yet, block until it does.
    # The bootstrap process runs concurrently. If it hits a critical error,
    # it terminates the runner â€” so this loop will not hang indefinitely.
    if not environment.runner.warming_complete:
        if not is_warming_observable(std):
            warn(std, "Warming is enabled on this runner but " +
                      "ASPECT_WORKFLOWS_RUNNER_WARMING_COMPLETE_MARKER_FILE is " +
                      "not set; unable to wait for warming to complete.")
            return environment
        print("Waiting for warming to complete...")
        for _ in time.sleep_iter(1000):
            if is_warming_complete(std):
                break

    # Re-read environment to pick up warming result fields.
    # TODO: replace with agent http api call once available
    return get_workflows_environment(std)

# `_section_heading` and `_status_marker` keep the AXL-rendered sub-sections
# (Warming, Bazel Health) visually consistent with the saved vigor output
# that comes out of `_display_runner_health` â€” blue `â€˘` bullet + label,
# colored âś“ / âś— status markers.

def _section_heading(label):
    """Sub-section heading: blank line + blue `â€˘ <label>`."""
    return "\n" + ansi.style("â€˘ " + label, ansi.BLUE)

def _status_marker(kind):
    """Status glyph: âś“ green, âś— red, ? yellow. Used as the
    leading char on a status line under a sub-section heading."""
    if kind == "ok":
        return ansi.style("âś“", ansi.GREEN)
    if kind == "fail":
        return ansi.style("âś—", ansi.RED)
    return ansi.style("?", ansi.YELLOW)

def _display_warming(environment):
    """
    Render the Warming sub-section under Runner Health.

    Runs after `_display_runner_health` so the saved-from-previous-job
    output appears first and warming context for *this* job appears
    underneath, alongside Bazel Health.
    """
    if not environment.runner.warming_enabled:
        return

    print(_section_heading("Warming"))
    if environment.runner.warming_current_cache:
        print("\t" + _status_marker("ok") +
              " runner warmed from cache version: " +
              environment.runner.warming_current_cache)
        return
    if environment.runner.runner_job_history == "":
        # First job on the runner and warming didn't produce a cache. On
        # subsequent jobs the runner has already done real work, so a
        # missing cache isn't a warning.
        print("\t" + _status_marker("fail") +
              " warming was unsuccessful â€” this first build will be cold")
        url = _bootstrap_log_url(environment.runner)
        if url:
            print("\tSee bootstrap logs for more details:")
            print("\t" + url)
        return

    # Warming enabled, no fresh cache, but we've been running jobs â€” quiet
    # informational line so the section still renders.
    print("\t" + _status_marker("ok") + " warmed by previous jobs on this runner")

def _display_bazel_health(health):
    """Render the Bazel Health sub-section under Runner Health."""
    print(_section_heading("Bazel Health"))
    if health.outcome == "healthy":
        print("\t" + _status_marker("ok") + " bazel health check passed")
    elif health.outcome == "unhealthy":
        print("\t" + _status_marker("fail") +
              " bazel health check failed: " + (health.message or "unknown error"))
    elif health.outcome == "inconclusive":
        print("\t" + _status_marker("warn") +
              " bazel health check inconclusive: " + (health.message or "unknown"))

def _bullet_header_label(line):
    """Return the section label of a Vigor bullet-header line
    (`â€˘ <label>` after ANSI stripping), or None if `line` isn't a bullet
    header. Vigor emits headers as
    `\\x1b[34mâ€˘\\x1b[0m \\x1b[34m<label>\\x1b[0m`."""
    stripped = ansi.strip(line)
    if not stripped.startswith("â€˘ "):
        return None
    return stripped[2:].strip()

def render_local_job_history(history):
    """Render a `â€˘ Job History` section from the raw history file contents.

    `history` is the verbatim text of `runner_job_history` â€” one line
    per `[<date>] <url> <path> <key>` entry, see
    `lib/runner_job_history.axl`. Matches Vigor's section format
    (`Number of builds on this runner: N` + `Most recently:` + up to
    10 lines) but takes the *last* 10 entries instead of the first.

    Emits the bullet header inline (no leading `\\n`) because the
    surrounding rewrite drops it into a slot whose previous section
    already ended with the inter-section blank line â€” using
    `_section_heading` here would double-blank.

    Returns the rendered section with a trailing newline.
    """
    lines = [line for line in history.split("\n") if line]
    out = [ansi.style("â€˘ Job History", ansi.BLUE)]
    out.append("\tNumber of builds on this runner: %d" % len(lines))
    if lines:
        out.append("\tMost recently:")
        recent = lines[-10:] if len(lines) > 10 else lines
        for line in recent:
            out.append("\t" + line)
    out.append("")
    return "\n".join(out)

def rewrite_runner_health_output(output, history):
    """Rewrite Vigor's pre-formatted runner-health `output`, replacing
    the `â€˘ Job History` section (which lists the first 10 entries
    instead of the most recent â€” see `render_local_job_history`) with a
    locally-rendered one built from `history`.

    Walks `output` line by line. The first bullet header whose label is
    `Job History` and everything up to the next bullet header is
    replaced with `render_local_job_history(history)`; every other line
    passes through verbatim. ANSI codes on the header are stripped for
    matching only.

    No-op if no Job History section is present â€” we don't synthesize a
    section the upstream report didn't include.

    Returns the rewritten string.
    """
    lines = output.split("\n")
    n = len(lines)
    i = 0
    replaced = False
    out = []
    for _ in range(n):
        if i >= n:
            break
        if not replaced and _bullet_header_label(lines[i]) == "Job History":
            out.append(render_local_job_history(history))
            replaced = True
            i += 1
            for _ in range(n - i):
                if i >= n:
                    break
                if _bullet_header_label(lines[i]) != None:
                    break
                i += 1
            continue
        out.append(lines[i])
        i += 1
    return "\n".join(out)

def _display_runner_health(environment, job_history):
    """Display the last runner health check results.

    Reads the JSON snapshot the fleet service writes between jobs. The
    Vigor `â€˘ Job History` section in that snapshot is rewritten inline
    against `job_history` so the "Most recently" list shows the last 10
    entries instead of the buggy first 10 â€” see
    `rewrite_runner_health_output`.

    `job_history` must correspond to the same point in time as Vigor's
    saved report (i.e. before this task's `append_runner_job_history`
    call). The caller is responsible for snapshotting it.
    """
    print(ansi.style("Runner Health", ansi.seq("1;4;34")))

    if not environment.runner.last_health_check:
        print("Health check has not yet been run on this runner")
        return

    data = json.try_decode(environment.runner.last_health_check, None)
    if data == None:
        print("Health check data is unavailable (malformed JSON)")
        return

    print("Last run on " + str(data["timestamp"]) + "\n")
    print(rewrite_runner_health_output(data["output"], job_history))

HealthCheckTrait = trait(
    health_check = attr(list[typing.Callable[[TaskContext], str | None]], default = [], description = "Hooks run during the task's setup phase to validate system health. Return a non-None error message to fail the task (e.g. an unhealthy Bazel server); return None when healthy."),
)

def run_health_checks(ctx, hc_trait):
    """Run every `hc_trait.health_check` hook and return the first non-None
    error message, or `None` when all pass (or `hc_trait` is `None`).

    Every hook runs even after one reports an error, so diagnostic hooks (e.g.
    the Workflows runner-env table) always print. A non-None result means the
    environment is unhealthy; the hook has already signaled the agent, and the
    caller (`lifecycle.setup_phase`) fails the task on it."""
    if hc_trait == None:
        return None
    health_error = None
    for hook in hc_trait.health_check:
        result = hook(ctx)
        if result != None and health_error == None:
            health_error = result
    return health_error

def ctx_bazel_ready_for_health_check(ctx, environment):
    """True if the active `RunCommand` (`ctx.bazel.active_rc()`) carries startup
    flags such that the Bazel health check would target the project-specific
    server.

    Returns True off-runner (no project-specific server to protect) or
    when `--output_base=` appears in the active run command's startup flags.
    Returns False on a Workflows runner with no active rc or no `--output_base`.

    Pure predicate; see `assert_ctx_bazel_ready_for_health_check` for
    the failing variant used as the runtime guard.
    """
    if environment.runner == None:
        return True
    rc = ctx.bazel.active_rc()
    if rc == None:
        return False
    for flag in rc.startup_flags():
        if flag.startswith("--output_base="):
            return True
    return False

def assert_ctx_bazel_ready_for_health_check(ctx, environment):
    """Fail if a Workflows runner is in use and the active run command
    (`ctx.bazel.active_rc()`) is missing `--output_base`.

    Built-in tasks satisfy this via `lib/lifecycle.axl::setup_phase`, which
    registers the active run command (through `bazel.setup_command` â†’
    `ctx.bazel.use_rc`) before running the `health_check` hooks. Custom tasks
    running the health check outside `setup_phase` must `use_rc` first.
    """
    if ctx_bazel_ready_for_health_check(ctx, environment):
        return
    fail(
        "Bazel health check would target the wrong server: the active run " +
        "command is missing --output_base on a Workflows runner. Run the " +
        "health check via lib/lifecycle.axl::setup_phase, or set an active " +
        "run command via ctx.bazel.use_rc (e.g. through bazel.setup_command) " +
        "before the health_check hooks.",
    )

def agent_health_check(ctx, environment):
    """Workflows `health_check` hook that runs during the Setup phase.

    1. Waits for runner cache warming to complete.
    2. Displays the last runner health check.
    3. Asserts the `ctx.bazel.startup_flags` ordering contract holds.
    4. Runs `ctx.bazel.health_check()` and displays the result.
    5. Signals the agent if the Bazel server is unhealthy.

    Returns:
      None if healthy, or a str error message if the Bazel server is
      unhealthy.
    """
    if environment.ci and environment.ci.host == "buildkite":
        print("--- :thermometer: Workflows runner health check")

    # Snapshot job-history before `_wait_for_warming` re-reads the
    # environment. `setup_phase` runs `append_runner_job_history` ahead
    # of this hook, so the file already contains the current task's
    # entry â€” but Vigor's saved snapshot in `last_health_check` was
    # written before this task ran. The feature-time `environment` was
    # captured in phase 3 (before phase 4 ran setup_phase), so this
    # field still reflects the pre-append state. Re-reading would
    # desync the rewritten Job History count from Vigor's report.
    job_history = environment.runner.runner_job_history

    environment = _wait_for_warming(ctx.std, environment)
    _display_runner_health(environment, job_history)
    _display_warming(environment)
    assert_ctx_bazel_ready_for_health_check(ctx, environment)
    health = ctx.bazel.health_check()
    _display_bazel_health(health)

    if health.outcome == "unhealthy":
        signal_bin = environment.runner.bin_dir + "/signal_instance_unhealthy"
        if ctx.std.fs.exists(signal_bin):
            ctx.std.process.command(signal_bin).spawn().wait()
        return health.message or "Bazel server is unhealthy"
    return None
