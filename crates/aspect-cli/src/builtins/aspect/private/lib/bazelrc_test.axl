"""Unit tests for `bazelrc.axl`'s pure helpers: version-constraint gating
(`constraint_matches`), the mixed plain/tuple flag resolution (`resolve_flags`),
and rc rendering (`render_bazelrc`).

These cover the logic that diverges from the runtime's own flag handling — the
version gating in particular must match `constraint_matches` in
`axl-runtime/src/engine/bazel/mod.rs` (assumed-latest when the version is
unknown). Run with: aspect tests axl
"""

load(
    "@aspect//bazelrc.axl",
    "constraint_matches",
    "render_bazelrc",
    "resolve_flags",
)

def _eq(label, got, want):
    if got != want:
        fail("%s: got %r, want %r" % (label, got, want))

def _test_constraint_gte_matches(_ctx):
    _eq("8.0.0 >= 8.0.0", constraint_matches(">=8.0.0", "8.0.0"), True)
    _eq("8.1.0 >= 8.0.0", constraint_matches(">=8.0.0", "8.1.0"), True)
    _eq("7.4.1 >= 8.0.0", constraint_matches(">=8.0.0", "7.4.1"), False)

def _test_constraint_lt_matches(_ctx):
    _eq("7.4.1 < 8.0.0", constraint_matches("<8.0.0", "7.4.1"), True)
    _eq("8.0.0 < 8.0.0", constraint_matches("<8.0.0", "8.0.0"), False)
    _eq("6.5.0 < 7.0.0", constraint_matches("<7.0.0", "6.5.0"), True)

def _test_constraint_unknown_version_assumes_latest(_ctx):
    # version == None → assumed-latest, matching the runtime: `>=` holds, `<` does not.
    _eq("none >= 8.0.0", constraint_matches(">=8.0.0", None), True)
    _eq("none < 8.0.0", constraint_matches("<8.0.0", None), False)
    _eq("none < 7.0.0", constraint_matches("<7.0.0", None), False)

def _test_resolve_flags_keeps_plain_drops_unmatched(_ctx):
    flags = [
        "--remote_accept_cached",
        ("--noexperimental_remote_cache_compression", "<8.0.0"),
        ("--noremote_cache_compression", ">=8.0.0"),
        ("--incompatible_remote_results_ignore_disk", "<7.0.0"),
    ]

    # Bazel 8: keep plain + the >=8 variant; drop both <-gated flags.
    _eq("resolve@8.0.0", resolve_flags(flags, "8.0.0"), [
        "--remote_accept_cached",
        "--noremote_cache_compression",
    ])

    # Bazel 7: keep plain + the <8 variant; drop the >=8 and <7 ones.
    _eq("resolve@7.4.1", resolve_flags(flags, "7.4.1"), [
        "--remote_accept_cached",
        "--noexperimental_remote_cache_compression",
    ])

    # Bazel 6: keep plain + both <-gated flags; drop the >=8 one.
    _eq("resolve@6.5.0", resolve_flags(flags, "6.5.0"), [
        "--remote_accept_cached",
        "--noexperimental_remote_cache_compression",
        "--incompatible_remote_results_ignore_disk",
    ])

    # Unknown version → assumed-latest: only the >=8 gated flag survives.
    _eq("resolve@unknown", resolve_flags(flags, None), [
        "--remote_accept_cached",
        "--noremote_cache_compression",
    ])

def _test_render_sections(_ctx):
    out = render_bazelrc(
        ["--nohome_rc", "--output_base=/mnt/output"],
        ["--remote_cache=grpcs://c:443", "--disk_cache="],
    )
    lines = out.split("\n")

    # Startup flags get a `startup ` prefix; build flags get a `common ` prefix.
    _eq("startup line", "startup --nohome_rc" in lines, True)
    _eq("startup output_base", "startup --output_base=/mnt/output" in lines, True)
    _eq("common remote_cache", "common --remote_cache=grpcs://c:443" in lines, True)
    _eq("common disk_cache", "common --disk_cache=" in lines, True)

    # No build flag leaks into a startup line and vice versa.
    _eq("no common startup_flag", "common --nohome_rc" in lines, False)
    _eq("no startup build_flag", "startup --remote_cache=grpcs://c:443" in lines, False)

    # Trailing newline so the file ends cleanly.
    _eq("trailing newline", out.endswith("\n"), True)

def _test_render_empty(_ctx):
    # Header only (no flags) still renders the two comment lines and a blank.
    out = render_bazelrc([], [])
    _eq("header present", out.startswith("# Generated by `aspect ci bazelrc`"), True)

_UNIT_TESTS = [
    _test_constraint_gte_matches,
    _test_constraint_lt_matches,
    _test_constraint_unknown_version_assumes_latest,
    _test_resolve_flags_keeps_plain_drops_unmatched,
    _test_render_sections,
    _test_render_empty,
]

def _test_impl(ctx):
    for t in _UNIT_TESTS:
        t(ctx)
    print("bazelrc.axl: OK (%d tests)" % len(_UNIT_TESTS))
    return 0

bazelrc_tests = task(
    kind = "test-bazelrc",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
