"""Tests for `lib/aspect_endpoint_auth.axl` — host parsing, the configured-deployment
ownership gate, and credential resolution for Aspect endpoints (BES backend, remote cache).

Run with:
  aspect dev test-aspect-endpoint-auth
"""

load("./aspect_endpoint_auth.axl", "credential_helper_covers_host", "endpoint_host", "headers_have_auth", "is_aspect_host", "login_hint", "needs_aspect_token")

def _eq(label, got, want):
    if got != want:
        fail("%s: got %r, want %r" % (label, got, want))

def _fake_ctx(owned_hosts = []):
    """Stand-in for `ctx`: `is_aspect_host`/`needs_aspect_token` read only
    `ctx.aspect.auth.deployment_for_host(host)`, which returns the owning
    deployment's name (here just the host itself) or None for unowned hosts."""
    owned = {h: h for h in owned_hosts}
    return struct(aspect = struct(auth = struct(
        deployment_for_host = lambda host: owned.get(host),
    )))

def _test_endpoint_host(_):
    """Host extraction strips scheme, userinfo, port, and path, and lowercases."""
    _eq("grpcs + path", endpoint_host("grpcs://bes.aws.awd-gha-test-dev.aspect.build/x"), "bes.aws.awd-gha-test-dev.aspect.build")
    _eq("grpc + port", endpoint_host("grpc://bes.aspect.build:443"), "bes.aspect.build")
    _eq("bare host", endpoint_host("bes.aspect.build"), "bes.aspect.build")
    _eq("bare host:port", endpoint_host("remote.buildbuddy.io:443"), "remote.buildbuddy.io")
    _eq("userinfo stripped", endpoint_host("grpcs://user@bes.aspect.build"), "bes.aspect.build")
    _eq("userinfo + port", endpoint_host("grpcs://user:pw@bes.aspect.build:443/x"), "bes.aspect.build")
    _eq("uppercase lowered", endpoint_host("GRPCS://BES.ASPECT.BUILD"), "bes.aspect.build")

def _test_is_aspect_host(_):
    """A host is Aspect-owned iff a configured deployment claims it (via the
    engine's `deployment_for_host`); nothing else matches."""
    ctx = _fake_ctx(["remote.acme.aspect.build", "bes.acme.aspect.build"])
    _eq("configured host matches", is_aspect_host(ctx, "remote.acme.aspect.build"), True)
    _eq("other configured host matches", is_aspect_host(ctx, "bes.acme.aspect.build"), True)
    _eq("unconfigured .aspect.build rejected", is_aspect_host(ctx, "remote.other.aspect.build"), False)
    _eq("third-party rejected", is_aspect_host(ctx, "remote.buildbuddy.io"), False)
    _eq("empty host rejected", is_aspect_host(ctx, ""), False)

def _test_needs_aspect_token(_):
    """Resolution is gated on a configured-deployment endpoint lacking
    user-supplied auth — the gate that keeps a stale login from aborting builds
    whose token would never be used."""
    ctx = _fake_ctx(["bes.acme.aspect.build"])
    _eq("owned endpoint, no user auth", needs_aspect_token(ctx, ["grpcs://bes.acme.aspect.build"], False), True)
    _eq("unowned endpoint", needs_aspect_token(ctx, ["grpcs://remote.buildbuddy.io"], False), False)
    _eq("no endpoints", needs_aspect_token(ctx, [], False), False)
    _eq("mixed: one owned endpoint triggers", needs_aspect_token(ctx, ["grpcs://remote.buildbuddy.io", "grpcs://bes.acme.aspect.build"], False), True)

    # User-supplied auth (a --bes-header / --remote_header authorization) suppresses
    # resolution even for an owned host, so a stale login cannot abort the build.
    _eq("user auth suppresses", needs_aspect_token(ctx, ["grpcs://bes.acme.aspect.build"], True), False)

def _test_headers_have_auth(_):
    """`--remote_header`/`--bes_header` authorization detection is
    case-insensitive and matches the header name exactly (not a value that
    happens to contain it)."""
    _eq("empty", headers_have_auth([]), False)
    _eq("unrelated headers", headers_have_auth(["x-foo=bar", "x-token=abc"]), False)
    _eq("lowercase", headers_have_auth(["authorization=Bearer x"]), True)
    _eq("titlecase", headers_have_auth(["Authorization=Bearer x"]), True)
    _eq("amongst others", headers_have_auth(["x-foo=bar", "AUTHORIZATION=Bearer x"]), True)
    _eq("value mentioning auth not matched", headers_have_auth(["x-note=authorization=no"]), False)

def _test_credential_helper_covers_host(_):
    """A `--credential_helper` registered for the endpoint host means Bazel will
    add its own `authorization`, so the CLI must treat the stream as already
    authenticated. Mirrors Bazel's scope resolution: default helper, exact host,
    and `*.<domain>` wildcard (domain itself + subdomains)."""
    host = "bes.acme.aspect.build"

    _eq("no helpers", credential_helper_covers_host([], host), False)
    _eq("unscoped default helper covers all", credential_helper_covers_host(["/usr/bin/cred-helper"], host), True)
    _eq("exact host match", credential_helper_covers_host(["bes.acme.aspect.build=/usr/bin/h"], host), True)
    _eq("exact host case-insensitive", credential_helper_covers_host(["BES.ACME.ASPECT.BUILD=/usr/bin/h"], host), True)
    _eq("other host no match", credential_helper_covers_host(["remote.acme.aspect.build=/usr/bin/h"], host), False)
    _eq("wildcard subdomain match", credential_helper_covers_host(["*.acme.aspect.build=/usr/bin/h"], host), True)
    _eq("wildcard domain itself match", credential_helper_covers_host(["*.acme.aspect.build=/h"], "acme.aspect.build"), True)
    _eq("wildcard non-subdomain no match", credential_helper_covers_host(["*.other.aspect.build=/h"], host), False)
    _eq("wildcard is not a substring match", credential_helper_covers_host(["*.aspect.build=/h"], "notacme.aspect.build"), True)
    _eq(
        "amongst others",
        credential_helper_covers_host(["remote.acme.aspect.build=/h", "bes.acme.aspect.build=/h"], host),
        True,
    )

def _test_login_hint(_):
    """The hint names a configured deployment with `--deployment`, but stays a
    bare login when no deployment owns the endpoint."""
    _eq("none → bare login", login_hint(None), "aspect auth login")
    _eq("empty → bare login", login_hint(""), "aspect auth login")
    _eq("deployment names itself", login_hint("gcp.acme"), "aspect auth login --deployment gcp.acme")

def _test_impl(ctx):
    _test_endpoint_host(ctx)
    _test_is_aspect_host(ctx)
    _test_needs_aspect_token(ctx)
    _test_headers_have_auth(ctx)
    _test_credential_helper_covers_host(ctx)
    _test_login_hint(ctx)
    print("aspect_endpoint_auth_test.axl: OK (6 sections)")
    return 0

aspect_endpoint_auth_tests = task(
    kind = "test-aspect-endpoint-auth",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
