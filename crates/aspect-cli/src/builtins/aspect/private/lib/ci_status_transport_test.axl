"""Tests for `lib/ci_status_transport.axl`.

`build_status_transport(env)` is pure + env-only, but there's no
env-mocking layer in AXL, so each subtest snapshots/restores the CI env
vars it touches against the real `ctx.std.env` (same pattern as
`ci_test.axl`).

Run with:
  aspect dev test-ci-status-transport
"""

load("./ci_status_transport.axl", "build_status_transport")

_ENV_KEYS = [
    "GITHUB_ACTIONS",
    "GITHUB_RUN_ID",
    "GITHUB_WORKFLOW",
    "GITHUB_JOB",
    "GITHUB_RUN_ATTEMPT",
    "BUILDKITE",
    "BUILDKITE_BUILD_ID",
    "BUILDKITE_PIPELINE_SLUG",
    "BUILDKITE_STEP_KEY",
    "BUILDKITE_LABEL",
    "BUILDKITE_RETRY_COUNT",
    "CIRCLECI",
    "CIRCLE_WORKFLOW_ID",
    "CIRCLE_PROJECT_REPONAME",
    "CIRCLE_JOB",
]

def _eq(label, got, want):
    if got != want:
        fail("%s: got %r, want %r" % (label, got, want))

def _snapshot_env(ctx):
    return {k: ctx.std.env.var(k) for k in _ENV_KEYS}

def _restore_env(ctx, snapshot):
    for k, v in snapshot.items():
        if v == None:
            ctx.std.env.remove_var(k)
        else:
            ctx.std.env.set_var(k, v)

def _clear_env(ctx):
    for k in _ENV_KEYS:
        ctx.std.env.remove_var(k)

def _set(ctx, pairs):
    for k, v in pairs.items():
        ctx.std.env.set_var(k, v)

def _test_transport_none_off_host(ctx):
    snapshot = _snapshot_env(ctx)
    _clear_env(ctx)
    _eq("transport — None off a recognized host", build_status_transport(ctx.std.env), None)
    _restore_env(ctx, snapshot)

def _test_transport_github(ctx):
    snapshot = _snapshot_env(ctx)
    _clear_env(ctx)
    _set(ctx, {
        "GITHUB_ACTIONS": "true",
        "GITHUB_RUN_ID": "12345",
        "GITHUB_WORKFLOW": "CI",
        "GITHUB_JOB": "build",
        "GITHUB_RUN_ATTEMPT": "2",
    })
    t = build_status_transport(ctx.std.env)
    _eq("github host", t.host, "github")
    _eq("github run_id", t.run_id, "12345")
    _eq("github workflow_name", t.workflow_name, "CI")
    _eq("github job_name", t.job_name, "build")
    _eq("github run_attempt", t.run_attempt, "2")
    _eq("github uses_artifacts", t.uses_artifacts, True)
    _eq("github auth_roles", t.auth_roles, ["prs.write", "actions.read"])
    _restore_env(ctx, snapshot)

def _test_transport_buildkite(ctx):
    snapshot = _snapshot_env(ctx)
    _clear_env(ctx)
    _set(ctx, {
        "BUILDKITE": "true",
        "BUILDKITE_BUILD_ID": "bk-build-abc",
        "BUILDKITE_PIPELINE_SLUG": "my-pipe",
        "BUILDKITE_STEP_KEY": "test-step",
        "BUILDKITE_RETRY_COUNT": "1",
    })
    t = build_status_transport(ctx.std.env)
    _eq("buildkite host", t.host, "buildkite")
    _eq("buildkite run_id", t.run_id, "bk-build-abc")
    _eq("buildkite workflow_name", t.workflow_name, "my-pipe")
    _eq("buildkite job_name (step key)", t.job_name, "test-step")
    # retry 1 → attempt 2 (BK is 0-based; we make it 1-based like GHA).
    _eq("buildkite run_attempt", t.run_attempt, "2")
    _eq("buildkite uses_artifacts", t.uses_artifacts, True)
    _eq("buildkite auth_roles", t.auth_roles, ["prs.write"])

    # Falls back to BUILDKITE_LABEL when no step key, and attempt 1 when
    # retry count is unset.
    _clear_env(ctx)
    _set(ctx, {
        "BUILDKITE": "true",
        "BUILDKITE_BUILD_ID": "bk-build-abc",
        "BUILDKITE_LABEL": ":hammer: Test",
    })
    t2 = build_status_transport(ctx.std.env)
    _eq("buildkite job_name (label fallback)", t2.job_name, ":hammer: Test")
    _eq("buildkite run_attempt default", t2.run_attempt, "1")
    _restore_env(ctx, snapshot)

def _test_transport_circleci(ctx):
    snapshot = _snapshot_env(ctx)
    _clear_env(ctx)
    _set(ctx, {
        "CIRCLECI": "true",
        "CIRCLE_WORKFLOW_ID": "cci-wf-xyz",
        "CIRCLE_PROJECT_REPONAME": "aspect-cli",
        "CIRCLE_JOB": "unit",
    })
    t = build_status_transport(ctx.std.env)
    _eq("circleci host", t.host, "circleci")
    _eq("circleci run_id", t.run_id, "cci-wf-xyz")
    _eq("circleci workflow_name", t.workflow_name, "aspect-cli")
    _eq("circleci job_name", t.job_name, "unit")
    _eq("circleci run_attempt", t.run_attempt, "1")
    # Comment-only: no cross-job artifact transport.
    _eq("circleci uses_artifacts", t.uses_artifacts, False)
    _eq("circleci auth_roles", t.auth_roles, ["prs.write"])
    _restore_env(ctx, snapshot)

def _test_impl(ctx):
    _test_transport_none_off_host(ctx)
    _test_transport_github(ctx)
    _test_transport_buildkite(ctx)
    _test_transport_circleci(ctx)
    print("ci_status_transport.axl: OK (4 sections)")
    return 0

ci_status_transport_tests = task(
    kind = "test-ci-status-transport",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
