"""Tests for `lib/rate_limit.axl`.

Covers:
  - `record_observation` — buffer truncation, reset-crossing detection,
                            watermark monotonicity, two-bucket independence.
  - `throttle_factor`     — empty / 1-obs / 2-obs paths, threshold ladder,
                            `max(1, ...)` floor, terminal-only sentinel.
  - `_check_thresholds`   — bumps `threshold_warned_tier[bucket]` once per
                            tier when LOW (≤ 20%) and IMPORTANT (≤ 5%)
                            crossings fire. The WARN line itself is a
                            side effect on the CLI log; tests pin the
                            tier-state machine.

Run with:
  aspect dev test-rate-limit
"""

load(
    "./rate_limit.axl",
    "BUCKET_APP",
    "BUCKET_ENV",
    "PHASE_EMIT",
    "PHASE_FALL_THROUGH",
    "PHASE_SUPPRESS",
    "apply_budget_refresh",
    "budget_exhausted",
    "cold_start_phase_change_gate_seconds",
    "effective_throttle_factor",
    "export_observations",
    "ingest_sibling_observations",
    "inspect_for_test",
    "record_from_headers",
    "record_observation",
    "record_token_budget",
    "reset_for_test",
    "set_state_for_test",
    "should_emit_phase_change",
    "throttle_factor",
    "time_throttle_factor",
    "usage_footer",
)

# CI markers `_is_ci` consults via `environment.detect_ci`, plus the
# `ASPECT_WORKFLOWS_GITHUB_API_RATE_LIMIT_COLD_START` override seam —
# cleared at every subtest setup so the cold-start floor stays off
# unless explicitly enabled. Running `aspect dev test-rate-limit` on
# a host where any of these is set would otherwise flip the floor on
# and break the existing factor / footer assertions.
_CI_ENV_MARKERS = (
    "GITHUB_ACTIONS",
    "BUILDKITE_AGENT_ACCESS_TOKEN",
    "CI_JOB_TOKEN",
    "CIRCLE_PROJECT_REPONAME",
    "CI",
    "ASPECT_WORKFLOWS_GITHUB_API_RATE_LIMIT_COLD_START",
)

# Stub TaskUpdate-shaped value for tests of `should_emit_phase_change`.
# The helper only reads `update.phase_change`; using a tiny local
# record avoids depending on the full `lifecycle.TaskUpdate` type.
_StubUpdate = record(phase_change = field(bool, default = False))

def _stub_update(phase_change):
    return _StubUpdate(phase_change = phase_change)

def _eq(label, got, want):
    if got != want:
        fail("%s: got %r, want %r" % (label, got, want))

def _assert(label, cond):
    if not cond:
        fail("%s: condition false" % label)

def _reset(ctx):
    """Clear all rate-limit state between subtests so each
    section runs from a known-empty starting point. Also clears
    every CI env marker the cold-start floor checks, so tests that
    don't opt into cold-start CI detection don't pick up the host's
    real CI markers."""
    reset_for_test(ctx)
    for marker in _CI_ENV_MARKERS:
        ctx.std.env.remove_var(marker)

def _force_cold_start_ci(ctx):
    """Force `_is_ci` to return True via the test-only override env
    var. Use in tests that need the cold-start floor to apply
    regardless of whether the host happens to be on CI."""
    ctx.std.env.set_var("ASPECT_WORKFLOWS_GITHUB_API_RATE_LIMIT_COLD_START", "1")

def _tier(ctx, bucket):
    """Project the trait's `threshold_warned_tier[bucket]` for assertions."""
    return inspect_for_test(ctx)["threshold_warned_tier"].get(bucket, 0)

# Far-future reset epoch — `time_to_reset` clamps well above the
# `_TIME_TO_RESET_FLOOR_S` floor, so the safe-burn calc has stable
# inputs regardless of the test runner's wall clock.
_FAR_FUTURE = 9999999999

def _test_record_basic(ctx):
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4800, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 100.0)
    obs = inspect_for_test(ctx)["observations"][BUCKET_APP]
    _eq("record_basic — single entry", len(obs), 1)
    _eq("record_basic — values stored", obs[0], [100.0, 4800, 5000, _FAR_FUTURE])
    _eq("record_basic — watermark seeded", inspect_for_test(ctx)["watermark"][BUCKET_APP], 4800)
    _eq("record_basic — limit seeded", inspect_for_test(ctx)["limits"][BUCKET_APP], 5000)

def _test_record_buffer_truncation(ctx):
    _reset(ctx)
    for i in range(25):
        record_observation(ctx, BUCKET_APP, remaining = 5000 - i, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = float(i))
    obs = inspect_for_test(ctx)["observations"][BUCKET_APP]
    _eq("buffer truncation — capped at 16", len(obs), 16)

    # The oldest entry kept is observation index 9 (remaining = 5000-9 = 4991).
    _eq("buffer truncation — oldest is most-recent 16", obs[0][1], 4991)
    _eq("buffer truncation — newest preserved", obs[-1][1], 4976)

def _test_watermark_monotone_decreasing(ctx):
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4800, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 3000, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 2.0)
    record_observation(ctx, BUCKET_APP, remaining = 4500, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 3.0)
    _eq("watermark — tracks the lowest seen", inspect_for_test(ctx)["watermark"][BUCKET_APP], 3000)

def _test_reset_crossing_flushes_buffer(ctx):
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 2000, limit = 5000, reset_epoch = 1000, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 1900, limit = 5000, reset_epoch = 1000, epoch_s = 2.0)

    # `reset_epoch` jumps +1800s — well past `_RESET_JUMP_S` (600s).
    # Buffer should flush, retaining only the new observation.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = 2800, epoch_s = 3.0)
    obs = inspect_for_test(ctx)["observations"][BUCKET_APP]
    _eq("reset crossing — buffer flushed to length 1", len(obs), 1)
    _eq("reset crossing — only newest retained", obs[0][1], 4900)

def _test_reset_crossing_rebaselines_watermark(ctx):
    """When the GitHub rate-limit window rolls mid-task, the bucket
    replenishes (remaining jumps back up). The watermark must reset
    too — otherwise `usage_footer` carries the pre-reset peak forward
    and renders a non-zero `% used` against the fresh window. The
    threshold-warn tier must also reset so a fresh burn-through in
    the new window re-fires LOW/IMPORTANT. The burn-rate inference
    must NOT throttle on the replenishment (the `remaining` going UP
    is a window roll, not aspect-cli accelerating its spend)."""
    _reset(ctx)

    # Pre-reset: burn down to 100/5000 (98% used) — fires LOW + IMPORTANT.
    record_observation(ctx, BUCKET_APP, remaining = 4500, limit = 5000, reset_epoch = 1000, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 100, limit = 5000, reset_epoch = 1000, epoch_s = 50.0)
    _eq("pre-reset — watermark at lowest", inspect_for_test(ctx)["watermark"][BUCKET_APP], 100)
    _eq("pre-reset — WARN tier at IMPORTANT", _tier(ctx, BUCKET_APP), 2)

    # Reset crossing: reset_epoch jumps from 1000 → 4600 (+3600s,
    # past `_RESET_JUMP_S`). `remaining` jumps back to 5000.
    record_observation(ctx, BUCKET_APP, remaining = 5000, limit = 5000, reset_epoch = 4600, epoch_s = 100.0)
    _eq(
        "post-reset — watermark re-baselined to fresh remaining",
        inspect_for_test(ctx)["watermark"][BUCKET_APP],
        5000,
    )
    _eq(
        "post-reset — buffer holds only the fresh observation",
        len(inspect_for_test(ctx)["observations"][BUCKET_APP]),
        1,
    )
    _eq("post-reset — WARN tier cleared", _tier(ctx, BUCKET_APP), 0)

    # Throttle factor with the single post-reset observation falls
    # through to the threshold ladder. 100% remaining → 1× (no throttle).
    _eq(
        "post-reset — throttle factor relaxes to 1×",
        throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0),
        1.0,
    )

    # Continue burning post-reset. burn-rate inference sees only
    # post-reset observations now, so it computes a meaningful rate.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = 4600, epoch_s = 110.0)

    # 100 calls in 10s = 10/s. safe_remaining = 4900 - 0.30*5000 = 3400.
    # time_to_reset = max(60, 4600-0) = 4600. safe_burn = 3400/4600 ≈ 0.74/s.
    # factor ≈ 10/0.74 ≈ 13.5.
    factor = throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0)
    _assert("post-reset — burn-rate sees only fresh-window data", factor > 5.0)

def _test_effective_factor_records_to_trait(ctx):
    """Each call to `effective_throttle_factor` writes the resulting
    factor to `trait.last_effective_factor[bucket]` so `usage_footer`
    can surface it without recomputing. Verifies the recording side
    effect across multiple calls."""
    _reset(ctx)
    effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10)
    _eq(
        "effective-factor recording — initial 1.0 stored",
        inspect_for_test(ctx)["last_effective_factor"][BUCKET_APP],
        1.0,
    )

    # Time-throttle ramp at 1 h elapsed with 10 s base → factor 6.
    effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 3600, min_interval_s = 10)
    _eq(
        "effective-factor recording — 6× stored after time throttle kicks in",
        inspect_for_test(ctx)["last_effective_factor"][BUCKET_APP],
        6.0,
    )

def _test_usage_footer_renders_throttle_clause(ctx):
    """`usage_footer` appends `, throttle N×` when the bucket's
    recorded effective factor is > 1. Stays silent at factor == 1
    (the no-pressure default) and flips to `terminal-only` at the
    sentinel."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)

    # Factor 1 → no throttle clause.
    effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10)
    if ", throttle" in usage_footer(ctx):
        fail("usage_footer at factor 1 should not surface a throttle clause: %r" % usage_footer(ctx))

    # Factor 6 (time-throttle clamp at 30 min) → `, throttle 6×`.
    effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 3600, min_interval_s = 10)
    if "throttle 6×" not in usage_footer(ctx):
        fail("usage_footer at factor 6 should surface `throttle 6×`: %r" % usage_footer(ctx))

    # Sentinel terminal-only → `, throttle terminal-only`.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 100, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10)
    if "throttle terminal-only" not in usage_footer(ctx):
        fail("usage_footer at terminal-only should surface that explicitly: %r" % usage_footer(ctx))

    # Factor 1.4 rounds to 1× — clause must be suppressed (no visible
    # stretch, no point in advertising it). Synthesize by setting the
    # trait field directly after an obs is in place so `usage_footer`
    # has both watermark + factor to render.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    set_state_for_test(ctx, last_effective_factor = {BUCKET_APP: 1.4, BUCKET_ENV: 1.0})
    if ", throttle" in usage_footer(ctx):
        fail("usage_footer at factor=1.4 (rounds to 1×) should suppress throttle clause: %r" % usage_footer(ctx))

def _test_burn_rate_replenishment_returns_floor(ctx):
    """If the reset crossing escapes detection (small `reset_epoch`
    delta) and the buffer ends up with mixed pre-/post-reset data,
    `delta_remaining` goes negative (remaining went UP). The factor
    floors at 1.0 — we never speed up cadence based on stale
    pre-reset data."""
    _reset(ctx)

    # Pre-reset observations on a 1000-epoch window. Then a "post-reset"
    # observation with the SAME reset_epoch (window didn't visibly roll)
    # — synthesizes the escaped-reset case where data is mixed.
    record_observation(ctx, BUCKET_APP, remaining = 100, limit = 5000, reset_epoch = 1000, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 50, limit = 5000, reset_epoch = 1000, epoch_s = 10.0)
    record_observation(ctx, BUCKET_APP, remaining = 5000, limit = 5000, reset_epoch = 1000, epoch_s = 20.0)

    # oldest.remaining = 100, newest.remaining = 5000 → delta_remaining = -4900 → burn_rate < 0 → 1.0.
    _eq(
        "replenishment without detected reset → factor floors at 1.0",
        throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0),
        1.0,
    )

def _test_two_bucket_independence(ctx):
    """Recording into one bucket must not touch the other — they have
    independent budgets and threshold-warn tiers."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    record_observation(ctx, BUCKET_ENV, remaining = 40, limit = 1000, reset_epoch = _FAR_FUTURE, epoch_s = 2.0)
    _eq("two-bucket — app buffer len 1", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 1)
    _eq("two-bucket — env buffer len 1", len(inspect_for_test(ctx)["observations"][BUCKET_ENV]), 1)

    # env at 4% (below IMPORTANT) bumps env tier to 2; app at 98% stays at 0.
    _eq("two-bucket — env tier at IMPORTANT", _tier(ctx, BUCKET_ENV), 2)
    _eq("two-bucket — app tier untouched", _tier(ctx, BUCKET_APP), 0)

def _test_threshold_factor_ladder(ctx):
    """With a single observation, the factor falls through the
    threshold ladder. Solo task (no visible siblings) means the
    swarm-size multiplier is 1, so the factor reads back as the raw
    ladder row. Verifies every boundary."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4800, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("threshold — 96% → 1×", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 1.0)

    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 2000, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("threshold — 40% → 2×", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 2.0)

    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 1250, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("threshold — 25% → 5×", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 5.0)

    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 600, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("threshold — 12% → 20×", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 20.0)

    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 400, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("threshold — 8% → 50×", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 50.0)

    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 150, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _assert("threshold — 3% → terminal-only", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0) >= 1000.0)

def _test_throttle_factor_floor(ctx):
    """A bucket whose `remaining` rose between observations (server
    replenished mid-task) must still produce factor ≥ 1.0. We never
    speed up — only slow down."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 1000, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 100.0)
    record_observation(ctx, BUCKET_APP, remaining = 1100, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 110.0)
    _eq("floor — rising remaining yields 1.0", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 1.0)

def _test_throttle_factor_burn_rate_inference(ctx):
    """With two observations and a positive burn rate, the factor
    scales with how aggressively the bucket is being consumed
    relative to the safe-burn rate (remaining / time_to_reset)."""
    _reset(ctx)

    # Reset 1 hour out (now_epoch_s = 0). Bucket has burned 100/sec
    # over 10s = effectively 100 calls/sec. safe_remaining = 4900 -
    # 0.30*6000 = 3100. safe_burn = 3100/3600 ≈ 0.86/sec. factor ≈
    # 100/0.86 ≈ 116×.
    reset_epoch = 3600
    record_observation(ctx, BUCKET_APP, remaining = 5900, limit = 6000, reset_epoch = reset_epoch, epoch_s = 100.0)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 6000, reset_epoch = reset_epoch, epoch_s = 110.0)
    factor_high = throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0)
    _assert("burn rate — high burn → high factor", factor_high > 50.0)

    _reset(ctx)

    # Same window but burn only 1 call/sec — well under safe-burn,
    # factor floors at 1.0.
    record_observation(ctx, BUCKET_APP, remaining = 5900, limit = 6000, reset_epoch = reset_epoch, epoch_s = 100.0)
    record_observation(ctx, BUCKET_APP, remaining = 5890, limit = 6000, reset_epoch = reset_epoch, epoch_s = 110.0)
    factor_low = throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0)
    _eq("burn rate — low burn under safe-burn yields 1.0", factor_low, 1.0)

def _test_threshold_warn_fires_once(ctx):
    """Crossing the LOW threshold (≤ 15% of limit) bumps the bucket's
    `threshold_warned_tier` to 1; further LOW-zone observations don't
    re-fire. Crossing IMPORTANT (≤ 5%) bumps to 2. The WARN line
    itself is a CLI-log side effect; the tier int is the dedup state."""
    _reset(ctx)
    _eq("warn — initial tier is 0", _tier(ctx, BUCKET_APP), 0)

    # 15% → bump to LOW (tier 1).
    record_observation(ctx, BUCKET_APP, remaining = 750, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("warn — LOW recorded at 15%", _tier(ctx, BUCKET_APP), 1)

    # 10% → still LOW, tier stays 1 (no re-fire).
    record_observation(ctx, BUCKET_APP, remaining = 500, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 2.0)
    _eq("warn — LOW does not re-fire at 10%", _tier(ctx, BUCKET_APP), 1)

    # 4% → bump to IMPORTANT (tier 2).
    record_observation(ctx, BUCKET_APP, remaining = 200, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 3.0)
    _eq("warn — IMPORTANT recorded at 4%", _tier(ctx, BUCKET_APP), 2)

    # 3% → still IMPORTANT, tier stays 2.
    record_observation(ctx, BUCKET_APP, remaining = 150, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 4.0)
    _eq("warn — IMPORTANT does not re-fire at 3%", _tier(ctx, BUCKET_APP), 2)

def _test_threshold_warn_re_fires_after_reset(ctx):
    """A reset crossing clears the bucket's tier so a fresh
    burn-through in the new window re-fires LOW + IMPORTANT instead
    of staying silent under the prior tier-2 dedup."""
    _reset(ctx)

    # First window: burn to 4% → tier 2 (IMPORTANT).
    record_observation(ctx, BUCKET_APP, remaining = 200, limit = 5000, reset_epoch = 1000, epoch_s = 1.0)
    _eq("first window — tier at IMPORTANT", _tier(ctx, BUCKET_APP), 2)

    # Window rolls (+3600s, past `_RESET_JUMP_S`). Tier clears.
    record_observation(ctx, BUCKET_APP, remaining = 5000, limit = 5000, reset_epoch = 4600, epoch_s = 100.0)
    _eq("post-reset — tier cleared", _tier(ctx, BUCKET_APP), 0)

    # Burn again in new window — LOW re-fires (tier → 1).
    record_observation(ctx, BUCKET_APP, remaining = 500, limit = 5000, reset_epoch = 4600, epoch_s = 200.0)
    _eq("new-window burn — tier re-fires to LOW", _tier(ctx, BUCKET_APP), 1)

def _test_threshold_warn_direct_to_important(ctx):
    """First observation already in the IMPORTANT zone (≤ 5%) fires
    both tiers on the same call — the bucket lands at tier 2 directly,
    matching the CLI's two-WARN-line emit order."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 150, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("warn — direct-to-IMPORTANT lands at tier 2", _tier(ctx, BUCKET_APP), 2)

def _test_reset_crossing_exact_boundary(ctx):
    """Reset-epoch jump of exactly `_RESET_JUMP_S` (600s) is at the
    threshold and does NOT flush (the check uses strict `>`); a jump
    of +601s does flush."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 100, limit = 5000, reset_epoch = 1000, epoch_s = 1.0)

    # +600s — at the boundary, not a flush.
    record_observation(ctx, BUCKET_APP, remaining = 90, limit = 5000, reset_epoch = 1600, epoch_s = 2.0)
    _eq(
        "reset crossing — exactly +600s preserves prior obs",
        len(inspect_for_test(ctx)["observations"][BUCKET_APP]),
        2,
    )

    # +601s — past the boundary, flushes the prior buffer.
    record_observation(ctx, BUCKET_APP, remaining = 80, limit = 5000, reset_epoch = 2202, epoch_s = 3.0)
    _eq(
        "reset crossing — +601s flushes prior obs",
        len(inspect_for_test(ctx)["observations"][BUCKET_APP]),
        1,
    )

def _test_effective_throttle_factor_picks_larger(ctx):
    """`effective_throttle_factor` returns max(quota_factor, time_factor).
    Test each side dominates the other under different inputs."""
    _reset(ctx)

    # Both factors 1.0 → 1.0.
    _eq(
        "effective — no pressure → 1.0",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        1.0,
    )

    # Time factor 6.0 (1h elapsed, 10s base → 60s target) dominates
    # a no-pressure quota factor of 1.0.
    _eq(
        "effective — time pressure dominates quota at rest",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 3600, min_interval_s = 10),
        6.0,
    )

    # Drop the quota into the threshold ladder's 5-10% step (factor 50.0).
    # Time at 0 elapsed → 1.0. Quota factor wins.
    record_observation(ctx, BUCKET_APP, remaining = 400, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq(
        "effective — quota pressure dominates time at task start",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        50.0,
    )

def _test_record_from_headers(ctx):
    """Header-list parsing path: case-insensitive name lookup, lenient
    integer parsing, silent no-op when `X-RateLimit-Remaining` isn't
    present (non-GitHub endpoint or transport error)."""
    _reset(ctx)
    record_from_headers(
        ctx,
        BUCKET_APP,
        [
            ("Content-Type", "application/json"),
            # GitHub's actual header capitalization is canonical, but
            # we look up case-insensitively in case a proxy lowercased
            # them (some HTTP/2 stacks do).
            ("x-ratelimit-limit", "5000"),
            ("X-RateLimit-Remaining", "4900"),
            ("X-RATELIMIT-RESET", "1700000000"),
        ],
        epoch_s = 5.0,
    )
    obs = inspect_for_test(ctx)["observations"][BUCKET_APP]
    _eq("headers — single observation recorded", len(obs), 1)
    _eq("headers — remaining parsed", obs[0][1], 4900)
    _eq("headers — limit parsed", obs[0][2], 5000)
    _eq("headers — reset_epoch parsed", obs[0][3], 1700000000)

    # No `X-RateLimit-Remaining` → silent no-op (non-GitHub response).
    _reset(ctx)
    record_from_headers(ctx, BUCKET_APP, [("Content-Type", "text/html")])
    _eq("headers — no x-ratelimit-* no-ops", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)

    # Empty header list → silent no-op.
    _reset(ctx)
    record_from_headers(ctx, BUCKET_APP, [])
    _eq("headers — empty list no-ops", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)

    # None headers → silent no-op (e.g. transport error returns no response object).
    _reset(ctx)
    record_from_headers(ctx, BUCKET_APP, None)
    _eq("headers — None no-ops", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)

    # Malformed limit string → silent no-op (limit ≤ 0 fails the validation
    # in record_observation, so the observation never lands).
    _reset(ctx)
    record_from_headers(ctx, BUCKET_APP, [
        ("X-RateLimit-Remaining", "4900"),
        ("X-RateLimit-Limit", "not-a-number"),
        ("X-RateLimit-Reset", "1700000000"),
    ])
    _eq("headers — malformed limit no-ops", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)

def _test_record_validation(ctx):
    """`record_observation` silently rejects bad inputs so callers
    don't have to validate themselves."""
    _reset(ctx)

    # Unknown bucket → no-op.
    record_observation(ctx, "unknown-bucket", remaining = 100, limit = 1000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("validation — unknown bucket app empty", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)
    _eq("validation — unknown bucket env empty", len(inspect_for_test(ctx)["observations"][BUCKET_ENV]), 0)

    # Zero limit → no-op (can't meaningfully compute a fraction).
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 100, limit = 0, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("validation — zero limit no-ops", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)

    # Negative limit → no-op (same reasoning).
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 100, limit = -5, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("validation — negative limit no-ops", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 0)

def _test_throttle_factor_empty_state(ctx):
    """`throttle_factor` with no recorded observations (the moment a
    task starts, before any GitHub API call) returns 1.0 so the
    caller's heartbeat cadence is unaffected."""
    _reset(ctx)
    _eq("empty-state — factor is 1.0", throttle_factor(ctx, BUCKET_APP), 1.0)

def _test_throttle_factor_exhausted(ctx):
    """With ≥ 2 observations and `remaining == 0`, the factor returns
    the terminal-only sentinel so callers drop every non-final emit."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 1, limit = 5000, reset_epoch = 3600, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 0, limit = 5000, reset_epoch = 3600, epoch_s = 2.0)
    _assert("exhausted — terminal-only factor", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0) >= 1000.0)

def _test_burn_rate_falls_back_on_degenerate_inputs(ctx):
    """The ≥ 2 observation path returns None on degenerate inputs
    (zero Δt, missing reset_epoch); `throttle_factor` then falls back
    to the threshold ladder on the latest observation."""

    # Zero Δt — both observations share the same monotonic timestamp.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 5.0)
    record_observation(ctx, BUCKET_APP, remaining = 4800, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 5.0)

    # 96% remaining on the threshold ladder → 1×.
    _eq("zero Δt — falls back to threshold (96% → 1×)", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 1.0)

    # Missing reset_epoch — burn-rate calc can't compute time_to_reset
    # without it, so falls back to the threshold ladder.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 700, limit = 5000, reset_epoch = 0, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 600, limit = 5000, reset_epoch = 0, epoch_s = 2.0)

    # 12% remaining on the threshold ladder → 20×.
    _eq("no reset_epoch — falls back to threshold (12% → 20×)", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 20.0)

def _test_usage_footer(ctx):
    """`usage_footer` is App-bucket-only — env-bucket pressure is
    surfaced via CLI INFO logs (first-observation + threshold
    transitions) but kept out of the GHSC / BK / PR-comment footer
    so the surface stays focused on the one bucket aspect-cli
    actively manages and swarm-coordinates on."""
    _reset(ctx)
    _eq("usage_footer — empty trait → empty string", usage_footer(ctx), "")

    # App-bucket observation only → footer renders the App payload
    # with thousands separators on the numbers, no bucket label.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4200, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)

    # The `resets in <duration>` segment depends on wall-clock time, so
    # assert the payload with `in` containment instead of an exact
    # match. The format under test:
    # `📊 GitHub API quota <used>/<limit> (<pct>% used, resets in <duration>)`.
    footer = usage_footer(ctx)
    if not footer.startswith("📊 GitHub API quota "):
        fail("usage_footer — App-only: missing prefix: %r" % footer)
    if "800/5,000 (16% used" not in footer:
        fail("usage_footer — App-only: missing payload: %r" % footer)
    if "resets in " not in footer:
        fail("usage_footer — App-only: missing `resets in`: %r" % footer)

    # Env-bucket observation alone → no footer. The surface skips
    # env-only data; CLI INFO logs carry it for operator visibility.
    _reset(ctx)
    record_observation(ctx, BUCKET_ENV, remaining = 100, limit = 1000, reset_epoch = _FAR_FUTURE, epoch_s = 2.0)
    _eq("usage_footer — env-only → empty string", usage_footer(ctx), "")

    # App + env observed → footer renders App only; the env bucket
    # stays in the INFO log layer.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    record_observation(ctx, BUCKET_ENV, remaining = 100, limit = 1000, reset_epoch = _FAR_FUTURE, epoch_s = 2.0)
    footer = usage_footer(ctx)
    if "100/5,000 (2% used" not in footer:
        fail("usage_footer — App + env: missing App payload: %r" % footer)
    if "GITHUB_TOKEN" in footer or "900/1,000" in footer:
        fail("usage_footer — App + env: env payload must NOT appear in surface footer: %r" % footer)

    # Empty state → "" (the moment a task starts, before any HTTP call).
    _reset(ctx)
    _eq("usage_footer — empty state → empty string", usage_footer(ctx), "")

def _test_time_throttle_factor_sliding_scale(ctx):
    """Verify the time-based sliding-scale throttle:
      - 0 ≤ elapsed < FAST (5 min)         → 1.0
      - FAST ≤ elapsed < SLOW (5..30 min) → linear ramp
      - elapsed ≥ SLOW (30 min)           → clamp at target
    Floored at 1.0 in every case."""
    min_interval = 10  # seconds — typical GHSC min_poll_interval_seconds.

    # Fast period: no throttle.
    _eq("time-throttle — 0s elapsed → 1.0", time_throttle_factor(0, min_interval), 1.0)
    _eq("time-throttle — 60s elapsed → 1.0", time_throttle_factor(60, min_interval), 1.0)
    _eq("time-throttle — 4m 59s elapsed → 1.0", time_throttle_factor(299, min_interval), 1.0)

    # At 5 min the ramp starts: factor is still 1.0 at the boundary.
    _eq("time-throttle — exactly 5 min → 1.0", time_throttle_factor(300, min_interval), 1.0)

    # Mid-ramp at ~17m 30s: halfway between FAST and SLOW. Target at
    # SLOW is 60/10 = 6.0; halfway from 1.0 is 3.5.
    halfway = (300 + 1800) // 2  # 1050s
    _eq("time-throttle — halfway 17.5m → 3.5", time_throttle_factor(halfway, min_interval), 3.5)

    # At 30 min the ramp clamps: target = 60s / 10s = 6.0.
    _eq("time-throttle — exactly 30 min → 6.0", time_throttle_factor(1800, min_interval), 6.0)
    _eq("time-throttle — 1h elapsed (past clamp) → 6.0", time_throttle_factor(3600, min_interval), 6.0)

    # If `min_interval` already meets or exceeds the target, factor is 1.0.
    _eq("time-throttle — min_interval == target → 1.0 at clamp", time_throttle_factor(3600, 60), 1.0)
    _eq("time-throttle — min_interval > target → 1.0 at clamp", time_throttle_factor(3600, 120), 1.0)

    # Degenerate inputs → 1.0 (no throttle).
    _eq("time-throttle — zero min_interval → 1.0", time_throttle_factor(3600, 0), 1.0)
    _eq("time-throttle — negative min_interval → 1.0", time_throttle_factor(3600, -5), 1.0)
    _eq("time-throttle — negative elapsed → 1.0", time_throttle_factor(-1, min_interval), 1.0)

def _test_export_observations_round_trip(ctx):
    """`export_observations` produces a JSON-friendly dict shape that
    `ingest_sibling_observations` consumes; the two are inverses."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4800, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 100.0)
    record_observation(ctx, BUCKET_APP, remaining = 4700, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 110.0)
    record_observation(ctx, BUCKET_ENV, remaining = 900, limit = 1000, reset_epoch = _FAR_FUTURE, epoch_s = 105.0)

    exported = export_observations(ctx)
    _eq("export — app entries serialised", len(exported.get(BUCKET_APP, [])), 2)
    _eq("export — env entries serialised", len(exported.get(BUCKET_ENV, [])), 1)
    _eq("export — first app entry is a dict", type(exported[BUCKET_APP][0]), "dict")
    _eq("export — first app epoch", exported[BUCKET_APP][0]["epoch_s"], 100.0)
    _eq("export — first app remaining", exported[BUCKET_APP][0]["remaining"], 4800)

    # Buckets with zero observations are omitted from the payload so
    # the artifact stays compact. Reset and re-export.
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4800, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 100.0)
    exported = export_observations(ctx)
    if BUCKET_ENV in exported:
        fail("export — empty env bucket should be omitted: %r" % exported)

def _test_ingest_sibling_observations(ctx):
    """Sibling-exported observations land under their `sibling_id` and
    feed into the merged view consumed by `throttle_factor`."""
    _reset(ctx)

    # Sibling A burned 100 calls in 10s; its export carries the two
    # observations spanning that window.
    sibling_a = {
        BUCKET_APP: [
            {"epoch_s": 100.0, "remaining": 5900, "limit": 6000, "reset_epoch": 3600},
            {"epoch_s": 110.0, "remaining": 5800, "limit": 6000, "reset_epoch": 3600},
        ],
    }
    ingest_sibling_observations(ctx, "sibling-a", sibling_a)

    sib = inspect_for_test(ctx)["sibling_observations"]
    _eq("ingest — sibling slice keyed by id", list(sib.keys()), ["sibling-a"])
    _eq("ingest — app bucket observations stored", len(sib["sibling-a"][BUCKET_APP]), 2)

    # Re-ingest under the same id overwrites — sibling sends a fresh
    # slice each cycle, the trait holds at most one per sibling.
    sibling_a_v2 = {
        BUCKET_APP: [
            {"epoch_s": 120.0, "remaining": 5700, "limit": 6000, "reset_epoch": 3600},
        ],
    }
    ingest_sibling_observations(ctx, "sibling-a", sibling_a_v2)
    sib = inspect_for_test(ctx)["sibling_observations"]
    _eq("ingest — overwrite by sibling_id", len(sib["sibling-a"][BUCKET_APP]), 1)

    # Malformed inputs silently no-op.
    _reset(ctx)
    ingest_sibling_observations(ctx, "", {BUCKET_APP: [{"epoch_s": 1, "remaining": 1, "limit": 1, "reset_epoch": 1}]})
    _eq("ingest — empty sibling_id no-ops", inspect_for_test(ctx)["sibling_observations"], {})
    ingest_sibling_observations(ctx, "sibling-b", "not a dict")
    _eq("ingest — non-dict payload no-ops", inspect_for_test(ctx)["sibling_observations"], {})
    ingest_sibling_observations(ctx, "sibling-b", {BUCKET_APP: [{"remaining": -1, "limit": 100}]})
    _eq("ingest — negative remaining filtered", inspect_for_test(ctx)["sibling_observations"], {})

def _test_merged_view_drives_throttle_factor(ctx):
    """A task with a single local observation falls back to the
    threshold ladder when consulting `throttle_factor` alone — but
    after ingesting sibling observations covering a real burn window,
    the merged view supplies ≥ 2 samples and the burn-rate path takes
    over. This is the convergence guarantee: every swarm member
    computing throttle_factor against the same merged sample set
    produces the same factor."""
    _reset(ctx)

    # Reset 1 hour out (now_epoch_s = 0). Sibling A burned 100 calls
    # in 10s = ~10/s. safe_burn ≈ (4700 - 0.30*5000) / 3600 ≈ 0.89/s.
    # factor ≈ 11× — well above threshold-ladder (96% remaining → 1×).
    reset_epoch = 3600

    # Only our own first observation: 4700/5000 → threshold ladder hits the 96% row → 1×.
    record_observation(ctx, BUCKET_APP, remaining = 4700, limit = 5000, reset_epoch = reset_epoch, epoch_s = 110.0)
    local_only = throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0)
    _eq("merged — local-only falls through to threshold", local_only, 1.0)

    # Sibling shares the missing prior observation — now merged buffer
    # has 2 samples spanning a real burn window.
    ingest_sibling_observations(ctx, "sibling-a", {
        BUCKET_APP: [
            {"epoch_s": 100.0, "remaining": 4800, "limit": 5000, "reset_epoch": reset_epoch},
        ],
    })
    with_sibling = throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0)
    _assert("merged — sibling sample unlocks burn-rate inference", with_sibling > 5.0)

def _test_merged_view_handles_flat_burn(ctx):
    """A merged buffer of observations where `remaining` doesn't change
    (steady-state, no actual burn) must produce factor 1.0 via the
    `burn_rate <= 0 → 1.0` floor in `_burn_rate_factor`. Exercises
    the merged path end-to-end with both local and sibling samples."""
    _reset(ctx)

    # Local + sibling both observed remaining = 4500 at different
    # times — represents a swarm that's quiet (no calls between
    # observations). Reset 1h out so `safe_remaining > 0`.
    reset_epoch = 3600
    for i in range(8):
        record_observation(ctx, BUCKET_APP, remaining = 4500, limit = 5000, reset_epoch = reset_epoch, epoch_s = float(i))

    sibling = {
        BUCKET_APP: [
            {"epoch_s": 100.0 + float(i), "remaining": 4500, "limit": 5000, "reset_epoch": reset_epoch}
            for i in range(8)
        ],
    }
    ingest_sibling_observations(ctx, "sibling-a", sibling)

    _eq(
        "merged — flat-burn merged buffer → factor 1.0",
        throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0),
        1.0,
    )

def _test_threshold_factor_scales_with_visible_swarm(ctx):
    """A cold-started task with one App-bucket observation reads the
    threshold ladder. When siblings are visible *for the same shared
    bucket*, the factor is multiplied by the swarm size (self +
    siblings) so the per-task interval stretches by enough to keep
    the swarm's collective burn under safe. Burn-rate inference
    covers the steady-state case; this multiplier covers the
    cold-start window before burn-rate observations stabilize.

    The test reaches the threshold-path branch by giving siblings
    the same `epoch_s` as the own observation — `delta_t == 0` makes
    `_burn_rate_factor` return None, so the fallback path runs."""
    _reset(ctx)

    # Solo task at 25% App-bucket remaining — ladder picks the 5× row.
    record_observation(ctx, BUCKET_APP, remaining = 1250, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("swarm — solo task at 25% → 5×", throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0), 5.0)

    # Three siblings, each with one App-bucket observation at the same
    # `epoch_s` as the own observation. Merged buffer has 4 samples
    # but `delta_t == 0`, so burn-rate inference returns None and the
    # threshold-path branch runs with `swarm = 4`.
    for i in range(3):
        ingest_sibling_observations(ctx, "sibling-%d" % i, {
            BUCKET_APP: [
                {"epoch_s": 1.0, "remaining": 1250, "limit": 5000, "reset_epoch": _FAR_FUTURE},
            ],
        })
    _eq(
        "swarm — 1 + 3 siblings at 25% → 5× × 4 = 20×",
        throttle_factor(ctx, BUCKET_APP, now_epoch_s = 0),
        20.0,
    )

def _test_threshold_factor_swarm_scaling_skips_env_bucket(ctx):
    """The Env bucket is the per-job `GITHUB_TOKEN` — siblings don't
    compete for it because each has its own quota. The swarm-size
    multiplier must stay 1 for Env even when many siblings are
    visible."""
    _reset(ctx)
    record_observation(ctx, BUCKET_ENV, remaining = 250, limit = 1000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq("env — solo at 25% → 5×", throttle_factor(ctx, BUCKET_ENV, now_epoch_s = 0), 5.0)

    # Three siblings, each with App-bucket activity (irrelevant to env quota).
    for i in range(3):
        ingest_sibling_observations(ctx, "sibling-%d" % i, {
            BUCKET_APP: [
                {"epoch_s": 0.5, "remaining": 4000, "limit": 5000, "reset_epoch": _FAR_FUTURE},
            ],
        })
    _eq(
        "env — siblings active on App bucket don't compete for Env → 5× unchanged",
        throttle_factor(ctx, BUCKET_ENV, now_epoch_s = 0),
        5.0,
    )

def _test_cold_start_floor_off_ci(ctx):
    """Without any CI marker set, `effective_throttle_factor` skips
    the cold-start floor — solo / local invocations don't pay the
    swarm-defensive 10× factor when no swarm is plausible."""
    _reset(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq(
        "cold-start off-CI — sparse buffer at 98% remaining → 1.0 (no floor)",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        1.0,
    )

def _test_cold_start_floor_on_ci_applies(ctx):
    """On a CI host with a sparse merged buffer (< 3 obs OR span < 30s),
    `effective_throttle_factor` floors at 10× even when remaining
    quota is high — the swarm could be burning quota in parallel that
    this task can't see yet."""
    _reset(ctx)
    _force_cold_start_ci(ctx)

    # 1 observation, 98% remaining. Without the floor: threshold ladder
    # row at > 50% → 1×. With the floor: 10×.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq(
        "cold-start on-CI — sparse buffer at 98% remaining → 10× floor",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        10.0,
    )

def _test_cold_start_floor_clears_when_buffer_dense(ctx):
    """The cold-start floor drops once the merged buffer has ≥ 3
    observations spanning ≥ 30s — burn-rate inference is stable and
    the floor is no longer needed. Below either bound it still applies.

    `reset_epoch = 0` on each observation forces `_burn_rate_factor`
    to return None (missing reset_epoch), so the threshold-ladder
    fallback runs at the 98% remaining row (1×). That keeps the test
    deterministic regardless of the test runner's wall clock — without
    it, `_FAR_FUTURE` against the real clock makes `time_to_reset`
    enormous and `safe_burn ≈ 0`, blowing up the factor."""
    _reset(ctx)
    _force_cold_start_ci(ctx)

    # 3 obs but only a 10s span — still in cold start.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = 0, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 4895, limit = 5000, reset_epoch = 0, epoch_s = 5.0)
    record_observation(ctx, BUCKET_APP, remaining = 4890, limit = 5000, reset_epoch = 0, epoch_s = 11.0)
    _eq(
        "cold-start on-CI — 3 obs spanning 10s still in cold start",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        10.0,
    )

    # Extend the span past 30s — burn-rate falls back to threshold
    # ladder (1×), and the cold-start floor releases too. Factor
    # drops to 1.0.
    _reset(ctx)
    _force_cold_start_ci(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = 0, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 4899, limit = 5000, reset_epoch = 0, epoch_s = 15.0)
    record_observation(ctx, BUCKET_APP, remaining = 4898, limit = 5000, reset_epoch = 0, epoch_s = 30.0)
    record_observation(ctx, BUCKET_APP, remaining = 4897, limit = 5000, reset_epoch = 0, epoch_s = 46.0)
    _eq(
        "cold-start on-CI — 4 obs spanning 45s release the floor",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        1.0,
    )

def _test_cold_start_floor_does_not_lower_higher_pressure(ctx):
    """The cold-start floor is a *floor*, not a ceiling — when the
    quota-pressure factor or time-throttle factor exceeds 10×, the
    larger value still wins. Verifies the floor composes as `max(...)`."""
    _reset(ctx)
    _force_cold_start_ci(ctx)

    # 1 obs at 8% remaining — threshold ladder picks the 5-10% row (50×).
    record_observation(ctx, BUCKET_APP, remaining = 400, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq(
        "cold-start floor — 50× quota pressure wins over 10× floor",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        50.0,
    )

def _test_cold_start_phase_change_gate_off_ci(ctx):
    """Without a CI marker, the phase-change gate is always 0 —
    local invocations have no swarm pressure to debounce against."""
    _reset(ctx)
    _eq(
        "phase-gate off-CI — empty state → 0s gate",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        0,
    )

    # Same answer with observations in hand.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    _eq(
        "phase-gate off-CI — sparse buffer still → 0s gate",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        0,
    )

def _test_cold_start_phase_change_gate_on_ci(ctx):
    """On CI, the gate is 5s while the merged buffer is sparse (< 3 obs
    OR span < 30s), then drops to 0 once burn-rate inference stabilises."""
    _reset(ctx)
    _force_cold_start_ci(ctx)

    # No observations yet — in cold start by the `< 3` branch.
    _eq(
        "phase-gate on-CI — empty buffer → 5s gate",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        5,
    )

    # 2 observations spanning 5s — still in cold start.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    record_observation(ctx, BUCKET_APP, remaining = 4895, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 6.0)
    _eq(
        "phase-gate on-CI — 2 obs / 5s span → 5s gate",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        5,
    )

    # 3 obs spanning > 30s — gate releases to 0.
    record_observation(ctx, BUCKET_APP, remaining = 4890, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 40.0)
    _eq(
        "phase-gate on-CI — 3 obs / 39s span → 0s gate (released)",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        0,
    )

def _test_cold_start_phase_change_gate_uses_sibling_observations(ctx):
    """The merged-view check means a task with only one local
    observation but enough sibling observations spanning > 30s
    correctly leaves the cold-start window — every swarm member
    agrees on whether the gate is open or closed."""
    _reset(ctx)
    _force_cold_start_ci(ctx)

    # Only one local observation — `< 3` would normally trip cold start.
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 50.0)
    _eq(
        "phase-gate on-CI — solo with 1 obs → 5s gate",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        5,
    )

    # A sibling exports two observations spanning 40s — merged buffer
    # now holds 3 obs across a 49s span. Gate releases.
    ingest_sibling_observations(ctx, "sibling-a", {
        BUCKET_APP: [
            {"epoch_s": 1.0, "remaining": 4990, "limit": 5000, "reset_epoch": _FAR_FUTURE},
            {"epoch_s": 41.0, "remaining": 4950, "limit": 5000, "reset_epoch": _FAR_FUTURE},
        ],
    })
    _eq(
        "phase-gate on-CI — merged view (1 local + 2 siblings, 49s span) → 0s gate",
        cold_start_phase_change_gate_seconds(ctx, BUCKET_APP),
        0,
    )

def _test_cold_start_phase_change_gate_invalid_bucket(ctx):
    """Unknown bucket names short-circuit to 0 so callers don't have
    to validate the bucket before calling."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    _eq(
        "phase-gate — unknown bucket → 0s gate",
        cold_start_phase_change_gate_seconds(ctx, "no-such-bucket"),
        0,
    )

def _test_should_emit_phase_change_non_phase_emit(ctx):
    """A non-phase-change emit always returns PHASE_FALL_THROUGH so
    the caller falls back to its normal heartbeat throttle."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    state = {}
    _eq(
        "phase-emit — heartbeat falls through",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(False), state, 1000, "_pc", "_emit"),
        PHASE_FALL_THROUGH,
    )

def _test_should_emit_phase_change_outside_cold_start(ctx):
    """A phase change outside the cold-start window returns
    PHASE_FALL_THROUGH so steady-state phase emits use the normal
    heartbeat throttle (avoiding the burst on chatty tasks past the
    cold-start window)."""
    _reset(ctx)
    state = {}

    # No CI marker — gate inactive, even for a phase emit.
    _eq(
        "phase-emit — off-CI phase change falls through",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(True), state, 1000, "_pc", "_emit"),
        PHASE_FALL_THROUGH,
    )

def _test_should_emit_phase_change_first_emit_passes(ctx):
    """The first phase emit in cold-start always passes — `last_pc=0`
    means "never stamped" and the debounce only applies between
    successive stamped emits. Without this carve-out a fast task
    whose first stamped phase advance happens at t < 5s would lose
    visibility."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    state = {}

    # First emit at t=50ms — `_pc` defaults to 0, would otherwise
    # trip the 5s × 1000ms gate. The first-emit carve-out lets it
    # through.
    _eq(
        "phase-emit — first emit passes regardless of `now`",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(True), state, 50, "_pc", "_emit"),
        PHASE_EMIT,
    )
    _eq("phase-emit — first emit stamps phase clock", state["_pc"], 50)
    _eq("phase-emit — first emit stamps heartbeat clock", state["_emit"], 50)

def _test_should_emit_phase_change_within_debounce_suppresses(ctx):
    """A second phase emit within the 5s debounce of a previously
    stamped emit returns PHASE_SUPPRESS and does NOT re-stamp state."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    state = {"_pc": 1000, "_emit": 1000}
    _eq(
        "phase-emit — within debounce → suppress",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(True), state, 3000, "_pc", "_emit"),
        PHASE_SUPPRESS,
    )
    _eq("phase-emit — suppressed call leaves phase clock untouched", state["_pc"], 1000)
    _eq("phase-emit — suppressed call leaves heartbeat clock untouched", state["_emit"], 1000)

def _test_should_emit_phase_change_after_debounce_emits(ctx):
    """A phase emit past the 5s × scale gap from the previous stamped
    emit passes and re-stamps both clocks."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    state = {"_pc": 1000, "_emit": 1000}

    # 6s later (1000 + 6000 = 7000ms). Past the 5s × 1000ms gate.
    _eq(
        "phase-emit — past debounce → emit",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(True), state, 7000, "_pc", "_emit"),
        PHASE_EMIT,
    )
    _eq("phase-emit — emit re-stamps phase clock", state["_pc"], 7000)
    _eq("phase-emit — emit re-stamps heartbeat clock", state["_emit"], 7000)

def _test_should_emit_phase_change_scale_seconds(ctx):
    """A caller using a second-clock (`monotonic()`) passes `scale=1`
    so the 5s gate compares directly against `now` in seconds."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    state = {"_pc": 10.0, "_emit": 10.0}

    # 3s later — still within the 5s gate.
    _eq(
        "phase-emit — second-clock within debounce → suppress",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(True), state, 13.0, "_pc", "_emit", scale = 1),
        PHASE_SUPPRESS,
    )

    # 6s later — past the gate.
    _eq(
        "phase-emit — second-clock past debounce → emit",
        should_emit_phase_change(ctx, BUCKET_APP, _stub_update(True), state, 16.0, "_pc", "_emit", scale = 1),
        PHASE_EMIT,
    )

def _test_cold_start_floor_records_to_last_effective_factor(ctx):
    """The cold-start floor must be recorded onto
    `last_effective_factor[bucket]` so `usage_footer` renders the
    correct `throttle 10×` clause during the cold-start window."""
    _reset(ctx)
    _force_cold_start_ci(ctx)
    record_observation(ctx, BUCKET_APP, remaining = 4900, limit = 5000, reset_epoch = _FAR_FUTURE, epoch_s = 1.0)
    effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10)
    _eq(
        "cold-start floor — recorded as last_effective_factor",
        inspect_for_test(ctx)["last_effective_factor"][BUCKET_APP],
        10.0,
    )
    if "throttle 10×" not in usage_footer(ctx):
        fail("cold-start floor — usage_footer should render `throttle 10×`: %r" % usage_footer(ctx))

def _test_cold_start_floor_re_engages_after_reset_crossing(ctx):
    """A reset-window crossing flushes the observation buffer (see
    `_test_reset_crossing_flushes_buffer`). The cold-start floor must
    re-engage in the new window because the post-reset buffer is
    sparse again — otherwise a long-running CI task in the middle
    of a fresh window would spend uncapped quota."""
    _reset(ctx)
    _force_cold_start_ci(ctx)

    # Accumulate enough observations to release the floor:
    # 4 obs across 45s, all in the same reset window (reset_epoch = 1000).
    for (epoch, remaining) in [(1.0, 4900), (15.0, 4899), (30.0, 4898), (46.0, 4897)]:
        record_observation(ctx, BUCKET_APP, remaining = remaining, limit = 5000, reset_epoch = 1000, epoch_s = epoch)
    _eq(
        "pre-reset — floor released with dense buffer",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        1.0,
    )

    # Reset crossing — `reset_epoch` jumps +3600s (well past `_RESET_JUMP_S`).
    # Buffer flushes; the new window has 1 observation.
    record_observation(ctx, BUCKET_APP, remaining = 5000, limit = 5000, reset_epoch = 4600, epoch_s = 100.0)
    _eq(
        "post-reset — floor re-engages on fresh sparse buffer",
        effective_throttle_factor(ctx, BUCKET_APP, elapsed_s = 0, min_interval_s = 10),
        10.0,
    )

def _budget(ctx, bucket = BUCKET_APP):
    """Project the `(token_budget, token_spent)` pair for `bucket`."""
    s = inspect_for_test(ctx)
    return (
        (s.get("token_budget") or {}).get(bucket),
        (s.get("token_spent") or {}).get(bucket, 0),
    )

def _test_budget_record_seeds_and_zeroes(ctx):
    _reset(ctx)

    # No budget issued yet → not exhausted (caller falls back to cadence).
    _assert("budget — unset is not exhausted", not budget_exhausted(ctx, BUCKET_APP))
    record_token_budget(ctx, BUCKET_APP, 100)
    _eq("budget — recorded, spend zeroed", _budget(ctx), (100, 0))
    _assert("budget — fresh budget not exhausted", not budget_exhausted(ctx, BUCKET_APP))

def _test_budget_zero_is_exhausted(ctx):
    _reset(ctx)

    # A drained bucket yields budget 0 → exhausted from the first call, with
    # zero spend (the design's "back off entirely" boundary).
    record_token_budget(ctx, BUCKET_APP, 0)
    _eq("budget — zero recorded", _budget(ctx), (0, 0))
    _assert("budget — zero budget is exhausted", budget_exhausted(ctx, BUCKET_APP))

def _test_budget_spend_counts_per_call(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 2)
    headers = [("X-RateLimit-Remaining", "4999"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(_FAR_FUTURE))]
    record_from_headers(ctx, BUCKET_APP, headers, epoch_s = 1.0)
    _eq("budget — one call counted", _budget(ctx)[1], 1)
    _assert("budget — 1/2 not exhausted", not budget_exhausted(ctx, BUCKET_APP))
    record_from_headers(ctx, BUCKET_APP, headers, epoch_s = 2.0)
    _eq("budget — two calls counted", _budget(ctx)[1], 2)
    _assert("budget — 2/2 exhausted", budget_exhausted(ctx, BUCKET_APP))

def _test_budget_counts_gitlab_headers(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 5)

    # GitLab spells the headers without the `X-` prefix.
    headers = [("RateLimit-Remaining", "900"), ("RateLimit-Limit", "1000"), ("RateLimit-Reset", str(_FAR_FUTURE))]
    record_from_headers(ctx, BUCKET_APP, headers, epoch_s = 1.0)
    _eq("budget — gitlab header counted as spend", _budget(ctx)[1], 1)
    _eq("budget — gitlab observation recorded", len(inspect_for_test(ctx)["observations"][BUCKET_APP]), 1)

def _test_budget_no_headers_no_spend(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 5)

    # Non-GitHub/GitLab response (no rate-limit headers) → no spend counted.
    record_from_headers(ctx, BUCKET_APP, [("Content-Type", "application/json")], epoch_s = 1.0)
    _eq("budget — non-rate-limit response not counted", _budget(ctx)[1], 0)

def _test_budget_refresh_floors_down_only(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 100)

    # Spend some, then a refresh that would RAISE the budget — must be ignored.
    record_from_headers(ctx, BUCKET_APP, [("X-RateLimit-Remaining", "1"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(_FAR_FUTURE))], epoch_s = 1.0)
    apply_budget_refresh(ctx, BUCKET_APP, 500)
    _eq("budget — refresh never raises", _budget(ctx), (100, 1))

    # A lower refresh shrinks the cap but keeps the spend counter.
    apply_budget_refresh(ctx, BUCKET_APP, 40)
    _eq("budget — refresh floors down, spend kept", _budget(ctx), (40, 1))

def _test_budget_refresh_seeds_when_unset(ctx):
    _reset(ctx)

    # With no budget set (none issued, or a window roll cleared it), a refresh
    # seeds the value rather than no-opping — so a fresh window's budget lands.
    apply_budget_refresh(ctx, BUCKET_APP, 50)
    _eq("budget — refresh seeds when unset", _budget(ctx), (50, 0))

def _test_budget_window_roll_reseeds(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 10)
    near = 1000
    for i in range(10):
        record_from_headers(ctx, BUCKET_APP, [("X-RateLimit-Remaining", "1"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(near))], epoch_s = float(i))
    _assert("budget — exhausted before roll", budget_exhausted(ctx, BUCKET_APP))

    # A window roll (`reset_epoch` jumps forward) clears the budget and zeroes
    # spend, so the task isn't stuck exhausted on the old window's allowance.
    # The roll observation is itself a call, so spend lands at 1 (it increments
    # after the roll reset within the same `record_from_headers`).
    record_from_headers(ctx, BUCKET_APP, [("X-RateLimit-Remaining", "5000"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(near + 4000))], epoch_s = 11.0)
    _eq("budget — roll clears the budget", _budget(ctx), (None, 1))
    _assert("budget — not exhausted after roll", not budget_exhausted(ctx, BUCKET_APP))

    # The next refresh seeds the fresh window's (larger) allowance.
    apply_budget_refresh(ctx, BUCKET_APP, 200)
    _eq("budget — fresh window allowance seeded", _budget(ctx), (200, 1))

def _test_budget_exhausted_shrink_below_spent(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 10)
    for i in range(5):
        record_from_headers(ctx, BUCKET_APP, [("X-RateLimit-Remaining", "1"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(_FAR_FUTURE))], epoch_s = float(i))
    _assert("budget — 5/10 not exhausted", not budget_exhausted(ctx, BUCKET_APP))

    # A refresh shrinks the cap below what's already spent → exhausted.
    apply_budget_refresh(ctx, BUCKET_APP, 4)
    _assert("budget — shrunk below spend → exhausted", budget_exhausted(ctx, BUCKET_APP))

def _test_budget_mint_resets_spend(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 2)
    record_from_headers(ctx, BUCKET_APP, [("X-RateLimit-Remaining", "1"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(_FAR_FUTURE))], epoch_s = 1.0)
    record_from_headers(ctx, BUCKET_APP, [("X-RateLimit-Remaining", "1"), ("X-RateLimit-Limit", "5000"), ("X-RateLimit-Reset", str(_FAR_FUTURE))], epoch_s = 2.0)
    _assert("budget — exhausted before re-mint", budget_exhausted(ctx, BUCKET_APP))

    # A fresh mint resets the spend counter against the new allowance.
    record_token_budget(ctx, BUCKET_APP, 50)
    _eq("budget — re-mint zeroes spend", _budget(ctx), (50, 0))
    _assert("budget — re-mint clears exhaustion", not budget_exhausted(ctx, BUCKET_APP))

def _test_budget_env_bucket_independent(ctx):
    _reset(ctx)
    record_token_budget(ctx, BUCKET_APP, 1)

    # Env-bucket spend must not exhaust the App budget (separate counters).
    record_from_headers(ctx, BUCKET_ENV, [("X-RateLimit-Remaining", "1"), ("X-RateLimit-Limit", "1000"), ("X-RateLimit-Reset", str(_FAR_FUTURE))], epoch_s = 1.0)
    _eq("budget — env spend isolated from app", _budget(ctx, BUCKET_APP)[1], 0)
    _assert("budget — app not exhausted by env spend", not budget_exhausted(ctx, BUCKET_APP))

def _test_impl(ctx):
    _test_record_basic(ctx)
    _test_record_buffer_truncation(ctx)
    _test_record_from_headers(ctx)
    _test_record_validation(ctx)
    _test_watermark_monotone_decreasing(ctx)
    _test_reset_crossing_flushes_buffer(ctx)
    _test_two_bucket_independence(ctx)
    _test_threshold_factor_ladder(ctx)
    _test_throttle_factor_floor(ctx)
    _test_throttle_factor_empty_state(ctx)
    _test_throttle_factor_exhausted(ctx)
    _test_throttle_factor_burn_rate_inference(ctx)
    _test_burn_rate_falls_back_on_degenerate_inputs(ctx)
    _test_threshold_warn_fires_once(ctx)
    _test_threshold_warn_direct_to_important(ctx)
    _test_threshold_warn_re_fires_after_reset(ctx)
    _test_reset_crossing_exact_boundary(ctx)
    _test_reset_crossing_rebaselines_watermark(ctx)
    _test_burn_rate_replenishment_returns_floor(ctx)
    _test_usage_footer(ctx)
    _test_time_throttle_factor_sliding_scale(ctx)
    _test_effective_throttle_factor_picks_larger(ctx)
    _test_effective_factor_records_to_trait(ctx)
    _test_usage_footer_renders_throttle_clause(ctx)
    _test_export_observations_round_trip(ctx)
    _test_ingest_sibling_observations(ctx)
    _test_merged_view_drives_throttle_factor(ctx)
    _test_merged_view_handles_flat_burn(ctx)
    _test_threshold_factor_scales_with_visible_swarm(ctx)
    _test_threshold_factor_swarm_scaling_skips_env_bucket(ctx)
    _test_cold_start_floor_off_ci(ctx)
    _test_cold_start_floor_on_ci_applies(ctx)
    _test_cold_start_floor_clears_when_buffer_dense(ctx)
    _test_cold_start_floor_does_not_lower_higher_pressure(ctx)
    _test_cold_start_floor_records_to_last_effective_factor(ctx)
    _test_cold_start_floor_re_engages_after_reset_crossing(ctx)
    _test_cold_start_phase_change_gate_off_ci(ctx)
    _test_cold_start_phase_change_gate_on_ci(ctx)
    _test_cold_start_phase_change_gate_uses_sibling_observations(ctx)
    _test_cold_start_phase_change_gate_invalid_bucket(ctx)
    _test_should_emit_phase_change_non_phase_emit(ctx)
    _test_should_emit_phase_change_outside_cold_start(ctx)
    _test_should_emit_phase_change_first_emit_passes(ctx)
    _test_should_emit_phase_change_within_debounce_suppresses(ctx)
    _test_should_emit_phase_change_after_debounce_emits(ctx)
    _test_should_emit_phase_change_scale_seconds(ctx)
    _test_budget_record_seeds_and_zeroes(ctx)
    _test_budget_zero_is_exhausted(ctx)
    _test_budget_spend_counts_per_call(ctx)
    _test_budget_counts_gitlab_headers(ctx)
    _test_budget_no_headers_no_spend(ctx)
    _test_budget_refresh_floors_down_only(ctx)
    _test_budget_refresh_seeds_when_unset(ctx)
    _test_budget_window_roll_reseeds(ctx)
    _test_budget_exhausted_shrink_below_spent(ctx)
    _test_budget_mint_resets_spend(ctx)
    _test_budget_env_bucket_independent(ctx)
    print("rate_limit.axl: OK (60 sections)")
    return 0

rate_limit_tests = task(
    kind = "test-rate-limit",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
    traits = [],
)
