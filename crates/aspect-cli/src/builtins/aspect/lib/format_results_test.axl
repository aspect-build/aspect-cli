"""Snapshot tests for `lib/format_results.axl` template rendering.

Run with:
  aspect dev test-format-template-snapshots

Scenarios:
  1. clean-passed        вЂ” no files need formatting
  2. files-need-format   вЂ” 3 files need formatting (scope=changed)
  3. scope-all-many      вЂ” 15 files need formatting (scope=all)
  4. severity-warn       вЂ” status=warning + drift; body must show files list
  5. formatter-error     вЂ” formatter binary crashed
  6. no-git              вЂ” no initial commit / not in git repo
  7. no-files-to-format  вЂ” scope=changed, no changed files found
  8. with-patch-url      вЂ” patch artifact uploaded; check run shows download link
  9. non-default-target  вЂ” custom formatter target label in repro command
 10. large               вЂ” 250 files to exercise the trim cascade
 11. in-progress         вЂ” status=running with affected_files (placeholder body)
 12. metadata-all        вЂ” GitHubStatusChecksTrait.metadata_keys = ["*"]
 13. applied             вЂ” formatter rewrote files (--severity=info path)
 14. early-fail          вЂ” status=failed, no specific failure mode (body says "Failed")
 15. aborted             вЂ” bazel aborted mid-build, no recorded affected files
 16. failing-with-drift  вЂ” status=failing (mid-stream --severity=fail): drift
                           detected, body must show files list (not placeholder)

Body-content invariant (asserted in the loop): the "Format task in progressвЂ¦"
placeholder renders IFF status == "running". A regression where `warning` or
`failing` short-circuits to the placeholder fails the suite.
"""

load("./format_results.axl", "init_data", "render_check_output")

# в”Ђв”Ђв”Ђ Fake-data builders в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

def _make_base():
    """Common metadata / runner info shared by all scenarios."""
    r = init_data()
    r["bazel"]["invocation_id"] = ""
    r["sink_invocation_id"] = ""
    r["start_time_ms"] = 1744630000000
    r["finish_time_ms"] = 1744630003200
    r["bazel"]["wall_time_ms"] = 3200
    r["bazel"]["workspace_status"] = {
        "BUILD_USER": "aspect-runner",
        "BUILD_HOST": "ip-10-0-86-10",
        "BUILD_TIMESTAMP": "1776727956",
    }
    r["bazel"]["metadata"] = {
        "BRANCH": "main",
        "BRANCH_NAME": "main",
        "COMMIT_SHA": "abc123def456789abcdef",
        "COMMIT_MESSAGE": "feat: add new auth flow",
        "COMMIT_AUTHOR": "Greg Magolan <greg@aspect.build>",
        "COMMIT_AUTHOR_NAME": "Greg Magolan",
        "COMMIT_AUTHOR_EMAIL": "greg@aspect.build",
        "COMMIT_TIMESTAMP": "2026-04-28 10:12:34 -0700",
        "USER": "Greg Magolan",
        "CI_HOST": "GITHUB",
        "VCS": "GITHUB",
        "REPO_OWNER": "aspect-build",
        "REPO_NAME": "silo",
        "BUILD_NUMBER": "12345",
        "RUN_TYPE": "PULL_REQUEST",
        "ASPECT_TASK_NAME": "Format",
        "ASPECT_TASK_ID": "format",
        "BUILD_URL": "https://github.com/aspect-build/silo/actions/runs/12345",
    }
    r["format"]["scope"] = "changed"
    r["format"]["formatter_target"] = "//tools/format"
    r["format"]["severity_resolved"] = "info"
    return r

def _make_clean():
    r = _make_base()
    r["changed_files_count"] = 18
    return r

def _make_files_need_format():
    r = _make_base()

    # changed_files_count is the input set the formatter saw (post-exclude-pattern);
    # affected_files is the post-format diff (what the formatter rewrote).
    # Both populated to exercise the Scope-with-count Configuration row.
    r["changed_files_count"] = 42
    r["format"]["affected_files"] = [
        "apps/web/src/auth/login.ts",
        "apps/web/src/utils/helpers.go",
        "tools/deploy/deploy.py",
    ]
    return r

def _make_scope_all_many():
    r = _make_base()
    r["format"]["scope"] = "all"
    r["format"]["affected_files"] = [
        "apps/web/src/auth/login.ts",
        "apps/web/src/auth/logout.ts",
        "apps/web/src/api/client.ts",
        "apps/web/src/api/types.ts",
        "apps/web/src/utils/helpers.go",
        "apps/web/src/utils/date.go",
        "tools/deploy/deploy.py",
        "tools/deploy/config.py",
        "tools/ci/validate.py",
        "tools/ci/report.py",
        "services/api/main.go",
        "services/api/handler.go",
        "services/api/middleware.go",
        "services/worker/main.go",
        "services/worker/queue.go",
    ]
    return r

def _make_severity_warn():
    r = _make_base()
    r["format"]["severity_resolved"] = "warn"
    r["format"]["affected_files"] = [
        "apps/web/src/auth/login.ts",
        "apps/api/handler.go",
    ]
    return r

def _make_applied():
    """`--severity=info` (or `auto` off CI) вЂ” formatter rewrote
    files, task exited 0. Title says "Formatted N file(s)"; body has
    no Fix section because the work has already been done locally."""
    r = _make_base()
    r["applied"] = True
    r["format"]["affected_files"] = [
        "apps/web/src/auth/login.ts",
        "apps/api/handler.go",
        "tools/deploy/deploy.py",
    ]
    return r

def _make_formatter_error():
    r = _make_base()
    r["format"]["formatter_error"] = True
    r["format"]["formatter_error_code"] = 2
    return r

def _make_early_fail():
    """Status `failed` with no specific failure mode recorded вЂ” the
    early-bail path in `_impl` when the formatter target's bootstrap
    build failed or `runnable.determine_entrypoint` couldn't resolve
    the entrypoint. Data dict carries no `affected_files`,
    `formatter_error`, `no_git`, or `no_files_to_format` so the
    renderer's fall-through branches would otherwise misleadingly
    show "Passed" / "All files are properly formatted."
    """
    return _make_base()

def _make_no_git():
    r = _make_base()
    r["format"]["no_git"] = True
    return r

def _make_no_files_to_format():
    r = _make_base()
    r["format"]["no_files_to_format"] = True
    return r

def _make_with_patch_url():
    r = _make_base()
    r["format"]["affected_files"] = [
        "apps/web/src/auth/login.ts",
        "tools/deploy/deploy.py",
    ]
    r["format"]["patch_url"] = "https://github.com/aspect-build/silo/actions/runs/12345/artifacts/999"
    return r

def _make_non_default_target():
    r = _make_base()
    r["format"]["formatter_target"] = "//tools/format:formatter_multirun"
    r["format"]["affected_files"] = ["services/api/main.go"]
    return r

def _make_large():
    """250 files to exercise the trim cascade."""
    r = _make_base()
    r["format"]["scope"] = "all"
    files = []
    for i in range(250):
        files.append("apps/generated/module_%d/handler.go" % i)
    r["format"]["affected_files"] = files
    return r

def _make_aborted():
    """Aborted-mid-build data: empty affected_files (paired with status=aborted)."""
    return _make_base()

def _make_failing_with_drift():
    """`--severity=fail` with mid-stream drift; `pick_task_status` returns "failing"."""
    r = _make_base()
    r["format"]["severity_resolved"] = "fail"
    r["format"]["affected_files"] = [
        "apps/web/src/auth/login.ts",
        "apps/api/handler.go",
    ]
    return r

# в”Ђв”Ђв”Ђ Test harness в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

def _render_ctx(task_name = "format"):
    return {
        "triggered_by": "Greg Magolan (pull_request)",
        "subject": "",
        "started_ms": 1744630000000,
        "ended_ms": 1744630003200,
        "progress": "",
        "task_name": task_name,
    }

def _links(ci = "github"):
    if ci == "buildkite":
        ci_label = "Buildkite"
        ci_url = "https://buildkite.com/aspect-build/silo/builds/12345/steps/canvas?sid=s1"
    else:
        ci_label = "GitHub Actions"
        ci_url = "https://github.com/aspect-build/silo/actions/runs/12345/job/99"
    return {
        "ci_label": ci_label,
        "ci_url": ci_url,
        "aspect_url": "",
        "results_base_url": "",
        "artifacts_browse_url": "",
        "artifact_urls": {},
        "testlogs_label_urls": {},
    }

def _test_impl(ctx):
    scenarios = [
        # (label,                             data,                        status,    ci,          metadata_keys)
        ("1. clean-passed В· GH", _make_clean(), "passed", "github", None),
        ("2. files-need-format В· GH", _make_files_need_format(), "failed", "github", None),
        ("3. scope-all-many В· BK", _make_scope_all_many(), "failed", "buildkite", None),
        ("4. severity-warn В· GH", _make_severity_warn(), "warning", "github", None),
        ("5. formatter-error В· GH", _make_formatter_error(), "failed", "github", None),
        ("6. no-git В· GH", _make_no_git(), "passed", "github", None),
        ("7. no-files-to-format В· GH", _make_no_files_to_format(), "passed", "github", None),
        ("8. with-patch-url В· GH", _make_with_patch_url(), "failed", "github", None),
        ("9. non-default-target В· GH", _make_non_default_target(), "failed", "github", None),
        ("10. large-trim В· GH", _make_large(), "failed", "github", None),
        ("11. in-progress В· GH", _make_files_need_format(), "running", "github", None),
        # Exercise GitHubStatusChecksTrait.metadata_keys through the shared summary renderer.
        ("12. files-need-format В· meta=*", _make_files_need_format(), "failed", "github", ["*"]),
        # `--severity=info` (or `auto` off-CI) вЂ” formatter rewrote
        # files and the task exited 0. Title and body should reflect
        # that the work has been applied (no "Fix" section, no failure
        # marker).
        ("13. applied В· GH", _make_applied(), "passed", "github", None),
        # Early-bail before the formatter ran (bootstrap-build failed or
        # entrypoint resolution failed). Title and body must say "Failed",
        # NOT "Passed" / "All files are properly formatted."
        ("14. early-fail В· GH", _make_early_fail(), "failed", "github", None),
        # Aborted-mid-build and drift-detected non-running statuses must
        # NOT fall through to "0 files need formatting" or the in-progress
        # placeholder.
        ("15. aborted В· GH", _make_aborted(), "aborted", "github", None),
        ("16. failing-with-drift В· GH", _make_failing_with_drift(), "failing", "github", None),
    ]

    sep = "=" * 70
    errors = []

    for (label, data, status, ci, metadata_keys) in scenarios:
        rc = _render_ctx()
        lk = _links(ci = ci)
        out = render_check_output(ctx, data, status, rc, lk, metadata_keys = metadata_keys)
        print(sep)
        print("SCENARIO: " + label)
        print(sep)
        print("TITLE:    " + out["title"])
        print("")
        print("SUMMARY:")
        print(out["summary"])
        print("")
        print("DETAILS (first 4000 chars):")
        print(out["text"][:4000])
        print("")

        # Invariant: "Format task in progressвЂ¦" placeholder renders IFF
        # status == "running".
        has_placeholder = "Format task in progress" in out["text"]
        if status == "running" and not has_placeholder:
            errors.append("%s: status=running but body has no in-progress placeholder" % label)
        if status != "running" and has_placeholder:
            errors.append("%s: status=%s rendered the in-progress placeholder" % (label, status))

    if errors:
        for e in errors:
            print("FAIL: " + e)
        fail("Body-content invariant violations: %d" % len(errors))

    print(sep)
    print("All " + str(len(scenarios)) + " format scenarios rendered without error.")
    return 0

format_template_snapshot_tests = task(
    name = "test-format-template-snapshots",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
