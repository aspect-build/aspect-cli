def _make_results_failed():
    """Build action failure + multiple test failures. Most common failure mode."""
    r = init_results()
    r["invocation_id"]     = "dead1234-beef-cafe-babe-123456789abc"
    r["build_tool_version"] = "9.0.1"
    r["build_command"]     = "test"
    r["wall_time_ms"]      = 45000
    r["cpu_time_ms"]       = 120000
    r["actions_executed"]  = 50
    r["actions_cached"]    = 80
    r["actions_total"]     = 130
    r["targets_total"]     = 80
    r["failed_actions_total"] = 2
    # One root target had both its compile and link fail — mnemonics list
    # captures both without duplicating the label entry.
    r["failed_actions"] = [{
        "label":     "//pkg/broken:lib",
        "mnemonics": ["CppCompile", "CppLink"],
    }]
    # Labels of targets whose own actions failed — used to classify derived failures.
    r["failed_action_labels"] = ["//pkg/broken:lib"]
    # failed_targets includes the root (//pkg/broken:lib) + three derived targets
    # whose build failed only because they depend on //pkg/broken:lib.
    r["failed_targets"] = [
        {"label": "//pkg/broken:lib"},                # root
        {"label": "//pkg/broken:bin"},                # derived
        {"label": "//pkg/consumer:service"},          # derived
        {"label": "//pkg/consumer:integration_test"}, # derived
    ]
    r["failed_test_total"] = 3
    r["failed_tests"] = [
        {"label": "//pkg/a:test", "cached": False, "duration_ms": 5000,  "status": "failed"},
        {"label": "//pkg/b:test", "cached": False, "duration_ms": 12000, "status": "timeout"},
        {"label": "//pkg/c:test", "cached": False, "duration_ms": 800,   "status": "failed"},
    ]
    r["passed_test_total"] = 21
    r["cached_test_total"] = 18
    r["executed_test_total"] = 3
    r["passed_tests"] = [
        {"label": "//pkg/d:test", "cached": True,  "duration_ms": 0},
        {"label": "//pkg/e:test", "cached": False, "duration_ms": 3200},
    ]
    r["workspace_status"] = {"BUILD_USER": "ci-bot", "BUILD_HOST": "runner-2"}
    # Pull request scenario — exercises the VCS/PR/branch/commit linking path.
    r["metadata"] = {
        "BRANCH":                "feature/new-api",
        "BRANCH_NAME":           "feature/new-api",
        "COMMIT_SHA":            "deadbeef12345678abcdef",
        "COMMIT_MESSAGE":        "wip: refactor compute() — BROKEN",
        "COMMIT_AUTHOR_NAME":    "Greg Magolan",
        "COMMIT_AUTHOR_EMAIL":   "greg@aspect.build",
        "VCS":                   "GITHUB",
        "REPO_OWNER":            "aspect-build",
        "REPO_NAME":             "silo",
        "RUN_TYPE":              "PULL_REQUEST",
        "PR_NUMBER":             "1102",
        "PR_ID":                 "1102",
        "PR_SOURCE_BRANCH_NAME": "feature/new-api",
        "PR_TARGET_BRANCH_NAME": "main",
    }
    r["build_repro"] = "bazel build //pkg/broken:lib"
    r["test_repro"]  = "bazel test //pkg/a:test //pkg/b:test //pkg/c:test"
    return r


