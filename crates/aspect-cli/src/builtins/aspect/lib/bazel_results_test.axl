    r["bazel"]["build_command"] = "build"
    r["bazel"]["wall_time_ms"] = 8500
    r["bazel"]["actions_executed"] = 12
    r["bazel"]["actions_cached"] = 30
    r["bazel"]["actions_total"] = 42
    r["bazel"]["targets_total"] = 20
    r["bazel"]["aborted"] = True
    r["bazel"]["abort_reason"] = "user_interrupt"
    r["bazel"]["abort_description"] = "Build interrupted by user"
    r["bazel"]["metadata"] = {"BRANCH": "main", "COMMIT_SHA": "aabbccdd11223344"}
    return r

def _make_results_large():
    """Large build: many targets and tests (tests the trim cascade in render_check_output)."""
    r = init_data()
    r["bazel"]["build_command"] = "test"
    r["bazel"]["wall_time_ms"] = 180000
    r["bazel"]["cpu_time_ms"] = 900000
    r["bazel"]["actions_executed"] = 500
    r["bazel"]["actions_cached"] = 2000
    r["bazel"]["actions_total"] = 2500
    r["bazel"]["targets_total"] = 600
    r["bazel"]["passed_test_total"] = 200
    r["bazel"]["cached_test_total"] = 180
    for i in range(200):
        r["bazel"]["passed_tests"].append({
            "label": "//generated/pkg_" + str(i) + ":test",
            "cached": i % 10 != 0,
            "duration_ms": (i % 5 + 1) * 1000,
        })
    r["bazel"]["failed_test_total"] = 2
    r["bazel"]["failed_tests"] = [
        {"label": "//generated/pkg_42:test", "cached": False, "duration_ms": 5000, "status": "failed"},
        {"label": "//generated/pkg_137:test", "cached": False, "duration_ms": 3000, "status": "failed"},
    ]
    for i in range(600):
        r["bazel"]["built_targets"].append({"label": "//generated/pkg_" + str(i // 3) + ":lib_" + str(i % 3)})
    r["bazel"]["options_parsed"] = {
        "explicit_cmd_line": ["--config=ci", "--keep_going"],
        "startup_options": ["--output_base=/tmp/bazel"],
        "cmd_line": [
            "--config=ci",
            "--keep_going",
            "--test_output=errors",
            "--bes_backend=grpcs://api.aspect.build",
            "--bes_results_url=https://app.aspect.build/invocations/",
            "--build_metadata=COMMIT_SHA=abc123",
            "--build_metadata=BRANCH=main",
        ],
    }
    r["bazel"]["metadata"] = {"BRANCH": "main"}
    return r

# ---------------------------------------------------------------------------
# Shared render context and links
# ---------------------------------------------------------------------------

def _render_ctx(targets = "//...", task_name = "test", progress = ""):
    return {
        "triggered_by": "ci-bot (workflow_dispatch)",
        "targets": targets,
        "started_ms": 1744630000000,
        "ended_ms": 1744630002200,
        "progress": progress,
        "task_name": task_name,
    }

def _links(with_artifact = False, ci = "github"):
    """Build a fake links dict for a snapshot scenario.

    ci: "github" | "buildkite" | "circleci" | "gitlab" — changes ci_label / ci_url.
    """
    if ci == "buildkite":
        ci_label = "Buildkite"
        ci_url = "https://buildkite.com/aspect-build/aspect-cli/builds/1354/steps/canvas?sid=s1"
        browse = "https://buildkite.com/aspect-build/aspect-cli/builds/1354/steps/canvas?sid=s1&tab=artifacts"
    elif ci == "circleci":
        ci_label = "CircleCI"
        ci_url = "https://circleci.com/gh/aspect-build/aspect-cli/9911"
        browse = "https://app.circleci.com/pipelines/github/aspect-build/aspect-cli/4406/workflows/78c35291-a904-4987-9444-54907e75291e/jobs/9911/artifacts"
    elif ci == "gitlab":
        ci_label = "GitLab CI"
        ci_url = "https://gitlab.com/aspect-build/aspect-cli/-/jobs/2469624812"

        # GitLab has no usable per-job browse URL for Generic Packages uploads;
        # _make_artifacts_browse_url returns "" for GitLab. Fixture matches.
        browse = ""
    else:
        ci_label = "GitHub Actions"
        ci_url = "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652/job/72239404829"
        browse = "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652"

    d = {
        "ci_label": ci_label,
        "ci_url": ci_url,
        # Typical live value: feature resolves
        # `WorkflowsEnvironment.build_events.results_url` +
        # `data["sink_invocation_id"]` into this field before rendering.
        "aspect_url": "https://app.aspect.build/invocations/sink-uuid-1234-5678-9abc",
        "results_base_url": "https://app.aspect.build/",
        "artifacts_browse_url": "",
        "artifact_urls": {},
        "testlogs_label_urls": {},
    }
    if with_artifact:
        d["artifacts_browse_url"] = browse
        if ci == "github":
            d["artifact_urls"] = {
                "testlogs": "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652/artifacts/6565661414",
                "profile": "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652/artifacts/6565661415",
            }
        elif ci == "gitlab":
            base = "https://gitlab.com/api/v4/projects/1/packages/generic"
            d["artifact_urls"] = {
                "testlogs": base + "/test.gl-test.testlogs-v1/2469624812/testlogs.tar.gz",
                "profile": base + "/test.gl-test.profile.gz/2469624812/profile.gz",
            }
        elif ci == "circleci":
            base = "https://output.circle-artifacts.com/output/job/bb66c8b1-b5d5-4aa5-87b7-d26c8a961ce8/artifacts/0/test/test-cci/testlogs"
            d["artifact_urls"] = {
                "testlogs": base + "/testlogs.tar.gz",
                "profile": "https://output.circle-artifacts.com/output/job/bb66c8b1-b5d5-4aa5-87b7-d26c8a961ce8/artifacts/0/test/test-cci/profile.gz",
            }

            # CircleCI uploads files individually, so each test label has direct
            # per-file URLs (test.log + test.xml). Populate the labels from both
            # _make_results_passed and _make_results_flaky so the snapshots under
            # `aspect-cli/crates/aspect-cli/src/builtins/aspect/lib/bazel_results_test.axl`
            # exercise the Artifacts column / [xml] bullet links.
            labels = [
                "//pkg/alpha:test",
                "//pkg/beta:test",
                "//pkg/gamma:test",
                "//pkg/delta:test",
                "//pkg/epsilon:test",
                "//flaky:timing_test",
                "//flaky:network_test",
                "//pkg/ok:unit_test",
                "//pkg/ok:e2e_test",
            ]
            per_label = {}
            for lbl in labels:
                label_path = lbl.lstrip("/").replace(":", "/")
                per_label[lbl] = {
                    "test.log": base + "/" + label_path + "/test.log",
                    "test.xml": base + "/" + label_path + "/test.xml",
                }
            d["testlogs_label_urls"] = per_label

        # Buildkite: URLs expire, so no per-kind URLs — just the browse page.
    return d

# ---------------------------------------------------------------------------
# Test task
# ---------------------------------------------------------------------------

def _test_impl(ctx):
    """Render each scenario and print TITLE + SUMMARY + first 3000 chars of DETAILS."""

    scenarios = [
        # (label, data, status, render_targets, use_artifact_link, ci, metadata_keys, progress)
        # metadata_keys exercises GitHubStatusChecksTrait.metadata_keys:
        #   None            → default (no extra_meta surfaced)
        #   ["*"]           → surface every non-standard metadata key
        #   ["K1", "K2"]    → surface only the named keys
        ("1. all-passed · GitHub", _make_results_passed(), "passed", "//...", True, "github", None, ""),
        ("2. failed · Buildkite", _make_results_failed(), "failed", "//...", True, "buildkite", None, ""),
        ("3. flaky · CircleCI", _make_results_flaky(), "passed", "//...", True, "circleci", None, ""),
        ("4. failing-live · GitLab", _make_results_failing_live(), "failing", "//...", False, "gitlab", None, ""),
        ("5. aborted · GitHub", _make_results_aborted(), "failed", "//...", False, "github", None, ""),
        ("6. large · Buildkite", _make_results_large(), "failed", "//...", False, "buildkite", None, ""),
        ("7. all-passed · GitLab", _make_results_passed(), "passed", "//...", True, "gitlab", None, ""),
        ("8. all-passed · CircleCI", _make_results_passed(), "passed", "//...", True, "circleci", None, ""),
        ("9. all-passed · Buildkite", _make_results_passed(), "passed", "//...", True, "buildkite", None, ""),
        # metadata_keys=["*"] — operator opts in to showing every non-standard BES
        # metadata key. TAG_ENV, TAG_REGION (from _make_results_passed.metadata)
        # should appear as extra_meta rows; standard keys stay in their slots.
        ("10. all-passed · GitHub · meta=*", _make_results_passed(), "passed", "//...", True, "github", ["*"], ""),
        # metadata_keys=["TAG_ENV", "TAG_REGION"] — operator allowlists specific
        # keys; TAG_ENV/TAG_REGION appear, WORKSPACE does not (not in list, not standard).
        ("11. all-passed · GitHub · meta=2", _make_results_passed(), "passed", "//...", True, "github", ["TAG_ENV", "TAG_REGION"], ""),
        # Incremental / fully-cached rebuild: build_metrics reports 0 newly
        # configured targets, but BES still sent 146 target_configured events.
        # The Build graph row should show "146 configured" via the counted
        # fallback, not "0 configured".
        ("12. fully-cached · GitHub", _make_results_fully_cached(), "passed", "//...", True, "github", None, ""),
        # Progress / "Last update" rendering. Running scenarios surface the
        # phase label below the metadata rows; terminal status suppresses it
        # so the title carries the outcome on its own.
        ("13. running · spawning · GitHub", _make_results_passed(), "running", "//...", False, "github", None, "Spawning bazel build..."),
        ("14. failing-live · GitLab · running", _make_results_failing_live(), "failing", "//...", False, "gitlab", None, "Spawning bazel build..."),
        # Terminal status with a stale progress field — the renderer
        # replaces it with "<Task> complete" on passed (so the row keeps
        # its visual rhythm across the running→passed transition) and
        # blanks it on failed (the failure title already says everything).
        ("15. passed · stale-progress · GH", _make_results_passed(), "passed", "//...", False, "github", None, "Spawning bazel build..."),
        # HTML escape — branch/commit_msg/tag/extra_meta with `<...>` tokens
        # render as escaped entities (`&lt;hr&gt;`) so BK/GHSC don't
        # interpret them as real HTML and break the metadata layout.
        ("16. html-chars-in-metadata · GH", _make_results_html_chars(), "passed", "//...", False, "github", ["*"], ""),
    ]

    sep = "=" * 70

    for (label, data, status, targets, with_artifact, ci, metadata_keys, progress) in scenarios:
        rc = _render_ctx(targets = targets, progress = progress)
        lk = _links(with_artifact = with_artifact, ci = ci)
        out = render_check_output(ctx, data, status, rc, lk, metadata_keys = metadata_keys)
        print(sep)
        print("SCENARIO: " + label)
        print(sep)
        print("TITLE:    " + out["title"])
        print("")
        print("SUMMARY:")
        print(out["summary"])
        print("")
        print("DETAILS (first 8000 chars):")
        print(out["text"][:8000])
        print("")

    print(sep)
    print("All " + str(len(scenarios)) + " scenarios rendered without error.")
    return 0

template_snapshot_tests = task(
    name = "test-template-snapshots",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
