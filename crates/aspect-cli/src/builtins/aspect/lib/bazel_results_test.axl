def _make_results_failing_live():
    """Mid-build state: some failures already recorded, build still running.

    This simulates the status check update emitted when process_event returns
    True for a failing test_summary while the build is still streaming events.
    """
    r = init_data()
    r["bazel"]["invocation_id"] = "11111111-2222-3333-4444-555555555555"
    r["bazel"]["build_tool_version"] = "9.0.1"
    r["bazel"]["build_command"] = "test"

    # wall_time_ms is 0 because build_metrics hasn't arrived yet
    r["bazel"]["wall_time_ms"] = 0
    r["bazel"]["actions_executed"] = 30
    r["bazel"]["actions_cached"] = 80
    r["bazel"]["actions_total"] = 110
    r["bazel"]["targets_total"] = 45
    r["bazel"]["failed_test_total"] = 1
    r["bazel"]["failed_tests"] = [
        {"label": "//pkg/slow:integration_test", "cached": False, "duration_ms": 14000, "status": "failed"},
    ]
    r["bazel"]["passed_test_total"] = 5
    r["bazel"]["cached_test_total"] = 5
    r["bazel"]["metadata"] = {"BRANCH": "main"}
    return r

def _make_results_fully_cached():
    """Incremental rebuild where build_metrics reports targets_configured = 0.

    Reproduces a real-world scenario seen in the field:
    https://github.com/aspect-build/aspect-cli/pull/1021/checks?check_run_id=73244967419

    Bazel reports `targets_configured = 0` in build_metrics when no targets
    needed re-analysis (everything resolved from skyframe / fully cached),
    but it still emits per-target `target_configured` BES events for every
    target in the request scope. The renderer must fall back to our own
    `targets_configured_counted` tally so the "Build graph" row shows the
    real target count instead of "0 configured".
    """
    r = init_data()
    r["bazel"]["invocation_id"] = "cache-1234-5678-9abc-def012345678"
    r["bazel"]["build_tool_version"] = "9.0.1"
    r["bazel"]["build_command"] = "build"
    r["bazel"]["wall_time_ms"] = 4200
    r["bazel"]["actions_executed"] = 1
    r["bazel"]["actions_total"] = 64604
    r["bazel"]["targets_total"] = 146

    # build_metrics reported 0 targets_configured (incremental rebuild) —
    # but BES streamed 146 target_configured events.
    r["bazel"]["targets_configured"] = 0
    r["bazel"]["targets_configured_counted"] = 146
    r["bazel"]["packages_loaded"] = 0
    r["bazel"]["metadata"] = {"BRANCH": "main"}
    return r

def _make_results_html_chars():
    """Branch / commit message containing HTML special characters.

    Exercises `html_escape` so the metadata row doesn't break when a
    user's commit message includes literal `<...>` tokens (e.g. a
    commit titled "use inline-styled <hr>") or when a branch name
    contains `&` / `<` / `>`. Without escaping the BK / GHSC renderer
    interprets `<hr>` as an actual horizontal rule and splits the
    metadata line.
    """
    r = init_data()
    r["bazel"]["invocation_id"] = "html123x-4567-89ab-cdef-012345678901"
    r["bazel"]["build_command"] = "build"
    r["bazel"]["wall_time_ms"] = 4500
    r["bazel"]["actions_executed"] = 240
    r["bazel"]["actions_total"] = 240
    r["bazel"]["targets_total"] = 120
    r["bazel"]["metadata"] = {
        "BRANCH_NAME": "feature/<sandbox>",
        "COMMIT_SHA": "abcdef1234567890",
        "COMMIT_MESSAGE": "fix(bk): use inline-styled <hr> for header/details divider",
        "TAG": "v1.0.0-beta<rc1>",
        "BUILD_USER": "<anonymous>",
        "BUILD_HOST": "<auto-runner>",
        "RUN_TYPE": "PULL_REQUEST",
        "USER": "<unknown>",
        "REPO_OWNER": "aspect-build",
        "REPO_NAME": "silo",
        "VCS": "GITHUB",
        "CI_HOST": "BUILDKITE",
        "EXTRA_HTML": "value with <tag> & ampersand",
    }
    return r

