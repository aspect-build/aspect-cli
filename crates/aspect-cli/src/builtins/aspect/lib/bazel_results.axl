"""

# Build/test detail template: bazel-aborted prelude, the hoisted
# Bazel targets section as the primary slot, then SHARED (which
# skips its own Bazel targets block thanks to
# `include_bazel_targets = False` set in details_data for these tasks).
DETAILS_TEMPLATE = """{% if aborted %}
> :warning: **Build aborted**{% if abort_reason %} (`{{ abort_reason }}`){% endif %}{% if abort_description %}: {{ abort_description }}{% endif %}

{% endif %}
""" + BAZEL_TARGETS_TEMPLATE + SHARED_DETAILS_BODY_TEMPLATE

def build_summary_data(ctx, data, status, render_ctx, links, metadata_keys, run_date = "", config_items = None, complete_suffix = ""):
    """Build Jinja2 template data for SUMMARY_TEMPLATE.

    render_ctx keys (all provided by the feature, not derived from BES):
      triggered_by: str  — who/what started this build (e.g. "greg (workflow_dispatch)")
      targets:      str  — target pattern string (e.g. "//...")
      started_ms:   int  — task start time in ms since epoch
      ended_ms:     int  — task end time (0 if still running)
      progress:     str  — last free-text progress message from task_update.progress

    `config_items` is a list of `{"key": str, "value": str}` dicts the
    per-kind renderer wants to surface as a configuration row directly
    below "Last update" — e.g. lint's Strategy, delivery's Mode. Tasks
    with nothing notable to surface (build/test) pass `None` (or omit)
    and the row is skipped entirely. Pulled up out of the per-kind
    details bodies because key configuration knobs are something a
    reviewer should see at-a-glance rather than buried in a collapsed
    detail block.

    `complete_suffix` is an optional decoration appended to the
    terminal "<Task> complete" Last-update line on a passed status —
    e.g. "checked 42 files" so format renders "Format complete · 42
    files checked". Renders as " · <suffix>" when set; ignored on
    non-passed status (the failure title already says everything).
    """

    # "Last update" — terminal-status handling:
    #   passed/warning → "<task_name> complete" (the title carries the
    #            outcome; this keeps the row's visual rhythm across
    #            running→passed instead of disappearing it).
    #   failed → preserve the last in-flight progress. The progress
    #            field tells reviewers *where* the failure happened —
    #            triage info that should stay visible.
    if status in ("running", "failing", "failed"):
        last_update = render_ctx.get("progress", "") or ""
    elif status in ("passed", "warning"):
        name = render_ctx.get("task_name", "") or "task"

        # "<name> task complete" rather than "<name> complete":
        # "test complete" reads as "the test passed" (singular) when
        # there may have been hundreds of tests; "test task complete"
        # reads as "the test task is finished", which is what we
        # actually mean. Same shape across all kinds: build / test /
        # lint / format / gazelle / delivery task complete.
        #
        # `warning` joins `passed` here: it's a terminal status with a
        # non-fatal signal (e.g. a lint task with warning-only findings,
        # a test task with flake-only failures). The verdict cell at
        # the top of the summary already renders the warning badge —
        # leaving Last update blank made it look like the row had been
        # truncated mid-way. Show "<name> task complete" + an optional
        # severity suffix.
        last_update = name + " task complete"
        if complete_suffix:
            last_update = last_update + " · " + complete_suffix
    elif status == "aborted":
        name = render_ctx.get("task_name", "") or "task"
        last_update = name + " task aborted"
    else:
        last_update = ""

    meta = data["bazel"].get("metadata", {})
    sha = meta.get("COMMIT_SHA", "")
    commit_msg = meta.get("COMMIT_MESSAGE", "")
    if len(commit_msg) > 72:
        commit_msg = commit_msg[:72] + "…"

    # Escape user-controlled metadata values flowing into the rendered
    # markdown — see the comment on `html_escape`. The `key` is also
    # user-controlled (custom `--build_metadata=KEY=value`) so escape
    # both halves.
    extra_meta = []
    keys = metadata_keys or []
    show_all = keys == ["*"]
    for k, v in meta.items():
        if k in RENDER_META_STANDARD_KEYS:
            continue

        # `TAGS` and `TAG_*` already render as 🏷 chips via `parse_tags`;
        # skip here so 📌 doesn't duplicate them.
        if k == "TAGS" or k.startswith("TAG_"):
            continue
        if show_all or k in keys:
            extra_meta.append({"key": html_escape(k), "value": html_escape(v)})

    return {
        "last_update": last_update,
        "config_items": config_items or [],
        "target_pattern": render_ctx.get("targets", "") if render_ctx else "",
        "branch": html_escape(meta.get("BRANCH_NAME", "")),
        "tag": html_escape(meta.get("TAG", "")),
        "short_sha": sha[:7] if sha else "",
        "commit_msg": html_escape(commit_msg),
        "detail_rows": build_invocation_rows(ctx, data, render_ctx, status, links = links, run_date = run_date, extra_meta = extra_meta),
    }

def build_kv_rows(kv):
    """Convert a key->value dict into [{key, value}] rows with empty values skipped.

    Keys are sorted alphabetically for stable rendering. Values are coerced to
    strings. Rows whose value is empty after coercion are dropped entirely so
    the template never renders blank metadata lines.
    """
    if not kv:
        return []
    out = []
    for key in sorted(kv.keys()):
        val = kv[key]
        if val == None:
            continue
        s = str(val) if type(val) != "string" else val
        if s:
            out.append({"key": key, "value": s})
    return out

def build_invocation_detail_rows(data, start_date, finish_date):
    """Build [{key, value}] rows for the Invocation section.

    Skips empty values so the template never renders rows like
    "**Server PID:** 0" or "**End time:** ".
    """
    rows = []

    def _maybe_add(key, value):
        if value:
            rows.append({"key": key, "value": str(value)})

    _maybe_add("Invocation ID", data["bazel"].get("invocation_id", ""))
    _maybe_add("Command", data["bazel"].get("build_command", ""))
    _maybe_add("Bazel version", data["bazel"].get("build_tool_version", ""))
    _maybe_add("Start time", start_date)
    _maybe_add("End time", finish_date)

    # BUILD_USER / BUILD_HOST come from the workspace_status script (local
    # username + machine hostname). Separate from the "user" shown in the
    # summary row, which prefers commit author — these are about *who/where
    # the build physically ran*, not who wrote the commit.
    ws = data["bazel"].get("workspace_status", {}) or {}
    _maybe_add("User", ws.get("BUILD_USER", ""))
    _maybe_add("Host name", ws.get("BUILD_HOST", ""))
    _maybe_add("CPU Target", data["bazel"].get("cpu_arch", ""))
    _maybe_add("Mode", data["bazel"].get("compilation_mode", ""))
    _maybe_add("Working directory", data["bazel"].get("working_directory", ""))
    _maybe_add("Workspace directory", data["bazel"].get("workspace_directory", ""))
    pid = data["bazel"].get("server_pid", 0)
    if pid and pid > 0:
        rows.append({"key": "Server PID", "value": str(pid)})
    return rows

def _remote_cache_hit_count(data):
    """Count of actions Bazel reports as `remote cache hit` runner.

    These are tallied as `actions_executed` by Bazel, but they didn't
    actually execute — they were fetched from the remote cache. The
    cache-rate display reclassifies them as cached so users see the
    real cache hit rate.

    `runner_counts` keys are `<runner_name> · <exec_kind>` (or
    `<runner_name>` if exec_kind is empty); see the build_metrics
    handler in `process_event`. Bazel's runner_name for remote cache
    hits is `remote cache hit`.
    """
    rc = data["bazel"].get("runner_counts", {}) or {}
    total = 0
    for key, count in rc.items():
        if key == "remote cache hit" or key.startswith("remote cache hit · "):
            total += count
    return total

def _effective_action_cache_counts(data):
    """Return (executed, cached, total) for the cache-rate display.

    Reclassifies `remote cache hit` runner counts as cached and caps
    cached at total in case the upstream counters are inconsistent.

    When `actions_total` is 0 (incremental rebuild where build_metrics
    reports a partial picture — e.g. one workspace-status action emits
    `actions_executed=1` but no `actions_created`), preserve the raw
    executed count so callers that fall back to "X action(s)" without
    a "(N created)" parenthetical still render meaningfully.
    """
    total = data["bazel"].get("actions_total", 0) or 0
    executed_raw = data["bazel"].get("actions_executed", 0) or 0
    if total <= 0:
        return (executed_raw, 0, 0)
    cached_raw = total - executed_raw if total > executed_raw else 0
    cached = cached_raw + _remote_cache_hit_count(data)
    if cached > total:
        cached = total
    executed = total - cached
    return (executed, cached, total)

def _cache_actions_line(data):
    """Return 'N of M cached (P%)' for actions, or '' when no actions."""
    _executed, cached, total = _effective_action_cache_counts(data)
    if total <= 0:
        return ""
    pct = (cached * 100) // total
    return format_int_comma(cached) + " of " + format_int_comma(total) + " cached (" + str(pct) + "%)"

def _cache_tests_line(data):
    """Return 'N of M cached (P%)' for tests, or '' when no tests ran."""
    pass_t = data["bazel"].get("passed_test_total", 0) or 0
    fail_t = data["bazel"].get("failed_test_total", 0) or 0
    flaky_t = data["bazel"].get("flaky_test_total", 0) or 0
    total = pass_t + fail_t + flaky_t
    if total <= 0:
        return ""
    cached = data["bazel"].get("cached_test_total", 0) or 0
    pct = (cached * 100) // total
    return format_int_comma(cached) + " of " + format_int_comma(total) + " cached (" + str(pct) + "%)"

def archive_bazel_attempt(data, human_attempt, exit_code):
    """Append a snapshot of the current `data["bazel"]` plus
    `data["sink_invocation_id"]` to `data["bazel_attempts"]` under the
    given 1-indexed attempt number, and return the updated list.

    Used by retry-loop callers (`bazel_runner.run_bazel_task` and
    `delivery._get_output_shas`) to preserve per-attempt state for
    the `🔁 Retry attempts` body section. The snapshot holds the
    `bazel` sub-dict by reference, so the caller MUST swap
    `data["bazel"]` for a fresh dict before the next iteration's BES
    events mutate it.
    """
    attempts = list(data.get("bazel_attempts", []) or [])
    attempts.append({
        "attempt": human_attempt,
        "exit_code": exit_code,
        "sink_invocation_id": data.get("sink_invocation_id", "") or "",
        "bazel": data["bazel"],
    })
    data["bazel_attempts"] = attempts
    return attempts

def _build_retry_attempt_rows(data, links):
    """Build per-attempt rows for the `🔁 Retry attempts` body section.

    Returns `[]` when no retries occurred (the common single-attempt
    path) — the template skips the section in that case.

    Each row: `{attempt, outcome, aspect_url}`. Attempt is the
    1-indexed human number, outcome is `"passed"` or `"failed"`,
    aspect_url resolves the per-attempt sink_invocation_id against
    `links.results_base_url` (empty string when no sink was
    configured, so the template suppresses the link).
    """
    attempts = data.get("bazel_attempts", []) or []
    if not attempts:
        return []
    base = (links or {}).get("results_base_url", "") if links else ""
    rows = []
    for a in attempts:
        sink_id = a.get("sink_invocation_id", "") or ""
        if base and sink_id:
            url = (base if base.endswith("/") else base + "/") + sink_id
        else:
            url = ""
        rows.append({
            "attempt": a.get("attempt", 0),
            "outcome": "passed" if a.get("exit_code", 1) == 0 else "failed",
            "aspect_url": url,
        })
    return rows

def _build_invocation_stats(data):
    """Build the Performance section payload for the template.

    Returns None when there's nothing meaningful to render (pre-build_metrics
    state); the template skips the section entirely in that case.
    """
    wall_ms = data["bazel"].get("wall_time_ms", 0) or 0
    server_cpu_ms = data["bazel"].get("cpu_time_ms", 0) or 0
    analysis_ms = data["bazel"].get("analysis_phase_time_ms", 0) or 0
    execution_ms = data["bazel"].get("execution_phase_time_ms", 0) or 0
    critical_ms = data["bazel"].get("critical_path_ms", 0) or 0
    cached_tests_ms = data["bazel"].get("cached_duration_ms", 0) or 0
    executed_tests_ms = data["bazel"].get("executed_duration_ms", 0) or 0

    actions_executed = data["bazel"].get("actions_executed", 0) or 0
    actions_created = data["bazel"].get("actions_total", 0) or 0

    targets_completed = data["bazel"].get("targets_total", 0) or 0
    targets_configured = data["bazel"].get("targets_configured", 0) or 0

    # Fall back to our own target_configured BES-event tally when build_metrics
    # reports zero. Bazel reports `targets_configured = 0` on cached / incremental
    # builds where no targets needed re-analysis, but it still emits per-target
    # `target_configured` events for everything in scope — so the counted tally
    # stays accurate even when the metrics path is empty.
    if targets_configured == 0:
        targets_configured = data["bazel"].get("targets_configured_counted", 0) or 0

    # Bazel's targets_configured includes aspect applications. The separate
    # "_not_including_aspects" variant lets us split "X configured, Y aspects".
    # Only compute the split when both fields are populated — a 0 in the
    # "_not_including_aspects" slot means Bazel didn't emit it (older version
    # or incremental run), NOT that there are 0 rule targets.
    targets_conf_plain = data["bazel"].get("targets_configured_not_including_aspects", 0) or 0
    aspect_applications = 0
    if targets_conf_plain > 0 and targets_configured > targets_conf_plain:
        aspect_applications = targets_configured - targets_conf_plain
    packages_loaded = data["bazel"].get("packages_loaded", 0) or 0

    cache_stats = data["bazel"].get("action_cache_stats", {}) or {}
    local_hits = cache_stats.get("hits", 0) or 0
    local_misses = cache_stats.get("misses", 0) or 0

    action_mnemonics = data["bazel"].get("action_mnemonics", {}) or {}
    mnemonic_pre = _render_counter_pre(action_mnemonics, "Mnemonic")

    runner_counts = data["bazel"].get("runner_counts", {}) or {}
    runner_pre = _render_counter_pre(runner_counts, "Runner")

    # Miss reasons: convert [{reason, count}, ...] to a counter for shared renderer.
    miss_details = cache_stats.get("miss_details", []) or []
    miss_counter = {}
    for md in miss_details:
        r = md.get("reason", "")
        c = md.get("count", 0) or 0
        if r and c > 0:
            miss_counter[r] = c
    miss_reasons_pre = _render_counter_pre(miss_counter, "Reason", name_display = _miss_reason_display)

    if (wall_ms == 0 and server_cpu_ms == 0 and analysis_ms == 0 and execution_ms == 0 and
        critical_ms == 0 and cached_tests_ms == 0 and executed_tests_ms == 0 and
        actions_created == 0 and actions_executed == 0 and
        targets_configured == 0 and targets_completed == 0 and
        packages_loaded == 0 and local_hits == 0 and local_misses == 0 and
        not mnemonic_pre and not runner_pre and not miss_reasons_pre):
        return None

    # Mirror Bazel's CLI wording:
    #   Analyzed 141 targets (735 packages loaded, 134094 targets configured, 133 aspect applications)
    # On incremental rebuilds Bazel reports zeros but still names the fields —
    # we do the same so the reader has a clear baseline ("nothing re-analyzed").
    targets_line = ""
    if targets_completed > 0 or targets_configured > 0:
        parts = []
        if targets_configured > 0 or targets_completed > 0:
            # Show configured count parenthetical when it was actually populated
            # *this* invocation. When it's zero on an incremental rebuild the
            # "(0 configured)" is informative — matches Bazel's own output.
            count_cfg = targets_conf_plain if targets_conf_plain > 0 else targets_configured
            parts.append(format_int_comma(count_cfg) + " configured")
            if aspect_applications > 0:
                parts.append(pluralize(aspect_applications, "aspect application"))
        if targets_completed > 0:
            base = pluralize(targets_completed, "target")
        else:
            base = pluralize(targets_configured, "target")
        targets_line = base + (" (" + ", ".join(parts) + ")" if parts else "")

    # Reclassify remote cache hits as cached so the `actions_line` and
    # `cache_actions_line` stay consistent with each other (otherwise
    # "X actions" wouldn't equal "total - cached" and the reader has to
    # do mental math to reconcile them).
    actions_line = ""
    if actions_executed > 0 or actions_created > 0:
        actions_executed_eff, _cached_eff, _total_eff = _effective_action_cache_counts(data)
        base = pluralize(actions_executed_eff, "action")
        if actions_created > 0 and actions_created != actions_executed_eff:
            actions_line = base + " (" + format_int_comma(actions_created) + " created)"
        else:
            actions_line = base

    packages_line = ""
    if packages_loaded >= 0 and (packages_loaded > 0 or targets_completed > 0):
        # Show even when 0 on incremental — matches Bazel's CLI and makes the
        # "fully incremental" state obvious.
        packages_line = pluralize(packages_loaded, "package") + " loaded"

    return {
        # Timing subsection
        "analysis_time": format_duration_ms(analysis_ms) if analysis_ms > 0 else "",
        "execution_time": format_duration_ms(execution_ms) if execution_ms > 0 else "",
        "elapsed_time": format_duration_ms(wall_ms) if wall_ms > 0 else "",
        "critical_path": format_duration_ms(critical_ms) if critical_ms > 0 else "",
        "bazel_server_time": _format_cpu_seconds(server_cpu_ms) if server_cpu_ms > 0 else "",
        "executed_tests_time": _format_cpu_seconds(executed_tests_ms) if executed_tests_ms > 0 else "",
        "cached_tests_time_saved": _format_cpu_seconds(cached_tests_ms) if cached_tests_ms > 0 else "",

        # Bazel-style one-liners matching `Analyzed N targets (… packages loaded, …)`.
        "targets_line": targets_line,
        "actions_line": actions_line,
        "packages_line": packages_line,

        # Cache stats — absolute counts + percentages for actions and tests.
        # Duplicates values that already appear in the metadata summary row;
        # repeated here so the Build metrics section is self-contained for
        # users drilling into it.
        "cache_actions_line": _cache_actions_line(data),
        "cache_tests_line": _cache_tests_line(data),

        # Local action cache.
        "local_cache_hits": format_int_comma(local_hits) if local_hits > 0 else "",
        "local_cache_misses": format_int_comma(local_misses) if local_misses > 0 else "",

        # Distribution tables (unchanged).
        "mnemonic_table": mnemonic_pre,
        "mnemonic_count": len(action_mnemonics),
        "runner_table": runner_pre,
        "runner_count": len(runner_counts),
        "miss_reasons_table": miss_reasons_pre,
    }

def build_details_data(data, links, render_ctx = None, status = "", start_date = "", finish_date = "", std = None, task_phases = None, task_active = None, task_elapsed_ms = 0, include_bazel_targets = True, render_repro_in_targets = False):
    """Build Jinja2 template data for DETAILS_TEMPLATE.

    start_date / finish_date are pre-formatted human-readable strings from the
    caller (render_check_output formats them via format_run_date, which shells
    out to `date` and therefore needs ctx which we don't have here).

    Args:
      task_phases:           `list[TaskPhase]` from `ctx.task.phases()`
                             — closed phases only. Empty when the task
                             didn't open any phase.
      task_active:           the currently-active `TaskPhase` (or None
                             when no phase is open). The active phase
                             appears as the trailing row in the Task
                             timing table with a status-aware verb in
                             the Description column.
      task_elapsed_ms:       int — `ctx.task.elapsed_ms` at render time.
                             Used as the Total row of Task timing so
                             header + body show the same number.
      include_bazel_targets: True for non-bazel tasks (Bazel targets is
                             part of the bazel-context group); False for
                             build/test (Bazel targets is hoisted into
                             the primary slot ahead of SHARED).
      render_repro_in_targets: True for build/test (the Bazel targets
                             section is the primary actionable slot, so
                             the Reproduce/Fix snippets render at its
                             top). False for non-bazel tasks — those
                             render their own Reproduce/Fix sections
                             higher in the body via their per-task
                             template.
    """

    # Command-line views: derived from options_parsed, not structured_command_line.
    # ALLOW_ENV comes from --build_metadata=ALLOW_ENV=pattern,pattern (defaults
    # applied when not set). See _redact_arg for the redaction rules.
    allow_env = _allow_env_patterns(data["bazel"].get("metadata", {}))
    opts_parsed = data["bazel"].get("options_parsed", {}) or {}
    target_pattern_for_cmd = (render_ctx or {}).get("targets", "") if render_ctx else ""
    _explicit_cmd = _assemble_explicit_command(
        data["bazel"].get("build_command", ""),
        target_pattern_for_cmd,
        opts_parsed.get("explicit_cmd_line", []),
        allow_env,
    )
    _startup_opts_redacted = _sorted_dedup(opts_parsed.get("startup_options", []), allow_env)
    _cmd_line_redacted = _sorted_dedup(opts_parsed.get("cmd_line", []), allow_env)

    target_kinds_map = data["bazel"].get("target_kinds") or {}

    def _prep_action(a):
        """Pre-process a failed build action for Jinja2 rendering.

        Adds `kind` from target_kinds map, pre-joins the mnemonics list, and
        truncates the label for bounded-width display.
        """
        entry = dict(a)
        mnemonics = a.get("mnemonics", []) or []
        entry["mnemonics_joined"] = ", ".join(mnemonics)
        original_label = a.get("label", "")
        entry["kind"] = target_kinds_map.get(original_label, "")
        entry["label"] = _truncate_label(original_label)
        return entry

    testlogs_label_urls = links.get("testlogs_label_urls", {})
    artifact_urls = links.get("artifact_urls", {}) or {}

    # Per-artifact-kind download links, stable ordering. Each link is
    # only rendered when the URL is actually populated in
    # `ArtifactsTrait.artifact_urls`, so kinds the current task didn't
    # produce are silently omitted. The format/gazelle/lint patch
    # entries here mirror the keys written by `feature/artifacts.axl`
    # ("testlogs"/"profile"/"execlog"/"bep") and the in-task patch
    # uploaders (`format.axl::_try_upload_format_diff` and the gazelle
    # equivalent), which write `format_diff` / `gazelle_diff`.
    artifact_links = []
    for kind, alabel in [
        ("testlogs", "Test logs"),
        ("profile", "Profile"),
        ("execlog", "Execlog"),
        ("bep", "BEP"),
        ("format_diff", "Format Patch"),
        ("gazelle_diff", "Gazelle Patch"),
        ("lint_diff", "Lint Patch"),
    ]:
        u = artifact_urls.get(kind, "")
        if u:
            artifact_links.append({"label": alabel, "url": u})

    def _with_duration(tests):
        """Add formatted duration, per-file artifact URLs, and kind to each test.

        Performs file-URL / kind lookups against the ORIGINAL label, then
        overwrites `entry["label"]` with the truncated display form so the
        rest of the render pipeline shows a bounded-width label.

        Per-file URLs are only populated on CIs that upload individual files
        (CircleCI); on tar-based CIs `log_url` / `xml_url` stay empty and the
        table simply omits the Artifacts column.
        """
        out = []
        for t in tests:
            entry = dict(t)
            ms = t.get("duration_ms", 0)
            entry["duration"] = format_duration_ms(ms) if ms > 0 else ""
            original_label = t.get("label", "")
            file_urls = testlogs_label_urls.get(original_label, {}) or {}
            entry["log_url"] = file_urls.get("test.log", "")
            entry["xml_url"] = file_urls.get("test.xml", "")

            # Backfill kind from the map if the test entry was built by a
            # fixture that didn't include it.
            if not entry.get("kind"):
                entry["kind"] = target_kinds_map.get(original_label, "")
            entry["label"] = _truncate_label(original_label)
            out.append(entry)
        return out

    # --- Bucketize tests by status ---
    # failed_tests is one list in data — split by .status into TEST_FAILED,
    # TEST_TIMEOUT, and FAILED_TO_BUILD (test-level, distinct from failed_actions
    # which are action-level build failures).
    raw_failed = data["bazel"].get("failed_tests", [])
    failed_by_status = {"failed": [], "timeout": [], "failed_to_build": []}
    for t in raw_failed:
        s = t.get("status", "failed")
        if s in failed_by_status:
            failed_by_status[s].append(t)
        else:
            failed_by_status["failed"].append(t)

    # passed_tests carries a .cached flag — split into cached vs executed.
    # Aggregate counts (passed_test_total, cached_test_total) are authoritative,
    # so only populate a bucket list when its aggregate count is non-zero —
    # otherwise a mismatched sample entry could render a "0 Tests Passed" header.
    raw_passed = sorted(data["bazel"].get("passed_tests", []), key = lambda t: t.get("label", ""))
    _has_executed = data["bazel"].get("passed_test_total", 0) > data["bazel"].get("cached_test_total", 0)
    _has_cached = data["bazel"].get("cached_test_total", 0) > 0
    passed_executed = [t for t in raw_passed if not t.get("cached")] if _has_executed else []
    passed_cached = [t for t in raw_passed if t.get("cached")] if _has_cached else []

    # Exclude test targets from built_targets so the SUCCESSFUL_BUILD bucket is
    # "targets that successfully built but were not tests".
    # Primary signal: rule kind ends in `_test` (populated by target_configured).
    # Fallback: for test fixtures without kinds, use labels from detail lists.
    test_labels_fallback = {}
    for t in (data["bazel"].get("passed_tests", []) + data["bazel"].get("flaky_tests", []) + raw_failed):
        lbl = t.get("label", "")
        if lbl:
            test_labels_fallback[lbl] = True

    def _is_test_entry(t):
        if _is_test_kind(t.get("kind", "")):
            return True

        # Kind missing (test fixture or target_configured event absent) — check label set.
        return t.get("label", "") in test_labels_fallback

    # Sort on the full label before truncating so ordering stays stable even
    # when multiple long labels share the same truncated prefix.
    built_non_test = [
        {"label": _truncate_label(t.get("label", "")), "kind": t.get("kind", "")}
        for t in sorted(
            [t for t in data["bazel"].get("built_targets", []) if not _is_test_entry(t)],
            key = lambda t: t.get("label", ""),
        )
    ]

    # --- Partition failed_targets into root (own action failed) vs derived
    # (no own action failed — some dep broke). Surfaces the same "Broken by"
    # UX as the Aspect Web UI without requiring the full rdeps graph.
    failed_action_labels_set = {l: True for l in _failed_action_labels(data)}

    # Sort on the full label before truncating.
    derived_failures = [
        {"label": _truncate_label(t["label"]), "kind": t.get("kind", "")}
        for t in sorted(
            [
                {"label": t.get("label", ""), "kind": t.get("kind", "")}
                for t in data["bazel"].get("failed_targets", [])
                if t.get("label", "") and t.get("label", "") not in failed_action_labels_set
            ],
            key = lambda t: t["label"],
        )
    ]

    # Cap derived failure list at the same limit we use for built_targets so
    # pathological cases (thousands of cascade failures) don't blow details_text.
    derived_failures_count = len(derived_failures)
    if len(derived_failures) > MAX_BUILT_TARGETS:
        derived_failures = derived_failures[:MAX_BUILT_TARGETS]

    # --- Bucket counts ---
    bucket_counts = _compute_bucket_counts(data)
    build_failure_count = bucket_counts.get(_BUCKET_FAILED_TO_BUILD, 0)
    failed_test_count = len(failed_by_status["failed"])
    timeout_test_count = len(failed_by_status["timeout"])
    flaky_test_count = data["bazel"].get("flaky_test_total", 0)
    passed_test_count = data["bazel"].get("passed_test_total", 0) - data["bazel"].get("cached_test_total", 0)
    if passed_test_count < 0:
        passed_test_count = 0
    cached_test_count = data["bazel"].get("cached_test_total", 0)
    built_non_test_count = bucket_counts.get(_BUCKET_SUCCESSFUL_BUILD, 0)

    # --- Overflow detection for trim cascade ---
    # failed_actions is now per-label (deduped); overflow = total unique failing
    # labels minus what fit in the capped list.
    failed_actions_overflow = len(_failed_action_labels(data)) - len(data["bazel"].get("failed_actions", []))
    passed_overflow = data["bazel"].get("passed_test_total", 0) - len(raw_passed)
    built_overflow = built_non_test_count - len(built_non_test)
    derived_failures_overflow = derived_failures_count - len(derived_failures)

    # --- Build column-aligned tables for <pre> sections ---
    _passed_table = _align_for_pre(_with_duration(passed_executed), has_duration = True)
    _cached_table = _align_for_pre(_with_duration(passed_cached), has_duration = True)
    _built_table = _align_for_pre(built_non_test, has_duration = False)
    _derived_table = _align_for_pre(derived_failures, has_duration = False)

    # Failed / timeout / flaky test buckets render as aligned tables
    # too — same `Label | Target Type | Duration` shape passed/cached
    # tests use, plus an Artifacts column when per-file URLs exist.
    # Consistency across every target / test bucket in the section.
    _failed_table = _align_for_pre(_with_duration(failed_by_status["failed"]), has_duration = True)
    _timeout_table = _align_for_pre(_with_duration(failed_by_status["timeout"]), has_duration = True)
    _flaky_table = _align_for_pre(_with_duration(data["bazel"].get("flaky_tests", [])), has_duration = True)

    # Build the failures table: Label | Target Type | Mnemonic. Each
    # row is { label (truncated), kind (from target_kinds), mnemonic
    # (comma-joined when an action failed multiple actions on the
    # same target — usually a single value like "Rustc" / "CppCompile").
    _build_failures_for_table = []
    for a in data["bazel"].get("failed_actions", []):
        original_label = a.get("label", "")
        mnemonics = a.get("mnemonics", []) or []
        _build_failures_for_table.append({
            "label": _truncate_label(original_label),
            "kind": target_kinds_map.get(original_label, ""),
            "mnemonic": ", ".join(mnemonics),
        })
    _build_failures_table = _align_for_pre(
        _build_failures_for_table,
        has_duration = False,
        has_mnemonic = True,
    )

    # --- Task timing table: aligned <pre> shape (Phase | Description | Duration). ---
    _task_timing_rows_data = _build_task_timing_rows(task_phases, task_active, status)
    _task_timing_total_str = format_duration_ms(task_elapsed_ms) if task_elapsed_ms > 0 else ""
    _task_timing_table = _align_task_timing_for_pre(
        _task_timing_rows_data,
        total_duration = _task_timing_total_str,
    )

    # --- "Nothing to show yet" signal ---
    # True when any of the target-level buckets has something to render. When
    # false AND the build isn't aborted, the template shows a waiting message
    # so the check run output isn't just a blank section before the command-
    # line and footer.
    _has_targets_info = (
        build_failure_count > 0 or
        failed_test_count > 0 or
        timeout_test_count > 0 or
        flaky_test_count > 0 or
        passed_test_count > 0 or
        cached_test_count > 0 or
        built_non_test_count > 0 or
        derived_failures_count > 0
    )

    # --- Badges ---
    actions_total = data["bazel"].get("actions_total", 0)
    if build_failure_count > 0:
        build_badge_url = "https://img.shields.io/badge/build-failed-red"
    elif actions_total > 0:
        build_badge_url = "https://img.shields.io/badge/build-" + str(actions_total) + "%20actions-blue"
    else:
        build_badge_url = "https://img.shields.io/badge/build-passed-brightgreen"

    pass_t_total = data["bazel"].get("passed_test_total", 0)
    if failed_test_count + timeout_test_count > 0:
        test_badge_url = ("https://img.shields.io/badge/tests-" +
                          str(pass_t_total) + "%20passed%2C%20" +
                          str(failed_test_count + timeout_test_count) + "%20failed-red")
    elif flaky_test_count > 0:
        test_badge_url = ("https://img.shields.io/badge/tests-" +
                          str(pass_t_total) + "%20passed%2C%20" +
                          str(flaky_test_count) + "%20flaky-yellow")
    elif pass_t_total > 0:
        test_badge_url = "https://img.shields.io/badge/tests-" + str(pass_t_total) + "%20passed-brightgreen"
    else:
        test_badge_url = ""

    return {
        "aborted": data["bazel"].get("aborted", False),
        "abort_reason": data["bazel"].get("abort_reason", ""),
        "abort_description": data["bazel"].get("abort_description", ""),
        # Empty string (falsy in Jinja2) when there's any target bucket to
        # render — flips to "1" when nothing has reported yet, so the template
        # shows a "waiting for data" placeholder instead of a blank section.
        "no_targets_info": "" if _has_targets_info else "1",
        # Stringified target count for the "## Targets (N)" header — uses the
        # aggregate target_completed count which covers both successes and failures.
        "total_targets": str(data["bazel"].get("targets_total", 0)),

        # --- Bucket sections (see _BUCKET_* constants for naming) ---
        # Each *_header is "{count} {plural header}" (e.g. "3 Test Failures").
        # Lists are empty when the bucket has no targets — template conditionals
        # skip empty sections.
        "build_failures": _build_failures_table["rows"],
        "build_failures_table_head": _build_failures_table["header"],
        "build_failures_table_sep": _build_failures_table["separator"],
        "build_failures_count": build_failure_count,
        "build_failures_header": _bucket_header(_BUCKET_FAILED_TO_BUILD, build_failure_count),
        "build_failures_overflow": str(failed_actions_overflow) if failed_actions_overflow > 0 else "",
        "build_failures_icon": _BUCKET_ICONS[_BUCKET_FAILED_TO_BUILD],
        # Per-task repro & fix command lists, authored by each
        # producer at terminal-emit time. See `lib/repro_commands.axl`
        # for the shape; the template iterates each list to emit the
        # "🔁 Reproduce" / "🛠️ Fix" sections.
        "repro_commands": list(data.get("repro_commands", []) or []),
        "fix_commands": list(data.get("fix_commands", []) or []),
        # Derived failures — targets that failed without emitting their own action
        # errors (a dep broke). Shown as a collapsed list under Build Failures.
        # Count is stringified (Jinja2 can't compare AXL ints directly; see
        # _prep_action for the same hack) — plural flip is a pre-computed string.
        "derived_failures": _derived_table["rows"],
        "derived_failures_table_head": _derived_table["header"],
        "derived_failures_table_sep": _derived_table["separator"],
        "derived_failures_count": str(derived_failures_count),
        "derived_failures_plural": "s" if derived_failures_count != 1 else "",
        "derived_failures_overflow": str(derived_failures_overflow) if derived_failures_overflow > 0 else "",
        "failed_tests": _failed_table["rows"],
        "failed_tests_table_head": _failed_table["header"],
        "failed_tests_table_sep": _failed_table["separator"],
        "failed_tests_has_artifacts": _failed_table.get("has_artifacts", False),
        "failed_tests_header": _bucket_header(_BUCKET_TEST_FAILED, failed_test_count),
        "failed_tests_icon": _BUCKET_ICONS[_BUCKET_TEST_FAILED],
        "timeout_tests": _timeout_table["rows"],
        "timeout_tests_table_head": _timeout_table["header"],
        "timeout_tests_table_sep": _timeout_table["separator"],
        "timeout_tests_has_artifacts": _timeout_table.get("has_artifacts", False),
        "timeout_tests_header": _bucket_header(_BUCKET_TEST_TIMEOUT, timeout_test_count),
        "timeout_tests_icon": _BUCKET_ICONS[_BUCKET_TEST_TIMEOUT],
        "flaky_tests": _flaky_table["rows"],
        "flaky_tests_table_head": _flaky_table["header"],
        "flaky_tests_table_sep": _flaky_table["separator"],
        "flaky_tests_has_artifacts": _flaky_table.get("has_artifacts", False),
        "flaky_tests_header": _bucket_header(_BUCKET_TEST_FLAKY, flaky_test_count),
        "flaky_tests_icon": _BUCKET_ICONS[_BUCKET_TEST_FLAKY],

        # Passed-test table: label | kind | duration [| artifacts], with column
        # headers + separator row for readability in <pre> blocks. The artifacts
        # column is only present when at least one test has per-file log/xml URLs
        # (CircleCI currently); passed_tests_has_artifacts drives the template.
        "passed_tests": _passed_table["rows"],
        "passed_tests_table_head": _passed_table["header"],
        "passed_tests_table_sep": _passed_table["separator"],
        "passed_tests_has_artifacts": _passed_table.get("has_artifacts", False),
        "passed_tests_count": passed_test_count,
        "passed_tests_header": _bucket_header(_BUCKET_TEST_PASSED, passed_test_count),
        "cached_tests": _cached_table["rows"],
        "cached_tests_table_head": _cached_table["header"],
        "cached_tests_table_sep": _cached_table["separator"],
        "cached_tests_has_artifacts": _cached_table.get("has_artifacts", False),
        "cached_tests_count": cached_test_count,
        "cached_tests_header": _bucket_header(_BUCKET_TEST_PASSED_CACHED, cached_test_count),

        # Built-targets table: label | kind (no duration for non-test targets).
        "built_targets": _built_table["rows"],
        "built_targets_table_head": _built_table["header"],
        "built_targets_table_sep": _built_table["separator"],
        "built_targets_count": built_non_test_count,
        # Sentinel flag for the template: render the section whenever the count
        # is non-zero, even when the sample list is empty (can happen when the
        # 250-entry built_targets cap is hit and the sample turns out to be
        # test-heavy so filtering leaves nothing visible).
        "built_targets_any": "1" if built_non_test_count > 0 else "",
        "built_targets_header": _bucket_header(_BUCKET_SUCCESSFUL_BUILD, built_non_test_count),
        "built_targets_overflow": str(built_overflow) if built_overflow > 0 else "",
        "passed_tests_overflow": str(passed_overflow) if passed_overflow > 0 else "",

        # Command-line views (derived from options_parsed, redacted for secrets).
        # long form: multi-line reproducer. short: "bazel test //foo:bar"
        # used as the <details> summary.
        "explicit_command_line": _explicit_cmd["long"],
        "explicit_command_line_short": _explicit_cmd["short"],
        "startup_options": _startup_opts_redacted,
        "cmd_line_options": _cmd_line_redacted,

        # Badges, BES links, CI links, artifacts.
        "build_badge_url": build_badge_url,
        "test_badge_url": test_badge_url,
        "bes_invocation_url": render_bes_url(data),
        "ci_label": links.get("ci_label", ""),
        "ci_url": links.get("ci_url", ""),
        "aspect_url": links.get("aspect_url", ""),
        "artifacts_browse_url": links.get("artifacts_browse_url", ""),
        "artifact_links": artifact_links,

        # --- Invocation / Aspect Workflows Runner / Workspace Status /
        # Build Metadata / Performance ---
        # Each is a list of {key, value} rows with empty values filtered out.
        # The template iterates and emits only the sections with at least one row.
        "invocation_rows": build_invocation_detail_rows(data, start_date, finish_date),
        "aspect_runner_rows": build_aspect_runner_rows(std) if std else [],
        "workspace_status_rows": build_kv_rows(data["bazel"].get("workspace_status", {})),
        "build_metadata_rows": build_kv_rows(data["bazel"].get("metadata", {})),
        "invocation_stats": _build_invocation_stats(data),
        # Per-attempt history when bazel retries occurred. Empty list
        # for the common single-attempt path; the template hides the
        # "🔁 Retry attempts" sub-section when empty.
        "retry_attempt_rows": _build_retry_attempt_rows(data, links),

        # Task timing — populated when the task opted into phases via
        # `task_update(..., phase=...)` / `ctx.task.phase(...)`. Empty
        # otherwise, in which case the template skips the section.
        # Aligned-table shape uses the same `<pre>`-aligned style every
        # other body section uses (Bazel targets, Workspace status,
        # ...) — see `_align_task_timing_for_pre`.
        "task_timing_table_head": _task_timing_table["header"],
        "task_timing_table_sep": _task_timing_table["separator"],
        "task_timing_rows": _task_timing_table["rows"],
        "task_timing_total_separator": _task_timing_table["total_separator"],
        "task_timing_total_line": _task_timing_table["total_line"],

        # Whether SHARED renders the Bazel targets block. False for
        # build/test (they hoist Bazel targets above SHARED into the
        # primary slot via `DETAILS_TEMPLATE`); True otherwise.
        "include_bazel_targets": include_bazel_targets,
        # Whether the Bazel targets block renders Reproduce / Fix
        # sections at its top. True only when Bazel targets is the
        # primary actionable slot (build/test).
        "render_repro_in_targets": render_repro_in_targets,
    }

def active_phase_data(ctx):
    """Return the currently-active `Phase` snapshot, or `None`.

    Thin pass-through to `ctx.task.current_phase()` — exists as a
    named helper so result libraries can pass it through their public
    `render_check_output` interface (`task_active = ...`) without
    every caller reaching into `ctx.task` themselves. The `duration_ms`
    on the returned Phase is the live elapsed at call time; the
    renderer layers status-aware suffixes ("(active)" / "(failing)" /
    "(failed during this phase)") onto the description for the body
    table.
    """
    return ctx.task.current_phase()

def _build_task_timing_rows(phases, active, status):
    """Format task phase timing as table rows for the Task timing
    body section.

    Filters out the synthetic `init` phase when its duration is under
    `_INIT_PHASE_HIDE_THRESHOLD_MS`. Caller-named phases always render
    even at 0ms (intentional boundaries).

    The Phase column renders bare names (display_name or titlecase) —
    no emoji prefix. Emojis have variable display widths that break
    `_pad_right`-based column alignment when some entries carry icons
    and others don't. The header strip's `⏱ <total> · 🔨 Build 38.3s
    | …` line keeps emoji because it's a single inline run, not a
    fixed-width column.

    The active phase, when present and the task is not yet terminal,
    appears as the trailing row with a status-aware suffix in the
    Description column ("(active)" / "(failing)"). On a terminal
    `failed` status, an entry with `interrupted = True` (set by the
    runtime's auto-close on `_impl` return) renders with a
    "(failed during this phase)" suffix instead of a bare description
    so the body table mirrors what the header strip shows.
    """

    def _name(name, display_name):
        return display_name or _titlecase(name)

    rows = []
    if phases:
        for p in phases:
            if p.name == "init" and p.duration_ms < _INIT_PHASE_HIDE_THRESHOLD_MS:
                continue
            desc = p.description or "—"
            if status == "failed" and p.interrupted:
                desc = desc + " (failed during this phase)"
            rows.append({
                "name": _name(p.name, p.display_name),
                "description": desc,
                "duration": format_duration_ms(p.duration_ms),
                "is_active": False,
            })
    if active:
        # Status-aware verb suffix on the active row, mirroring what
        # the header strip shows. The `is_active` flag drives a
        # leading-arrow marker in the rendered Phase column so the
        # in-flight row stands out on live status surfaces.
        verb_suffix = {
            "failed": " (failed during this phase)",
            "passed": "",
            "failing": " (failing)",
        }.get(status, " (active)")
        rows.append({
            "name": _name(active.name, active.display_name),
            "description": (active.description or "—") + verb_suffix,
            "duration": format_duration_ms(active.duration_ms),
            # Mark live-only — at terminal there's no "active" row, so
            # the marker only ever appears on heartbeat / live emits.
            "is_active": status not in ("passed", "failed", "aborted"),
        })
    return rows

def render_check_output(ctx, data, status, render_ctx, links, templates = None, metadata_keys = None):
    """Render title, summary, and text for a GitHub check run output field.

    This is the public entry point for the "bazel_results" task_update kind.
    Features call this from their task_update handler when kind == "bazel_results".

    Args:
        ctx:           TaskContext
        data:       dict from init_data(), updated by process_event
        status:        "running" | "failing" | "passed" | "failed"
        render_ctx:    display context from the feature (triggered_by, targets,
                       started_ms, ended_ms, progress) — see build_summary_data
        links:         dict with ci_label, ci_url, aspect_url
        templates:     optional override dict — keys "summary" and/or "details"
                       replace the built-in Jinja2 templates
        metadata_keys: list of extra BES metadata keys to surface in the summary;
                       pass ["*"] to show all keys

    Returns:
        dict with keys "title", "summary", "text" — suitable for check run output
    """

    # Render-debug logs are gated on `_ASPECT_DEBUG_STATUS_RENDER_CHECK`.
    # Status surfaces re-render on every emit (one per phase, plus
    # per-BES-event refresh), and a normal task can produce dozens of
    # renders — way too noisy to mix into the standard debug stream.
    # Set `_ASPECT_DEBUG_STATUS_RENDER_CHECK=1` to opt back in for
    # render-specific diagnostics.
    debug_render = bool(ctx.std.env.var("_ASPECT_DEBUG_STATUS_RENDER_CHECK"))
    if debug_render:
        trace.log("debug [render_check_output] status=" + status)
        trace.log("debug [render_check_output]   invocation_id=" + (data["bazel"].get("invocation_id") or ""))
        trace.log("debug [render_check_output]   wall_time_ms=" + str(data["bazel"].get("wall_time_ms", 0)))
        trace.log("debug [render_check_output]   targets_total=" + str(data["bazel"].get("targets_total", 0)))
        trace.log("debug [render_check_output]   built_targets=" + str(len(data["bazel"].get("built_targets", []))))
        trace.log("debug [render_check_output]   passed_test_total=" + str(data["bazel"].get("passed_test_total", 0)))
        trace.log("debug [render_check_output]   passed_tests=" + str(len(data["bazel"].get("passed_tests", []))))
        trace.log("debug [render_check_output]   failed_test_total=" + str(data["bazel"].get("failed_test_total", 0)))
        trace.log("debug [render_check_output]   flaky_test_total=" + str(data["bazel"].get("flaky_test_total", 0)))
        trace.log("debug [render_check_output]   actions_total=" + str(data["bazel"].get("actions_total", 0)))
        op = data["bazel"].get("options_parsed") or {}
        trace.log("debug [render_check_output]   options_parsed explicit=" + str(len(op.get("explicit_cmd_line", []))) +
                  " startup=" + str(len(op.get("startup_options", []))) +
                  " cmd=" + str(len(op.get("cmd_line", []))))
        ws = data["bazel"].get("workspace_status") or {}
        if ws:
            trace.log("debug [render_check_output]   workspace_status=" + str(ws))
        meta = data["bazel"].get("metadata") or {}
        if meta:
            trace.log("debug [render_check_output]   metadata=" + str(meta))
        passed = data["bazel"].get("passed_tests") or []
        if passed:
            sample = [t.get("label", "") for t in passed[:5]]
            trace.log("debug [render_check_output]   passed_tests sample=" + str(sample))
        built = data["bazel"].get("built_targets") or []
        if built:
            sample = [t.get("label", "") for t in built[:3]]
            trace.log("debug [render_check_output]   built_targets sample=" + str(sample))

    # GitHub hard limit for check run output.text is 65535 bytes.
    # We use 65000 as a safe ceiling to leave headroom for encoding overhead.
    _DETAILS_LIMIT = 65000

    t = templates or {}
    run_date = format_run_date(ctx, data.get("start_time_ms", 0))
    finish_date = format_run_date(ctx, data.get("finish_time_ms", 0))
    summary_data = build_summary_data(ctx, data, status, render_ctx, links, metadata_keys, run_date = run_date)
    details_data = build_details_data(
        data,
        links,
        render_ctx = render_ctx,
        status = status,
        start_date = run_date,
        finish_date = finish_date,
        std = ctx.std,
        task_phases = ctx.task.phases(),
        task_active = active_phase_data(ctx),
        task_elapsed_ms = ctx.task.elapsed_ms,
        # Build/test hoist the Bazel targets section into the primary
        # slot above SHARED (see DETAILS_TEMPLATE), so SHARED skips it.
        include_bazel_targets = False,
        # Bazel targets is build/test's primary actionable slot, so the
        # Reproduce/Fix sections render at its top.
        render_repro_in_targets = True,
    )

    if debug_render:
        trace.log("debug [render_check_output]   summary target_pattern=" + summary_data.get("target_pattern", ""))
        trace.log("debug [render_check_output]   summary branch=" + summary_data.get("branch", ""))
        trace.log("debug [render_check_output]   summary short_sha=" + summary_data.get("short_sha", ""))
        trace.log("debug [render_check_output]   summary detail_rows count=" + str(len(summary_data.get("detail_rows", []))))
        trace.log("debug [render_check_output]   details startup_options=" + str(len(details_data.get("startup_options", []))) +
                  " cmd_line_options=" + str(len(details_data.get("cmd_line_options", []))) +
                  " explicit=" + str(bool(details_data.get("explicit_command_line", ""))))
        trace.log("debug [render_check_output]   run_date=" + run_date)
        trace.log("debug [render_check_output]   cpu_arch=" + str(data["bazel"].get("cpu_arch", "")))
        trace.log("debug [render_check_output]   compilation_mode=" + str(data["bazel"].get("compilation_mode", "")))
        trace.log("debug [render_check_output]   build_tool_version=" + str(data["bazel"].get("build_tool_version", "")))
        trace.log("debug [render_check_output]   targets_configured=" + str(data["bazel"].get("targets_configured", 0)))
        trace.log("debug [render_check_output]   packages_loaded=" + str(data["bazel"].get("packages_loaded", 0)))

    details_tmpl = t.get("details") or DETAILS_TEMPLATE
    summary_text = ctx.template.jinja2(t.get("summary") or SUMMARY_TEMPLATE, data = summary_data)
    details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    # --- Fit details within the GitHub limit ---
    # Strategy (each step re-renders only if still over):
    #   1. Drop Build Metadata (most expendable — custom key-value junk).
    #   2. Drop Workspace Status.
    #   3. Drop Invocation (reference info, covered by Aspect Web UI).
    #   4. Drop Performance details.
    #   5. Drop parsed-options lists (saves ~10-20 KB typically).
    #   6. Halve the built_targets list until it fits.
    #   7. Halve the passed_tests list the same way.
    #   8. Last resort: drop cached_tests too.
    # Priority reasoning: bucket lists (targets/tests) are the primary
    # signal users load the check for; the reference sections
    # (metadata, workspace status, invocation details) are redundant
    # with the Aspect Web UI, so drop them first.
    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   OVER LIMIT (" + str(len(details_text)) +
                      "), dropping build_metadata sub-block from Bazel details")
        details_data["build_metadata_rows"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping workspace_status sub-block from Bazel details")
        details_data["workspace_status_rows"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping invocation sub-block from Bazel details")
        details_data["invocation_rows"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping Runner metadata section")
        details_data["aspect_runner_rows"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping Performance")
        details_data["invocation_stats"] = None
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        if debug_render:
            trace.log("debug [render_check_output]   still OVER (" + str(len(details_text)) +
                      "), dropping parsed-options lists")
        details_data["startup_options"] = []
        details_data["cmd_line_options"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        built = details_data.get("built_targets", [])
        built_total = details_data.get("built_targets_count", 0)

        # Halve the list up to 10 times (handles up to 2^10 = 1024× overage).
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(built) == 0:
                break
            built = built[:len(built) // 2]
            overflow = built_total - len(built)
            details_data["built_targets"] = built
            details_data["built_targets_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = ctx.template.jinja2(details_tmpl, data = details_data)
        if debug_render:
            trace.log("debug [render_check_output]   after target trim: details len=" + str(len(details_text)) +
                      " built_targets=" + str(len(built)))

    if len(details_text) > _DETAILS_LIMIT:
        passed = details_data.get("passed_tests", [])
        passed_total = details_data.get("passed_tests_count", 0)
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(passed) == 0:
                break
            passed = passed[:len(passed) // 2]
            overflow = passed_total - len(passed)
            details_data["passed_tests"] = passed
            details_data["passed_tests_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = ctx.template.jinja2(details_tmpl, data = details_data)
        if debug_render:
            trace.log("debug [render_check_output]   after test trim: details len=" + str(len(details_text)) +
                      " passed_tests=" + str(len(passed)))

    if len(details_text) > _DETAILS_LIMIT:
        # Last resort: drop cached_tests too.
        details_data["cached_tests"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if debug_render:
        trace.log("debug [render_check_output]   summary len=" + str(len(summary_text)))
        trace.log("debug [render_check_output]   details len=" + str(len(details_text)))
        trace.log("debug [render_check_output] --- summary ---")
        trace.log(summary_text)
        trace.log("debug [render_check_output] --- details (first 5000 chars) ---")
        trace.log(details_text[:5000])

    target_pattern = render_ctx.get("targets", "") if render_ctx else ""
    task_name = render_ctx.get("task_name", "") if render_ctx else ""
    return {
        "title": summary_title(
            data,
            status,
            target_pattern = target_pattern,
            task_name = task_name,
        ),
        "summary": summary_text,
        "text": details_text,
    }
