def _build_summary_data(ctx, results, status, render_ctx, metadata_keys, run_date = ""):
    """Build Jinja2 template data for SUMMARY_TEMPLATE.

    render_ctx keys (all provided by the feature, not derived from BES):
      triggered_by: str  — who/what started this build (e.g. "greg (workflow_dispatch)")
      targets:      str  — target pattern string (e.g. "//...")
      started_ms:   int  — task start time in ms since epoch
      ended_ms:     int  — task end time (0 if still running)
      progress:     str  — last free-text progress message from task_update.progress
    """
    last_update = render_ctx.get("progress") or summary_title(results, status)

    meta = results.get("metadata", {})
    sha = meta.get("COMMIT_SHA", "")
    commit_msg = meta.get("COMMIT_MESSAGE", "")
    if len(commit_msg) > 72:
        commit_msg = commit_msg[:72] + "…"

    extra_meta = []
    keys = metadata_keys or []
    show_all = keys == ["*"]
    for k, v in meta.items():
        if k in _RENDER_META_STANDARD_KEYS:
            continue
        if show_all or k in keys:
            extra_meta.append({"key": k, "value": v})

    return {
        "last_update":    last_update,
        "target_pattern": render_ctx.get("targets", "") if render_ctx else "",
        "branch":         meta.get("BRANCH", ""),
        "tag":            meta.get("TAG", ""),
        "short_sha":      sha[:7] if sha else "",
        "commit_msg":     commit_msg,
        "extra_meta":     extra_meta,
        "detail_rows":    _build_invocation_rows(ctx, results, render_ctx, status, run_date = run_date),
    }


def _build_details_data(results, links, render_ctx = None, status = ""):
    """Build Jinja2 template data for DETAILS_TEMPLATE."""
    actions_total    = results["actions_total"]
    actions_executed = results["actions_executed"]
    actions_cached   = results["actions_cached"]
    cache_pct_int = (actions_cached * 100) // actions_total if actions_total > 0 else 0

    if results["failed_actions_total"] > 0 or len(results["failed_targets"]) > 0:
        build_badge_url = "https://img.shields.io/badge/build-failed-red"
    elif actions_total > 0:
        build_badge_url = "https://img.shields.io/badge/build-" + str(actions_total) + "%20actions-blue"
    else:
        build_badge_url = "https://img.shields.io/badge/build-passed-brightgreen"

    fail_t  = results["failed_test_total"]
    pass_t  = results["passed_test_total"]
    flaky_t = results["flaky_test_total"]

    if fail_t > 0:
        test_badge_url = ("https://img.shields.io/badge/tests-" +
                          str(pass_t) + "%20passed%2C%20" + str(fail_t) + "%20failed-red")
    elif flaky_t > 0:
        test_badge_url = ("https://img.shields.io/badge/tests-" +
                          str(pass_t) + "%20passed%2C%20" + str(flaky_t) + "%20flaky-yellow")
    elif pass_t > 0:
        test_badge_url = "https://img.shields.io/badge/tests-" + str(pass_t) + "%20passed-brightgreen"
    else:
        test_badge_url = ""

    if actions_total > 0:
        cache_color = "brightgreen" if cache_pct_int >= 80 else ("yellow" if cache_pct_int >= 50 else "red")
        cache_badge_url = "https://img.shields.io/badge/cache-" + str(cache_pct_int) + "%25%20hit-" + cache_color
    else:
        cache_badge_url = ""

    overflow = results["failed_actions_total"] - len(results["failed_actions"])

    def _prep_action(a):
        """Pre-process a failed action entry for Jinja2 template rendering.

        AXL passes integers to Jinja2 as JSON-serialized objects, which makes
        integer 0 truthy (non-empty dict). Convert stderr_truncated to a plain
        string — empty string when 0 so {% if %} evaluates correctly.
        """
        entry = dict(a)
        truncated = a.get("stderr_truncated", 0)
        entry["stderr_truncated"] = str(truncated) if truncated and truncated != 0 else ""
        return entry

    testlogs_label_urls = links.get("testlogs_label_urls", {})

    def _with_duration(tests):
        out = []
        for t in tests:
            entry = dict(t)
            ms = t.get("duration_ms", 0)
            entry["duration"] = _format_duration_ms(ms) if ms > 0 else ""
            # Per-file download URL from CircleCI/GitLab artifact upload (empty on GitHub/Buildkite).
            entry["log_url"] = testlogs_label_urls.get(t.get("label", ""), "")
            out.append(entry)
        return out

    passed_tests      = results.get("passed_tests", [])
    pass_t_total      = results.get("passed_test_total", 0)
    pass_overflow     = pass_t_total - len(passed_tests)
    built_targets     = results.get("built_targets", [])
    targets_total_int = results.get("targets_total", 0)
    built_overflow    = targets_total_int - len(built_targets)

    return {
        "aborted":                 results.get("aborted", False),
        "abort_reason":            results.get("abort_reason", ""),
        "abort_description":       results.get("abort_description", ""),
        "failed_actions":          [_prep_action(a) for a in results["failed_actions"]],
        "failed_actions_overflow": str(overflow) if overflow > 0 else "",
        "build_repro":             results.get("build_repro", ""),
        "failed_test_total":       str(fail_t),
        "failed_tests":            _with_duration(results["failed_tests"]),
        "flaky_test_total":        str(flaky_t),
        "flaky_tests":             _with_duration(results["flaky_tests"]),
        "test_repro":              results.get("test_repro", ""),
        "passed_test_total":       str(pass_t),
        "passed_tests":            _with_duration(sorted(passed_tests, key = lambda t: t.get("label", ""))),
        "passed_test_overflow":    str(pass_overflow) if pass_overflow > 0 else "",
        "cached_test_total":       str(results["cached_test_total"]),
        "targets_total":           str(targets_total_int),
        "built_targets":           sorted(built_targets, key = lambda t: t.get("label", "")),
        "built_targets_overflow":  str(built_overflow) if built_overflow > 0 else "",
        "actions_executed":        str(actions_executed),
        "actions_cached":          str(actions_cached),
        "actions_total":           str(actions_total),
        "command_lines":           [{"label": k, "cmd": _wrap_command_line(v)} for k, v in (results.get("command_lines") or {}).items()],
        "build_badge_url":         build_badge_url,
        "test_badge_url":          test_badge_url,
        "cache_badge_url":         cache_badge_url,
        "bes_invocation_url":       _render_bes_url(results),
        "ci_label":                 links.get("ci_label", ""),
        "ci_url":                   links.get("ci_url", ""),
        "aspect_url":               links.get("aspect_url", ""),
        # Testlogs artifact: populated by ArtifactUpload feature after the first
        # successful upload. Used to render a "Download test logs" link near the
        # test results sections. Empty strings when ArtifactUpload is not enabled.
        "testlogs_artifact_url":    links.get("testlogs_artifact_url", ""),
        "testlogs_artifact_name":   links.get("testlogs_artifact_name", ""),
    }


def render_check_output(ctx, results, status, render_ctx, links, templates = None, metadata_keys = None):
    """Render title, summary, and text for a GitHub check run output field.

    This is the public entry point for the "bazel_results" task_update kind.
    Features call this from their task_update handler when kind == "bazel_results".

    Args:
        ctx:           TaskContext
        results:       dict from init_results(), updated by process_event
        status:        "running" | "failing" | "passed" | "failed"
        render_ctx:    display context from the feature (triggered_by, targets,
                       started_ms, ended_ms, progress) — see _build_summary_data
        links:         dict with ci_label, ci_url, aspect_url
        templates:     optional override dict — keys "summary" and/or "details"
                       replace the built-in Jinja2 templates
        metadata_keys: list of extra BES metadata keys to surface in the summary;
                       pass ["*"] to show all keys

    Returns:
        dict with keys "title", "summary", "text" — suitable for check run output
    """
    debug = bool(ctx.std.env.var("ASPECT_DEBUG"))
    if debug:
        print("debug [render_check_output] status=" + status)
        print("debug [render_check_output]   invocation_id=" + (results.get("invocation_id") or ""))
        print("debug [render_check_output]   wall_time_ms=" + str(results.get("wall_time_ms", 0)))
        print("debug [render_check_output]   targets_total=" + str(results.get("targets_total", 0)))
        print("debug [render_check_output]   built_targets=" + str(len(results.get("built_targets", []))))
        print("debug [render_check_output]   passed_test_total=" + str(results.get("passed_test_total", 0)))
        print("debug [render_check_output]   passed_tests=" + str(len(results.get("passed_tests", []))))
        print("debug [render_check_output]   failed_test_total=" + str(results.get("failed_test_total", 0)))
        print("debug [render_check_output]   flaky_test_total=" + str(results.get("flaky_test_total", 0)))
        print("debug [render_check_output]   actions_total=" + str(results.get("actions_total", 0)))
        cl_keys = list((results.get("command_lines") or {}).keys())
        print("debug [render_check_output]   command_line_labels=" + str(cl_keys))
        for cl_label, cl_cmd in (results.get("command_lines") or {}).items():
            print("debug [render_check_output]   command_line[" + cl_label + "]=" + cl_cmd[:120])
        ws = results.get("workspace_status") or {}
        if ws:
            print("debug [render_check_output]   workspace_status=" + str(ws))
        meta = results.get("metadata") or {}
        if meta:
            print("debug [render_check_output]   metadata=" + str(meta))
        passed = results.get("passed_tests") or []
        if passed:
            sample = [t.get("label", "") for t in passed[:5]]
            print("debug [render_check_output]   passed_tests sample=" + str(sample))
        built = results.get("built_targets") or []
        if built:
            sample = [t.get("label", "") for t in built[:3]]
            print("debug [render_check_output]   built_targets sample=" + str(sample))

    # GitHub hard limit for check run output.text is 65535 bytes.
    # We use 65000 as a safe ceiling to leave headroom for encoding overhead.
    _DETAILS_LIMIT = 65000

    t = templates or {}
    run_date = _format_run_date(ctx, results.get("start_time_ms", 0))
    summary_data = _build_summary_data(ctx, results, status, render_ctx, metadata_keys, run_date = run_date)
    details_data = _build_details_data(results, links, render_ctx = render_ctx, status = status)

    if debug:
        print("debug [render_check_output]   summary target_pattern=" + summary_data.get("target_pattern", ""))
        print("debug [render_check_output]   summary branch=" + summary_data.get("branch", ""))
        print("debug [render_check_output]   summary short_sha=" + summary_data.get("short_sha", ""))
        print("debug [render_check_output]   summary detail_rows count=" + str(len(summary_data.get("detail_rows", []))))
        print("debug [render_check_output]   details command_lines count=" + str(len(details_data.get("command_lines", []))))
        print("debug [render_check_output]   run_date=" + run_date)
        print("debug [render_check_output]   cpu_arch=" + str(results.get("cpu_arch", "")))
        print("debug [render_check_output]   compilation_mode=" + str(results.get("compilation_mode", "")))
        print("debug [render_check_output]   build_tool_version=" + str(results.get("build_tool_version", "")))
        print("debug [render_check_output]   targets_configured=" + str(results.get("targets_configured", 0)))
        print("debug [render_check_output]   packages_loaded=" + str(results.get("packages_loaded", 0)))

    details_tmpl = t.get("details") or DETAILS_TEMPLATE
    summary_text = ctx.template.jinja2(t.get("summary") or SUMMARY_TEMPLATE, data = summary_data)
    details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    # --- Fit details within the GitHub limit ---
    # Strategy (each step re-renders only if still over):
    #   1. Drop command lines (saves ~10-20 KB typically).
    #   2. Halve the built_targets list until it fits (removes the overflow note
    #      and replaces it with an accurate one, so counts stay correct).
    #   3. Halve the passed_tests list the same way.
    if len(details_text) > _DETAILS_LIMIT:
        if debug:
            print("debug [render_check_output]   OVER LIMIT (" + str(len(details_text)) +
                  "), dropping command lines")
        details_data["command_lines"] = []
        details_text = ctx.template.jinja2(details_tmpl, data = details_data)

    if len(details_text) > _DETAILS_LIMIT:
        built = details_data.get("built_targets", [])
        targets_total_int = results.get("targets_total", 0)
        # Halve the list up to 10 times (handles up to 2^10 = 1024× overage).
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(built) == 0:
                break
            built = built[:len(built) // 2]
            overflow = targets_total_int - len(built)
            details_data["built_targets"] = built
            details_data["built_targets_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = ctx.template.jinja2(details_tmpl, data = details_data)
        if debug:
            print("debug [render_check_output]   after target trim: details len=" + str(len(details_text)) +
                  " built_targets=" + str(len(built)))

    if len(details_text) > _DETAILS_LIMIT:
        passed = details_data.get("passed_tests", [])
        pass_t_total = results.get("passed_test_total", 0)
        for _ in range(10):
            if len(details_text) <= _DETAILS_LIMIT or len(passed) == 0:
                break
            passed = passed[:len(passed) // 2]
            overflow = pass_t_total - len(passed)
            details_data["passed_tests"] = passed
            details_data["passed_test_overflow"] = str(overflow) if overflow > 0 else ""
            details_text = ctx.template.jinja2(details_tmpl, data = details_data)
        if debug:
            print("debug [render_check_output]   after test trim: details len=" + str(len(details_text)) +
                  " passed_tests=" + str(len(passed)))

    if debug:
        print("debug [render_check_output]   summary len=" + str(len(summary_text)))
        print("debug [render_check_output]   details len=" + str(len(details_text)))
        print("debug [render_check_output] --- summary ---")
        print(summary_text)
        print("debug [render_check_output] --- details (first 5000 chars) ---")
        print(details_text[:5000])

    return {
        "title":   summary_title(results, status),
        "summary": summary_text,
        "text":    details_text,
    }
