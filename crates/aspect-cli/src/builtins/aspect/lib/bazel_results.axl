def render_markdown(ctx, results, links = None):
    """Render a Markdown summary from accumulated results.

    Args:
        ctx:     TaskContext (for ctx.template.liquid)
        results: dict from init_results(), updated by process_event
        links:   optional dict with keys ci_label, ci_url, aspect_url
                 for a footer linking to the CI job and Aspect Web UI

    Returns:
        str — Markdown suitable for a GitHub check run summary field (max 65535 chars)
    """
    data = dict(results)
    # Pre-format durations so the Liquid template can render them as plain strings.
    data["executed_duration"] = _format_duration_ms(data["executed_duration_ms"]) if data["executed_duration_ms"] > 0 else ""
    data["cached_duration"]   = _format_duration_ms(data["cached_duration_ms"])   if data["cached_duration_ms"]   > 0 else ""

    # Pre-format per-test durations (Liquid has no duration filter).
    for t in data.get("failed_tests", []):
        t["duration_ms_fmt"] = _format_duration_ms(t.get("duration_ms", 0)) if t.get("duration_ms", 0) > 0 else ""
    for t in data.get("flaky_tests", []):
        t["duration_ms_fmt"] = _format_duration_ms(t.get("duration_ms", 0)) if t.get("duration_ms", 0) > 0 else ""

    links_data = links or {"ci_label": "", "ci_url": "", "aspect_url": ""}
    return ctx.template.liquid(_SUMMARY_TEMPLATE, data = {"results": data, "links": links_data})


def summary_title(results, status):
    """Build a short title string for the check run output.

    Args:
        results: dict from init_results()
        status:  "running" | "failing" | "passed" | "failed"

    Returns:
        str — max ~255 chars, suitable for check run output.title
    """
    parts = []
    if results["failed_actions_total"] > 0:
        parts.append(str(results["failed_actions_total"]) + " build failure(s)")
    if results["failed_test_total"] > 0:
        parts.append(str(results["failed_test_total"]) + " failed")
    if results["flaky_test_total"] > 0:
        parts.append(str(results["flaky_test_total"]) + " flaky")
    if parts:
        return ", ".join(parts)
    if results["aborted"]:
        reason = results["abort_reason"]
        if reason and reason != "build_failed":
            return "Build aborted (" + reason + ")"
        return "Build aborted"
    if status in ("running", "failing"):
        return "In progress"
    if status == "passed":
        passed = results["passed_test_total"]
        if passed > 0:
            cached = results["cached_test_total"]
            if cached > 0:
                return str(passed) + " test(s) passed (" + str(cached) + " cached)"
            return str(passed) + " test(s) passed"
        return "Passed"
    return "Failed"


def now_ms(ctx):
    """Return current time as milliseconds since epoch.

    Used for rate-limiting status check updates.

    Uses `date '+%s000'` (epoch seconds + literal "000") rather than `%3N`
    because macOS date does not support the `%N` nanoseconds format.
    The result is rounded to the nearest second, which is sufficient for the
    1-second default throttle interval.
    """
    result = ctx.std.process.command("date").args(["+%s000"]).stdout("piped").spawn().wait_with_output()
    if result.status.code == 0:
        val = result.stdout.strip()
        if val:
            return int(val)
    return 0


# ---------------------------------------------------------------------------
# Check run rendering — Jinja2 templates and data builders for the
# "bazel_results" task_update kind.
#
# render_check_output() is the public entry point. Callers pass:
#   ctx       — TaskContext
#   results   — dict from init_results(), updated by process_event
#   status    — "running" | "failing" | "passed" | "failed"
#   render_ctx — feature-supplied display context (see render_check_output docstring)
#   links     — dict with keys ci_label, ci_url, aspect_url, bes_invocation_url
#   templates — optional override dict from GitHubStatusChecksTrait.templates
#   metadata_keys — optional list of extra BES metadata keys to surface
# ---------------------------------------------------------------------------

# Standard BES metadata keys that have dedicated template slots.
# These are excluded from the extra_meta list even when metadata_keys=["*"].
_RENDER_META_STANDARD_KEYS = [
    "BRANCH", "COMMIT_SHA", "TAG", "COMMIT_MESSAGE",
    "COMMIT_AUTHOR", "COMMIT_AUTHOR_EMAIL", "COMMIT_TIMESTAMP",
    "USER", "CI", "VCS", "REPO", "REPO_OWNER",
]


def _wrap_command_line(cmd):
    """Wrap a command line at -- flag boundaries for readability in <pre> blocks.

    Splits on ' --' and re-joins with ' \\\n  --' so each flag starts on its own
    line with a shell line-continuation backslash.

    Example:
      bazel --startup_flag build --flag1 --flag2=val
      →
      bazel --startup_flag build \
        --flag1 \
        --flag2=val
    """
    parts = cmd.split(" --")
    if len(parts) <= 1:
        return cmd
    lines = [parts[0]]
    for part in parts[1:]:
        lines.append("  --" + part)
    return " \\\n".join(lines)


def _render_bes_url(results):
    """Construct the full BES invocation URL from bes_results_url + invocation_id."""
    base = results.get("bes_results_url", "")
    inv  = results.get("invocation_id", "")
    if not base or not inv:
        return ""
    return (base if base.endswith("/") else base + "/") + inv


def _format_run_date(ctx, epoch_ms):
    """Format an epoch timestamp (milliseconds) as a human-readable date string.

    Uses the system `date` command with cross-platform flags:
      macOS: date -r <seconds>
      Linux: date -d @<seconds>

    Returns "" if epoch_ms is 0 or the command fails.
    """
    if not epoch_ms or epoch_ms <= 0:
        return ""
    epoch_s = str(epoch_ms // 1000)
    result = ctx.std.process.command("sh").args([
        "-c",
        "date -r " + epoch_s + " 2>/dev/null || date -d '@" + epoch_s + "'",
    ]).stdout("piped").stderr("piped").spawn().wait_with_output()
    if result.status.code == 0:
        val = result.stdout.strip()
        if val:
            return val
    return ""


def _build_invocation_rows(ctx, results, render_ctx, status, run_date = ""):
    """Build dynamic invocation detail rows for the SUMMARY_TEMPLATE.

    Returns a list of rows, where each row is a list of {icon, value} dicts.
    Empty values are omitted; empty rows are excluded.

    Row 0: status, timing, user, host, tool
    Row 1: targets, actions, packages, analysis cache age, cpu arch, mode,
           test cache hit rate (only when test_summary events were received)
    Row 2: build UUID, VCS info (branch, commit, tag)
    Row 3: run date
    Row 4: links (CI system, BES invocation viewer)
    """
    ws   = results.get("workspace_status") or {}
    meta = results.get("metadata") or {}

    def _item(icon, value):
        return {"icon": icon, "value": value}

    _status_icons = {
        "passed":  "✅",
        "failed":  "❌",
        "failing": "⚠️",
        "running": "🔄",
    }
    _status_labels = {
        "passed":  "Succeeded",
        "failed":  "Failed",
        "failing": "Failing",
        "running": "Running",
    }

    # --- Row 0: status, timing, user, host, tool ---
    row0 = [_item(_status_icons.get(status, "🔄"), _status_labels.get(status, "Running"))]

    wall_time_ms = results.get("wall_time_ms", 0)
    if wall_time_ms > 0:
        row0.append(_item("⏱", _format_duration_ms(wall_time_ms)))

    cpu_time_ms = results.get("cpu_time_ms", 0)
    if cpu_time_ms > 0:
        row0.append(_item("⚙️", _format_duration_ms(cpu_time_ms) + " CPU"))

    build_user = ws.get("BUILD_USER", "") or meta.get("USER", "")
    if build_user:
        row0.append(_item("👤", build_user))

    build_host = ws.get("BUILD_HOST", "")
    if build_host:
        row0.append(_item("🖥", build_host))

    tool_version = results.get("build_tool_version", "")
    build_cmd    = results.get("build_command", "")
    if tool_version or build_cmd:
        tool_str = "bazel"
        if tool_version:
            tool_str += " v" + tool_version
        if build_cmd:
            tool_str += " " + build_cmd
        row0.append(_item("🔧", tool_str))

    # --- Row 1: targets, actions, packages, analysis cache age, cpu, mode,
    #            test cache hit rate ---
    row1 = []

    targets_total      = results.get("targets_total", 0)
    targets_configured = results.get("targets_configured", 0)
    if targets_total > 0:
        t_str = str(targets_total) + " target" + ("s" if targets_total != 1 else "")
        if targets_configured > 0:
            t_str += " (" + str(targets_configured) + " configured)"
        row1.append(_item("📦", t_str))

    actions_executed = results.get("actions_executed", 0)
    actions_total    = results.get("actions_total", 0)
    if actions_executed > 0 or actions_total > 0:
        a_str = str(actions_executed) + " action" + ("s" if actions_executed != 1 else "")
        if actions_total > 0:
            a_str += " (" + str(actions_total) + " created)"
        row1.append(_item("⚡", a_str))

    packages = results.get("packages_loaded", 0)
    if packages > 0:
        row1.append(_item("📂", str(packages) + " package" + ("s" if packages != 1 else "")))

    num_analyses = results.get("num_analyses", 0)
    num_builds   = results.get("num_builds", 0)
    if num_analyses > 0 or num_builds > 0:
        # Analysis cache age: cumulative analyses/builds in the current Bazel server session.
        # High values indicate a warm analysis cache.
        row1.append(_item("🔬", str(num_analyses) + " analyses, " + str(num_builds) + " builds"))

    cpu_arch = results.get("cpu_arch", "")
    if cpu_arch:
        row1.append(_item("💻", cpu_arch))

    mode = results.get("compilation_mode", "")
    if mode:
        row1.append(_item("🏎", mode))

    # Test cache hit rate — only shown when test_summary events were received,
    # because for build-only invocations we don't have reliable per-test cache data.
    pass_t  = results.get("passed_test_total", 0)
    fail_t  = results.get("failed_test_total", 0)
    flaky_t = results.get("flaky_test_total", 0)
    total_tests = pass_t + fail_t + flaky_t
    if total_tests > 0:
        cached_t  = results.get("cached_test_total", 0)
        cache_pct = (cached_t * 100) // total_tests
        row1.append(_item("⊘", str(cache_pct) + "% test cache hit"))

    # --- Row 2: build UUID, VCS ---
    row2 = []

    invocation_id = results.get("invocation_id", "")
    if invocation_id:
        row2.append(_item("🔑", invocation_id))

    branch = meta.get("BRANCH", "")
    if branch:
        row2.append(_item("🌿", branch))

    commit_sha = meta.get("COMMIT_SHA", "")
    if commit_sha:
        row2.append(_item("✏️", commit_sha))

    tag = meta.get("TAG", "")
    if tag:
        row2.append(_item("🏷", tag))

    # --- Row 3: run date ---
    row3 = []
    if run_date:
        row3.append(_item("📅", run_date))

    # --- Row 4: links (CI system + BES/Aspect Web UI invocation viewer) ---
    row4 = []

    bes_url = _render_bes_url(results)
    if bes_url:
        row4.append(_item("🔗", "[View invocation](" + bes_url + ")"))

    env = ctx.std.env
    if env.var("GITHUB_ACTIONS"):
        server   = env.var("GITHUB_SERVER_URL") or "https://github.com"
        repo     = env.var("GITHUB_REPOSITORY") or ""
        run_id   = env.var("GITHUB_RUN_ID") or ""
        if repo and run_id:
            row4.append(_item("🐙", "[GitHub Actions](" + server + "/" + repo + "/actions/runs/" + run_id + ")"))
    elif env.var("BUILDKITE"):
        build_url = env.var("BUILDKITE_BUILD_URL") or ""
        step_id   = env.var("BUILDKITE_STEP_ID") or ""
        if build_url:
            bk_url = build_url + "/steps/canvas?sid=" + step_id if step_id else build_url
            row4.append(_item("🏗", "[Buildkite](" + bk_url + ")"))
    elif env.var("CIRCLECI"):
        ci_url = env.var("CIRCLE_BUILD_URL") or ""
        if ci_url:
            row4.append(_item("⭕", "[CircleCI](" + ci_url + ")"))
    elif env.var("GITLAB_CI"):
        ci_url = env.var("CI_JOB_URL") or ""
        if ci_url:
            row4.append(_item("🦊", "[GitLab CI](" + ci_url + ")"))

    rows = []
    for row in [row0, row1, row2, row3, row4]:
        if row:
            rows.append(row)
    return rows


SUMMARY_TEMPLATE = """
<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bazel/bazel-original.svg" height="14" /> **`{{ target_pattern }}`**{%- if commit_msg %} · {{ commit_msg }}{%- endif %}{%- if short_sha %} · :pencil2: `{{ short_sha }}`{%- endif %}{%- if branch %} · :herb: `{{ branch }}`{%- endif %}{%- if tag %} · :label: `{{ tag }}`{%- endif %}
