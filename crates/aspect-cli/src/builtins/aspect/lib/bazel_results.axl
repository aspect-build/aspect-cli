{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_duration }}{% if failed_tests_has_artifacts %} | {{ t.aligned_artifacts }}{% endif %}
{%- endfor %}</pre>
</details>

{% endif %}
