{{ t.aligned_label }} | {{ t.aligned_kind }}
{%- endfor %}
{%- endif %}
{% if built_targets_overflow %}_{{ built_targets_overflow }} more not shown._{% endif %}</pre>
</details>

{% endif %}
{% endif %}
{% if render_repro_in_targets %}""" + REPRO_COMMANDS_BLOCK + FIX_COMMANDS_BLOCK + """{% endif %}
"""

# `SHARED_DETAILS_BODY_TEMPLATE` is the section block every task
# renders below its primary data. Top-level sections, in order:
#   1. Artifacts
#   2. Task timing  (when phases were used)
#   3. Bazel targets  (when caller hasn't hoisted it — i.e. non-bazel tasks)
#   4. Bazel details  (umbrella; consolidates command line,
#      invocation details, metrics, workspace status, build metadata,
#      and options into one collapsible-by-sub-block section)
#   5. Runner metadata  (only on Aspect Workflows)
#   6. footer
#
# Mirrors the Aspect UI's invocation tabs (Targets / Logs / Details):
# `Bazel targets` ↔ Targets tab, `Bazel details` ↔ Details tab.
# (Logs aren't available on status surfaces.)
#
# `include_bazel_targets` is True for non-bazel tasks (Bazel targets
# is part of the bazel-context group); False for build/test (Bazel
# targets is hoisted into slot 1 ahead of SHARED).
SHARED_DETAILS_BODY_TEMPLATE = """{% if artifacts_browse_url or artifact_links %}
### 📎 Artifacts

{% if artifacts_browse_url %}[Artifacts]({{ artifacts_browse_url }}){% endif %}{% if artifact_links %}{% if artifacts_browse_url %} · {% endif %}{% for a in artifact_links %}[{{ a.label }}]({{ a.url }}){% if not loop.last %} · {% endif %}{% endfor %}{% endif %}

{% endif %}
{% if task_timing_rows %}
### ⏱️ Task timing

<pre>
{{- task_timing_table_head }}
{{ task_timing_table_sep }}
{%- for p in task_timing_rows %}
{{ p.aligned_name }} | {{ p.aligned_description }} | {{ p.aligned_duration }}
{%- endfor %}
{%- if task_timing_total_line %}
{{ task_timing_total_separator }}
{{ task_timing_total_line }}
{%- endif %}</pre>

{% endif %}
{% if include_bazel_targets %}
""" + BAZEL_TARGETS_TEMPLATE + """
{% endif %}
{% if explicit_command_line or invocation_rows or invocation_stats or workspace_status_rows or build_metadata_rows or startup_options or cmd_line_options or retry_attempt_rows %}
### 🧮 Bazel details

{% if retry_attempt_rows -%}
<details open>
<summary>🔁 Retry attempts ({{ retry_attempt_rows|length }})</summary>

{% for a in retry_attempt_rows -%}
- Attempt {{ a.attempt }} ({{ a.outcome }}){% if a.aspect_url %} — [Aspect]({{ a.aspect_url }}){% endif %}
{% endfor %}
</details>

{% endif -%}
{% if explicit_command_line -%}
<details>
<summary>📟 Command line · <code>{{ explicit_command_line_short | e }}</code></summary>

