"""Bazel build event result accumulation and Markdown rendering.

Processes the BES event stream to track failed build actions, failed build
targets, and test outcomes (failed / flaky / passed). Produces a Markdown
summary suitable for GitHub check run output bodies.

Designed to be reusable by any feature that wants to report Bazel results
(GitHub status checks, Buildkite annotations, etc.).

Event kinds consumed:
  "build_started"            — resets all state; captures invocation UUID, tool version, command, start time
  "structured_command_line"  — captures bes_results_url and reconstructs full command line strings
  "build_metadata"           — captures --build_metadata / --bes_metadata key=value pairs
  "workspace_status"         — captures workspace_status key=value pairs (BUILD_USER, etc.)
  "configuration"            — captures cpu arch and compilation_mode (target config only)
  "action_completed"         — accumulates failed build actions (up to MAX_FAILED_ACTIONS)
  "target_completed"         — accumulates failed build targets
  "test_result"              — captures per-attempt log URI and duration (keyed by label)
  "test_summary"             — buckets tests into failed / flaky / passed; tracks duration
  "build_metrics"            — captures action/target/package counts and timing
  "aborted"                  — captures build abort reason and description

Payload fields used:
  BuildStarted.uuid, .build_tool_version, .command, .start_time_millis
  CommandLine.command_line_label, .sections[].section_type (ChunkList|OptionList oneof)
  BuildMetadata.metadata             — dict[str,str] of --build_metadata/--bes_metadata pairs
  WorkspaceStatus.item               — repeated list of {key, value} structs (proto field is "item")
  Configuration.cpu, .compilation_mode, .is_tool_configuration
  ActionExecuted.success, .type, .stderr (File)
  TargetComplete.success
  TestResult.test_action_output (File list), .test_attempt_duration_millis
  TestSummary.overall_status, .total_num_cached, .total_run_duration_millis (split by cached/executed)
  BuildMetrics.action_summary.{actions_executed, actions_created}
  BuildMetrics.timing_metrics.{wall_time_in_ms, cpu_time_in_ms}
  BuildMetrics.target_metrics.targets_configured
  BuildMetrics.package_metrics.packages_loaded
  BuildMetrics.cumulative_metrics.{num_analyses, num_builds}
  Aborted.abort_reason, .description
  event.id.label       — target label for all event types

Post-processing (call at build_end, not during streaming):
  resolve_stderr(ctx, results)  — reads stderr files into action entries
  compute_repro(results)        — builds "bazel build/test ..." repro commands
"""

# Maximum number of failed build actions to display (matches Marvin's MAX_BUILD_ERRORS).
MAX_FAILED_ACTIONS = 5

# Maximum number of test targets to track (matches Marvin's MAX_TEST_TARGETS).
MAX_TEST_TARGETS = 100

# Maximum characters to read from a stderr/log file for inline display.
# Matches Marvin's MAX_MESSAGE_RUNES.
MAX_STDERR_CHARS = 3000

# Maximum characters for a repro command string.
# Matches Marvin's MAX_REPRO_COMMAND_RUNES.
MAX_REPRO_CHARS = 1000

# Maximum number of successfully-built target labels to track.
MAX_BUILT_TARGETS = 250

# bb_clientd FUSE mount root used to resolve bytestream:// URIs.
# Must match the path configured in the Aspect Workflows runner environment.
_BB_CLIENTD_ROOT = "/var/cache/bb_clientd"

# TestSummary overall_status values from BlazeTestStatus proto enum.
# starbuf_derive::Enumeration converts CamelCase variant names to lowercase snake_case:
#   BlazeTestStatus::Failed → "failed",  BlazeTestStatus::FailedToBuild → "failed_to_build"
_TEST_STATUS_PASSED  = "passed"
_TEST_STATUS_FLAKY   = "flaky"
_TEST_STATUS_FAILED  = "failed"
_TEST_STATUS_TIMEOUT = "timeout"
_TEST_STATUS_NO_STATUS = "no_status"
_TEST_STATUS_FAILED_TO_BUILD = "failed_to_build"
_TEST_STATUS_INCOMPLETE = "incomplete"

_FAILED_STATUSES = [_TEST_STATUS_FAILED, _TEST_STATUS_TIMEOUT, _TEST_STATUS_FAILED_TO_BUILD]


def _format_duration_ms(ms):
    """Format a duration in milliseconds as a human-readable string.

    Examples: 500ms → "0.5s", 1500ms → "1.5s", 65000ms → "1m 5s"
    """
    if ms <= 0:
        return "0s"
    total_s = ms // 1000
    frac_s  = (ms % 1000) // 100  # tenths of a second
    if total_s < 60:
        if frac_s > 0:
            return str(total_s) + "." + str(frac_s) + "s"
        return str(total_s) + "s"
    minutes = total_s // 60
    seconds = total_s % 60
    if seconds > 0:
        return str(minutes) + "m " + str(seconds) + "s"
    return str(minutes) + "m"


def _bes_get(obj, field, default = None):
    """Safely access a single attribute on a BES event object.

    Returns default if obj is None or if the attribute is not present on the
    object (i.e. the field name doesn't match the deserialized proto schema).

    This prevents AttributeError on malformed or schema-mismatched BES events.
    For chained access (e.g. payload.stderr.file) call it twice:
        uri = _bes_get(_bes_get(payload, "stderr"), "file", "")
    """
    if obj == None:
        return default
    return getattr(obj, field, default)


def _file_uri_to_path(uri):
    """Convert a file:// or bytestream:// URI to a local filesystem path.

    bytestream:// URIs are resolved via the bb_clientd FUSE mount:
      bytestream://host:port/blobs/<hash>/<size>
      -> {_BB_CLIENTD_ROOT}/cas/{host}/blobs/sha256/file/{hash}-{size}
    """
    if not uri:
        return uri
    if uri.startswith("file://"):
        return uri[len("file://"):]
    if uri.startswith("bytestream://"):
        rest = uri[len("bytestream://"):]
        parts = rest.split("/")
        host_port = parts[0]
        host = host_port.split(":")[0]
        blob_hash = parts[2]
        blob_size = parts[3]
        return _BB_CLIENTD_ROOT + "/cas/" + host + "/blobs/sha256/file/" + blob_hash + "-" + blob_size
    return uri


def _read_file_truncated(ctx, uri, max_chars):
    """Resolve a BES file URI and read up to max_chars characters.

    Args:
        ctx:       TaskContext (for ctx.std.fs)
        uri:       file:// or bytestream:// URI from a BES event
        max_chars: maximum number of characters to return

    Returns:
        (content: str, truncated: int) — truncated is the number of
        additional characters present in the file beyond max_chars (0 if
        the file fit entirely).
    """
    path = _file_uri_to_path(uri)
    if not path or not ctx.std.fs.exists(path):
        return ("", 0)
    # Over-read slightly so we can detect whether the file was truncated.
    raw = ctx.std.fs.open(path).read(max_chars + 100)
    text = raw if type(raw) == "str" else ""
    if len(text) > max_chars:
        return (text[:max_chars], len(text) - max_chars)
    return (text, 0)


def _make_repro(operation, labels, max_chars):
    """Build a 'bazel <operation> <labels>' repro command string.

    Truncates the label list so the total command length does not exceed
    max_chars characters.

    Args:
        operation: "build" or "test"
        labels:    list of target labels to include
        max_chars: maximum character length of the returned command

    Returns:
        (cmd: str, n_included: int) — cmd is the repro command (empty string
        if no labels fit), n_included is how many labels were included.
    """
    base = "bazel " + operation + " "
    included = []
    used = len(base)
    for label in labels:
        needed = len(label) + 1  # +1 for the separating space
        if used + needed > max_chars:
            break
        included.append(label)
        used += needed
    if not included:
        return ("", 0)
    return (base + " ".join(included), len(included))


def init_results():
    """Create a fresh results accumulator.

    Returns:
        dict to be stored in build state and passed to process_event /
        resolve_stderr / compute_repro / render_markdown.
    """
    return {
        # Failed build targets (not test-related): [{label}]
        "failed_targets": [],
        # Failed build actions (detailed):
        #   [{label, mnemonic, stderr_uri, stderr_content, stderr_truncated}]
        # Capped at MAX_FAILED_ACTIONS. stderr_uri is the file:// or
        # bytestream:// URI; stderr_content is empty until resolve_stderr() is
        # called; stderr_truncated is the number of chars omitted (0 = full).
        "failed_actions": [],
        # Total failed action count (may exceed len(failed_actions) due to cap)
        "failed_actions_total": 0,
        # Test outcomes:
        #   [{label, cached, duration_ms}]
        # duration_ms comes from test_summary.total_run_duration_millis.
        "failed_tests": [],
        "flaky_tests":  [],
        # Aggregate test counts
        "passed_test_total": 0,
        "failed_test_total": 0,
        "flaky_test_total":  0,
        "cached_test_total": 0,
        # Tests with at least one non-cached run (used in footer)
        "executed_test_total": 0,
        # Wall-clock time for executed tests only (ms), from total_run_duration_millis.
        "executed_duration_ms": 0,
        # Wall-clock time for cached tests (ms) — represents time saved by the cache.
        "cached_duration_ms": 0,
        # Per-test detail from test_result events (keyed by label; last attempt wins):
        #   {label -> {"log_path": str, "duration_ms": int}}
        # log_path is a local filesystem path (resolved from the BES URI), or ""
        # if the file is remote / not yet available.
        "test_details": {},
        # Build action metrics from the build_metrics event
        "actions_executed": 0,
        "actions_cached": 0,
        "actions_total": 0,
        # Total number of targets that completed (success + failure), from counting
        # target_completed events. Matches the "N targets" count in BuildBuddy.
        # distinct from targets_configured (which is 0 when analysis is fully cached).
        "targets_total": 0,
        # Bazel invocation UUID from build_started event
        "invocation_id": "",
        # Base URL of the BES results viewer (e.g. "https://app.buildbuddy.io/invocation/").
        # Parsed from structured_command_line events. Append invocation_id to get the
        # full invocation URL. Empty when --bes_results_url is not set.
        "bes_results_url": "",
        # Bazel-measured wall-clock time in ms, from build_metrics.timing_metrics.
        # More accurate than client-side timing (excludes CLI overhead). 0 until received.
        "wall_time_ms": 0,
        # Key=value pairs from the BES build_metadata event.
        # Populated by --build_metadata and --bes_metadata Bazel flags.
        # Standard keys produced by build_metadata.axl:
        #   BRANCH, COMMIT_SHA, COMMIT_MESSAGE, COMMIT_AUTHOR, COMMIT_TIMESTAMP,
        #   USER, CI, VCS, REPO, REPO_OWNER, TAG
        # Custom keys: anything the user injects via --bes_metadata=MY_KEY=value
        "metadata": {},
        # Key=value pairs from the BES workspace_status event.
        # Standard keys: BUILD_USER, BUILD_HOST, BUILD_TIMESTAMP
        # Custom keys: whatever the workspace_status script emits
        "workspace_status": {},
        # Abort information from the aborted event
        "aborted": False,
        "abort_reason": "",       # snake_case proto enum, e.g. "interrupted", "analysis_failure"
        "abort_description": "",  # human-readable description from BES
        # Repro commands — populated by compute_repro(), empty until called.
        "build_repro": "",        # "bazel build //a //b ..."
        "build_repro_total": 0,   # total unique failed build labels (some may be omitted)
        "test_repro": "",         # "bazel test //a //b ..."
        "test_repro_total": 0,    # total failed test labels
        # All successfully-built target labels (test + non-test), capped at MAX_BUILT_TARGETS.
        "built_targets": [],
        # Passed test targets [{label, cached, duration_ms}], capped within MAX_TEST_TARGETS
        # total across failed_tests + flaky_tests + passed_tests.
        "passed_tests": [],
        # Command line strings keyed by Bazel's command_line_label
        # (e.g. "original command line", "canonical command line", "effective command line").
        # Populated from structured_command_line BES events.
        "command_lines": {},
        # Invocation IDs assigned by gRPC BES sinks when forwarding to the Aspect Web UI
        # (or other backends). Set by build.axl/test.axl after the build completes.
        # These differ from build_started.uuid and are needed for correct Web UI links.
        "sink_invocation_ids": [],
        # Bazel tool version and command from build_started (e.g. "9.0.1", "test")
        "build_tool_version": "",
        "build_command": "",
        # Build start time in milliseconds since epoch (from build_started.start_time_millis)
        "start_time_ms": 0,
        # CPU time in ms from build_metrics.timing_metrics.cpu_time_in_ms
        "cpu_time_ms": 0,
        # Number of targets that were configured (from build_metrics.target_metrics)
        "targets_configured": 0,
        # Number of packages loaded (from build_metrics.package_metrics)
        "packages_loaded": 0,
        # Cumulative analyses/builds from build_metrics.cumulative_metrics (analysis cache age)
        "num_analyses": 0,
        "num_builds": 0,
        # CPU architecture and compilation mode from the configuration event
        "cpu_arch": "",
        "compilation_mode": "",
    }


def process_event(results, event, debug=False):
    """Update results in-place from a single build event.

    All BES field accesses go through _bes_get() to guard against AttributeError
    on schema-mismatched or malformed events. When debug=True a warning is printed
    to stdout whenever an expected field is absent.

    Args:
        results: dict from init_results(), mutated in place
        event:   BuildEvent from BazelTrait.build_event hook
        debug:   when True, print warnings for missing expected BES fields

    Returns:
        True if results changed in a way that warrants a status check update,
        False otherwise.
    """
    kind = event.kind

    if kind == "build_started":
        # Retry: reset everything so we start fresh with the new event stream.
        fresh = init_results()
        for k in fresh:
            results[k] = fresh[k]
        # Capture fields from build_started for invocation details.
        payload = event.payload
        uuid = _bes_get(payload, "uuid", "") or ""
        if debug and not uuid:
            print("warning: BES build_started event missing expected field 'uuid'")
        results["invocation_id"]      = uuid
        results["build_tool_version"] = _bes_get(payload, "build_tool_version", "") or ""
        results["build_command"]      = _bes_get(payload, "command", "") or ""
        results["start_time_ms"]      = _bes_get(payload, "start_time_millis", 0) or 0
        return False

    elif kind == "structured_command_line":
        # Parse bes_results_url and reconstruct full command line strings from BES events.
        # Bazel emits one event per label ("original command line", "canonical command line",
        # "effective command line", etc.) — each is stored separately in command_lines.
        payload = event.payload
        cmd_label = (_bes_get(payload, "command_line_label", "") or "") if payload else ""
        if payload:
            sections = _bes_get(payload, "sections", None) or []
            cmd_parts = []
            for section in sections:
                # section_type is the starbuf-serialized oneof: NoneOr<ChunkList|OptionList>.
                # It allocates the inner ChunkList or OptionList value directly.
                sec_type = _bes_get(section, "section_type", None)
                if sec_type:
                    # Try as ChunkList: inner field is "chunk" (repeated string)
                    chunks = _bes_get(sec_type, "chunk", None)
                    if chunks != None:
                        for chunk in chunks:
                            if chunk:
                                cmd_parts.append(chunk)
                    else:
                        # Try as OptionList: inner field is "option" (repeated Option)
                        for opt in (_bes_get(sec_type, "option", None) or []):
                            name = _bes_get(opt, "option_name", "") or ""
                            if name == "bes_results_url":
                                val = _bes_get(opt, "option_value", "") or ""
                                if val:
                                    results["bes_results_url"] = val
                                    if debug:
                                        print("debug: captured bes_results_url=" + val)
                            combined = _bes_get(opt, "combined_form", "") or ""
                            if combined:
                                cmd_parts.append(combined)
                            elif name:
                                val = _bes_get(opt, "option_value", "") or ""
                                if val:
                                    cmd_parts.append("--" + name + "=" + val)
                                else:
                                    cmd_parts.append("--" + name)
            if cmd_parts and cmd_label:
                cmd_str = " ".join(cmd_parts)
                results["command_lines"][cmd_label] = cmd_str
                if debug:
                    print("debug: command_line[" + cmd_label + "] len=" + str(len(cmd_str)))
        return False

    elif kind == "build_metadata":
        # Merge --build_metadata and --bes_metadata key=value pairs into results.
        # This event arrives once per invocation, early in the stream.
        # No live update needed — metadata is context, not a status change.
        payload = event.payload
        if payload:
            payload_meta = _bes_get(payload, "metadata", None)
            if payload_meta:
                for k, v in payload_meta.items():
                    if k and v:
                        results["metadata"][k] = v
        return False

    elif kind == "workspace_status":
        # Capture workspace status variables (BUILD_USER, BUILD_HOST, etc.).
        # The proto field is `item` — a repeated list of {key, value} structs.
        payload = event.payload
        if payload:
            for ws_item in (_bes_get(payload, "item", None) or []):
                if ws_item:
                    key = _bes_get(ws_item, "key", "") or ""
                    val = _bes_get(ws_item, "value", "") or ""
                    if key and val:
                        results["workspace_status"][key] = val
        return False

    elif kind == "action_completed":
        payload = event.payload
        success = _bes_get(payload, "success", None)
        label   = _bes_get(event.id, "label", "") or ""
        if debug and success == None:
            print("warning: BES action_completed event missing expected field 'success' (label=" + label + ")")
        if not success:
            results["failed_actions_total"] += 1
            if len(results["failed_actions"]) < MAX_FAILED_ACTIONS:
                stderr_obj = _bes_get(payload, "stderr", None)
                stderr_uri = _bes_get(stderr_obj, "file", "") or ""
                mnemonic   = _bes_get(payload, "type", "") or ""
                results["failed_actions"].append({
                    "label":            label,
                    "mnemonic":         mnemonic,
                    "stderr_uri":       stderr_uri,
                    "stderr_content":   "",   # populated by resolve_stderr()
                    "stderr_truncated": 0,
                })
                return True
        return False

    elif kind == "target_completed":
        results["targets_total"] += 1
        payload = event.payload
        success = _bes_get(payload, "success", None)
        label   = _bes_get(event.id, "label", "") or ""
        if debug and success == None:
            print("warning: BES target_completed event missing expected field 'success' (label=" + label + ")")
        if not success:
            results["failed_targets"].append({"label": label})
            return True
        else:
            if label and len(results["built_targets"]) < MAX_BUILT_TARGETS:
                results["built_targets"].append({"label": label})
        return False

    elif kind == "test_result":
        # Capture the log file URI and duration for the most recent attempt.
        # test_result fires once per shard/run/attempt; the last write wins.
        # test_summary (processed later) provides the authoritative final outcome.
        label   = _bes_get(event.id, "label", "") or ""
        payload = event.payload
        log_uri = ""
        if payload:
            for output in (_bes_get(payload, "test_action_output", None) or []):
                if output and _bes_get(output, "name", "") == "test.log":
                    log_uri = _bes_get(output, "file", "") or ""
                    break
        duration_ms = (_bes_get(payload, "test_attempt_duration_millis", 0) or 0) if payload else 0
        results["test_details"][label] = {
            "log_path":    _file_uri_to_path(log_uri),
            "duration_ms": duration_ms,
        }
        # No status update — test_summary provides the authoritative signal.
        return False

    elif kind == "test_summary":
        payload     = event.payload
        status      = _bes_get(payload, "overall_status", "") or ""
        label       = _bes_get(event.id, "label", "") or ""
        num_cached  = _bes_get(payload, "total_num_cached", 0) or 0
        # total_run_duration_millis is deprecated in the proto but still populated by Bazel.
        # Bucket duration by whether the test actually ran or was served from cache.
        duration_ms = _bes_get(payload, "total_run_duration_millis", 0) or 0
        if debug and not status:
            print("warning: BES test_summary event missing expected field 'overall_status' (label=" + label + ")")
        if debug and not label:
            print("warning: BES test_summary event missing expected field 'id.label'")
        cached = num_cached > 0
        if cached:
            if duration_ms:
                results["cached_duration_ms"] += duration_ms
        else:
            results["executed_test_total"] += 1
            if duration_ms:
                results["executed_duration_ms"] += duration_ms

        total_tracked = (len(results["failed_tests"]) +
                         len(results["flaky_tests"]) +
                         len(results["passed_tests"]))

        if status in _FAILED_STATUSES:
            results["failed_test_total"] += 1
            if total_tracked < MAX_TEST_TARGETS:
                results["failed_tests"].append({
                    "label":       label,
                    "cached":      cached,
                    "duration_ms": duration_ms,
                })
            return True
        elif status == _TEST_STATUS_FLAKY:
            results["flaky_test_total"] += 1
            if total_tracked < MAX_TEST_TARGETS:
                results["flaky_tests"].append({
                    "label":       label,
                    "cached":      cached,
                    "duration_ms": duration_ms,
                })
            return True
        else:
            # PASSED, NO_STATUS, INCOMPLETE — count and record label for the details list
            results["passed_test_total"] += 1
            if cached:
                results["cached_test_total"] += 1
            if label and total_tracked < MAX_TEST_TARGETS:
                results["passed_tests"].append({
                    "label":       label,
                    "cached":      cached,
                    "duration_ms": duration_ms,
                })
        return False

    elif kind == "build_metrics":
        payload        = event.payload
        action_summary = _bes_get(payload, "action_summary", None)
        if action_summary:
            executed = _bes_get(action_summary, "actions_executed", 0) or 0
            # Use total - executed rather than remote_cache_hits (deprecated) because
            # this captures local cache hits too, giving a more accurate cached count.
            total    = _bes_get(action_summary, "actions_created", 0) or 0
            results["actions_executed"] = executed
            results["actions_cached"]   = total - executed if total > executed else 0
            results["actions_total"]    = total
        elif debug:
            print("warning: BES build_metrics event missing expected field 'action_summary'")
        timing_metrics = _bes_get(payload, "timing_metrics", None)
        if timing_metrics:
            wall_time = _bes_get(timing_metrics, "wall_time_in_ms", 0) or 0
            if wall_time > 0:
                results["wall_time_ms"] = wall_time
            cpu_time = _bes_get(timing_metrics, "cpu_time_in_ms", 0) or 0
            if cpu_time > 0:
                results["cpu_time_ms"] = cpu_time
        target_metrics = _bes_get(payload, "target_metrics", None)
        if target_metrics:
            configured = _bes_get(target_metrics, "targets_configured", 0) or 0
            if configured > 0:
                results["targets_configured"] = configured
        package_metrics = _bes_get(payload, "package_metrics", None)
        if package_metrics:
            loaded = _bes_get(package_metrics, "packages_loaded", 0) or 0
            if loaded > 0:
                results["packages_loaded"] = loaded
        cumulative_metrics = _bes_get(payload, "cumulative_metrics", None)
        if cumulative_metrics:
            num_analyses = _bes_get(cumulative_metrics, "num_analyses", 0) or 0
            num_builds   = _bes_get(cumulative_metrics, "num_builds", 0) or 0
            if num_analyses > 0:
                results["num_analyses"] = num_analyses
            if num_builds > 0:
                results["num_builds"] = num_builds
        if debug:
            print("debug: build_metrics wall_time_ms=" + str(results["wall_time_ms"]) +
                  " cpu_time_ms=" + str(results["cpu_time_ms"]) +
                  " targets_configured=" + str(results["targets_configured"]) +
                  " packages_loaded=" + str(results["packages_loaded"]))
        return True

    elif kind == "configuration":
        # Capture cpu arch and compilation_mode from the target (non-tool) configuration.
        # Fires once per build configuration; skip exec/host tool configurations.
        payload = event.payload
        if payload:
            is_tool = _bes_get(payload, "is_tool_configuration", False)
            if not is_tool:
                cpu  = _bes_get(payload, "cpu", "") or ""
                mode = _bes_get(payload, "compilation_mode", "") or ""
                if cpu:
                    results["cpu_arch"] = cpu
                if mode:
                    results["compilation_mode"] = mode
        return False

    elif kind == "aborted":
        results["aborted"] = True
        payload = event.payload
        if payload:
            results["abort_reason"]      = _bes_get(payload, "abort_reason", "") or ""
            results["abort_description"] = _bes_get(payload, "description",   "") or ""
        return True

    return False


def resolve_stderr(ctx, results):
    """Read stderr file content into each captured failed action entry.

    Call this once at build_end (after all events have been processed) rather
    than during streaming, so file I/O doesn't delay live status check updates.

    Args:
        ctx:     TaskContext (for ctx.std.fs)
        results: dict from init_results(), updated in place
    """
    for action in results["failed_actions"]:
        uri = action.get("stderr_uri", "")
        if uri and not action.get("stderr_content"):
            content, truncated = _read_file_truncated(ctx, uri, MAX_STDERR_CHARS)
            action["stderr_content"]   = content
            action["stderr_truncated"] = truncated


def compute_repro(results):
    """Compute 'bazel build/test ...' repro commands from accumulated results.

    Call this once at build_end (after all events have been processed).
    Populates results["build_repro"], results["build_repro_total"],
    results["test_repro"], and results["test_repro_total"] in place.

    The build repro deduplicates action labels to unique target labels
    (multiple failed actions may point to the same target).

    Args:
        results: dict from init_results(), updated in place
    """
    # Build repro: unique labels from failed_actions, preserving insertion order.
    seen = {}
    build_labels = []
    for a in results["failed_actions"]:
        lbl = a.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            build_labels.append(lbl)
    # Fall back to failed_targets when there are no action-level labels.
    if not build_labels:
        build_labels = [t["label"] for t in results["failed_targets"]]

    results["build_repro_total"] = len(build_labels)
    cmd, _ = _make_repro("build", build_labels, MAX_REPRO_CHARS)
    results["build_repro"] = cmd

    # Test repro: labels of all failed tests (already capped at MAX_TEST_TARGETS).
    test_labels = [t["label"] for t in results["failed_tests"]]
    results["test_repro_total"] = len(test_labels)
    cmd, _ = _make_repro("test", test_labels, MAX_REPRO_CHARS)
    results["test_repro"] = cmd


