"""Bazel build event result accumulation and Markdown rendering.

Processes the BES event stream to track failed build actions, failed build
targets, and test outcomes (failed / flaky / passed). Produces a Markdown
summary suitable for GitHub check run output bodies.

Designed to be reusable by any feature that wants to report Bazel data
(GitHub status checks, Buildkite annotations, etc.).

Event kinds consumed:
  "build_started"            — resets all state; captures invocation UUID, tool version, command, start time
  "structured_command_line"  — captures bes_results_url and reconstructs full command line strings
  "build_metadata"           — captures --build_metadata / --bes_metadata key=value pairs
  "workspace_status"         — captures workspace_status key=value pairs (BUILD_USER, etc.)
  "configuration"            — captures cpu arch and compilation_mode (target config only)
  "action_completed"         — accumulates failed build actions (up to MAX_FAILED_ACTIONS)
  "target_completed"         — accumulates failed build targets
  "test_result"              — captures per-attempt log URI and duration (keyed by label)
  "test_summary"             — buckets tests into failed / flaky / passed; tracks duration
  "build_metrics"            — captures action/target/package counts and timing
  "aborted"                  — captures build abort reason and description

Payload fields used:
  BuildStarted.uuid, .build_tool_version, .command, .start_time_millis
  CommandLine.command_line_label, .sections[].section_type (ChunkList|OptionList oneof)
  BuildMetadata.metadata             — dict[str,str] of --build_metadata/--bes_metadata pairs
  WorkspaceStatus.item               — repeated list of {key, value} structs (proto field is "item")
  Configuration.cpu, .compilation_mode, .is_tool_configuration
  ActionExecuted.success, .type, .stderr (File)
  TargetComplete.success
  TestResult.test_action_output (File list), .test_attempt_duration_millis
  TestSummary.overall_status, .total_num_cached, .total_run_duration_millis (split by cached/executed)
  BuildMetrics.action_summary.{actions_executed, actions_created}
  BuildMetrics.timing_metrics.{wall_time_in_ms, cpu_time_in_ms}
  BuildMetrics.target_metrics.targets_configured
  BuildMetrics.package_metrics.packages_loaded
  BuildMetrics.cumulative_metrics.{num_analyses, num_builds}
  Aborted.abort_reason, .description
  event.id.label       — target label for all event types

Note: stderr output is deliberately NOT captured. Bazel's BES stream can include
action stderr inline when upload strategies put contents in the event payload —
we've observed 40+ MB stderr in the wild (verbose linker errors, pathological
template instantiations). Pulling those into the Starlark heap costs memory and
isn't worth it for a check run display. We show the failing target label plus
the list of failing action mnemonics; users follow the CI link for the raw log.
"""

load(
    "./environment.axl",
    "build_aspect_runner_rows",
    "display_cloud_provider",
    "is_aspect_workflows_runner",
)
load("./path_glob.axl", "match_path")
load("./result_text.axl", "emoji_for_status")

# Max number of unique failed build target labels to track detail for. Entries
# are small (label + deduped mnemonic list) so this can be generous.
MAX_FAILED_ACTIONS = 25

# Maximum number of test targets to track (matches Marvin's MAX_TEST_TARGETS).
MAX_TEST_TARGETS = 100

# Maximum characters for a repro command string.
# Matches Marvin's MAX_REPRO_COMMAND_RUNES.
MAX_REPRO_CHARS = 1000

# Maximum number of successfully-built target labels to track.
MAX_BUILT_TARGETS = 250

# Minimum cadence for live status surface updates during BES streaming.
# Tasks driving bazel emit a `task_update` whenever `process_event`
# flips something interesting; the gap between those is bursty.
# Without a heartbeat the rendered `⏱` timer + per-phase counters
# would visibly stall during quiet stretches.
#
# Each BES loop polls events.try_pop() on a `BES_DRAIN_TICK_MS`
# cadence and force-emits a refresh if more than this many ms have
# elapsed since the last emit. 5s aligns with how often the platforms
# actually surface annotation refreshes — Buildkite throttles
# annotation updates to ~4s server-side, and GitHub status checks
# refresh on a similarly slow cadence — so a 5s heartbeat lets at
# most one refresh per platform tick land without piling up unused
# emits.
MIN_HEARTBEAT_INTERVAL_MS = 5000

# Sleep interval between BES event drain passes. Each tick:
#   - drains all currently-available events via events.try_pop()
#   - emits at most once (per interesting event batch or heartbeat)
#   - checks events.done() for stream termination
# 250ms gives 4 wake-ups per second — heartbeats fire within 250ms of
# the threshold, low CPU. Short enough that long event-quiet stretches
# (e.g. CI's 60s progress-message reduction) don't stall the loop.
BES_DRAIN_TICK_MS = 250

# bb_clientd FUSE mount root used to resolve bytestream:// URIs.
# Must match the path configured in the Aspect Workflows runner environment.
_BB_CLIENTD_ROOT = "/var/cache/bb_clientd"

# TestSummary overall_status values from BlazeTestStatus proto enum.
# starbuf_derive::Enumeration converts CamelCase variant names to lowercase snake_case:
#   BlazeTestStatus::Failed → "failed",  BlazeTestStatus::FailedToBuild → "failed_to_build"
_TEST_STATUS_PASSED = "passed"
_TEST_STATUS_FLAKY = "flaky"
_TEST_STATUS_FAILED = "failed"
_TEST_STATUS_TIMEOUT = "timeout"
_TEST_STATUS_NO_STATUS = "no_status"
_TEST_STATUS_FAILED_TO_BUILD = "failed_to_build"
_TEST_STATUS_INCOMPLETE = "incomplete"
_TEST_STATUS_REMOTE_FAILURE = "remote_failure"
_TEST_STATUS_BLAZE_HALTED_BEFORE_TESTING = "blaze_halted_before_testing"

# Every non-pass terminal status Bazel considers a failure. REMOTE_FAILURE and
# BLAZE_HALTED_BEFORE_TESTING are genuine failures (remote infra error / build
# aborted before the test ran) and must not be silently counted as passes.
_FAILED_STATUSES = [
    _TEST_STATUS_FAILED,
    _TEST_STATUS_TIMEOUT,
    _TEST_STATUS_FAILED_TO_BUILD,
    _TEST_STATUS_REMOTE_FAILURE,
    _TEST_STATUS_BLAZE_HALTED_BEFORE_TESTING,
]

def pluralize(count, singular, plural = None):
    """Return `<count> <singular>` or `<count> <plural>` based on count.

    Examples:
        pluralize(1, "target")    → "1 target"
        pluralize(2, "target")    → "2 targets"
        pluralize(12500, "action") → "12,500 actions"
        pluralize(0, "file")      → "0 files"
        pluralize(1, "warning", plural = "warnings") → "1 warning"

    Counts are formatted with thousands separators via
    `format_int_comma` so large bazel numbers (10K+ actions, 1M+ tests
    in big repos) read cleanly. Defaults `plural` to `singular + "s"`
    for the common English case; pass an explicit `plural=` for
    irregular forms or when the singular already ends in `s` /
    past-participle (`"delivered"` should not pluralize to
    `"delivereds"`).
    """
    if plural == None:
        plural = singular + "s"
    return format_int_comma(count) + " " + (singular if count == 1 else plural)

def html_escape(s):
    """Escape HTML special characters so user-provided text renders safely.

    BES metadata flowing through the renderer (commit message, branch
    name, tag, custom metadata keys/values, triggered-by string, …) is
    user-controlled — a commit message that contains "<hr>" would
    otherwise be interpreted as a literal `<hr>` element by BK
    (concatenated into a single HTML body) and by GHSC (markdown
    permits raw HTML), splitting the metadata row across an injected
    horizontal rule. Apply this helper to every user-controlled string
    on its way into the rendered markdown — including link display
    text and code-span content; only URL components and our own
    template literals stay unescaped.

    `&` MUST be replaced first so we don't double-escape the `&` we're
    about to introduce for `<` and `>`.
    """
    return s.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")

def format_duration_ms(ms):
    """Format a duration in milliseconds as a human-readable string.

    Three regimes for legibility:
      < 1s     → "5ms", "500ms"   — millisecond precision so tiny phases
                                    don't all read as "0s"
      < 1m     → "1.5s", "59.9s"  — tenth-of-a-second precision
      ≥ 1m     → "1m 5s", "61m"   — whole seconds inside minutes

    Mirrors the runtime's `format_duration` (multi_phase.rs) so the
    surface header strip and the runtime's "→ Completed" line read
    the same.
    """
    if ms <= 0:
        return "0ms"
    if ms < 1000:
        return str(ms) + "ms"
    total_s = ms // 1000
    frac_s = (ms % 1000) // 100  # tenths of a second
    if total_s < 60:
        if frac_s > 0:
            return str(total_s) + "." + str(frac_s) + "s"
        return str(total_s) + "s"
    minutes = total_s // 60
    seconds = total_s % 60
    if seconds > 0:
        return str(minutes) + "m " + str(seconds) + "s"
    return str(minutes) + "m"

def _format_cpu_seconds(ms):
    """Format an aggregate CPU-time duration with an explicit unit.

    Scales through seconds → minutes → hours the same way `format_duration_ms`
    scales wall-clock time, but preserves the "cpu-" prefix on the unit so
    the reader knows this is CPU (summed across parallel threads), not wall.

    Examples:
      2300     → "2.3 cpu-seconds"
      23300    → "23.3 cpu-seconds"
      98000    → "1.6 cpu-minutes"     (98s)
      600000   → "10 cpu-minutes"
      3660000  → "1 cpu-hour"
      5400000  → "1.5 cpu-hours"
    """
    if ms <= 0:
        return ""
    total_s = ms // 1000

    # Under a minute — decimal seconds.
    if total_s < 60:
        tenths = (ms % 1000) // 100
        base = format_int_comma(total_s)
        if tenths > 0:
            base = base + "." + str(tenths)
        return base + " cpu-seconds"

    # Under an hour — decimal minutes, one place.
    if total_s < 3600:
        whole = total_s // 60
        tenths = ((total_s % 60) * 10) // 60
        if tenths > 0:
            return format_int_comma(whole) + "." + str(tenths) + " cpu-minutes"
        return pluralize(whole, "cpu-minute")

    # Hours and up.
    whole = total_s // 3600
    tenths = ((total_s % 3600) * 10) // 3600
    if tenths > 0:
        return format_int_comma(whole) + "." + str(tenths) + " cpu-hours"
    return pluralize(whole, "cpu-hour")

def format_int_comma(n):
    """Format an integer with thousands separators: 12345 → "12,345"."""
    if n < 0:
        return "-" + format_int_comma(-n)
    s = str(n)

    # Insert commas every 3 digits from the right.
    out = []
    n_len = len(s)
    for i in range(n_len):
        if i > 0 and (n_len - i) % 3 == 0:
            out.append(",")
        out.append(s[i])
    return "".join(out)

def _miss_reason_display(reason):
    """Pretty-print a Bazel MissReason enum string.

    "DIFFERENT_FILES" → "Different files"
    "DIGEST_MISMATCH" → "Digest mismatch"
    Unknown/empty returns the input unchanged.
    """
    if not reason:
        return reason
    s = reason.lower().replace("_", " ")
    return s[0].upper() + s[1:] if s else s

def _bes_get(obj, field, default = None):
    """Safely access a single attribute on a BES event object.

    Returns default if obj is None or if the attribute is not present on the
    object (i.e. the field name doesn't match the deserialized proto schema).

    This prevents AttributeError on malformed or schema-mismatched BES events.
    For chained access (e.g. payload.stderr.file) call it twice:
        uri = _bes_get(_bes_get(payload, "stderr"), "file", "")
    """
    if obj == None:
        return default
    return getattr(obj, field, default)

def _file_uri_to_path(uri):
    """Convert a file:// or bytestream:// URI to a local filesystem path.

    bytestream:// URIs are resolved via the bb_clientd FUSE mount:
      bytestream://host:port/blobs/<hash>/<size>
      -> {_BB_CLIENTD_ROOT}/cas/{host}/blobs/sha256/file/{hash}-{size}
    """
    if not uri:
        return uri
    if uri.startswith("file://"):
        return uri[len("file://"):]
    if uri.startswith("bytestream://"):
        rest = uri[len("bytestream://"):]
        parts = rest.split("/")
        host_port = parts[0]
        host = host_port.split(":")[0]
        blob_hash = parts[2]
        blob_size = parts[3]
        return _BB_CLIENTD_ROOT + "/cas/" + host + "/blobs/sha256/file/" + blob_hash + "-" + blob_size
    return uri

def _repro_with_prefix(prefix, labels, max_chars):
    """Build a '<prefix> <labels>' repro command string.

    Truncates the label list so the total command length does not exceed
    max_chars characters.

    Args:
        prefix:    leading command (e.g. "bazel build", "aspect mytask")
        labels:    list of target labels to include
        max_chars: maximum character length of the returned command

    Returns:
        (cmd: str, n_included: int) — cmd is the repro command (empty string
        if no labels fit), n_included is how many labels were included.
    """
    base = prefix + " "
    included = []
    used = len(base)
    for label in labels:
        needed = len(label) + 1  # +1 for the separating space
        if used + needed > max_chars:
            break
        included.append(label)
        used += needed
    if not included:
        return ("", 0)
    return (base + " ".join(included), len(included))

def init_data():
    """Create a fresh data accumulator.

    Two-tier shape: task-managed scalars at the root, BES-derived
    bazel state under `["bazel"]`. Everything under "Bazel details"
    in the rendered body reads from `data["bazel"][...]`; task-driven
    scalars (start/finish time, target pattern, sink invocation id,
    repro/fix command lists) stay at the root so non-bazel tasks
    can populate them too.

    See `crates/aspect-cli/src/builtins/aspect/DEVELOPMENT.md` for
    the full schema.
    """
    return {
        # ---------- Task-managed scalars (root) ----------
        # Build start / finish in milliseconds since epoch. For build/test
        # these come from BES (build_started.start_time_millis,
        # build_finished.finish_time_millis) — populated by process_event.
        # For non-bazel tasks (lint/format/gazelle/delivery) the task code
        # stamps them itself with `now_ms(ctx)`.
        "start_time_ms": 0,
        "finish_time_ms": 0,
        # Space-joined target pattern from the task's args. Set by the
        # task impl, used by the renderer for the "Targets" subject line.
        "target_pattern": "",
        # Invocation ID minted by the gRPC BES sinks for the Aspect Web UI
        # / other backends. Set by bazel_runner.axl after Build::spawn
        # returns; empty when no BES sinks were configured. Differs from
        # build_started.uuid (which Bazel generates server-side).
        "sink_invocation_id": "",
        # Repro & fix commands authored by the producer at
        # terminal-emit time. Each entry is `{"command", "description"}`.
        # See `lib/repro_commands.axl` for helpers and shape.
        "repro_commands": [],
        "fix_commands": [],
        # Per-attempt history when bazel retried. Empty on the common
        # single-attempt path; gates the rendered "🔁 Retry attempts"
        # body section. Each entry: `{attempt (1-indexed), exit_code,
        # sink_invocation_id, bazel (full sub-dict snapshot)}`.
        # Populated by `archive_bazel_attempt` from the two retry-loop
        # callers (`bazel_runner.run_bazel_task`,
        # `delivery._get_output_shas`).
        "bazel_attempts": [],

        # ---------- Bazel state (BES-derived) ----------
        # Everything Bazel emits via the Build Event Protocol lands here.
        # Populated by `process_event(data, event)` as events stream.
        # Tasks that don't run bazel leave this dict at its zero/empty
        # defaults; the renderer skips empty sub-blocks.
        "bazel": {
            # Failed build targets (not test-related): [{label}]
            "failed_targets": [],
            # Failed build actions, grouped by target label:
            #   [{label, mnemonics}]   where mnemonics = deduped list of strings
            # Capped at MAX_FAILED_ACTIONS unique labels. Deliberately NOT capturing
            # stderr — BES action events can carry 40+ MB inline and we don't want
            # that on the Starlark heap. The CI link covers the raw log.
            "failed_actions": [],
            # Total failed action count (may exceed len(failed_actions) due to cap)
            "failed_actions_total": 0,
            # Deduplicated list of target labels that had at least one failed action.
            # Uncapped (strings only, bounded by unique target count). Used to
            # partition failed_targets into root failures (own action failed, stderr
            # available) vs derived failures (no own action failed — a dep broke).
            "failed_action_labels": [],

            # Test outcomes: [{label, cached, duration_ms}]
            # duration_ms comes from test_summary.total_run_duration_millis.
            "failed_tests": [],
            "flaky_tests": [],
            "passed_tests": [],
            # Aggregate test counts.
            "passed_test_total": 0,
            "failed_test_total": 0,
            "flaky_test_total": 0,
            "cached_test_total": 0,
            "executed_test_total": 0,
            # Wall-clock time for executed tests only (ms), from total_run_duration_millis.
            "executed_duration_ms": 0,
            # Wall-clock time for cached tests (ms) — represents time saved by the cache.
            "cached_duration_ms": 0,
            # Per-test detail from test_result events (keyed by label; last attempt wins):
            #   {label -> {"log_path": str, "duration_ms": int}}
            # log_path is a local filesystem path (resolved from the BES URI), or ""
            # if the file is remote / not yet available.
            "test_details": {},

            # Target inventory.
            # label -> rule kind (e.g. "cc_library", "py_test"), populated from
            # target_configured events. Used to detect test targets and display
            # the kind beside each label.
            "target_kinds": {},
            # All successfully-built target labels (test + non-test), capped at MAX_BUILT_TARGETS.
            "built_targets": [],
            # Total number of targets that completed (success + failure), from
            # counting target_completed events. Distinct from targets_configured.
            "targets_total": 0,
            # Counts from build_metrics.target_metrics.
            "targets_configured": 0,
            "targets_configured_not_including_aspects": 0,
            "targets_configured_counted": 0,

            # Build action metrics from the build_metrics event.
            "actions_executed": 0,
            "actions_cached": 0,
            "actions_total": 0,
            # Per-mnemonic action counts (e.g. CppCompile, Rustc, ...). Populated
            # preferentially from build_metrics.action_summary.action_data (Bazel's
            # authoritative tally that includes cached actions on incremental
            # rebuilds); falls back to our own action_completed event counter
            # until build_metrics arrives at the end of the stream.
            "action_mnemonics": {},
            # Per-runner action counts. Populated from
            # build_metrics.action_summary.runner_count. Empty on builds that
            # don't emit runner_count (older Bazel, partial output).
            "runner_counts": {},
            # Local (disk) action cache statistics from
            # build_metrics.action_cache_statistics. Distinct from the combined
            # hit rate in the summary — these numbers are the LOCAL cache only
            # (misses here may still hit remote cache).
            "action_cache_stats": {
                "hits": 0,
                "misses": 0,
                # List of {reason, count} for why local cache misses happened.
                "miss_details": [],
            },

            # Build phase timing (from build_metrics.timing_metrics).
            # 0 until build_metrics arrives.
            "wall_time_ms": 0,  # bazel-measured wall (excludes CLI overhead)
            "cpu_time_ms": 0,
            "analysis_phase_time_ms": 0,
            "execution_phase_time_ms": 0,
            # Wall time along the longest action chain — the floor on execution
            # parallelism. Captured from timing_metrics.critical_path_duration_millis
            # (Bazel 7+) or critical_path_in_ms (older). 0 when unavailable.
            "critical_path_ms": 0,

            # Number of packages loaded (from build_metrics.package_metrics).
            "packages_loaded": 0,
            # Cumulative analyses/builds from build_metrics.cumulative_metrics
            # (analysis cache age).
            "num_analyses": 0,
            "num_builds": 0,

            # Bazel invocation UUID from build_started event.
            "invocation_id": "",
            # Base URL of the BES data viewer. Parsed from the
            # structured_command_line event's `--bes_results_url` option.
            # Append invocation_id to get the full invocation URL. Empty when
            # --bes_results_url is not set.
            "bes_results_url": "",
            # Bazel tool version and command from build_started (e.g. "9.0.1", "test").
            "build_tool_version": "",
            "build_command": "",

            # CPU architecture and compilation mode from the configuration event.
            "cpu_arch": "",
            "compilation_mode": "",
            # Invocation physical details (from build_started event).
            # Populated once at the start; display-only — skip rows with empty values.
            "workspace_directory": "",
            "working_directory": "",
            "server_pid": 0,

            # Key=value pairs from the BES build_metadata event.
            # Populated by --build_metadata and --bes_metadata Bazel flags.
            # Standard keys produced by build_metadata.axl:
            #   BRANCH, COMMIT_SHA, COMMIT_MESSAGE, COMMIT_AUTHOR, COMMIT_TIMESTAMP,
            #   USER, CI, VCS, REPO, REPO_OWNER, TAG
            # Custom keys: anything the user injects via --bes_metadata=MY_KEY=value
            "metadata": {},
            # Key=value pairs from the BES workspace_status event.
            # Standard keys: BUILD_USER, BUILD_HOST, BUILD_TIMESTAMP
            # Custom keys: whatever the workspace_status script emits.
            "workspace_status": {},

            # Command-line views derived from the BES options_parsed event.
            # Modeled after Aspect's Web UI: one assembled "explicit" command
            # (the user-perceived command) plus browseable startup/cmd_line
            # option lists. Intentionally does NOT reconstruct from
            # structured_command_line — that produces full canonical output
            # including every .bazelrc default override and wrapper-injected
            # flag, which is noisy and unreadable.
            "options_parsed": {
                # User-specified flags only (pre-bazelrc, pre-config expansion).
                # Used with build_command + target pattern to assemble the
                # "explicit" copy-pasteable command shown in the check run.
                "explicit_cmd_line": [],
                # Fully-resolved startup options (post-bazelrc).
                "startup_options": [],
                # Fully-resolved command options (post-bazelrc, post-config expansion).
                "cmd_line": [],
            },

            # Abort information from the aborted event.
            "aborted": False,
            "abort_reason": "",  # snake_case proto enum, e.g. "interrupted", "analysis_failure"
            "abort_description": "",  # human-readable description from BES
        },
    }

def process_event(data, event):
    """Update data in-place from a single build event.

    All BES field accesses go through _bes_get() to guard against AttributeError
    on schema-mismatched or malformed events. Diagnostic warnings about missing
    BES fields go through `trace`, so they only surface under ASPECT_DEBUG
    or when an OTel endpoint is configured.

    Args:
        data: dict from init_data(), mutated in place
        event:   BuildEvent from BazelTrait.build_event hook

    Returns:
        True if data changed in a way that warrants a status check update,
        False otherwise.
    """
    kind = event.kind

    if kind == "build_started":
        # Retry: reset everything so we start fresh with the new event stream.
        # `sink_invocation_id` is task-managed (set by the task right after
        # `ctx.bazel.build(...)` returns, well before this event arrives) and
        # is intentionally preserved across the reset — wiping it would
        # silently drop the Aspect Workflows link from every annotation /
        # status check from the moment build_started lands.
        preserved_sink_id = data.get("sink_invocation_id", "") or ""
        fresh = init_data()
        for k in fresh:
            data[k] = fresh[k]
        data["sink_invocation_id"] = preserved_sink_id

        # Capture fields from build_started for invocation details.
        payload = event.payload
        uuid = _bes_get(payload, "uuid", "") or ""
        if not uuid:
            trace.log("warning: BES build_started event missing expected field 'uuid'")
        data["bazel"]["invocation_id"] = uuid
        data["bazel"]["build_tool_version"] = _bes_get(payload, "build_tool_version", "") or ""
        data["bazel"]["build_command"] = _bes_get(payload, "command", "") or ""
        data["start_time_ms"] = _bes_get(payload, "start_time_millis", 0) or 0
        data["bazel"]["workspace_directory"] = _bes_get(payload, "workspace_directory", "") or ""
        data["bazel"]["working_directory"] = _bes_get(payload, "working_directory", "") or ""
        data["bazel"]["server_pid"] = _bes_get(payload, "server_pid", 0) or 0

        # Return True so live task_updates pick up the first burst of metadata
        # (invocation_id, build_command, start_time, etc.) the moment bazel
        # emits build_started — without this, metadata only surfaces in the
        # annotation once the first target_completed event lands, which can
        # be several seconds into the build.
        return True

    elif kind == "structured_command_line":
        # We only need one piece of information from this event: bes_results_url
        # (rendered as the "View invocation" link). Full-command reconstruction
        # is done from the cleaner options_parsed event instead — see below.
        payload = event.payload
        if payload:
            for section in (_bes_get(payload, "sections", None) or []):
                sec_type = _bes_get(section, "section_type", None)
                if sec_type:
                    for opt in (_bes_get(sec_type, "option", None) or []):
                        if _bes_get(opt, "option_name", "") == "bes_results_url":
                            val = _bes_get(opt, "option_value", "") or ""
                            if val:
                                data["bazel"]["bes_results_url"] = val
                                trace.log("debug: captured bes_results_url=" + val)
                            break
        return False

    elif kind == "options_parsed":
        # Authoritative source for the command-line views we display. Mirrors what
        # Aspect's Web UI does — show one assembled "Explicit" command
        # (what the user perceives) plus two browseable lists of parsed options
        # (startup + cmd_line), both fully resolved. Avoids the noisy raw form of
        # structured_command_line which dumps every .bazelrc default override.
        payload = event.payload
        if payload:
            data["bazel"]["options_parsed"]["explicit_cmd_line"] = list(_bes_get(payload, "explicit_cmd_line", None) or [])
            data["bazel"]["options_parsed"]["startup_options"] = list(_bes_get(payload, "startup_options", None) or [])
            data["bazel"]["options_parsed"]["cmd_line"] = list(_bes_get(payload, "cmd_line", None) or [])

            # Fallback capture of bes_results_url in case the structured_command_line
            # event arrives after us or is absent.
            if not data["bazel"].get("bes_results_url"):
                for arg in data["bazel"]["options_parsed"]["cmd_line"]:
                    if arg.startswith("--bes_results_url="):
                        data["bazel"]["bes_results_url"] = arg[len("--bes_results_url="):]
                        break
            trace.log("debug: options_parsed explicit=" + str(len(data["bazel"]["options_parsed"]["explicit_cmd_line"])) +
                      " startup=" + str(len(data["bazel"]["options_parsed"]["startup_options"])) +
                      " cmd=" + str(len(data["bazel"]["options_parsed"]["cmd_line"])))

        # Trigger a live update — the "Explicit command line" / "Options
        # parsed" detail blocks are populated entirely from this event and
        # users expect them to appear in the annotation as soon as they're
        # available, not only once a target completes.
        return True

    elif kind == "build_metadata":
        # Merge --build_metadata and --bes_metadata key=value pairs into data.
        # This event arrives once per invocation, early in the stream.
        payload = event.payload
        if payload:
            payload_meta = _bes_get(payload, "metadata", None)
            if payload_meta:
                for k, v in payload_meta.items():
                    if k and v:
                        data["bazel"]["metadata"][k] = v

        # Trigger a live update — row 2 (repo / PR / branch / commit / trigger)
        # and the Build Metadata detail block are populated from this event.
        return True

    elif kind == "workspace_status":
        # Capture workspace status variables (BUILD_USER, BUILD_HOST, etc.).
        # The proto field is `item` — a repeated list of {key, value} structs.
        payload = event.payload
        if payload:
            for ws_item in (_bes_get(payload, "item", None) or []):
                if ws_item:
                    key = _bes_get(ws_item, "key", "") or ""
                    val = _bes_get(ws_item, "value", "") or ""
                    if key and val:
                        data["bazel"]["workspace_status"][key] = val

        # Trigger a live update — row 1's user/host segments and the
        # Workspace Status detail block are populated from this event.
        return True

    elif kind == "action_completed":
        payload = event.payload
        success = _bes_get(payload, "success", None)
        label = _bes_get(event.id, "label", "") or ""

        # Mnemonic is small (unlike payload.stderr, which Bazel may inline at
        # 40+ MB — we deliberately never touch it) and useful for the failure
        # listing. Per-mnemonic build-wide totals are read authoritatively from
        # build_metrics.action_summary.action_data when build_metrics arrives
        # (that tally includes cached actions which never fire this event, so
        # counting here would systematically under-report on incremental builds).
        mnemonic = _bes_get(payload, "type", "") or ""
        if success == None:
            trace.log("warning: BES action_completed event missing expected field 'success' (label=" + label + ")")
        if not success:
            data["bazel"]["failed_actions_total"] += 1

            # Track unique labels of targets whose own actions failed (root
            # failures). Uncapped, strings only — used to classify derived
            # failures (failed_targets without a matching failed action).
            if label and label not in data["bazel"]["failed_action_labels"]:
                data["bazel"]["failed_action_labels"].append(label)

            # Group by label: one entry per unique target, deduped list of
            # mnemonics (a single target can emit multiple failed actions —
            # CppCompile + CppLink, for instance).
            entry = None
            for a in data["bazel"]["failed_actions"]:
                if a.get("label", "") == label:
                    entry = a
                    break
            if entry:
                if mnemonic and mnemonic not in entry["mnemonics"]:
                    entry["mnemonics"].append(mnemonic)
            elif len(data["bazel"]["failed_actions"]) < MAX_FAILED_ACTIONS:
                data["bazel"]["failed_actions"].append({
                    "label": label,
                    "mnemonics": [mnemonic] if mnemonic else [],
                })
                return True
        return False

    elif kind == "target_configured":
        # target_configured carries the rule kind (e.g. "cc_library rule",
        # "py_test rule"); target_completed does NOT. Capture it into target_kinds
        # so later handlers (target_completed, test_summary) can enrich their
        # entries and the renderer can detect tests via kind.endswith("_test").
        #
        # Bazel appends " rule" to the kind string (e.g. "cc_test rule"); strip
        # that suffix so display is clean and _is_test_kind can use "_test".
        #
        # Also bump our own targets_configured tally. Bazel emits this event
        # for every target in the request scope — including those resolved
        # from skyframe on incremental rebuilds — so this counter stays
        # accurate when build_metrics reports zero newly-configured targets.
        payload = event.payload
        label = _bes_get(event.id, "label", "") or ""
        target_kind = _bes_get(payload, "target_kind", "") or ""
        if target_kind.endswith(" rule"):
            target_kind = target_kind[:-len(" rule")]
        if label and target_kind:
            data["bazel"]["target_kinds"][label] = target_kind
        data["bazel"]["targets_configured_counted"] += 1
        return False

    elif kind == "target_completed":
        data["bazel"]["targets_total"] += 1
        payload = event.payload
        success = _bes_get(payload, "success", None)
        label = _bes_get(event.id, "label", "") or ""

        # Kind was captured on the prior target_configured event.
        target_kind = data["bazel"]["target_kinds"].get(label, "") if label else ""
        if success == None:
            trace.log("warning: BES target_completed event missing expected field 'success' (label=" + label + ")")
        if not success:
            data["bazel"]["failed_targets"].append({"label": label, "kind": target_kind})
            return True
        elif label and len(data["bazel"]["built_targets"]) < MAX_BUILT_TARGETS:
            data["bazel"]["built_targets"].append({"label": label, "kind": target_kind})
        return False

    elif kind == "test_result":
        # Capture the log file URI and duration for the most recent attempt.
        # test_result fires once per shard/run/attempt; the last write wins.
        # test_summary (processed later) provides the authoritative final outcome.
        label = _bes_get(event.id, "label", "") or ""
        payload = event.payload
        log_uri = ""
        if payload:
            for output in (_bes_get(payload, "test_action_output", None) or []):
                if output and _bes_get(output, "name", "") == "test.log":
                    log_uri = _bes_get(output, "file", "") or ""
                    break
        duration_ms = (_bes_get(payload, "test_attempt_duration_millis", 0) or 0) if payload else 0
        data["bazel"]["test_details"][label] = {
            "log_path": _file_uri_to_path(log_uri),
            "duration_ms": duration_ms,
        }

        # No status update — test_summary provides the authoritative signal.
        return False

    elif kind == "test_summary":
        payload = event.payload
        status = _bes_get(payload, "overall_status", "") or ""
        label = _bes_get(event.id, "label", "") or ""
        num_cached = _bes_get(payload, "total_num_cached", 0) or 0

        # total_run_duration_millis is deprecated in the proto but still populated by Bazel.
        # Bucket duration by whether the test actually ran or was served from cache.
        duration_ms = _bes_get(payload, "total_run_duration_millis", 0) or 0
        if not status:
            trace.log("warning: BES test_summary event missing expected field 'overall_status' (label=" + label + ")")
        if not label:
            trace.log("warning: BES test_summary event missing expected field 'id.label'")
        cached = num_cached > 0
        if cached:
            if duration_ms:
                data["bazel"]["cached_duration_ms"] += duration_ms
        else:
            data["bazel"]["executed_test_total"] += 1
            if duration_ms:
                data["bazel"]["executed_duration_ms"] += duration_ms

        total_tracked = (len(data["bazel"]["failed_tests"]) +
                         len(data["bazel"]["flaky_tests"]) +
                         len(data["bazel"]["passed_tests"]))

        if status in _FAILED_STATUSES:
            data["bazel"]["failed_test_total"] += 1
            if total_tracked < MAX_TEST_TARGETS:
                data["bazel"]["failed_tests"].append({
                    "label": label,
                    "cached": cached,
                    "duration_ms": duration_ms,
                    "kind": data["bazel"]["target_kinds"].get(label, ""),
                    # Carry the raw BES status so _compute_bucket_counts /
                    # build_details_data can split into TEST_FAILED vs
                    # TEST_TIMEOUT vs FAILED_TO_BUILD buckets.
                    "status": status,
                })
            return True
        elif status == _TEST_STATUS_FLAKY:
            data["bazel"]["flaky_test_total"] += 1
            if total_tracked < MAX_TEST_TARGETS:
                data["bazel"]["flaky_tests"].append({
                    "label": label,
                    "cached": cached,
                    "duration_ms": duration_ms,
                    "kind": data["bazel"]["target_kinds"].get(label, ""),
                })
            return True
        else:
            # PASSED is the common case. NO_STATUS (target wasn't run / filtered)
            # and INCOMPLETE (test was interrupted) also land here — neither is a
            # strict "pass", but we have no dedicated bucket for them and they're
            # rare enough that lumping them in gives a closer answer than calling
            # them failures would.
            data["bazel"]["passed_test_total"] += 1
            if cached:
                data["bazel"]["cached_test_total"] += 1
            if label and total_tracked < MAX_TEST_TARGETS:
                data["bazel"]["passed_tests"].append({
                    "label": label,
                    "cached": cached,
                    "duration_ms": duration_ms,
                    "kind": data["bazel"]["target_kinds"].get(label, ""),
                })
        return False

    elif kind == "build_metrics":
        payload = event.payload
        action_summary = _bes_get(payload, "action_summary", None)
        if action_summary:
            executed = _bes_get(action_summary, "actions_executed", 0) or 0

            # Use total - executed rather than remote_cache_hits (deprecated) because
            # this captures local cache hits too, giving a more accurate cached count.
            total = _bes_get(action_summary, "actions_created", 0) or 0
            data["bazel"]["actions_executed"] = executed
            data["bazel"]["actions_cached"] = total - executed if total > executed else 0
            data["bazel"]["actions_total"] = total

            # Prefer Bazel's per-mnemonic tally over our event-based counter.
            # Reason: on fully-incremental rebuilds Bazel skips action_completed
            # events for cached actions, so the event counter under-reports.
            # action_summary.action_data is Bazel's authoritative tally and
            # includes all action slots Bazel evaluated this build.
            #
            # Also sum per-mnemonic `actions_created` — on incremental rebuilds
            # Bazel leaves the top-level `actions_created` at 0 but still
            # populates the per-mnemonic values, so summing here recovers the
            # aspect-inclusive grand total for the "Actions (N created)" line.
            per_mnemonic = {}
            per_mnemonic_sum_created = 0
            for ad in (_bes_get(action_summary, "action_data", None) or []):
                if ad:
                    m = _bes_get(ad, "mnemonic", "") or ""
                    c = _bes_get(ad, "actions_executed", 0) or 0
                    if m and c > 0:
                        per_mnemonic[m] = per_mnemonic.get(m, 0) + c
                    created = _bes_get(ad, "actions_created", 0) or 0
                    if created > 0:
                        per_mnemonic_sum_created += created
            if per_mnemonic:
                data["bazel"]["action_mnemonics"] = per_mnemonic

            # If the top-level `actions_created` was 0 (common on incremental
            # rebuilds where Bazel only tallies new action definitions), fall
            # back to the sum of per-mnemonic created counts.
            if data["bazel"]["actions_total"] == 0 and per_mnemonic_sum_created > 0:
                data["bazel"]["actions_total"] = per_mnemonic_sum_created

            # Per-runner action counts (local, remote cache hit, internal, etc.).
            # Skip the synthetic "total" entry Bazel emits — it sums the rest,
            # and including it would double-count in the distribution table
            # and make the percentages add up to 200%.
            per_runner = {}
            for rc in (_bes_get(action_summary, "runner_count", None) or []):
                if rc:
                    name = _bes_get(rc, "name", "") or ""
                    count = _bes_get(rc, "count", 0) or 0
                    exec_kind = _bes_get(rc, "exec_kind", "") or ""
                    if name == "total":
                        continue
                    if name and count > 0:
                        # Include exec_kind in the display name so Remote/Local
                        # distinction stays visible ("remote cache hit · Remote").
                        display = name + (" · " + exec_kind if exec_kind else "")
                        per_runner[display] = per_runner.get(display, 0) + count
            if per_runner:
                data["bazel"]["runner_counts"] = per_runner
        else:
            trace.log("warning: BES build_metrics event missing expected field 'action_summary'")
        timing_metrics = _bes_get(payload, "timing_metrics", None)
        if timing_metrics:
            wall_time = _bes_get(timing_metrics, "wall_time_in_ms", 0) or 0
            if wall_time > 0:
                data["bazel"]["wall_time_ms"] = wall_time
            cpu_time = _bes_get(timing_metrics, "cpu_time_in_ms", 0) or 0
            if cpu_time > 0:
                data["bazel"]["cpu_time_ms"] = cpu_time
            analysis_time = _bes_get(timing_metrics, "analysis_phase_time_in_ms", 0) or 0
            if analysis_time > 0:
                data["bazel"]["analysis_phase_time_ms"] = analysis_time
            execution_time = _bes_get(timing_metrics, "execution_phase_time_in_ms", 0) or 0
            if execution_time > 0:
                data["bazel"]["execution_phase_time_ms"] = execution_time

            # Critical path — the sum of wall time along the longest action
            # chain (the floor on parallelism). In Bazel 7+ the field is a
            # google.protobuf.Duration (seconds + nanos), not an int-ms, so
            # we have to decode it. Older Bazel used int-ms fields; we check
            # both shapes so we work across versions.
            cp_field = _bes_get(timing_metrics, "critical_path_time", None)
            cp_ms = 0
            if cp_field != None:
                # Duration proto: {seconds, nanos}. AXL surfaces it as a
                # struct/dict-ish with those fields; fall back to 0 when either
                # is missing so a stray {} entry doesn't blow up arithmetic.
                cp_secs = _bes_get(cp_field, "seconds", 0) or 0
                cp_nanos = _bes_get(cp_field, "nanos", 0) or 0
                cp_ms = cp_secs * 1000 + cp_nanos // 1000000
            if cp_ms == 0:
                cp_ms = (_bes_get(timing_metrics, "critical_path_duration_millis", 0) or
                         _bes_get(timing_metrics, "critical_path_in_ms", 0) or 0)
            if cp_ms > 0:
                data["bazel"]["critical_path_ms"] = cp_ms
        target_metrics = _bes_get(payload, "target_metrics", None)
        if target_metrics:
            configured = _bes_get(target_metrics, "targets_configured", 0) or 0
            if configured > 0:
                data["bazel"]["targets_configured"] = configured

            # Bazel distinguishes "targets_configured" (rule + aspect) from
            # "targets_configured_not_including_aspects" (just rule targets).
            # We keep both so the Performance section's Build graph row can split them:
            #   "134,094 configured, 133 aspect applications".
            without_aspects = _bes_get(target_metrics, "targets_configured_not_including_aspects", 0) or 0
            if without_aspects > 0:
                data["bazel"]["targets_configured_not_including_aspects"] = without_aspects
        package_metrics = _bes_get(payload, "package_metrics", None)
        if package_metrics:
            loaded = _bes_get(package_metrics, "packages_loaded", 0) or 0
            if loaded > 0:
                data["bazel"]["packages_loaded"] = loaded
        cumulative_metrics = _bes_get(payload, "cumulative_metrics", None)
        if cumulative_metrics:
            num_analyses = _bes_get(cumulative_metrics, "num_analyses", 0) or 0
            num_builds = _bes_get(cumulative_metrics, "num_builds", 0) or 0
            if num_analyses > 0:
                data["bazel"]["num_analyses"] = num_analyses
            if num_builds > 0:
                data["bazel"]["num_builds"] = num_builds

        # Local action cache — hits/misses and reasons for misses.
        action_cache = _bes_get(payload, "action_cache_statistics", None)
        if action_cache:
            hits = _bes_get(action_cache, "hits", 0) or 0
            misses = _bes_get(action_cache, "misses", 0) or 0
            data["bazel"]["action_cache_stats"]["hits"] = hits
            data["bazel"]["action_cache_stats"]["misses"] = misses
            md_list = []
            for md in (_bes_get(action_cache, "miss_details", None) or []):
                if md:
                    reason = _bes_get(md, "reason", "") or ""
                    count = _bes_get(md, "count", 0) or 0
                    if reason and count > 0:
                        md_list.append({"reason": reason, "count": count})
            if md_list:
                data["bazel"]["action_cache_stats"]["miss_details"] = md_list
        trace.log("debug: build_metrics wall_time_ms=" + str(data["bazel"]["wall_time_ms"]) +
                  " cpu_time_ms=" + str(data["bazel"]["cpu_time_ms"]) +
                  " targets_configured=" + str(data["bazel"]["targets_configured"]) +
                  " packages_loaded=" + str(data["bazel"]["packages_loaded"]))
        return True

    elif kind == "build_finished":
        # Populated once at the very end of the stream.
        payload = event.payload
        if payload:
            finish_ms = _bes_get(payload, "finish_time_millis", 0) or 0
            if finish_ms > 0:
                data["finish_time_ms"] = finish_ms
        return False

    elif kind == "configuration":
        # Configuration events fire once per build configuration — for exec/
        # tool configs, the target config, and any transitions. Strategy:
        #   • Skip the sentinel `id == "none"` event (metadata placeholder).
        #   • Simple last-writer-wins across the remaining configs — the
        #     target configuration typically arrives after exec/tool configs.
        #   • Read from `make_variable.TARGET_CPU` / `make_variable.COMPILATION_MODE`.
        #     These carry the Bazel-idiomatic names users recognize
        #     ("aarch64", "fastbuild"); the top-level `cpu` field is the
        #     internal platform name ("darwin_arm64") which reads poorly.
        id_config = _bes_get(event.id, "configuration", None)
        config_id = _bes_get(id_config, "id", "") or ""
        if config_id == "none":
            return False
        payload = event.payload
        cpu_or_mode_changed = False
        if payload:
            make_vars = _bes_get(payload, "make_variable", None)
            cpu = ""
            mode = ""
            if make_vars:
                cpu = make_vars.get("TARGET_CPU", "") or ""
                mode = make_vars.get("COMPILATION_MODE", "") or ""

            # Fallback to top-level fields for older Bazel that may not
            # populate make_variable. Matches our prior behavior.
            if not cpu:
                cpu = _bes_get(payload, "cpu", "") or ""
            if not mode:
                mode = _bes_get(payload, "compilation_mode", "") or ""
            if cpu:
                data["bazel"]["cpu_arch"] = cpu
                cpu_or_mode_changed = True
            if mode:
                data["bazel"]["compilation_mode"] = mode
                cpu_or_mode_changed = True

        # Trigger a live update if the row-3 cpu/mode segments changed.
        return cpu_or_mode_changed

    elif kind == "aborted":
        data["bazel"]["aborted"] = True
        payload = event.payload
        if payload:
            data["bazel"]["abort_reason"] = _bes_get(payload, "abort_reason", "") or ""
            data["bazel"]["abort_description"] = _bes_get(payload, "description", "") or ""
        return True

    return False

def resolve_aspect_url(links, data):
    """Return the Aspect Web UI URL for an invocation, or "" if unavailable.

    The Aspect Web UI indexes invocations by the UUID the gRPC sink
    (`stream_sink.rs`) mints when it spawns BES subscribers. We read BES
    events from Bazel via a unix socket and forward the stream before
    `build_started` arrives with Bazel's own UUID, so the sink makes up
    its own UUID up-front and uses *that* as the stream-level
    invocation_id the backend sees. The URL must be keyed on
    `sink_invocation_id` (Bazel's own `invocation_id` is a different UUID
    that the Aspect backend has no record of).

    Tasks that build with sinks active populate `data["sink_invocation_id"]`
    by reading `build.sink_invocation_id` immediately after
    `ctx.bazel.build(...)` returns (the runtime mints the UUID inside
    `Build::spawn` before returning, so the field is available before
    the BES loop). See `bazel_runner.axl` for the canonical pattern.
    Tasks whose builds run without sinks leave the field empty — and we
    suppress the link rather than rendering a 404-bound URL keyed on
    Bazel's UUID.

    Treats `links["results_base_url"]` (sourced from
    `WorkflowsEnvironment.build_events.results_url` by the per-surface
    feature impl) like Bazel treats its own `--bes_results_url`: the
    URL prefix to append the invocation ID to. The Aspect Web UI uses
    `{base}/{id}` with no `/invocations/` segment, so the base is just
    the bare host. Typical value:

        ASPECT_WORKFLOWS_BES_RESULTS_URL=https://app.oss.aspect.build

    The join below is `endswith("/")`-tolerant — both the typical
    no-trailing-slash form and the with-trailing-slash variant produce
    the same `{base}/{id}` URL with exactly one `/` between them.
    """
    base = links.get("results_base_url", "") if links else ""
    if not base:
        return ""
    inv_id = data.get("sink_invocation_id", "") or ""
    if not inv_id:
        return ""
    return (base if base.endswith("/") else base + "/") + inv_id

def failed_labels(data):
    """Collect the deduplicated list of failed target labels from `data["bazel"]`.

    Merges action-level failures (preferred when present — finer-grained, has
    stderr), target-level failures (fallback for derived breakage with no own
    action failure), and failed test labels into one list with insertion-order
    dedup. Used by the repro-command builder to narrow a CI rerun to just the
    labels that actually broke.

    Pure function — does NOT mutate `data`.
    """
    seen = {}
    labels = []

    # Action-level failures first (most precise — these are the ones with stderr).
    for a in data["bazel"].get("failed_actions", []):
        lbl = a.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            labels.append(lbl)

    # Target-level failures (covers derived failures with no own action failure).
    for t in data["bazel"].get("failed_targets", []):
        lbl = t.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            labels.append(lbl)

    # Failed test targets.
    for t in data["bazel"].get("failed_tests", []):
        lbl = t.get("label", "")
        if lbl and lbl not in seen:
            seen[lbl] = True
            labels.append(lbl)

    return labels

def compute_reproducer_command(data, task_name, max_chars = MAX_REPRO_CHARS):
    """Legacy helper preserved for test fixtures. New code should append
    `{"command", "description"}` entries to `data["repro_commands"]`
    directly via `lib/repro_commands.axl::build_aspect_command`.

    Returns `(command, total)` from the deduped failure-label set.
    """
    labels = failed_labels(data)
    cmd, _ = _repro_with_prefix("aspect " + task_name, labels, max_chars)
    return (cmd, len(labels))

_TITLE_MAX_LEN = 160
_TITLE_SUBJECT_MAX = 60

def _truncate_for_title(text, max_len):
    """Truncate text for a GitHub check title, preserving word boundaries where possible."""
    if len(text) <= max_len:
        return text
    window = text[:max_len - 1]
    last_space = window.rfind(" ")
    if last_space > max_len // 2:
        return window[:last_space] + "…"
    return window + "…"

def summary_title(data, status, target_pattern = "", task_name = ""):
    """Build the check run title in the form '<status_emoji> <task_name> <subject> · <state>'.

    Mirrors Aspect Web UI conventions — see _BUCKET_INVOCATION_LABELS
    for the state vocabulary and compute_invocation_state for priority rules.

    Examples:
        "🔄 test //... · Running..."
        "✅ test //... · Tests passed (cached)"
        "❌ build //... · Failed to build"
        "🔥 deploy production · Invocation disconnected"

    Args:
        data:           dict from init_data()
        status:         "running" | "failing" | "passed" | "failed" | "warning" | "aborted"
        target_pattern: subject (e.g. "//..." for a build/test task)
        task_name:      raw task identifier (`ctx.task.name`) — the
                        lowercase string declared on `task(name=...)`.

    Returns:
        str — max 160 chars (GitHub check title limit)
    """
    subject = _truncate_for_title(target_pattern, _TITLE_SUBJECT_MAX) if target_pattern else ""
    state = compute_invocation_state(data, status)
    icon = emoji_for_status(status)

    # `{icon} {task} {subject}` reads naturally as the "what"; the
    # state clause then gets a `·` separator as the outcome.
    front_parts = []
    if task_name:
        front_parts.append(icon + " " + task_name)
    else:
        front_parts.append(icon)
    if subject:
        front_parts.append(subject)
    front = " ".join(front_parts)

    if front and state:
        title = front + " · " + state
    elif front:
        title = front
    else:
        title = state
    return _truncate_for_title(title, _TITLE_MAX_LEN)

def now_ms(ctx):
    """Return current time as milliseconds since epoch.

    Used for rate-limiting status check updates.

    Uses `date '+%s000'` (epoch seconds + literal "000") rather than `%3N`
    because macOS date does not support the `%N` nanoseconds format.
    The result is rounded to the nearest second, which is sufficient for the
    1-second default throttle interval.
    """
    result = ctx.std.process.command("date").args(["+%s000"]).stdout("piped").spawn().wait_with_output()
    if result.status.code == 0:
        val = result.stdout.strip()
        if val:
            return int(val)
    return 0

# ---------------------------------------------------------------------------
# Check run rendering — Jinja2 templates and data builders for the
# "bazel_results" task_update kind.
#
# render_check_output() is the public entry point. Callers pass:
#   ctx       — TaskContext
#   data   — dict from init_data(), updated by process_event
#   status    — "running" | "failing" | "passed" | "failed"
#   render_ctx — feature-supplied display context (see render_check_output docstring)
#   links     — dict with keys ci_label, ci_url, aspect_url, bes_invocation_url
#   templates — optional override dict from GitHubStatusChecksTrait.templates
#   metadata_keys — optional list of extra BES metadata keys to surface
# ---------------------------------------------------------------------------

# Standard BES metadata keys that have dedicated template slots.
# These are excluded from the extra_meta list even when metadata_keys=["*"].
RENDER_META_STANDARD_KEYS = [
    "BRANCH_NAME",
    "COMMIT_SHA",
    "TAG",
    "COMMIT_MESSAGE",
    "COMMIT_AUTHOR",
    "COMMIT_AUTHOR_EMAIL",
    "COMMIT_AUTHOR_NAME",
    "COMMIT_TIMESTAMP",
    "USER",
    "CI_HOST",
    "VCS",
    "REPO_NAME",
    "REPO_OWNER",
    "REPO_URL",
    "ASPECT_TASK_NAME",
    "ASPECT_TASK_ID",
    "ASPECT_TASK_URL",
    "BUILD_URL",
    "BUILD_NUMBER",
    "RUN_TYPE",
    "PR_ID",
    "PR_NUMBER",
    "PR_SOURCE_BRANCH_NAME",
    "PR_TARGET_BRANCH_NAME",
    "TAGS",
    "ASPECT_WORKFLOWS_LINKS",
]

# ---------------------------------------------------------------------------
# VCS helpers — mirror the Aspect Web UI (silo kilgore/app/layout/header/
# ExecutionContext.tsx) so users get the same link shape across both surfaces.
# ---------------------------------------------------------------------------

# Per-VCS URL shape. Display name and icon are used in the summary line.
_VCS_CONFIG = {
    "GITHUB": {
        "domain": "github.com",
        "tree_path": "/tree",
        "commit_path": "/commit",
        "pr_path": "/pull",
        "display_name": "GitHub",
        "icon": ":octocat:",
    },
    "GITLAB": {
        "domain": "gitlab.com",
        "tree_path": "/-/tree",
        "commit_path": "/-/commit",
        "pr_path": "/-/merge_requests",
        "display_name": "GitLab",
        "icon": "🦊",
    },
    "BITBUCKET": {
        "domain": "bitbucket.org",
        "tree_path": "/src",
        "commit_path": "/commits",
        "pr_path": "/pull-requests",
        "display_name": "Bitbucket",
        "icon": "🪣",
    },
}

def merged_meta(data):
    """Merge build_metadata and workspace_status into one dict.

    --build_metadata values take precedence over workspace_status when both set
    the same key — matches the Aspect Web UI getBuildMetadataValue() semantics
    (silo kilgore/app/util/buildMetadata.ts). Empty values are skipped so a
    blank workspace_status entry doesn't shadow a populated build_metadata one.
    """
    merged = {}
    for k, v in (data["bazel"].get("workspace_status", {}) or {}).items():
        if k and v:
            merged[k] = v
    for k, v in (data["bazel"].get("metadata", {}) or {}).items():
        if k and v:
            merged[k] = v
    return merged

def _owner_repo_from_url(url):
    """Extract (owner, repo) from a repo URL like https://host/owner/repo.

    Returns ("", "") if the URL doesn't have that shape. Strips trailing
    slashes and a trailing ".git" suffix. Supports nested groups by taking
    the last segment as the repo name (matches GitLab URL semantics).
    """
    if not url:
        return ("", "")
    rest = url
    scheme_end = rest.find("://")
    if scheme_end >= 0:
        rest = rest[scheme_end + 3:]

    # Drop the host segment.
    slash = rest.find("/")
    if slash < 0:
        return ("", "")
    path = rest[slash + 1:]
    if path.endswith("/"):
        path = path[:-1]
    if path.endswith(".git"):
        path = path[:-len(".git")]
    parts = path.split("/")
    if len(parts) < 2:
        return ("", "")
    return (parts[0], parts[-1])

def vcs_info(meta):
    """Return VCS link info for the status-check summary, or None when unknown.

    Requires VCS plus either REPO_URL (preferred — supports self-hosted hosts
    like github.mycorp.com or gitlab.mycorp.com with the correct authority) OR
    REPO_OWNER + REPO_NAME (legacy fallback, hardcodes the public domain).

    When REPO_URL is provided, owner/repo are parsed from it rather than read
    from REPO_OWNER/REPO_NAME. That way `REPO_URL` is self-consistent as an
    override — callers don't have to coordinate the URL with separate keys.
    """
    vcs = (meta.get("VCS") or "").upper()
    if not vcs or vcs not in _VCS_CONFIG:
        return None
    c = _VCS_CONFIG[vcs]
    repo_url = meta.get("REPO_URL", "")
    repo_owner = ""
    repo_name = ""
    if repo_url:
        (repo_owner, repo_name) = _owner_repo_from_url(repo_url)
    if not repo_owner or not repo_name:
        repo_owner = meta.get("REPO_OWNER") or repo_owner
        repo_name = meta.get("REPO_NAME") or repo_name
    if not repo_url:
        if not repo_owner or not repo_name:
            return None
        repo_url = "https://" + c["domain"] + "/" + repo_owner + "/" + repo_name
    if repo_url.endswith("/"):
        repo_url = repo_url[:-1]
    return {
        "repo_url": repo_url,
        "repo_owner": repo_owner,
        "repo_name": repo_name,
        "tree_path": c["tree_path"],
        "commit_path": c["commit_path"],
        "pr_path": c["pr_path"],
        "display_name": c["display_name"],
        "icon": c["icon"],
    }

_TRIGGER_LABELS = {
    "BRANCH_PUSH": "Branch push run",
    "PULL_REQUEST": "Pull request run",
    "TAG": "Tag push run",
    "SCHEDULED": "Scheduled run",
    "MANUAL": "Manual run",
}

def _trigger_label(run_type):
    """Human-readable label for a RUN_TYPE metadata value."""
    return _TRIGGER_LABELS.get(run_type or "", "")

def parse_tags(meta):
    """Collect tags from TAGS (comma-separated) and TAG_* keys.

    TAGS is split on commas and stripped. Each TAG_X=Y key contributes "X=Y"
    (or just "X" when Y is empty). Keys are
    sorted so ordering is stable. Returns a list of display strings.
    """
    out = []
    seen = {}
    raw = meta.get("TAGS", "") or ""
    if raw:
        for t in raw.split(","):
            t = t.strip()
            if t and t not in seen:
                seen[t] = True
                out.append(t)
    for k in sorted(meta.keys()):
        if k.startswith("TAG_") and k != "TAGS":
            name = k[len("TAG_"):]
            val = meta[k]
            if name:
                display = name + "=" + val if val else name
                if display not in seen:
                    seen[display] = True
                    out.append(display)
    return out

def parse_workflows_links(meta):
    """Parse ASPECT_WORKFLOWS_LINKS as a list of {text, url}.

    Format:
        [text one](https://a.example),[text two](https://b.example)
    Entries are comma-separated at the top level. Only http:// and https://
    URLs are accepted; malformed entries are silently skipped.
    """
    raw = meta.get("ASPECT_WORKFLOWS_LINKS", "") or ""
    if not raw:
        return []
    out = []
    for part in raw.split(","):
        part = part.strip()
        if not part.startswith("[") or "](" not in part or not part.endswith(")"):
            continue
        rb = part.find("]")
        if rb <= 1:
            continue
        text = part[1:rb]
        if not part[rb + 1:].startswith("("):
            continue
        url = part[rb + 2:-1]
        if text and (url.startswith("http://") or url.startswith("https://")):
            out.append({"text": text, "url": url})
    return out

# ---------------------------------------------------------------------------
# Target buckets — mirror the Aspect Web UI Bucket enum and labels.
# Every target/test gets classified into exactly one bucket based on its final
# status. Buckets are used to render the details sections and to pick the
# single invocation state label surfaced in the title.
# ---------------------------------------------------------------------------

_BUCKET_TEST_FAILED = "test_failed"
_BUCKET_SUCCESSFUL_BUILD = "successful_build"
_BUCKET_TEST_TIMEOUT = "test_timeout"
_BUCKET_TEST_FLAKY = "test_flaky"
_BUCKET_FAILED_TO_BUILD = "failed_to_build"
_BUCKET_TEST_PASSED = "test_passed"
_BUCKET_TEST_PASSED_CACHED = "test_passed_cached"
_BUCKET_ABORTED_STATE = "aborted_state"
_BUCKET_SKIPPED = "skipped"
_BUCKET_PENDING = "pending"

# Header text shown above each bucket in the details output. {s} is a
# plural-s marker replaced by "" when the count is 1 and "s" otherwise.
_BUCKET_HEADERS = {
    _BUCKET_TEST_FAILED: "Test Failure{s}",
    _BUCKET_SUCCESSFUL_BUILD: "Target{s} Built",
    _BUCKET_TEST_TIMEOUT: "Test Timeout{s}",
    _BUCKET_TEST_FLAKY: "Test Flake{s}",
    _BUCKET_FAILED_TO_BUILD: "Build Failure{s}",
    _BUCKET_TEST_PASSED_CACHED: "Test{s} Cached",
    _BUCKET_TEST_PASSED: "Test{s} Passed",
    _BUCKET_ABORTED_STATE: "Target{s} Aborted",
    _BUCKET_SKIPPED: "Target{s} Skipped",
    _BUCKET_PENDING: "Target{s} Pending",
}

# Single-phrase label used in the check run title (summary_title output).
# Empty string means "no label worth showing in the title" (e.g. unknown).
_BUCKET_INVOCATION_LABELS = {
    _BUCKET_TEST_FAILED: "Tests failed",
    _BUCKET_SUCCESSFUL_BUILD: "Successful build",
    _BUCKET_TEST_TIMEOUT: "Tests timeout",
    _BUCKET_TEST_FLAKY: "Tests flaky",
    _BUCKET_FAILED_TO_BUILD: "Failed to build",
    _BUCKET_TEST_PASSED_CACHED: "Tests passed (cached)",
    _BUCKET_TEST_PASSED: "Tests passed",
    _BUCKET_ABORTED_STATE: "Invocation disconnected",
    _BUCKET_SKIPPED: "Invocation skipped",
    _BUCKET_PENDING: "Running...",
}

# Emoji icons matched to each bucket — used as a visible prefix on the bucket
# header in details output.
_BUCKET_ICONS = {
    _BUCKET_TEST_FAILED: "❌",
    _BUCKET_SUCCESSFUL_BUILD: "✅",
    _BUCKET_TEST_TIMEOUT: "⏱",
    _BUCKET_TEST_FLAKY: "🌀",
    _BUCKET_FAILED_TO_BUILD: "💥",
    _BUCKET_TEST_PASSED_CACHED: "⚡",
    _BUCKET_TEST_PASSED: "✅",
    _BUCKET_ABORTED_STATE: "⚠️",
    _BUCKET_SKIPPED: "⤵️",
    _BUCKET_PENDING: "🔄",
}

# Priority groups for picking the dominant invocation-state label. Iterated
# top-down; first group with any non-empty bucket wins. Within an error group
# there's an intrinsic tiebreaker ordering — see compute_invocation_state.
_BUCKET_PRIORITY_GROUPS = [
    [
        _BUCKET_ABORTED_STATE,
        _BUCKET_FAILED_TO_BUILD,
        _BUCKET_TEST_FAILED,
        _BUCKET_TEST_TIMEOUT,
        _BUCKET_TEST_FLAKY,
    ],
    [_BUCKET_TEST_PASSED],
    [_BUCKET_TEST_PASSED_CACHED],
    [_BUCKET_SUCCESSFUL_BUILD],
    [_BUCKET_SKIPPED],
]

# Order in which buckets render in the details output: errors first, then
# successes, then skipped/pending.
_BUCKET_DISPLAY_ORDER = [
    _BUCKET_ABORTED_STATE,
    _BUCKET_FAILED_TO_BUILD,
    _BUCKET_TEST_FAILED,
    _BUCKET_TEST_TIMEOUT,
    _BUCKET_TEST_FLAKY,
    _BUCKET_TEST_PASSED,
    _BUCKET_TEST_PASSED_CACHED,
    _BUCKET_SUCCESSFUL_BUILD,
    _BUCKET_SKIPPED,
    _BUCKET_PENDING,
]

def _bucket_header(bucket, count):
    """Build the 'N <Thing>(s)' header string for a bucket."""
    raw = _BUCKET_HEADERS.get(bucket, "")
    plural = "s" if count != 1 else ""
    return str(count) + " " + raw.replace("{s}", plural)

def _is_test_kind(kind):
    """True when a Bazel rule kind identifies a test target.

    Bazel convention: test rules end in `_test` (e.g. `cc_test`, `py_test`,
    `sh_test`, `go_test`, `rust_test`). Non-test kinds (`cc_library`, `cc_binary`,
    `genrule`, `filegroup`, ...) don't have this suffix.
    """
    return kind.endswith("_test") if kind else False

def _pad_right(s, width):
    """Pad s with trailing spaces to at least `width` characters. No truncation."""
    n = width - len(s)
    if n <= 0:
        return s
    return s + " " * n

# Column header strings for target-list tables in <pre> blocks.
_TABLE_HDR_LABEL = "Label"
_TABLE_HDR_KIND = "Target Type"
_TABLE_HDR_DURATION = "Duration"
_TABLE_HDR_ARTIFACTS = "Artifacts"
_TABLE_HDR_MNEMONIC = "Mnemonic"

# Task-timing columns. Same `<pre>`-aligned shape as `_align_for_pre`
# produces for target/test tables, just different header text.
_TT_HDR_PHASE = "Phase"
_TT_HDR_DESCRIPTION = "Description"
_TT_HDR_DURATION = "Duration"

# Maximum label length (chars) displayed in target lists. Labels longer than
# this are truncated with a `...` suffix so the columns in <pre> tables don't
# blow out to terminal-unfriendly widths. The total string length after
# truncation is exactly _LABEL_MAX_LEN (including the 3 trailing dots).
_LABEL_MAX_LEN = 90

def _truncate_label(s):
    """Cap a target label at _LABEL_MAX_LEN with a `...` suffix when longer."""
    if not s or len(s) <= _LABEL_MAX_LEN:
        return s
    return s[:_LABEL_MAX_LEN - 3] + "..."

def _artifact_anchors(entry):
    """Build the rendered Artifacts cell for a test entry and its visible width.

    Returns (html, visible_width). `html` is the raw string emitted into the
    <pre> block — HTML <a> tags when URLs exist, empty string otherwise.
    `visible_width` is the width the reader actually sees (e.g. "log xml" = 7),
    used for column alignment; it ignores the <a href="..."> markup.
    """
    parts_html = []
    parts_visible = []
    if entry.get("log_url"):
        parts_html.append('<a href="' + entry["log_url"] + '">log</a>')
        parts_visible.append("log")
    if entry.get("xml_url"):
        parts_html.append('<a href="' + entry["xml_url"] + '">xml</a>')
        parts_visible.append("xml")
    html = " ".join(parts_html)
    visible = " ".join(parts_visible)
    return html, len(visible)

def _align_for_pre(entries, has_duration = True, has_mnemonic = False):
    """Build a column-aligned table for <pre> rendering.

    Columns:
      - label, kind                        (always)
      - duration                           (when has_duration=True)
      - artifacts                          (auto-detected from entry log_url/xml_url)
      - mnemonic                           (when has_mnemonic=True; for build failures)

    Returns a dict:
        rows:      list of entries augmented with aligned_label / aligned_kind
                   (and aligned_duration / aligned_artifacts / aligned_mnemonic
                   when their column is present).
        header:    pre-formatted header line ("Label | Target Type | ...").
        separator: separator line matching the column widths.

    Columns are padded to max(header_text_width, widest_value). The artifacts
    column appears only when at least one entry has a log_url or xml_url; its
    width is computed on the *visible* anchor text (e.g. "log xml" = 7 chars),
    not the raw HTML, so alignment inside <pre> stays correct when GitHub
    renders the tags as links.
    """
    if not entries:
        return {"rows": [], "header": "", "separator": ""}

    label_w = len(_TABLE_HDR_LABEL)
    kind_w = len(_TABLE_HDR_KIND)
    dur_w = len(_TABLE_HDR_DURATION) if has_duration else 0
    mnemonic_w = len(_TABLE_HDR_MNEMONIC) if has_mnemonic else 0
    artifacts_w = 0

    # Pre-build artifact cells so we can use their visible width for alignment.
    artifact_cells = []
    for e in entries:
        html, vis_w = _artifact_anchors(e)
        artifact_cells.append((html, vis_w))
        if vis_w > artifacts_w:
            artifacts_w = vis_w

    has_artifacts = artifacts_w > 0
    if has_artifacts and artifacts_w < len(_TABLE_HDR_ARTIFACTS):
        artifacts_w = len(_TABLE_HDR_ARTIFACTS)

    for e in entries:
        lbl = e.get("label", "") or ""
        knd = e.get("kind", "") or ""
        if len(lbl) > label_w:
            label_w = len(lbl)
        if len(knd) > kind_w:
            kind_w = len(knd)
        if has_duration:
            dur = e.get("duration", "") or ""
            if len(dur) > dur_w:
                dur_w = len(dur)
        if has_mnemonic:
            mn = e.get("mnemonic", "") or ""
            if len(mn) > mnemonic_w:
                mnemonic_w = len(mn)

    # Header line: "Label<pad> | Target Type<pad> | Duration<pad> | Mnemonic<pad> | Artifacts<pad>"
    hdr_cells = [_pad_right(_TABLE_HDR_LABEL, label_w), _pad_right(_TABLE_HDR_KIND, kind_w)]
    if has_duration:
        hdr_cells.append(_pad_right(_TABLE_HDR_DURATION, dur_w))
    if has_mnemonic:
        hdr_cells.append(_pad_right(_TABLE_HDR_MNEMONIC, mnemonic_w))
    if has_artifacts:
        hdr_cells.append(_pad_right(_TABLE_HDR_ARTIFACTS, artifacts_w))
    header = " | ".join(hdr_cells)

    # Separator: dashes the width of each column, joined with `-+-` so `+`
    # lands directly under the `|` separators in the data rows.
    sep_cells = ["-" * label_w, "-" * kind_w]
    if has_duration:
        sep_cells.append("-" * dur_w)
    if has_mnemonic:
        sep_cells.append("-" * mnemonic_w)
    if has_artifacts:
        sep_cells.append("-" * artifacts_w)
    separator = "-+-".join(sep_cells)

    rows = []
    for i in range(len(entries)):
        e = entries[i]
        row = dict(e)
        row["aligned_label"] = _pad_right(e.get("label", "") or "", label_w)
        row["aligned_kind"] = _pad_right(e.get("kind", "") or "", kind_w)
        if has_duration:
            row["aligned_duration"] = _pad_right(e.get("duration", "") or "", dur_w)
        if has_mnemonic:
            row["aligned_mnemonic"] = _pad_right(e.get("mnemonic", "") or "", mnemonic_w)
        if has_artifacts:
            html, vis_w = artifact_cells[i]

            # Right-pad on visible width: append spaces equal to the deficit
            # between the column width and the visible (rendered) width.
            pad = " " * (artifacts_w - vis_w) if artifacts_w > vis_w else ""
            row["aligned_artifacts"] = html + pad
        rows.append(row)
    return {"rows": rows, "header": header, "separator": separator, "has_artifacts": has_artifacts}

def _align_task_timing_for_pre(entries, total_duration = ""):
    """Build a column-aligned <pre> table for the Task timing section.

    Columns: Phase | Description | Duration. Same shape as
    `_align_for_pre` produces for target/test tables — same
    `<header line>` + `<separator>` + data rows pattern that's
    becoming the standard look across status-surface body sections.

    The optional `total_duration` is the task's total wall time
    (`ctx.task.elapsed_ms`, formatted). When set, an aligned `Total`
    row is included so the table is self-contained in the body view
    (mirrors the `⏱` total in the header strip).

    Returns:
      rows:             list of `{aligned_name, aligned_description, aligned_duration}` dicts.
      header:           pre-formatted header line.
      separator:        `-+-` separator line matching the column widths.
      total_separator:  the same separator, rendered between the phase rows
                        and the Total row so the sum stands apart. "" when
                        no total was supplied.
      total_line:       pre-formatted total row, or "" when no total was supplied.
    """
    if not entries:
        return {
            "rows": [],
            "header": "",
            "separator": "",
            "total_separator": "",
            "total_line": "",
        }

    # `-> ` marker prefixes the active row's Phase cell so reviewers
    # can spot the in-flight phase at a glance. The prefix is only
    # reserved when an `is_active` entry actually exists in this
    # render (i.e. live emits); at terminal the table renders flush
    # with no prefix column, so the post-run view is the cleaner of
    # the two.
    _ACTIVE_PREFIX = "-> "
    _BLANK_PREFIX = " " * len(_ACTIVE_PREFIX)
    has_active = any([e.get("is_active") for e in entries])
    prefix_w = len(_ACTIVE_PREFIX) if has_active else 0
    inactive_prefix = _BLANK_PREFIX if has_active else ""

    name_w = prefix_w + len(_TT_HDR_PHASE)
    desc_w = len(_TT_HDR_DESCRIPTION)
    dur_w = len(_TT_HDR_DURATION)

    # Include total in width calculations so the Total row aligns.
    total_label = "Total"
    if prefix_w + len(total_label) > name_w:
        name_w = prefix_w + len(total_label)
    if total_duration and len(total_duration) > dur_w:
        dur_w = len(total_duration)

    for e in entries:
        n = e.get("name", "") or ""
        d = e.get("description", "") or ""
        dur = e.get("duration", "") or ""
        row_prefix_len = prefix_w if (has_active and not e.get("is_active")) else (len(_ACTIVE_PREFIX) if e.get("is_active") else 0)
        if row_prefix_len + len(n) > name_w:
            name_w = row_prefix_len + len(n)
        if len(d) > desc_w:
            desc_w = len(d)
        if len(dur) > dur_w:
            dur_w = len(dur)

    header = " | ".join([
        _pad_right(inactive_prefix + _TT_HDR_PHASE, name_w),
        _pad_right(_TT_HDR_DESCRIPTION, desc_w),
        _pad_right(_TT_HDR_DURATION, dur_w),
    ])
    separator = "-+-".join(["-" * name_w, "-" * desc_w, "-" * dur_w])

    rows = []
    for e in entries:
        if e.get("is_active"):
            prefix = _ACTIVE_PREFIX
        elif has_active:
            prefix = _BLANK_PREFIX
        else:
            prefix = ""
        rows.append({
            "aligned_name": _pad_right(prefix + (e.get("name", "") or ""), name_w),
            "aligned_description": _pad_right(e.get("description", "") or "", desc_w),
            "aligned_duration": _pad_right(e.get("duration", "") or "", dur_w),
        })

    total_line = ""
    total_separator = ""
    if total_duration:
        # Visual delimiter between per-phase rows and the Total row —
        # makes the sum stand apart at the bottom rather than reading
        # as just another phase row.
        total_separator = separator
        total_line = " | ".join([
            _pad_right(inactive_prefix + total_label, name_w),
            _pad_right("", desc_w),
            _pad_right(total_duration, dur_w),
        ])

    return {
        "rows": rows,
        "header": header,
        "separator": separator,
        "total_separator": total_separator,
        "total_line": total_line,
    }

def _render_counter_pre(counter, name_col, name_display = None, count_col = "Count", pct_col = "%", limit = 15):
    """Render a {name -> count} dict as a column-aligned <pre> body string.

    Sorted by count desc, then name asc. Shows at most `limit` rows plus a
    trailing "…N more" footer when overflow occurs. Each row carries the raw
    count (comma-formatted) and a percentage of the total.

    Args:
        counter:      dict mapping display name to integer count
        name_col:     header label for the first (name) column
        name_display: optional function(name) -> display string
        count_col:    header label for the count column
        pct_col:      header label for the percentage column
        limit:        max rows shown before overflowing to "…N more"

    Returns the complete <pre>-ready string (no wrapping <pre> tags) or "" if
    the counter is empty.
    """
    if not counter:
        return ""
    items = sorted(
        [(k, counter[k]) for k in counter],
        key = lambda x: (-x[1], x[0]),
    )
    total = 0
    for (_, c) in items:
        total += c
    shown = items[:limit]
    more_count = len(items) - len(shown)
    more_tally = 0
    for i in range(len(shown), len(items)):
        more_tally += items[i][1]

    name_w = len(name_col)
    count_w = len(count_col)
    pct_w = len(pct_col)

    formatted = []
    for (name, count) in shown:
        display = name_display(name) if name_display else name
        pct_tenths = (count * 1000) // total if total > 0 else 0
        pct_str = str(pct_tenths // 10) + "." + str(pct_tenths % 10) + "%"
        c_str = format_int_comma(count)
        formatted.append({"name": display, "count": c_str, "pct": pct_str})
        if len(display) > name_w:
            name_w = len(display)
        if len(c_str) > count_w:
            count_w = len(c_str)
        if len(pct_str) > pct_w:
            pct_w = len(pct_str)

    header = _pad_right(name_col, name_w) + " | " + _pad_right(count_col, count_w) + " | " + _pad_right(pct_col, pct_w)
    sep = "-" * name_w + "-+-" + "-" * count_w + "-+-" + "-" * pct_w
    lines = [header, sep]
    for r in formatted:
        lines.append(_pad_right(r["name"], name_w) + " | " + _pad_right(r["count"], count_w) + " | " + _pad_right(r["pct"], pct_w))
    if more_count > 0:
        lines.append("…" + str(more_count) + " more (" + format_int_comma(more_tally) + " actions)")
    return "\n".join(lines)

def _failed_action_labels(data):
    """Return the unique set of target labels whose actions failed.

    Normally populated by process_event (action_completed handler); falls back
    to deriving from failed_actions entries when not pre-populated (test fixtures
    that set data fields directly without running the event pipeline).
    """
    labels = data["bazel"].get("failed_action_labels", [])
    if labels:
        return list(labels)
    seen = {}
    for a in data["bazel"].get("failed_actions", []):
        lbl = a.get("label", "")
        if lbl:
            seen[lbl] = True
    return list(seen.keys())

def _compute_bucket_counts(data):
    """Count targets in each bucket. Returns dict[bucket -> int].

    Derives per-bucket counts from the accumulated data state:
      - failed_actions / failed_targets → FAILED_TO_BUILD
      - failed_tests split by .status     → TEST_FAILED / TEST_TIMEOUT / FAILED_TO_BUILD
      - flaky_tests                       → TEST_FLAKY
      - passed_tests split by .cached     → TEST_PASSED / TEST_PASSED_CACHED
      - built_targets (non-test only)     → SUCCESSFUL_BUILD
      - aborted flag                      → ABORTED_STATE
    """
    counts = {b: 0 for b in _BUCKET_DISPLAY_ORDER}
    if data["bazel"].get("aborted", False):
        counts[_BUCKET_ABORTED_STATE] = 1

    # Count *root* failures (targets with own action failures) — not
    # derived dep-broken ones, which would inflate the bucket header.
    # `failed_actions` is authoritative when present; otherwise fall
    # back to all `failed_targets` (mid-stream / older BES).
    _root_action_labels = _failed_action_labels(data)
    if _root_action_labels:
        counts[_BUCKET_FAILED_TO_BUILD] = len(_root_action_labels)
    else:
        counts[_BUCKET_FAILED_TO_BUILD] = len(data["bazel"].get("failed_targets", []))
    for t in data["bazel"].get("failed_tests", []):
        s = t.get("status", "failed")
        if s == "timeout":
            counts[_BUCKET_TEST_TIMEOUT] += 1
        elif s == "failed_to_build":
            counts[_BUCKET_FAILED_TO_BUILD] += 1
        else:
            counts[_BUCKET_TEST_FAILED] += 1
    counts[_BUCKET_TEST_FLAKY] = data["bazel"].get("flaky_test_total", 0)
    passed_cached = data["bazel"].get("cached_test_total", 0)
    passed_total = data["bazel"].get("passed_test_total", 0)
    counts[_BUCKET_TEST_PASSED_CACHED] = passed_cached
    counts[_BUCKET_TEST_PASSED] = passed_total - passed_cached if passed_total > passed_cached else 0

    # successful − tests. Aggregates only, since the capped
    # built_targets sample would under-count.
    successful_target_count = data["bazel"].get("targets_total", 0) - len(data["bazel"].get("failed_targets", []))
    if successful_target_count < 0:
        successful_target_count = 0
    test_target_count = passed_total + data["bazel"].get("failed_test_total", 0) + data["bazel"].get("flaky_test_total", 0)
    non_test_built = successful_target_count - test_target_count if successful_target_count > test_target_count else 0
    counts[_BUCKET_SUCCESSFUL_BUILD] = non_test_built
    return counts

def compute_invocation_state(data, status):
    """Return the invocation-state label for the title.

    Walks the priority groups top-down; the first group with any non-empty
    bucket wins. Within an error group, the intrinsic ordering in the group
    list acts as tiebreaker (ABORTED > FAILED_TO_BUILD > FAILED > TIMEOUT > FLAKY).

    Returns "Running..." while the build is in progress — that overrides
    bucket state since partial data aren't yet authoritative.
    """

    # Aborted build: label is fixed, no matter what else ran.
    if data["bazel"].get("aborted", False):
        return _BUCKET_INVOCATION_LABELS[_BUCKET_ABORTED_STATE]

    # In-progress: always Running... regardless of mid-stream failures.
    if status in ("running", "failing"):
        return _BUCKET_INVOCATION_LABELS[_BUCKET_PENDING]
    counts = _compute_bucket_counts(data)
    for group in _BUCKET_PRIORITY_GROUPS:
        for bucket in group:
            if counts.get(bucket, 0) > 0:
                return _BUCKET_INVOCATION_LABELS[bucket]
    return ""

_REDACTED = "<REDACTED>"

# Bazel flag names whose values carry gRPC/HTTP headers — always redacted since
# headers routinely carry bearer tokens, API keys, cookies, etc.
_HEADER_OPTION_NAMES = [
    "remote_header",
    "remote_cache_header",
    "remote_exec_header",
    "remote_downloader_header",
    "bes_header",
]

# Bazel flag names of the `--foo=KEY=VALUE` env-passthrough form. Values (the
# VALUE portion) are redacted unless the KEY matches the ALLOW_ENV allowlist.
# Matches Bazel's set of env-pass-through options; we deliberately do not list
# `common_env` — it's not a standard Bazel option.
_ENV_VAR_OPTION_NAMES = [
    "action_env",
    "client_env",
    "host_action_env",
    "repo_env",
    "test_env",
]

# Env var names whose value is expected to be a git repository URL. These stay
# visible in the output (the URL itself is informative) but any user:password
# prefix in the URL gets scrubbed. Covers the common CI-provided git-url vars.
_KNOWN_GIT_REPO_URL_KEYS = [
    "REPO_URL",
    "GIT_URL",
    "TRAVIS_REPO_SLUG",
    "BUILDKITE_REPO",
    "GIT_REPOSITORY_URL",
    "CIRCLE_REPOSITORY_URL",
    "GITHUB_REPOSITORY",
    "CI_REPOSITORY_URL",
]

# Default ALLOW_ENV when the user hasn't specified one via build_metadata.
# Curated to CI/VCS identifiers that are publicly safe to surface (commit SHA,
# branch, PR number, run ID, repo URL — the kind of info that typically ends
# up in the commit message or the CI job name anyway). Values of env vars we
# don't recognize are redacted by default.
#
# Users override via `--build_metadata=ALLOW_ENV=MY_VAR,OTHER_*`.
_DEFAULT_ALLOW_ENV = [
    # Who ran the build.
    "USER",
    "GITHUB_ACTOR",
    "BUILDKITE_BUILD_CREATOR",
    "GITLAB_USER_NAME",
    "CIRCLE_USERNAME",
    # Repo URLs (stripped of credentials separately, see _KNOWN_GIT_REPO_URL_KEYS).
    "GITHUB_REPOSITORY",
    "BUILDKITE_REPO",
    "TRAVIS_REPO_SLUG",
    "GIT_URL",
    "GIT_REPOSITORY_URL",
    "CI_REPOSITORY_URL",
    "REPO_URL",
    "CIRCLE_REPOSITORY_URL",
    # Commit SHAs.
    "GITHUB_SHA",
    "CIRCLE_SHA1",
    "BUILDKITE_COMMIT",
    "TRAVIS_COMMIT",
    "BITRISE_GIT_COMMIT",
    "GIT_COMMIT",
    "VOLATILE_GIT_COMMIT",
    "CI_COMMIT_SHA",
    "COMMIT_SHA",
    # Run identifiers + URLs.
    "GITHUB_RUN_ID",
    "BUILDKITE_BUILD_URL",
    "BUILDKITE_JOB_ID",
    # Branches / refs.
    "GITHUB_HEAD_REF",
    "GITHUB_REF",
    "CIRCLE_BRANCH",
    "BUILDKITE_BRANCH",
    "TRAVIS_BRANCH",
    "BITRISE_GIT_BRANCH",
    "GIT_BRANCH",
    "CI_COMMIT_BRANCH",
    "CI_MERGE_REQUEST_SOURCE_BRANCH_NAME",
    # Generic CI flags.
    "CI",
    "CI_RUNNER",
]

# Env var values that are *always* safe to surface regardless of allowlist:
# no-op markers and booleans that never carry secrets. Comparison is
# case-insensitive for the booleans.
_SAFE_ENV_VALUES_LITERAL = ["", "0", "1"]
_SAFE_ENV_VALUES_BOOL = ["true", "false"]

def _allow_env_patterns(metadata):
    """Resolve the ALLOW_ENV glob patterns from --build_metadata=ALLOW_ENV=...

    Comma-separated glob list. Falls back to _DEFAULT_ALLOW_ENV when the user
    hasn't specified one. A single `*` entry allows everything (escape hatch).
    """
    raw = (metadata or {}).get("ALLOW_ENV", "")
    if not raw:
        return _DEFAULT_ALLOW_ENV
    return [p.strip() for p in raw.split(",") if p.strip()]

def _is_allowed_env(key, allow_env):
    """True when KEY is on the allowlist (case-insensitive, globs supported).

    Case-insensitive matching: lowercase both sides and delegate to
    path_glob.match_path. ALLOW_ENV patterns are simple shell-style globs
    over single env-var names (no `/`), so the path-segment-aware
    matcher behaves identically here.
    """
    key_lc = key.lower()
    for pat in allow_env:
        if pat == "*" or match_path(pat.lower(), key_lc):
            return True
    return False

def _is_safe_env_value(value):
    """True for values that are always safe to surface regardless of allowlist.

    Matches empty, `0`, `1`, and `true`/`false` (case-insensitive). Common
    boolean-ish flags (e.g. `CI=true`, `BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1`)
    carry no secret and are useful debugging context.
    """
    if value in _SAFE_ENV_VALUES_LITERAL:
        return True
    lowered = value.lower()
    for b in _SAFE_ENV_VALUES_BOOL:
        if lowered == b:
            return True
    return False

def _strip_url_creds(s):
    """Redact the user:password prefix in any URL embedded in `s`.

    Recognizes `scheme://user:password@host/path` and rewrites it to
    `scheme://user:<REDACTED>@host/path`. Scheme must start with a letter
    (a-z / A-Z) followed by scheme-legal chars (alnum, `+-.`) and `://`.
    Handles at most ~10 URLs per string (more than enough for one CLI flag).
    """
    if "://" not in s:
        return s
    result = s
    cursor = 0
    for _ in range(10):
        idx = result.find("://", cursor)
        if idx < 0:
            break

        # Walk back to find scheme start; require at least one alpha char.
        scheme_start = idx
        i = idx - 1
        for _ in range(64):
            if i < 0:
                break
            c = result[i]
            is_alpha = (c >= "a" and c <= "z") or (c >= "A" and c <= "Z")
            is_digit = c >= "0" and c <= "9"
            if is_alpha or is_digit or c == "+" or c == "-" or c == ".":
                scheme_start = i
                i -= 1
            else:
                break

        # Scheme must start with a letter.
        first = result[scheme_start]
        is_first_alpha = (first >= "a" and first <= "z") or (first >= "A" and first <= "Z")
        if not is_first_alpha or scheme_start == idx:
            cursor = idx + 3
            continue

        # Find the `:` that separates user from password (must come before `@`
        # and before whitespace/newline/end).
        colon = -1
        for j in range(idx + 3, len(result)):
            c = result[j]
            if c == ":":
                colon = j
                break
            if c == "@" or c == " " or c == "\t" or c == "\r" or c == "\n":
                break
        if colon < 0:
            cursor = idx + 3
            continue

        # Find the `@` that closes the userinfo.
        at = -1
        for j in range(colon + 1, len(result)):
            c = result[j]
            if c == "@":
                at = j
                break
            if c == " " or c == "\t" or c == "\r" or c == "\n":
                break
        if at < 0:
            cursor = idx + 3
            continue

        # Redact the password slot.
        result = result[:colon + 1] + _REDACTED + result[at:]
        cursor = colon + 1 + len(_REDACTED) + 1
    return result

def _split_combined_form(arg):
    """Split a `--flag=value` token into (`--flag`, `value`). Empty value if
    there's no `=`. Preserves `=` signs inside the value (cut on the first one).
    """
    eq = arg.find("=")
    if eq < 0:
        return (arg, "")
    return (arg[:eq], arg[eq + 1:])

def _is_header_option(name):
    """True when `name` (bare flag name, no leading `--`) is a header option."""
    for h in _HEADER_OPTION_NAMES:
        if name == h:
            return True
    return False

def _is_env_option(name):
    """True when `name` (bare flag name, no leading `--`) is an env-passthrough."""
    for e in _ENV_VAR_OPTION_NAMES:
        if name == e:
            return True
    return False

def _redact_env_value(value, allow_env):
    """Redact the value portion of an env-passthrough flag (`VAR=stuff`).

    - Preserves surrounding `"..."` / `'...'` quoting when present.
    - When no `=` is present (e.g. `--action_env=FOO` to inherit), returns
      the value as-is — env var names aren't considered sensitive here.
    - Known git-URL env var names have their URL credentials stripped but
      keep the URL itself visible.
    - Values that are `""`, `"0"`, `"1"`, `"true"`, `"false"` are never redacted.
    - Otherwise: redact when the var name isn't on the allowlist.
    """
    if not value:
        return value

    # Preserve wrapping quotes.
    first = value[0]
    last = value[-1] if len(value) > 0 else ""
    if (first == "\"" or first == "'") and last == first and len(value) >= 2:
        inner = value[1:-1]
        return first + _redact_env_value(inner, allow_env) + first

    # Split VAR=val; when no =, nothing to redact.
    eq = value.find("=")
    if eq < 0:
        return value
    var_name = value[:eq]
    var_value = value[eq + 1:]

    # Safe values are always surfaced.
    if _is_safe_env_value(var_value):
        return var_name + "=" + var_value

    # Known git-URL env vars: strip URL creds but keep the URL.
    upper_name = var_name.upper()
    for key in _KNOWN_GIT_REPO_URL_KEYS:
        if upper_name == key:
            return var_name + "=" + _strip_url_creds(var_value)

    # Allowlisted KEY → show value, with URL creds stripped as belt-and-suspenders.
    if _is_allowed_env(var_name, allow_env):
        return var_name + "=" + _strip_url_creds(var_value)
    return var_name + "=" + _REDACTED

def _redact_arg(arg, allow_env):
    """Redact one command-line token:

      1. Header flags (`--remote_header=...`, `--bes_header=...`, etc.) —
         value wholly replaced with <REDACTED>.
      2. Env-passthrough flags (`--client_env=KEY=VALUE`, ...) — value handled
         per allowlist / safe-values / known-git-URL rules (see `_redact_env_value`).
      3. Any other flag value — URL credentials stripped (`scheme://user:pass@`
         rewritten to `scheme://user:<REDACTED>@`).

    Non-flag tokens pass through unchanged (subcommands, target patterns).
    """
    if not arg.startswith("--"):
        return _strip_url_creds(arg)
    name, value = _split_combined_form(arg)

    # Bare flag name: strip leading dashes, stop at `=` (already stripped).
    bare = name[2:] if name.startswith("--") else name
    if _is_header_option(bare):
        return name + "=" + _REDACTED
    if _is_env_option(bare):
        return name + "=" + _redact_env_value(value, allow_env)

    # Generic flag — apply URL credential stripping only.
    if value:
        return name + "=" + _strip_url_creds(value)
    return arg

def _redact_args(args, allow_env):
    """Apply _redact_arg to each element of a list."""
    return [_redact_arg(a, allow_env) for a in args]

# Characters that are safe to leave unquoted in a shell token. Anything else
# (whitespace, $, `, ;, &, |, <, >, quotes, etc.) triggers single-quoting.
_SHELL_SAFE_CHARS = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_=./:@,+%"

def _shell_quote(s):
    """Single-quote s for shell if it contains whitespace or any unsafe chars.

    Embedded single quotes are escaped with the POSIX idiom `'\\''` (close the
    quote, add a backslash-escaped quote, reopen). Empty strings become `''`.
    Tokens made up entirely of _SHELL_SAFE_CHARS are returned untouched.
    """
    if not s:
        return "''"
    for i in range(len(s)):
        if s[i] not in _SHELL_SAFE_CHARS:
            return "'" + s.replace("'", "'\\''") + "'"
    return s

def _is_shell_safe(s):
    """True when s contains only characters that need no shell escaping."""
    if not s:
        return True
    for i in range(len(s)):
        if s[i] not in _SHELL_SAFE_CHARS:
            return False
    return True

def _quote_flag(token):
    """Shell-quote a command-line flag for display in a copy-pasteable command.

    For `--flag=value` tokens the quote boundary is pushed to after the `=`,
    so the flag name stays readable:
        --config=ci                         →  --config=ci        (unchanged)
        --build_metadata=KEY=hello world    →  --build_metadata='KEY=hello world'

    Tokens without an `=` — including space-separated "flag value" forms like
    `--build_event_binary_file /var/foo.bin` that Bazel can emit as a single
    string — fall back to whole-token quoting so the flag and its value stay
    bound together:
        --build_event_binary_file /var/foo  →  '--build_event_binary_file /var/foo'

    Non-flag tokens (targets, subcommands) also fall back to whole-token quoting.
    """
    if not token:
        return "''"

    # Value-only quoting requires a shell-safe `--name=` prefix; an
    # unsafe flag name would slip past a value-quoted token.
    if token.startswith("--") and "=" in token:
        idx = token.index("=")
        flag_part = token[:idx + 1]  # includes the `=`
        value = token[idx + 1:]
        if _is_shell_safe(flag_part):
            return flag_part + _shell_quote(value)
    return _shell_quote(token)

def _format_shell_command(head, flags, targets):
    """Format a reproducer command as a multi-line backslash-continued shell command.

    Layout:
        bazel <command> \\
          --flag1=val1 \\
          --flag2=val2 \\
          -- \\
          //target1 \\
          //target2

    Each flag gets its own line; targets come last and are separated from flags
    by a bare `--` (signals "everything after this is a target, not a flag" —
    the standard Bazel/Unix idiom). Tokens are expected to be pre-quoted by the
    caller so embedded-space values stay intact.
    """
    if not head:
        return ""
    lines = [head]
    for f in flags:
        lines.append("  " + f)
    if targets:
        # `--` only matters when there are flags to disambiguate from. With
        # no flags it's redundant, so skip it for a cleaner reproducer.
        if flags:
            lines.append("  --")
        for t in targets:
            lines.append("  " + t)
    return " \\\n".join(lines)

# Max length for the one-line preview used as the <details> summary. Longer
# invocations get an ellipsis so the summary stays a reasonable width.
_EXPLICIT_SHORT_MAX = 120

def _assemble_explicit_command(build_command, target_pattern, explicit_cmd_line, allow_env):
    """Build both forms of the explicit command for the status-check details:

        {"short": "bazel test //foo:bar",           # <details> summary preview
         "long":  "bazel test \\\n  --flag=val \\\n  -- \\\n  //foo:bar"}

    Each token is redacted first (secrets), then shell-quoted only if needed —
    regular flags like `--config=ci` stay as-is, but flags with spaces or shell
    metacharacters get wrapped in single quotes with embedded quotes escaped.
    Returns empty strings when there's nothing to render (no build_command).
    """
    if not build_command:
        return {"short": "", "long": ""}

    redacted = _redact_args(explicit_cmd_line or [], allow_env)
    flags = [_quote_flag(a) for a in redacted]

    # Split the pattern so each target lands on its own line in `long`.
    target_tokens = []
    if target_pattern:
        for t in target_pattern.split(" "):
            if t:
                target_tokens.append(_shell_quote(t))

    head = "bazel " + build_command

    # Short form: "bazel <command> <targets>" (skip flags).
    short_parts = [head]
    short_parts.extend(target_tokens)
    short = " ".join(short_parts)
    if len(short) > _EXPLICIT_SHORT_MAX:
        short = short[:_EXPLICIT_SHORT_MAX - 1] + "…"

    long_form = _format_shell_command(head, flags, target_tokens)
    return {"short": short, "long": long_form}

def _sorted_dedup(args, allow_env):
    """Redact + alphabetically sort + dedup + shell-quote. For browseable option lists.

    Sort is applied to the pre-quote form so unquoted and quoted variants of the
    same flag don't end up as neighbors.
    """
    redacted = _redact_args(args or [], allow_env)
    unique = sorted(set(redacted))
    return [_quote_flag(a) for a in unique]

def render_bes_url(data):
    """Construct the full BES invocation URL from bes_results_url + invocation_id.

    Uses Bazel's `invocation_id` (the UUID Bazel mints for its own
    BEP stream — captured from the `BuildStarted` BEP event), not the
    Aspect-side `sink_invocation_id`. The two are distinct: the
    `--bes_results_url` consumer only sees Bazel's UUID, so the link
    must key on that. `resolve_aspect_url` is the parallel helper for
    the Aspect Web UI which is keyed on `sink_invocation_id`.

    Returns "" when either piece is unavailable (caller suppresses
    the link rather than rendering a broken URL).
    """
    base = data["bazel"].get("bes_results_url", "")
    inv = data["bazel"].get("invocation_id", "")
    if not base or not inv:
        return ""
    return (base if base.endswith("/") else base + "/") + inv

def format_run_date(ctx, epoch_ms):
    """Format an epoch timestamp (milliseconds) as a human-readable date string.

    Single source of truth for "render a Unix timestamp as the default
    `date` form (e.g. `Sun May 10 07:16:05 UTC 2026`)" across all
    status surfaces — bazel/format/gazelle/lint/delivery per-task check
    bodies AND the github_status_comments PR-comment header.

    Uses the system `date` command with cross-platform flags:
      macOS: date -r <seconds>
      Linux: date -d @<seconds>
    The `sh -c "A || B"` form picks whichever lands first — keeps the
    helper working both on developer laptops (often macOS) and on CI
    runners (Linux).

    No `-u` flag — `date` honors `$TZ` first, then `/etc/localtime`.
    On most hosted CI runners that resolves to UTC, but workflows can
    set `TZ=America/Los_Angeles` (or any IANA zone) at the env level
    to render headlines in the team's local time. Locally, the
    runner-machine TZ is just whatever the developer is set to. Either
    way the producer-side render is honest about which clock it's on
    (`%Z` is the TZ abbreviation in the default `date` format).

    Returns "" if epoch_ms is 0/negative or the command fails — callers
    can drop the field instead of rendering junk.
    """
    if not epoch_ms or epoch_ms <= 0:
        return ""
    epoch_s = str(epoch_ms // 1000)
    result = ctx.std.process.command("sh").args([
        "-c",
        "date -r " + epoch_s + " 2>/dev/null || date -d '@" + epoch_s + "'",
    ]).stdout("piped").stderr("piped").spawn().wait_with_output()
    if result.status.code == 0:
        val = result.stdout.strip()
        if val:
            return val
    return ""

STATUS_ICONS = {
    "passed": "✅",
    "failed": "❌",
    "failing": "⚠️",
    "running": "🔄",
}

STATUS_LABELS = {
    "passed": "Succeeded",
    "failed": "Failed",
    "failing": "Failing...",
    "running": "Running...",
}

def ci_link_item(ctx, links):
    """Build the CI-host link item for the final summary row.

    Prefers a pre-resolved ci_url from the feature (e.g. a job-level deep link
    resolved against the GitHub API); falls back to deriving from env vars so
    the link works even when the feature doesn't pass one through.
    """
    env = ctx.std.env
    override_url = (links or {}).get("ci_url", "") or ""
    if env.var("GITHUB_ACTIONS"):
        url = override_url
        if not url:
            server = env.var("GITHUB_SERVER_URL") or "https://github.com"
            repo = env.var("GITHUB_REPOSITORY") or ""
            run_id = env.var("GITHUB_RUN_ID") or ""
            if repo and run_id:
                url = server + "/" + repo + "/actions/runs/" + run_id
        if url:
            return {"icon": "🐙", "value": "[GitHub Actions](" + url + ")"}
    elif env.var("BUILDKITE"):
        url = override_url
        if not url:
            build_url = env.var("BUILDKITE_BUILD_URL") or ""
            step_id = env.var("BUILDKITE_STEP_ID") or ""
            if build_url:
                url = build_url + "/steps/canvas?sid=" + step_id if step_id else build_url
        if url:
            return {"icon": "🏗", "value": "[Buildkite](" + url + ")"}
    elif env.var("CIRCLECI"):
        url = override_url or env.var("CIRCLE_BUILD_URL") or ""
        if url:
            return {"icon": "⭕", "value": "[CircleCI](" + url + ")"}
    elif env.var("GITLAB_CI"):
        url = override_url or env.var("CI_JOB_URL") or ""
        if url:
            return {"icon": "🦊", "value": "[GitLab CI](" + url + ")"}
    return None

def _titlecase(s):
    """Title-case the first character and convert underscores to spaces.

    Phase names are lowercase identifiers (`detect`, `build`,
    `bazel_query`); this renders them as `Detect`, `Build`,
    `Bazel query` for display. Subsequent words stay lowercase — the
    input is an identifier, not a sentence, so leading-cap-only
    matches how renderers and CLIs typically format programmatic
    names. Callers that need a non-naive display label (e.g.
    `preflight` → `Pre-flight`) set `Phase.display_name`; the
    renderer prefers that over this helper.
    """
    if not s:
        return s
    return s[0].upper() + s[1:].replace("_", " ")

# Synthetic `init` phase entries below this duration are hidden from
# the header phase strip (and from the runtime's breakdown line). The
# init phase covers Aspect runtime startup + trait setup before the
# task's first explicit `phase()` mark; on a fast path that's a few
# ms of work and not worth a slot in the strip. Above the threshold,
# init surfaces as a real entry the user might want to investigate.
# Caller-named phases are never suppressed even at 0ms; intentional
# boundaries always render. Matches the Rust-side
# INIT_PHASE_HIDE_THRESHOLD_MS.
_INIT_PHASE_HIDE_THRESHOLD_MS = 50

def format_elapsed_with_phases(ctx, status):
    """Render the `⏱` item content for the status surface header.

    Total task time leads. Completed phases render in chronological
    order (oldest first). The "highlight" slot — placed between total
    and history, separated by ` | ` — carries the phase that's
    currently demanding attention: the active phase while running /
    failing, or the interrupted phase on terminal failure. On
    terminal-passed (or terminal-failed without an interrupted
    phase) there's no highlight slot and history follows total
    after an em-dash.

    Shapes:
      No phases used:                    "12.4s"
      Phases, running:                   "4m13s · 🔨 Build 4m11s | ⚙ Setup 1.7s · 🔍 Detect 1.2s"
      Phases, failing:                   "4m13s · 🔨 Build (failing 4m11s) | ⚙ Setup 1.7s · 🔍 Detect 1.2s"
      Phases, passed (terminal):         "46.8s — ⚙ Setup 1.7s · 🔍 Detect 1.2s · 🔨 Build 45.3s"
      Phases, failed-during-phase:       "1m 15s · 🔨 Build (failed after 1m 12s) | Init 2.3s"
      Phases, failed-after-phase-bound:  "1m 15s — Init 2.3s · 🔨 Build 1m 12s"

    Each phase name leads with a small unicode icon supplied by the
    task at phase-transition time (`Phase(name="build", emoji="🔨")`);
    the runtime carries it on the `TaskPhase` snapshot so the renderer
    reads `p.emoji` (closed) / `current.emoji` (live) directly. Active
    running phase drops the `(active …)` parenthetical since position
    alone — leading slot, before the `|` separator — makes "active"
    implicit. Failure rider stays (`(failed after …)` / `(failing …)`)
    since that one carries triage info.

    `ctx.task.elapsed_ms` refreshes on every read; the active phase
    auto-closes when the runtime emits the closing line, so terminal
    snapshots already show all phases as completed.

    The synthetic `init` phase is hidden when its duration is under
    `_INIT_PHASE_HIDE_THRESHOLD_MS`.
    """
    elapsed_ms = ctx.task.elapsed_ms
    if elapsed_ms <= 0:
        return ""

    text = format_duration_ms(elapsed_ms)
    phases = ctx.task.phases()
    current = ctx.task.current_phase()

    # Filter out the synthetic init phase when negligible.
    visible_phases = [
        p
        for p in phases
        if not (p.name == "init" and p.duration_ms < _INIT_PHASE_HIDE_THRESHOLD_MS)
    ]

    if not visible_phases and not current:
        return text

    is_failed = status == "failed"
    history = []
    highlight = ""
    for p in visible_phases:
        name_t = _phase_label(p.name, p.emoji, p.display_name)
        dur = format_duration_ms(p.duration_ms)
        if is_failed and p.interrupted and not highlight:
            # The phase that was active when the task hit a non-zero
            # exit; runtime auto-closes it with `interrupted=True`.
            highlight = "%s (failed after %s)" % (name_t, dur)
        else:
            history.append("%s %s" % (name_t, dur))
    if current:
        cur_dur = format_duration_ms(current.duration_ms)
        name_t = _phase_label(current.name, current.emoji, current.display_name)
        if status == "failed":
            # `current_phase` is still set because the surface render
            # fires from inside `_impl` before the runtime's auto-close.
            highlight = "%s (failed after %s)" % (name_t, cur_dur)
        elif status == "passed":
            # Render as a completed-in-order entry — no highlight slot
            # on terminal success.
            history.append("%s %s" % (name_t, cur_dur))
        elif status == "failing":
            highlight = "%s (failing %s)" % (name_t, cur_dur)
        else:  # running (or any unknown non-terminal)
            # Drop the `(active …)` parenthetical — leading slot
            # before the `|` already implies "active".
            highlight = "%s %s" % (name_t, cur_dur)

    if highlight and history:
        return "%s · %s | %s" % (text, highlight, " · ".join(history))
    if highlight:
        return "%s · %s" % (text, highlight)
    return "%s — %s" % (text, " · ".join(history))

def _phase_label(phase, emoji, display_name):
    """`<emoji> <Display name>` for the surface header phase strip.

    `emoji` is the phase icon the producer supplied via
    `Phase(name=..., emoji=...)` at transition time; the runtime
    carries it on the phase snapshot. Empty string renders the title
    alone.

    `display_name` is the producer-supplied label override via
    `Phase(display_name=...)`. When non-empty it's used verbatim;
    when empty, fall back to `_titlecase(phase)` (so `bazel_query` →
    `Bazel query` works out of the box and only the irregulars need
    an explicit override — currently just `preflight` → `Pre-flight`).
    """
    name_t = display_name or _titlecase(phase)
    if emoji:
        return emoji + " " + name_t
    return name_t

def build_invocation_rows(ctx, data, render_ctx, status, links = None, run_date = "", extra_meta = None):
    """Build the summary rows for SUMMARY_TEMPLATE.

    Returns up to 7 rows, each a list of {icon, value} dicts rendered
    `· ` separated by the template. Rows with no items are excluded.
    See `DEVELOPMENT.md → Summary header rows` for the rationale
    behind each grouping.

        Row 1 (status & timing):  status · date · elapsed
        Row 2 (actor & toolchain): user · host · CLI version
        Row 3 (VCS context):       repo · PR · branch · commit · trigger
        Row 4 (build content):     targets · actions · tests · tool · CPU · mode
        Row 5 (Workflows runner):  runner version · cloud · AZ · instance · ID
                                   (only on an Aspect Workflows runner)
        Row 6 (tags & custom):     custom links · tags
        Row 7 (external links):    Aspect Workflows · CI host
    """
    meta = merged_meta(data)
    vcs = vcs_info(meta)

    def _item(icon, value):
        return {"icon": icon, "value": value}

    # Row 1: status · date · elapsed — outcome + when + how long.
    row1 = [_item(STATUS_ICONS.get(status, "🔄"), STATUS_LABELS.get(status, "Running"))]

    if run_date:
        row1.append(_item("📅", run_date))

    elapsed_text = format_elapsed_with_phases(ctx, status)
    if elapsed_text:
        row1.append(_item("⏱", elapsed_text))

    # Row 2: actor & toolchain — user · host · CLI version.
    row2 = []

    # Show the most human-readable *name* and omit the email — GFM
    # autolinks bare `user@host.tld` into mailto:, and HTML-entity
    # tricks don't work because GitHub decodes before the autolink scan.
    # The full "Name <email>" still appears in Build Metadata below.
    commit_author_name = meta.get("COMMIT_AUTHOR_NAME", "")
    commit_author = meta.get("COMMIT_AUTHOR", "")
    commit_author_email = meta.get("COMMIT_AUTHOR_EMAIL", "")
    if commit_author_name:
        user_display = commit_author_name
    elif commit_author:
        # COMMIT_AUTHOR is typically "Name <email>"; strip the "<…>" tail.
        lt = commit_author.find(" <")
        user_display = commit_author[:lt] if lt > 0 else commit_author
    elif meta.get("USER", ""):
        user_display = meta["USER"]
    elif meta.get("BUILD_USER", ""):
        user_display = meta["BUILD_USER"]
    elif commit_author_email:
        # Last resort — wrap in backticks so GFM can't autolink the `@`.
        user_display = "`" + commit_author_email + "`"
    else:
        user_display = ""
    if user_display:
        row2.append(_item("👤", html_escape(user_display)))

    build_host = meta.get("BUILD_HOST", "")
    if build_host:
        row2.append(_item("🖥", html_escape(build_host)))

    # `:aspect:` is a BK-only emoji shortcode; everywhere else it
    # renders as literal text, so fall back to 💎 off-BK.
    cli_version = ctx.std.env.aspect_cli_version() if ctx else ""
    if cli_version:
        on_bk = ctx and ctx.std.env.var("BUILDKITE")
        cli_icon = ":aspect:" if on_bk else "💎"
        row2.append(_item(cli_icon, "aspect-cli v" + cli_version))

    # Row 3: VCS context — repo · PR · branch · commit · trigger.
    row3 = []
    if vcs:
        # Link text is the repo name only — the icon tells the host.
        link_text = vcs["repo_name"] if vcs["repo_name"] else vcs["display_name"]
        row3.append(_item(vcs["icon"], "[" + link_text + "](" + vcs["repo_url"] + ")"))

        pr_id = meta.get("PR_ID", "")
        pr_number = meta.get("PR_NUMBER", "")
        if pr_id and pr_number:
            pr_url = vcs["repo_url"] + vcs["pr_path"] + "/" + pr_id
            row3.append(_item(":twisted_rightwards_arrows:", "[#" + pr_number + "](" + pr_url + ")"))
        elif pr_number:
            # No PR_ID to build a deep link — still show the number for context.
            row3.append(_item(":twisted_rightwards_arrows:", "#" + pr_number))

        branch = meta.get("BRANCH_NAME", "")
        if branch:
            branch_url = vcs["repo_url"] + vcs["tree_path"] + "/" + branch
            row3.append(_item("⎇", "[" + html_escape(branch) + "](" + branch_url + ")"))

        sha = meta.get("COMMIT_SHA", "")
        if sha:
            short_sha = sha[:7]
            commit_msg = meta.get("COMMIT_MESSAGE", "")
            if len(commit_msg) > 60:
                commit_msg = commit_msg[:60] + "…"
            display = short_sha + (" - " + html_escape(commit_msg) if commit_msg else "")
            commit_url = vcs["repo_url"] + vcs["commit_path"] + "/" + sha
            row3.append(_item("✏️", "[" + display + "](" + commit_url + ")"))
    else:
        # No VCS info — show unlinked branch/commit for context.
        branch = meta.get("BRANCH_NAME", "")
        if branch:
            row3.append(_item("⎇", html_escape(branch)))
        sha = meta.get("COMMIT_SHA", "")
        if sha:
            short_sha = sha[:7] if len(sha) > 7 else sha
            commit_msg = meta.get("COMMIT_MESSAGE", "")
            if len(commit_msg) > 60:
                commit_msg = commit_msg[:60] + "…"
            display = short_sha + (" - " + html_escape(commit_msg) if commit_msg else "")
            row3.append(_item("✏️", display))

    trigger = _trigger_label(meta.get("RUN_TYPE", ""))
    if trigger:
        row3.append(_item("🏃", trigger))

    # ------------------------------------------------------------------
    # Row 4 — build content: targets · actions · tests · tool · CPU · mode
    # ------------------------------------------------------------------
    row4 = []

    # Targets: just the completed count. Aspect-inclusive "configured"
    # numbers move to the Performance section where they have room and context.
    targets_total = data["bazel"].get("targets_total", 0)
    if targets_total > 0:
        row4.append(_item("📦", pluralize(targets_total, "target")))

    # Actions: "N of M actions executed (X% cached)" — M (the
    # aspect-inclusive total) is available on every run, including
    # incrementals, because the build_metrics handler falls back to
    # summing per-mnemonic action_data.actions_created when the
    # top-level total is missing. Remote cache hits are reclassified
    # as cached (they don't actually execute) — see
    # `_effective_action_cache_counts`. When everything was cached
    # (executed == 0), drop the "0 of" prefix and "executed" qualifier;
    # the "100% cached" already tells the reader nothing ran.
    actions_executed_raw = data["bazel"].get("actions_executed", 0)
    actions_executed, cached, actions_total = _effective_action_cache_counts(data)
    if actions_total > 0:
        pct = (cached * 100) // actions_total
        if actions_executed == 0:
            row4.append(_item(
                "⚡",
                pluralize(actions_total, "action") + " (" + str(pct) + "% cached)",
            ))
        else:
            row4.append(_item(
                "⚡",
                format_int_comma(actions_executed) + " of " + format_int_comma(actions_total) + " actions executed (" + str(pct) + "% cached)",
            ))
    elif actions_executed_raw > 0:
        row4.append(_item("⚡", pluralize(actions_executed_raw, "action")))

    # Tests: mirror the actions format. When all tests were cached
    # (exec_t == 0), drop "0 of" + "executed" — the "100% cached"
    # already tells the reader nothing ran.
    pass_t = data["bazel"].get("passed_test_total", 0)
    fail_t = data["bazel"].get("failed_test_total", 0)
    flaky_t = data["bazel"].get("flaky_test_total", 0)
    total_tests = pass_t + fail_t + flaky_t
    if total_tests > 0:
        cached_t = data["bazel"].get("cached_test_total", 0)
        exec_t = total_tests - cached_t if total_tests > cached_t else 0
        pct = (cached_t * 100) // total_tests if total_tests > 0 else 0
        if exec_t == 0:
            row4.append(_item(
                ":test_tube:",
                pluralize(total_tests, "test") + " (" + str(pct) + "% cached)",
            ))
        else:
            row4.append(_item(
                ":test_tube:",
                format_int_comma(exec_t) + " of " + format_int_comma(total_tests) + " tests executed (" + str(pct) + "% cached)",
            ))

    tool_version = data["bazel"].get("build_tool_version", "")
    build_cmd = data["bazel"].get("build_command", "")
    if tool_version or build_cmd:
        tool_str = "bazel"
        if tool_version:
            tool_str += " v" + tool_version
        if build_cmd:
            tool_str += " " + build_cmd
        row4.append(_item("🔧", tool_str))

    # (Invocation ID intentionally omitted from the summary metadata — it's a
    # long UUID that burns a lot of horizontal space for little at-a-glance
    # value. The full ID still appears in the Invocation details section.)

    cpu_arch = data["bazel"].get("cpu_arch", "")
    if cpu_arch:
        # 🎯 is the closest Unicode emoji for "target CPU architecture" —
        # no dedicated chip / microprocessor emoji renders in GitHub check
        # runs, so we play on `TARGET_CPU` (the Bazel make_variable we read).
        row4.append(_item("🎯", cpu_arch))

    mode = data["bazel"].get("compilation_mode", "")
    if mode:
        row4.append(_item("⚙️", mode))

    # ------------------------------------------------------------------
    # Row 5 — Workflows runner hardware (only when running on one).
    # Compact view: version, cloud, AZ, instance type, instance id. Full
    # field set lives in the `### Runner metadata` details section below.
    # ------------------------------------------------------------------
    row5 = []
    env = ctx.std.env
    if is_aspect_workflows_runner(env):
        version = env.var("ASPECT_WORKFLOWS_RUNNER_VERSION") or ""
        cloud = env.var("ASPECT_WORKFLOWS_RUNNER_CLOUD_PROVIDER") or ""
        az = env.var("ASPECT_WORKFLOWS_RUNNER_AZ") or ""
        itype = env.var("ASPECT_WORKFLOWS_RUNNER_INSTANCE_TYPE") or ""
        iid = env.var("ASPECT_WORKFLOWS_RUNNER_INSTANCE_ID") or ""
        if version:
            row5.append(_item("🚀", "Workflows runner v" + version))
        if cloud:
            row5.append(_item("☁️", display_cloud_provider(cloud)))
        if az:
            row5.append(_item("📍", az))
        if itype:
            row5.append(_item("💠", itype))
        if iid:
            row5.append(_item("🤖", iid))

    # ------------------------------------------------------------------
    # Row 6 — taxonomy: custom links · tags · operator-pinned metadata
    # 🏷 carries repo-defined tags (TAGS + TAG_*); 📌 carries the
    # operator-selected subset of arbitrary `--build_metadata=K=V`
    # entries surfaced via `GitHubStatusChecksTrait.metadata_keys`.
    # ------------------------------------------------------------------
    row6 = []
    for lnk in parse_workflows_links(meta):
        row6.append(_item("🔗", "[" + lnk["text"] + "](" + lnk["url"] + ")"))
    for tag in parse_tags(meta):
        row6.append(_item("🏷", tag))
    for entry in (extra_meta or []):
        row6.append(_item("📌", entry["key"] + " = " + entry["value"]))

    # ------------------------------------------------------------------
    # Row 7 — external links: Aspect Workflows · CI host. The "click
    # here for more detail" surfaces, separated from the intrinsic
    # metadata above so they're easy to find at the bottom.
    # ------------------------------------------------------------------
    row7 = []

    # Aspect Web UI link — keyed on the sink_invocation_id the Aspect
    # backend received the stream under (`resolve_aspect_url`).
    aspect_url = (links or {}).get("aspect_url", "") or ""
    if aspect_url:
        row7.append(_item("✨", "[Aspect](" + aspect_url + ")"))

    # Generic BES results link — keyed on Bazel's own invocation_id.
    # Surfaces user-supplied `--bes_results_url` consumers alongside
    # Aspect when both are configured. These point at distinct backends
    # with distinct UUIDs; they're complementary, not redundant.
    bes_url = (links or {}).get("bes_url", "") or render_bes_url(data)
    if bes_url and bes_url != aspect_url:
        row7.append(_item("🔗", "[BES](" + bes_url + ")"))
    ci_item = ci_link_item(ctx, links)
    if ci_item:
        row7.append(ci_item)

    rows = []
    for row in [row1, row2, row3, row4, row5, row6, row7]:
        if row:
            rows.append(row)
    return rows

SUMMARY_TEMPLATE = """{% if detail_rows %}{% for row in detail_rows %}
{% for item in row %}{{ item.icon }} {{ item.value }}{% if not loop.last %} · {% endif %}{% endfor %}{% if not loop.last %}  {% endif %}
{%- endfor %}{% endif %}
{% if config_items %}
:gear: {% for item in config_items %}**{{ item.key }}:** `{{ item.value }}`{% if not loop.last %} · {% endif %}{% endfor %}{% if last_update %}  {% endif %}{% endif %}{% if last_update %}
:speech_balloon: **Last update:** `{{ last_update }}`{% endif %}"""

# `REPRO_COMMANDS_BLOCK` and `FIX_COMMANDS_BLOCK` are reusable
# Jinja snippets each task's details template can splice in where
# the user expects to find the actionable command. They iterate the
# producer-authored `repro_commands` / `fix_commands` lists and
# render one fenced code block per entry plus an optional italic
# description line.
#
# Section headings use the same emojis the PR-comment aggregator
# uses (🔁 / 🛠️) so the per-task body and the rolled-up comment
# stay visually consistent.
REPRO_COMMANDS_BLOCK = """{%- if repro_commands %}
### 🔁 Reproduce
{% for c in repro_commands %}
```
{{ c.command }}
```
{% if c.description %}_{{ c.description }}_

{% endif %}{% endfor %}

{% endif %}"""

FIX_COMMANDS_BLOCK = """{%- if fix_commands %}
### 🛠️ Fix
{% for c in fix_commands %}
```
{{ c.command }}
```
{% if c.description %}_{{ c.description }}_

{% endif %}{% endfor %}

{% endif %}"""

# `BAZEL_TARGETS_TEMPLATE` is the bazel-targets detail block: build
# failures (root + dep-broken), failed/timeout/flaky tests, optional
# repro/fix sections (only for bazel-primary tasks — gated by
# `render_repro_in_targets`), and built-targets / cached-tests
# tables. Pulled out of SHARED so build/test can render it as their
# *primary* section (slot 1) while non-bazel tasks render it as
# their bazel-context section (slot 4) — controlled by the
# `include_bazel_targets` Jinja flag in SHARED.
BAZEL_TARGETS_TEMPLATE = """### 🎯 Bazel targets ({{ total_targets }})

{% if no_targets_info %}
{%- if not aborted %}
:hourglass_flowing_sand: **Build in progress** — target data will appear here as Bazel reports them.
{% endif %}
{%- else %}
{%- if build_failures or derived_failures %}
<details open>
<summary>{{ build_failures_icon }} {{ build_failures_header }}</summary>

{% if build_failures %}<pre>
{{- build_failures_table_head }}
{{ build_failures_table_sep }}
{%- for t in build_failures %}
{{ t.aligned_label }} | {{ t.aligned_kind }} | {{ t.aligned_mnemonic }}
{%- endfor %}
{% if build_failures_overflow %}_{{ build_failures_overflow }} more root failure(s) not shown._{% endif %}</pre>
{% endif %}
{% if derived_failures %}
<details><summary>{{ derived_failures_count }} more target{{ derived_failures_plural }} blocked by a failed dependency</summary>

<pre>
{{- derived_failures_table_head }}
{{ derived_failures_table_sep }}
{%- for t in derived_failures %}
{{ t.aligned_label }} | {{ t.aligned_kind }}
{%- endfor %}
{% if derived_failures_overflow %}_{{ derived_failures_overflow }} more not shown._{% endif %}</pre>
</details>
{% endif %}
</details>

{% endif %}
{%- if failed_tests %}
<details open>
