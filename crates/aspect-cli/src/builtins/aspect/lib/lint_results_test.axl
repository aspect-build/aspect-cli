"""Snapshot tests for `lib/lint_results.axl` template rendering.

Run with:
  aspect dev test-lint-template-snapshots

Mirrors the shape of `bazel_results_test.axl` — hand-crafted results dicts
covering the main scenarios (no findings / mixed severity / errors only /
build failure), rendered through the lint renderer, printed for visual
inspection of TITLE, SUMMARY, and DETAILS output.

Scenarios:
  1. clean-passed    — no diagnostics, build succeeded
  2. mixed-findings  — errors + warnings + info across multiple tools
  3. errors-only     — only errors, terminal status "failed"
  4. warnings-only   — only warnings, terminal status "passed" (soft strategy)
  5. build-failed    — underlying Bazel build crashed before all linters ran
  6. large           — 200+ findings (exercises the trim cascade)
  7. hold-the-line   — hold_the_line strategy, changed_files present
"""
load("./lint_results.axl", "render_check_output", "init_results", "accumulate")


# ─── Fake-data builders ───────────────────────────────────────────────────────

def _make_base():
    """Common metadata / runner info shared by all scenarios.

    Matches the shape lint_init_results() produces — populates the fields
    build_summary_data reads when rendering the summary metadata rows
    (status/date, repo/branch/commit, user, CI/Aspect links).
    """
    r = init_results()
    r["invocation_id"]       = "lint-abc12345-def4-5678-9abc-def012345678"
    r["sink_invocation_id"]  = "sink-uuid-1234-5678-9abc"
    r["build_tool_version"]  = "9.0.1"
    r["build_command"]       = "build"
    r["start_time_ms"]       = 1744630000000
    r["finish_time_ms"]      = 1744630004500
    r["wall_time_ms"]        = 4500
    r["workspace_status"]    = {
        "BUILD_USER":      "aspect-runner",
        "BUILD_HOST":      "ip-10-0-86-10",
        "BUILD_TIMESTAMP": "1776727956",
    }
    r["metadata"] = {
        "BRANCH":             "main",
        "BRANCH_NAME":        "main",
        "COMMIT_SHA":         "abc123def456789abcdef",
        "COMMIT_MESSAGE":     "refactor: extract lint renderer",
        "COMMIT_AUTHOR":      "Greg Magolan <greg@aspect.build>",
        "COMMIT_AUTHOR_NAME": "Greg Magolan",
        "COMMIT_AUTHOR_EMAIL": "greg@aspect.build",
        "COMMIT_TIMESTAMP":   "2026-04-14 16:32:09 -0700",
        "USER":               "Greg Magolan",
        "CI_HOST":             "BUILDKITE",
        "VCS":                 "GITHUB",
        "REPO_OWNER":          "aspect-build",
        "REPO_NAME":           "silo",
        "BUILD_NUMBER":        "49508",
        "RUN_TYPE":            "BRANCH_PUSH",
        "ASPECT_TASK_NAME":    "Lint",
        "ASPECT_TASK_ID":      "lint",
        "BUILD_URL":           "https://buildkite.com/aspect-build/silo-aws/builds/49508",
    }
    r["target_pattern"] = "//..."
    r["strategy"]       = "hard"
    return r


def _make_results_clean():
    r = _make_base()
    # No diagnostics — lint passed.
    return r


def _make_results_mixed():
    """Mixed severities across tools — the common "most builds look like this" case."""
    r = _make_base()
    diags = [
        {"tool": "eslint",       "file": "apps/web/src/auth/login.ts",      "line": 42,  "rule_id": "no-unused-vars",   "severity": "error",   "message": "'foo' is defined but never used"},
        {"tool": "eslint",       "file": "apps/web/src/auth/login.ts",      "line": 58,  "rule_id": "no-console",       "severity": "warning", "message": "Unexpected console statement"},
        {"tool": "eslint",       "file": "apps/web/src/utils/helpers.ts",   "line": 15,  "rule_id": "prefer-const",     "severity": "warning", "message": "'x' is never reassigned. Use 'const' instead."},
        {"tool": "eslint",       "file": "apps/web/src/api/client.ts",      "line": 103, "rule_id": "no-floating-promises", "severity": "error", "message": "Promises must be awaited, end with a call to .catch, end with a call to .then with a rejection handler or be explicitly marked as ignored with the `void` operator"},
        {"tool": "eslint",       "file": "apps/web/src/api/client.ts",      "line": 204, "rule_id": "no-explicit-any",  "severity": "warning", "message": "Unexpected any. Specify a different type."},
        {"tool": "pylint",       "file": "tools/deploy/deploy.py",         "line": 88,  "rule_id": "C0116",            "severity": "warning", "message": "Missing function or method docstring"},
        {"tool": "pylint",       "file": "tools/deploy/deploy.py",         "line": 120, "rule_id": "W0611",            "severity": "warning", "message": "Unused import os"},
        {"tool": "pylint",       "file": "tools/deploy/config.py",         "line": 5,   "rule_id": "E0401",            "severity": "error",   "message": "Unable to import 'missing_module'"},
        {"tool": "pylint",       "file": "tools/ci/validate.py",           "line": 14,  "rule_id": "C0411",            "severity": "warning", "message": "standard import 'os' should be placed before third-party imports"},
        {"tool": "pylint",       "file": "tools/ci/validate.py",           "line": 42,  "rule_id": "R0913",            "severity": "info",    "message": "Too many arguments (6/5)"},
        {"tool": "markdownlint", "file": "docs/README.md",                 "line": 23,  "rule_id": "MD041",            "severity": "warning", "message": "First line in file should be a top-level heading"},
        {"tool": "markdownlint", "file": "docs/CONTRIBUTING.md",           "line": 12,  "rule_id": "MD022",            "severity": "warning", "message": "Headings should be surrounded by blank lines"},
    ]
    accumulate(r, diags)
    return r


def _make_results_errors_only():
    r = _make_base()
    diags = [
        {"tool": "eslint", "file": "apps/web/src/index.ts",       "line": 10, "rule_id": "no-undef",   "severity": "error", "message": "'Foo' is not defined"},
        {"tool": "eslint", "file": "apps/web/src/bootstrap.ts",   "line": 25, "rule_id": "no-undef",   "severity": "error", "message": "'Bar' is not defined"},
        {"tool": "pylint", "file": "tools/build/generator.py",    "line": 103,"rule_id": "E1101",      "severity": "error", "message": "Instance of 'Generator' has no 'write' member"},
    ]
    accumulate(r, diags)
    return r


def _make_results_warnings_only():
    r = _make_base()
    r["strategy"] = "soft"
    diags = [
        {"tool": "eslint", "file": "apps/web/src/auth/utils.ts", "line": 15, "rule_id": "prefer-const",  "severity": "warning", "message": "'y' is never reassigned. Use 'const' instead."},
        {"tool": "eslint", "file": "apps/web/src/api/client.ts", "line": 204, "rule_id": "no-explicit-any", "severity": "warning", "message": "Unexpected any. Specify a different type."},
        {"tool": "pylint", "file": "tools/deploy/deploy.py",    "line": 88, "rule_id": "C0116",          "severity": "warning", "message": "Missing function or method docstring"},
    ]
    accumulate(r, diags)
    return r


def _make_results_build_failed():
    r = _make_base()
    r["build_failed"] = True
    # Partial diagnostics captured before the build aborted.
    diags = [
        {"tool": "eslint", "file": "apps/web/src/auth/login.ts", "line": 42, "rule_id": "no-unused-vars", "severity": "error", "message": "'foo' is defined but never used"},
    ]
    accumulate(r, diags)
    return r


def _make_results_large():
    """200+ findings to exercise the group-table trim cascade."""
    r = _make_base()
    diags = []
    for i in range(60):
        diags.append({
            "tool": "eslint",
            "file": "apps/web/src/gen/module_" + str(i) + ".ts",
            "line": (i % 100) + 1,
            "rule_id": "no-unused-vars",
            "severity": "error",
            "message": "Variable 'foo_" + str(i) + "' is defined but never used",
        })
    for i in range(150):
        diags.append({
            "tool": "eslint",
            "file": "apps/web/src/gen/module_" + str(i) + ".ts",
            "line": (i % 100) + 2,
            "rule_id": "no-console",
            "severity": "warning",
            "message": "Unexpected console statement on this line",
        })
    for i in range(30):
        diags.append({
            "tool": "pylint",
            "file": "tools/gen/module_" + str(i) + ".py",
            "line": (i % 50) + 1,
            "rule_id": "C0116",
            "severity": "info",
            "message": "Missing function or method docstring for gen_" + str(i),
        })
    accumulate(r, diags)
    return r


def _make_results_hold_the_line():
    r = _make_base()
    r["strategy"] = "hold_the_line"
    r["changed_files"] = [
        {"file": "apps/web/src/auth/login.ts",   "lines": [42, 58]},
        {"file": "apps/web/src/api/client.ts",   "lines": [103, 204]},
    ]
    diags = [
        {"tool": "eslint", "file": "apps/web/src/auth/login.ts",  "line": 42,  "rule_id": "no-unused-vars",      "severity": "error",   "message": "'foo' is defined but never used"},
        {"tool": "eslint", "file": "apps/web/src/api/client.ts",  "line": 103, "rule_id": "no-floating-promises", "severity": "error",  "message": "Promises must be awaited"},
        {"tool": "eslint", "file": "apps/web/src/api/client.ts",  "line": 204, "rule_id": "no-explicit-any",      "severity": "warning", "message": "Unexpected any"},
    ]
    accumulate(r, diags)
    return r


# ─── Test harness ─────────────────────────────────────────────────────────────

def _render_ctx(targets = "//...", task_display_name = "Lint"):
    return {
        "triggered_by":      "Greg Magolan (workflow_dispatch)",
        "targets":           targets,
        "started_ms":        1744630000000,
        "ended_ms":          1744630004500,
        "progress":          "",
        "task_display_name": task_display_name,
    }


def _links(with_artifact = False, ci = "github"):
    if ci == "buildkite":
        ci_label = "Buildkite"
        ci_url   = "https://buildkite.com/aspect-build/aspect-cli/builds/1354/steps/canvas?sid=s1"
    elif ci == "circleci":
        ci_label = "CircleCI"
        ci_url   = "https://circleci.com/gh/aspect-build/aspect-cli/9911"
    elif ci == "gitlab":
        ci_label = "GitLab CI"
        ci_url   = "https://gitlab.com/aspect-build/aspect-cli/-/jobs/2469624812"
    else:
        ci_label = "GitHub Actions"
        ci_url   = "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652/job/72239404829"

    d = {
        "ci_label":             ci_label,
        "ci_url":               ci_url,
        "aspect_url":           "https://app.aspect.build/invocations/sink-uuid-1234-5678-9abc",
        "results_base_url":     "https://app.aspect.build/",
        "artifacts_browse_url": "",
        "artifact_urls":        {},
        "testlogs_label_urls":  {},
    }
    if with_artifact and ci == "github":
        d["artifacts_browse_url"] = "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652"
    return d


def _test_impl(ctx):
    """Render each scenario and print TITLE + SUMMARY + first 4000 chars of DETAILS."""

    scenarios = [
        # (label, results, status, targets, with_artifact, ci, metadata_keys)
        ("1. clean-passed · GitHub",      _make_results_clean(),         "passed",  "//...",   True,  "github",    None),
        ("2. mixed-findings · GitHub",    _make_results_mixed(),         "failed",  "//...",   True,  "github",    None),
        ("3. errors-only · Buildkite",    _make_results_errors_only(),   "failed",  "//...",   True,  "buildkite", None),
        ("4. warnings-only · GitHub",     _make_results_warnings_only(), "passed",  "//...",   True,  "github",    None),
        ("5. build-failed · GitHub",      _make_results_build_failed(),  "failed",  "//...",   False, "github",    None),
        ("6. large-trim · GitHub",        _make_results_large(),         "failed",  "//...",   True,  "github",    None),
        ("7. hold-the-line · GitHub",     _make_results_hold_the_line(), "failed",  "//...",   True,  "github",    None),
        # Exercise GitHubStatusChecksTrait.metadata_keys through the shared summary renderer.
        ("8. mixed · meta=*",             _make_results_mixed(),         "failed",  "//...",   True,  "github",    ["*"]),
    ]

    sep = "=" * 70

    for (label, results, status, targets, with_artifact, ci, metadata_keys) in scenarios:
        rc = _render_ctx(targets = targets)
        lk = _links(with_artifact = with_artifact, ci = ci)
        out = render_check_output(ctx, results, status, rc, lk, metadata_keys = metadata_keys)
        print(sep)
        print("SCENARIO: " + label)
        print(sep)
        print("TITLE:    " + out["title"])
        print("")
        print("SUMMARY:")
        print(out["summary"])
        print("")
        print("DETAILS (first 4000 chars):")
        print(out["text"][:4000])
        print("")

    print(sep)
    print("All " + str(len(scenarios)) + " lint scenarios rendered without error.")
    return 0


lint_template_snapshot_tests = task(
    name = "test-lint-template-snapshots",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
