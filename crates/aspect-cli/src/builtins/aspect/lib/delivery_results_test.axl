"""Tests for `lib/delivery_results.axl`.

Two test tasks live in this file:

  test-delivery-template-snapshots — Jinja2 template snapshot tests.
    Hand-crafted data dicts exercise every outcome bucket (ok / skip /
    warn / fail / pending) and the trim cascade.

    Scenarios:
      1. all-delivered    — every target freshly delivered
      2. mixed-outcomes   — delivered + skipped + warned + failed
      3. all-skipped      — same hash already delivered this commit
      4. all-failed       — every delivery target exited non-zero
      5. dry-run          — --dry-run marks everything pending
      6. forced           — --force-target re-delivers a previously delivered target
      7. large            — 200 data to exercise the trim cascade
      8. no-targets       — empty target list → "No targets" title
      9. build-failed     — delivery aborted before any targets ran (synthetic warns)

  test-delivery-results — focused unit tests for `init_data`, `add_result`,
    and `build_manifest`. Locks the manifest schema so a future field rename
    surfaces here instead of breaking customer manifests in the wild.
"""

load("./delivery_results.axl", "add_result", "build_manifest", "init_data", "render_check_output")
load("./text.axl", "SUBJECT_TITLE_MAX")

# A resolved subject far longer than the title's character budget (60),
# as a query-driven delivery over many labels would produce. The title
# must truncate it; see `_check_long_subject_title_is_capped`.
_LONG_SUBJECT = " ".join(["//apps/service_%d:release" % i for i in range(12)])

# ─── Fake-data builders ───────────────────────────────────────────────────────

def _make_base():
    """Common metadata / runner info shared by all scenarios.

    Matches the shape init_data() produces — populates the fields
    build_summary_data reads when rendering the summary metadata rows
    (status/date, repo/branch/commit, user, CI/Aspect links).
    """
    r = init_data()
    r["bazel"]["invocation_id"] = "dlv-abc12345-def4-5678-9abc-def012345678"
    r["sink_invocation_id"] = "sink-uuid-1234-5678-9abc"
    r["bazel"]["build_tool_version"] = "9.0.1"
    r["bazel"]["build_command"] = "build"
    r["start_time_ms"] = 1744630000000
    r["finish_time_ms"] = 1744630012500
    r["bazel"]["wall_time_ms"] = 12500
    r["bazel"]["workspace_status"] = {
        "BUILD_USER": "aspect-runner",
        "BUILD_HOST": "ip-10-0-86-10",
        "BUILD_TIMESTAMP": "1776727956",
    }
    r["bazel"]["metadata"] = {
        "BRANCH": "main",
        "BRANCH_NAME": "main",
        "COMMIT_SHA": "abc123def456789abcdef",
        "COMMIT_MESSAGE": "deploy: cut release v1.42.0",
        "COMMIT_AUTHOR": "Greg Magolan <greg@aspect.build>",
        "COMMIT_AUTHOR_NAME": "Greg Magolan",
        "COMMIT_AUTHOR_EMAIL": "greg@aspect.build",
        "COMMIT_TIMESTAMP": "2026-04-14 16:32:09 -0700",
        "USER": "Greg Magolan",
        "CI_HOST": "BUILDKITE",
        "VCS": "GITHUB",
        "REPO_OWNER": "aspect-build",
        "REPO_NAME": "silo",
        "BUILD_NUMBER": "49508",
        "RUN_TYPE": "BRANCH_PUSH",
        "ASPECT_TASK_NAME": "Delivery",
        "ASPECT_TASK_ID": "delivery",
        "BUILD_URL": "https://buildkite.com/aspect-build/silo-aws/builds/49508",
    }
    r["target_pattern"] = "//apps/..."
    r["delivery"]["prefix"] = "delivery"
    r["delivery"]["ci_host"] = "bk"
    r["delivery"]["commit_sha"] = "abc123def456789abcdef"
    r["delivery"]["build_url"] = "https://buildkite.com/aspect-build/silo-aws/builds/49508"

    # Default run-shape — the snapshot scenarios that exercise non-default
    # values flip these explicitly after calling _make_base().
    r["delivery"]["mode"] = "selective"
    r["delivery"]["dry_run"] = False
    r["delivery"]["track_state"] = True
    return r

_SHA_1 = "11112222333344445555666677778888aaaabbbbccccddddeeeeffff00001111"
_SHA_2 = "22223333444455556666777788889999bbbbccccddddeeeeffff000011112222"
_SHA_3 = "33334444555566667777888899990000ccccddddeeeeffff0000111122223333"
_SHA_4 = "44445555666677778888999900001111ddddeeeeffff0000111122223333444"
_SHA_5 = "55556666777788889999000011112222eeeeffff000011112222333344445555"

def _make_all_delivered():
    r = _make_base()
    add_result(r, "//apps/web:release", "ok", message = r["delivery"]["build_url"], output_sha = _SHA_1)
    add_result(r, "//apps/api:release", "ok", message = r["delivery"]["build_url"], output_sha = _SHA_2)
    add_result(r, "//apps/worker:release", "ok", message = r["delivery"]["build_url"], output_sha = _SHA_3)
    add_result(r, "//apps/cli:release", "ok", message = r["delivery"]["build_url"], output_sha = _SHA_4)
    return r

def _make_mixed():
    r = _make_base()
    add_result(
        r,
        "//apps/web:release",
        "ok",
        message = r["delivery"]["build_url"],
        output_sha = _SHA_1,
    )
    add_result(
        r,
        "//apps/api:release",
        "ok",
        message = r["delivery"]["build_url"],
        output_sha = _SHA_2,
    )
    add_result(
        r,
        "//apps/cli:release",
        "skip",
        message = "https://buildkite.com/aspect-build/silo-aws/builds/49495",
        output_sha = _SHA_3,
    )
    add_result(
        r,
        "//apps/legacy:release",
        "warn",
        message = "no entrypoint (not in BES)",
        output_sha = _SHA_4,
    )
    add_result(
        r,
        "//apps/experimental:release",
        "fail",
        message = "exit 1",
        output_sha = _SHA_5,
    )
    return r

def _make_all_skipped():
    r = _make_base()
    prior = "https://buildkite.com/aspect-build/silo-aws/builds/49495"
    add_result(r, "//apps/web:release", "skip", message = prior, output_sha = _SHA_1)
    add_result(r, "//apps/api:release", "skip", message = prior, output_sha = _SHA_2)
    add_result(r, "//apps/worker:release", "skip", message = prior, output_sha = _SHA_3)
    return r

def _make_all_failed():
    r = _make_base()
    add_result(r, "//apps/web:release", "fail", message = "exit 1", output_sha = _SHA_1)
    add_result(r, "//apps/api:release", "fail", message = "exit 137", output_sha = _SHA_2)
    add_result(r, "//apps/worker:release", "fail", message = "exit 2", output_sha = _SHA_3)
    return r

def _make_dry_run():
    r = _make_base()
    r["delivery"]["dry_run"] = True
    add_result(r, "//apps/web:release", "pending", message = "dry-run", output_sha = _SHA_1)
    add_result(r, "//apps/api:release", "pending", message = "dry-run", output_sha = _SHA_2)
    add_result(
        r,
        "//apps/cli:release",
        "pending",
        message = "dry-run (forced)",
        output_sha = _SHA_3,
        is_forced = True,
    )
    return r

def _make_always_dry_run_untracked():
    """`--mode=always --dry-run --track-state=false` — the most-permissive
    combination, exercises all three modifiers in the rendered Mode line."""
    r = _make_base()
    r["delivery"]["mode"] = "always"
    r["delivery"]["dry_run"] = True
    r["delivery"]["track_state"] = False
    add_result(r, "//apps/web:release", "pending", message = "dry-run", output_sha = _SHA_1)
    add_result(r, "//apps/api:release", "pending", message = "dry-run", output_sha = _SHA_2)
    return r

def _make_forced():
    r = _make_base()
    add_result(
        r,
        "//apps/web:release",
        "ok",
        message = r["delivery"]["build_url"],
        output_sha = _SHA_1,
        is_forced = True,
    )
    add_result(
        r,
        "//apps/api:release",
        "ok",
        message = r["delivery"]["build_url"],
        output_sha = _SHA_2,
    )
    return r

def _make_large():
    """200 deliveries to exercise the per-group trim cascade."""
    r = _make_base()
    r["target_pattern"] = "//apps/..."
    for i in range(120):
        add_result(
            r,
            "//apps/svc_" + str(i) + ":release",
            "ok",
            message = r["delivery"]["build_url"],
            output_sha = _SHA_1,
        )
    for i in range(50):
        add_result(
            r,
            "//apps/svc_legacy_" + str(i) + ":release",
            "skip",
            message = "https://buildkite.com/aspect-build/silo-aws/builds/49495",
            output_sha = _SHA_2,
        )
    for i in range(20):
        add_result(
            r,
            "//apps/svc_broken_" + str(i) + ":release",
            "fail",
            message = "exit 1",
            output_sha = _SHA_3,
        )
    for i in range(10):
        add_result(
            r,
            "//apps/svc_warn_" + str(i) + ":release",
            "warn",
            message = "no entrypoint (not in BES)",
            output_sha = _SHA_4,
        )
    return r

def _make_no_targets():
    r = _make_base()
    r["target_pattern"] = ""
    return r

def _make_build_failed():
    """Build-phase failure before any target delivery: synthetic warns per target."""
    r = _make_base()
    for label in [
        "//apps/web:release",
        "//apps/api:release",
        "//apps/worker:release",
    ]:
        add_result(r, label, "warn", message = "build failed (exit 1)")
    return r

# ─── Test harness ─────────────────────────────────────────────────────────────

def _render_ctx(subject = "//apps/...", task_kind = "delivery", progress = ""):
    return {
        "triggered_by": "Greg Magolan (workflow_dispatch)",
        "subject": subject,
        "started_ms": 1744630000000,
        "ended_ms": 1744630012500,
        "progress": progress,
        "task_kind": task_kind,
    }

def _links(ci = "buildkite", with_manifest = False):
    if ci == "github":
        ci_label = "GitHub Actions"
        ci_url = "https://github.com/aspect-build/aspect-cli/actions/runs/24410554652/job/72239404829"
    elif ci == "circleci":
        ci_label = "CircleCI"
        ci_url = "https://circleci.com/gh/aspect-build/aspect-cli/9911"
    elif ci == "gitlab":
        ci_label = "GitLab CI"
        ci_url = "https://gitlab.com/aspect-build/aspect-cli/-/jobs/2469624812"
    else:
        ci_label = "Buildkite"
        ci_url = "https://buildkite.com/aspect-build/silo-aws/builds/49508/steps/canvas?sid=s1"
    artifact_urls = {}
    artifacts_browse_url = ""
    manifest_artifacts = []
    if with_manifest:
        artifacts_browse_url = "https://buildkite.com/aspect-build/silo-aws/builds/49508#artifacts"

        # Two manifest uploads — the JSON (default) plus a YAML side-artifact
        # from a customer `upload_manifest` hook — to exercise the per-file
        # link rendering.
        manifest_artifacts = [
            {
                "name": "delivery-manifest.json",
                "url": "https://buildkite.com/aspect-build/silo-aws/builds/49508/artifacts/delivery-manifest.json",
            },
            {
                "name": "delivery-images.yml",
                "url": "https://buildkite.com/aspect-build/silo-aws/builds/49508/artifacts/delivery-images.yml",
            },
        ]
    return {
        "ci_label": ci_label,
        "ci_url": ci_url,
        "aspect_url": "https://app.aspect.build/invocations/sink-uuid-1234-5678-9abc",
        "results_base_url": "https://app.aspect.build/",
        "artifacts_browse_url": artifacts_browse_url,
        "artifact_urls": artifact_urls,
        "manifest_artifacts": manifest_artifacts,
        "testlogs_label_urls": {},
    }

def _test_impl(ctx):
    scenarios = [
        # (label,                            data,                     status,     subject,        ci,          metadata_keys, progress, with_manifest)
        ("1. all-delivered · BK", _make_all_delivered(), "passed", "//apps/...", "buildkite", None, "", False),
        ("2. mixed-outcomes · BK", _make_mixed(), "failed", "//apps/...", "buildkite", None, "", False),
        ("3. all-skipped · GH", _make_all_skipped(), "passed", "//apps/...", "github", None, "", False),
        ("4. all-failed · BK", _make_all_failed(), "failed", "//apps/...", "buildkite", None, "", False),
        ("5. dry-run · BK", _make_dry_run(), "passed", "//apps/...", "buildkite", None, "", False),
        ("6. forced · GH", _make_forced(), "passed", "//apps/...", "github", None, "", False),
        ("7. large · BK", _make_large(), "failed", "//apps/...", "buildkite", None, "", False),
        ("8. no-targets · BK", _make_no_targets(), "passed", "", "buildkite", None, "", False),
        ("9. build-failed · BK", _make_build_failed(), "failed", "//apps/...", "buildkite", None, "", False),
        # Exercise GitHubStatusChecksTrait.metadata_keys through the shared summary renderer.
        ("10. mixed · meta=*", _make_mixed(), "failed", "//apps/...", "buildkite", ["*"], "", False),
        # Progress scenarios — confirm the "Last update" line surfaces the
        # phase label that delivery.axl threads into TaskUpdate.progress.
        ("11. progress=building · running · BK", _make_mixed(), "running", "//apps/...", "buildkite", None, "Building 8 targets for delivery...", False),
        ("12. progress=delivering · running · BK", _make_mixed(), "running", "//apps/...", "buildkite", None, "Delivering 3 of 8 targets...", False),
        # Mode line — exercises both the default-suppressed path (no
        # qualifiers when `selective` + tracked + non-dry-run) and the
        # all-modifiers path. The dry-run scenario above covers the
        # single-modifier case.
        ("13. mode=always · dry-run · untracked", _make_always_dry_run_untracked(), "passed", "//apps/...", "buildkite", None, "", False),
        # Long resolved subject — a query-driven delivery resolves many
        # labels and emits them as a refined `subject`. The title must cap
        # it (asserted in `_check_long_subject_title_is_capped`).
        ("14. long resolved subject (capped)", _make_all_delivered(), "passed", _LONG_SUBJECT, "buildkite", None, "", False),
        # Manifest artifact links — populates `manifest_artifacts` with two
        # entries (JSON + YAML) so the rendered surface emits a per-file
        # download link for each (plus the Artifacts browse link).
        ("15. all-delivered + manifest artifact · BK", _make_all_delivered(), "passed", "//apps/...", "buildkite", None, "", True),
    ]

    sep = "=" * 70

    for (label, data, status, subject, ci, metadata_keys, progress, with_manifest) in scenarios:
        rc = _render_ctx(subject = subject, progress = progress)
        lk = _links(ci = ci, with_manifest = with_manifest)
        out = render_check_output(ctx, data, status, rc, lk, metadata_keys = metadata_keys)
        print(sep)
        print("SCENARIO: " + label)
        print(sep)
        print("TITLE:    " + out["title"])
        print("")
        print("SUMMARY:")
        print(out["summary"])
        print("")
        print("DETAILS (first 4000 chars):")
        print(out["text"][:4000])
        print("")

    _check_long_subject_title_is_capped(ctx)

    print(sep)
    print("All " + str(len(scenarios)) + " delivery scenarios rendered without error.")
    return 0

def _check_long_subject_title_is_capped(ctx):
    """A resolved subject longer than the title budget is truncated with a
    `…` in the rendered title, not emitted whole."""
    rc = _render_ctx(subject = _LONG_SUBJECT)
    out = render_check_output(ctx, _make_all_delivered(), "passed", rc, _links())
    title = out["title"]
    if _LONG_SUBJECT in title:
        fail("long subject not truncated in title: %r" % title)
    if "…" not in title:
        fail("truncated title missing `…` ellipsis: %r" % title)

    # The subject is capped at SUBJECT_TITLE_MAX; the rest of the title is the
    # emoji + " delivery " + " · N delivered" verdict (~30 chars). A bound just
    # past that catches a partial- or non-truncation regression — a full
    # untruncated subject (300+ chars) would blow well past it.
    if len(title) > SUBJECT_TITLE_MAX + 40:
        fail("title unexpectedly long (%d chars): %r" % (len(title), title))

delivery_template_snapshot_tests = task(
    kind = "test-delivery-template-snapshots",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)

# ─── Unit tests ──────────────────────────────────────────────────────────────

def _test_init_data_shape(ctx):
    r = init_data()
    if "delivery" not in r:
        fail("init_data: missing 'delivery' key")
    d = r["delivery"]
    for k in [
        "ci_host",
        "build_url",
        "commit_sha",
        "prefix",
        "deliveries",
        "mode",
        "dry_run",
        "track_state",
        "counts",
    ]:
        if k not in d:
            fail("init_data: missing 'delivery.%s'" % k)
    if d["mode"] != "selective":
        fail("init_data: default mode should be 'selective', got %r" % d["mode"])
    if d["dry_run"] != False or d["track_state"] != True:
        fail("init_data: default run-shape flags drifted")
    if d["deliveries"] != [] or d["counts"] != {}:
        fail("init_data: deliveries/counts should start empty")

def _test_add_result_seeds_custom(ctx):
    """add_result seeds an empty `custom` dict so the per-target hook can
    enrich without re-checking existence on every key."""
    r = init_data()
    add_result(r, "//a:b", "ok", message = "msg", output_sha = "abc")
    e = r["delivery"]["deliveries"][-1]
    if e.get("custom") != {}:
        fail("add_result: expected empty custom dict, got %r" % e.get("custom"))
    if e["label"] != "//a:b" or e["outcome"] != "ok":
        fail("add_result: scalar fields drifted: %r" % e)
    if e["is_forced"] != False:
        fail("add_result: is_forced default should be False, got %r" % e["is_forced"])

def _test_add_result_bumps_counts(ctx):
    r = init_data()
    add_result(r, "//a:b", "ok")
    add_result(r, "//c:d", "ok")
    add_result(r, "//e:f", "fail")
    add_result(r, "//g:h", "skip")
    counts = r["delivery"]["counts"]
    if counts != {"ok": 2, "fail": 1, "skip": 1}:
        fail("add_result: counts drifted: %r" % counts)

def _test_add_result_coerces_none_strings(ctx):
    """add_result must not write None into string fields — JSON consumers
    expect strings, and `message or ""` / `output_sha or ""` guarantees that."""
    r = init_data()
    add_result(r, "//a:b", "warn", message = None, output_sha = None)
    e = r["delivery"]["deliveries"][-1]
    if e["message"] != "" or e["output_sha"] != "":
        fail("add_result: None should coerce to '': %r" % e)

def _test_build_manifest_required_top_level_fields(ctx):
    """The manifest schema is a customer-facing contract — every documented
    top-level field must be present even when the source `data` is sparse."""
    r = init_data()
    m = build_manifest(r)
    for k in [
        "schema_version",
        "ci_host",
        "build_url",
        "commit_sha",
        "prefix",
        "mode",
        "dry_run",
        "track_state",
        "counts",
        "deliveries",
    ]:
        if k not in m:
            fail("build_manifest: missing top-level field %r" % k)
    if m["schema_version"] != 1:
        fail("build_manifest: schema_version drifted from 1: %r" % m["schema_version"])

def _test_build_manifest_carries_metadata(ctx):
    r = init_data()
    r["delivery"]["ci_host"] = "bk"
    r["delivery"]["build_url"] = "https://example/123"
    r["delivery"]["commit_sha"] = "deadbeef"
    r["delivery"]["prefix"] = "my-task"
    r["delivery"]["mode"] = "always"
    r["delivery"]["dry_run"] = True
    r["delivery"]["track_state"] = False
    m = build_manifest(r)
    if m["ci_host"] != "bk" or m["build_url"] != "https://example/123":
        fail("build_manifest: CI metadata drifted: %r" % m)
    if m["commit_sha"] != "deadbeef" or m["prefix"] != "my-task":
        fail("build_manifest: commit/prefix drifted: %r" % m)
    if m["mode"] != "always" or m["dry_run"] != True or m["track_state"] != False:
        fail("build_manifest: run-shape flags drifted: %r" % m)

def _test_build_manifest_required_entry_fields(ctx):
    """Every per-entry field documented in add_result()'s docstring must
    appear on every manifest entry."""
    r = init_data()
    add_result(r, "//a:b", "ok", message = "msg", output_sha = "sha", is_forced = True)
    m = build_manifest(r)
    if len(m["deliveries"]) != 1:
        fail("build_manifest: dropped entry: %r" % m["deliveries"])
    e = m["deliveries"][0]
    for k in ["label", "outcome", "message", "output_sha", "is_forced", "custom"]:
        if k not in e:
            fail("build_manifest: entry missing field %r in %r" % (k, e))

def _test_build_manifest_preserves_custom_enrichment(ctx):
    """Whatever the per-target hook wrote into `custom` flows through to
    the manifest unchanged — this is the customer's escape hatch for
    ruleset-specific data like image digests."""
    r = init_data()
    add_result(r, "//a:b", "ok")
    r["delivery"]["deliveries"][0]["custom"]["image_digest"] = "sha256:cafef00d"
    r["delivery"]["deliveries"][0]["custom"]["layer_path"] = "/tmp/layer.tar"
    m = build_manifest(r)
    custom = m["deliveries"][0]["custom"]
    if custom.get("image_digest") != "sha256:cafef00d":
        fail("build_manifest: dropped custom.image_digest")
    if custom.get("layer_path") != "/tmp/layer.tar":
        fail("build_manifest: dropped custom.layer_path")

def _test_build_manifest_preserves_extra_entry_fields(ctx):
    """Extra fields attached to an entry after add_result (e.g. on-disk
    path fields delivery.axl layers on before firing the per-target hook)
    flow through to the manifest unchanged."""
    r = init_data()
    add_result(r, "//a:b", "ok")
    e = r["delivery"]["deliveries"][0]
    e["entrypoint_path"] = "/abs/path/a"
    e["runfiles_dir"] = "/abs/path/a.runfiles"
    e["default_outputs"] = ["/abs/path/a", "/abs/path/a.digest"]
    m = build_manifest(r)
    me = m["deliveries"][0]
    if me["entrypoint_path"] != "/abs/path/a":
        fail("build_manifest: dropped entrypoint_path")
    if me["runfiles_dir"] != "/abs/path/a.runfiles":
        fail("build_manifest: dropped runfiles_dir")
    if me["default_outputs"] != ["/abs/path/a", "/abs/path/a.digest"]:
        fail("build_manifest: dropped default_outputs")

def _test_build_manifest_entries_are_copies(ctx):
    """`build_manifest` returns dict-copied entries so a customer mutating
    the manifest can't corrupt the live source state."""
    r = init_data()
    add_result(r, "//a:b", "ok")
    m = build_manifest(r)
    m["deliveries"][0]["label"] = "MUTATED"
    if r["delivery"]["deliveries"][0]["label"] != "//a:b":
        fail("build_manifest: entries are not copies — mutation leaked back to source")

def _test_build_manifest_counts_independent(ctx):
    """The counts dict is also copied; bumping the manifest's count doesn't
    bump the live one."""
    r = init_data()
    add_result(r, "//a:b", "ok")
    m = build_manifest(r)
    m["counts"]["ok"] = 999
    if r["delivery"]["counts"]["ok"] != 1:
        fail("build_manifest: counts dict not copied")

_UNIT_TESTS = [
    _test_init_data_shape,
    _test_add_result_seeds_custom,
