def _test_impl(ctx):
    for t in _UNIT_TESTS:
        t(ctx)
    print("repro_commands.axl: OK (%d tests)" % len(_UNIT_TESTS))
    return 0

repro_commands_tests = task(
    name = "test-repro-commands",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
