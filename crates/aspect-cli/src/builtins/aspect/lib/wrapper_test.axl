"""Unit tests for lib/wrapper.axl: workspace-root detection, wrapper-version
parsing, marker detection, install classification, flag harvesting/derivation,
template rendering, shell detection, and per-shell snippet rendering.

Run with: aspect dev test-wrapper
"""

load(
    "./wrapper.axl",
    "BazelFlagLists",
    "FlagSpec",
    "InstallAction",
    "Shell",
    "classify_install",
    "derive_flag_lists",
    "detect_shell",
    "find_workspace_root",
    "flag_specs_from_collection",
    "has_wrapper_marker",
    "parse_wrapper_version",
    "render_flag_array",
    "render_install",
    "render_wrapper",
    "shell_snippet",
)
load("./wrapper_template.axl", "WRAPPER_DOC", "WRAPPER_TEMPLATE")

def _eq(label, got, want):
    if got != want:
        fail("%s: got %r, want %r" % (label, got, want))

def _fake_std(current_dir, existing_paths):
    """A minimal `std` exposing only what find_workspace_root touches:
    env.current_dir() and fs.exists()."""
    existing = {p: True for p in existing_paths}
    return struct(
        env = struct(current_dir = lambda: current_dir),
        fs = struct(exists = lambda p: p in existing),
    )

def _test_workspace_root_at_cwd(ctx):
    std = _fake_std("/home/me/repo", ["/home/me/repo/MODULE.bazel"])
    _eq("root at cwd", find_workspace_root(std), "/home/me/repo")

def _test_workspace_root_at_ancestor(ctx):
    std = _fake_std("/home/me/repo/pkg/sub", ["/home/me/repo/WORKSPACE.bazel"])
    _eq("root at ancestor", find_workspace_root(std), "/home/me/repo")

def _test_workspace_root_picks_deepest(ctx):
    # Both an outer and an inner workspace exist; the deepest (nearest) wins.
    std = _fake_std(
        "/mono/proj/pkg",
        ["/mono/WORKSPACE", "/mono/proj/MODULE.bazel"],
    )
    _eq("deepest root", find_workspace_root(std), "/mono/proj")

def _test_workspace_root_legacy_workspace_file(ctx):
    std = _fake_std("/repo", ["/repo/WORKSPACE"])
    _eq("legacy WORKSPACE", find_workspace_root(std), "/repo")

def _test_workspace_root_none_when_absent(ctx):
    std = _fake_std("/tmp/scratch/deep", [])
    _eq("no root", find_workspace_root(std), None)

def _test_parse_version_quoted(ctx):
    content = "#!/usr/bin/env bash\nASPECT_BAZEL_WRAPPER_VERSION=\"7\"\nexport ASPECT_BAZEL_WRAPPER_VERSION\n"
    _eq("quoted version", parse_wrapper_version(content), "7")

def _test_parse_version_unquoted(ctx):
    _eq("unquoted version", parse_wrapper_version("ASPECT_BAZEL_WRAPPER_VERSION=12\n"), "12")

def _test_parse_version_absent(ctx):
    _eq("absent version", parse_wrapper_version("#!/usr/bin/env bash\necho hi\n"), None)

def _test_parse_version_empty(ctx):
    _eq("empty content", parse_wrapper_version(""), None)
    _eq("none content", parse_wrapper_version(None), None)

def _test_marker_present(ctx):
    _eq("marker present", has_wrapper_marker("# aspect-build/tools-bazel-wrapper\n..."), True)

def _test_marker_absent(ctx):
    _eq("marker absent", has_wrapper_marker("#!/usr/bin/env bash\necho hi\n"), False)
    _eq("marker none", has_wrapper_marker(None), False)

def _test_classify_install(ctx):
    _eq("fresh install", classify_install(None, "abc").value, InstallAction("install").value)

def _test_classify_noop(ctx):
    _eq("identical executable noop", classify_install("abc", "abc", True).value, InstallAction("noop").value)

def _test_classify_upgrade(ctx):
    _eq("differs upgrade", classify_install("old", "new").value, InstallAction("upgrade").value)

def _test_classify_repair_non_executable(ctx):
    # Matching bytes but not executable -> upgrade (install repairs the mode).
    _eq("non-exec repair", classify_install("abc", "abc", False).value, InstallAction("upgrade").value)

def _test_classify_noop_default_executable(ctx):
    # Default existing_executable is True, so matching bytes no-op.
    _eq("default exec noop", classify_install("abc", "abc").value, InstallAction("noop").value)

def _test_detect_shell_bash(ctx):
    _eq("bash", detect_shell("/bin/bash").value, Shell("bash").value)

def _test_detect_shell_zsh(ctx):
    _eq("zsh", detect_shell("/usr/local/bin/zsh").value, Shell("zsh").value)

def _test_detect_shell_fish(ctx):
    _eq("fish", detect_shell("/opt/homebrew/bin/fish").value, Shell("fish").value)

def _test_detect_shell_unknown(ctx):
    _eq("unknown shell", detect_shell("/bin/dash"), None)

def _test_detect_shell_unset(ctx):
    _eq("unset shell", detect_shell(None), None)
    _eq("empty shell", detect_shell(""), None)

def _test_shell_snippet_posix(ctx):
    snippet = shell_snippet(Shell("zsh"))
    if "export ASPECT_WRAPPER_SKIP=1" not in snippet:
        fail("zsh snippet missing export toggle: %r" % snippet)
    if "~/.zshrc" not in snippet:
        fail("zsh snippet missing rc path: %r" % snippet)
    if "Bazelisk" not in snippet:
        fail("zsh snippet missing Bazelisk note: %r" % snippet)

def _test_shell_snippet_fish(ctx):
    snippet = shell_snippet(Shell("fish"))
    if "set -gx ASPECT_WRAPPER_SKIP 1" not in snippet:
        fail("fish snippet missing set toggle: %r" % snippet)
    if "config.fish" not in snippet:
        fail("fish snippet missing config path: %r" % snippet)

def _test_flag_specs_from_collection(ctx):
    # A fake struct standing in for the proto FlagCollection/FlagInfo; exercises
    # the None-coercion of optional proto fields and the commands copy.
    fake = struct(flag_infos = [
        struct(name = "keep_going", requires_value = None, has_negative_flag = True, abbreviation = None, commands = ["build"]),
        struct(name = "config", requires_value = True, has_negative_flag = False, abbreviation = "c", commands = ["build", "test"]),
    ])
    specs = flag_specs_from_collection(fake)
    _eq("length", len(specs), 2)
    _eq("null requires_value -> False", specs[0].requires_value, False)
    _eq("null abbreviation -> empty", specs[0].abbreviation, "")
    _eq("has_negative_flag preserved", specs[0].has_negative_flag, True)
    _eq("commands copied", specs[0].commands, ["build"])
    _eq("config requires_value", specs[1].requires_value, True)
    _eq("config abbreviation", specs[1].abbreviation, "c")

def _test_derive_flag_lists_classifies_by_signal(ctx):
    specs = [
        FlagSpec(name = "config", requires_value = True, has_negative_flag = False, abbreviation = "", commands = ["build", "test"]),
        FlagSpec(name = "keep_going", requires_value = False, has_negative_flag = True, abbreviation = "k", commands = ["build", "test"]),
        FlagSpec(name = "compilation_mode", requires_value = True, has_negative_flag = False, abbreviation = "c", commands = ["build"]),
        FlagSpec(name = "watchfs", requires_value = False, has_negative_flag = True, abbreviation = "", commands = ["startup"]),
    ]
    lists = derive_flag_lists(specs)
    _eq("value flags", lists.value_flags, ["compilation_mode", "config"])
    _eq("bool flags", lists.bool_flags, ["keep_going", "watchfs"])
    _eq("short value flags", lists.short_value_flags, ["-c"])
    _eq("short bool flags", lists.short_bool_flags, ["-k"])
    _eq("verbs (startup excluded)", lists.verbs, ["build", "test"])

def _test_derive_flag_lists_dedupes_and_sorts(ctx):
    specs = [
        FlagSpec(name = "b", requires_value = True, has_negative_flag = False, abbreviation = "", commands = ["test", "build"]),
        FlagSpec(name = "a", requires_value = True, has_negative_flag = False, abbreviation = "", commands = ["build"]),
        FlagSpec(name = "a", requires_value = True, has_negative_flag = False, abbreviation = "", commands = ["test"]),
    ]
    lists = derive_flag_lists(specs)
    _eq("deduped sorted value flags", lists.value_flags, ["a", "b"])
    _eq("deduped sorted verbs", lists.verbs, ["build", "test"])

def _test_derive_flag_lists_omits_unclassified(ctx):
    specs = [FlagSpec(name = "help", requires_value = False, has_negative_flag = False, abbreviation = "", commands = ["build"])]
    lists = derive_flag_lists(specs)
    _eq("unclassified omitted from value", lists.value_flags, [])
    _eq("unclassified omitted from bool", lists.bool_flags, [])
    _eq("verbs still collected", lists.verbs, ["build"])

def _test_render_flag_array_indents_and_joins(ctx):
    _eq("three items", render_flag_array(["a", "b", "c"]), "    a\n    b\n    c")
    _eq("empty", render_flag_array([]), "")

def _test_render_wrapper_substitutes_all_placeholders(ctx):
    template = "\n".join([
        "BAZEL_VERBS=(",
        "{{BAZEL_VERBS}}",
        ")",
        "BAZEL_VALUE_FLAGS=(",
        "{{BAZEL_VALUE_FLAGS}}",
        ")",
        "BAZEL_BOOL_FLAGS=(",
        "{{BAZEL_BOOL_FLAGS}}",
        ")",
        "BAZEL_SHORT_VALUE_FLAGS=(",
        "{{BAZEL_SHORT_VALUE_FLAGS}}",
        ")",
        "BAZEL_SHORT_BOOL_FLAGS=(",
        "{{BAZEL_SHORT_BOOL_FLAGS}}",
        ")",
    ])
    lists = BazelFlagLists(
        verbs = ["build", "test"],
        value_flags = ["config"],
        bool_flags = ["keep_going"],
        short_value_flags = ["c"],
        short_bool_flags = ["k"],
    )
    out = render_wrapper(template, lists)
    _eq("verbs filled", "    build\n    test" in out, True)
    _eq("value filled", "    config" in out, True)
    _eq("bool filled", "    keep_going" in out, True)
    _eq("no placeholders left", "{{" not in out, True)

def _test_render_install_stamps_versions(ctx):
    template = "\n".join([
        'ASPECT_BAZEL_WRAPPER_VERSION="{{ASPECT_CLI_VERSION}}"',
        'ASPECT_BAZEL_WRAPPER_BAZEL_VERSION="{{BAZEL_VERSION}}"',
        "BAZEL_VERBS=(",
        "{{BAZEL_VERBS}}",
        ")",
        "BAZEL_VALUE_FLAGS=(",
        "{{BAZEL_VALUE_FLAGS}}",
        ")",
        "BAZEL_BOOL_FLAGS=(",
        "{{BAZEL_BOOL_FLAGS}}",
        ")",
        "BAZEL_SHORT_VALUE_FLAGS=(",
        "{{BAZEL_SHORT_VALUE_FLAGS}}",
        ")",
        "BAZEL_SHORT_BOOL_FLAGS=(",
        "{{BAZEL_SHORT_BOOL_FLAGS}}",
        ")",
    ])
    lists = BazelFlagLists(verbs = ["build"], value_flags = ["config"], bool_flags = ["keep_going"], short_value_flags = ["c"], short_bool_flags = ["k"])
    out = render_install(template, lists, "9.9.9", "9.0.0")
    _eq("cli version stamped", parse_wrapper_version(out), "9.9.9")
    _eq("bazel version stamped", 'ASPECT_BAZEL_WRAPPER_BAZEL_VERSION="9.0.0"' in out, True)
    _eq("no placeholders left", "{{" not in out, True)

def _test_template_has_all_placeholders(ctx):
    for ph in ["{{BAZEL_VERBS}}", "{{BAZEL_VALUE_FLAGS}}", "{{BAZEL_BOOL_FLAGS}}", "{{BAZEL_SHORT_VALUE_FLAGS}}", "{{BAZEL_SHORT_BOOL_FLAGS}}", "{{ASPECT_CLI_VERSION}}", "{{BAZEL_VERSION}}"]:
        _eq("placeholder " + ph + " present once", WRAPPER_TEMPLATE.count(ph), 1)
    _eq("doc nonempty", len(WRAPPER_DOC) > 0, True)
    _eq("marker kept", "# aspect-build/tools-bazel-wrapper" in WRAPPER_TEMPLATE, True)
    _eq("aspect verbs kept intact", "ASPECT_VERBS_WITH_BAZEL_FLAGS=(" in WRAPPER_TEMPLATE, True)

def _test_template_array_push_uses_printf(ctx):
    _eq("array_push uses printf %q", "printf '%q'" in WRAPPER_TEMPLATE, True)

_UNIT_TESTS = [
    _test_workspace_root_at_cwd,
    _test_workspace_root_at_ancestor,
    _test_workspace_root_picks_deepest,
    _test_workspace_root_legacy_workspace_file,
    _test_workspace_root_none_when_absent,
    _test_parse_version_quoted,
    _test_parse_version_unquoted,
    _test_parse_version_absent,
    _test_parse_version_empty,
    _test_marker_present,
    _test_marker_absent,
    _test_classify_install,
    _test_classify_noop,
    _test_classify_upgrade,
    _test_classify_repair_non_executable,
    _test_classify_noop_default_executable,
    _test_detect_shell_bash,
    _test_detect_shell_zsh,
    _test_detect_shell_fish,
    _test_detect_shell_unknown,
    _test_detect_shell_unset,
    _test_shell_snippet_posix,
    _test_shell_snippet_fish,
    _test_flag_specs_from_collection,
    _test_derive_flag_lists_classifies_by_signal,
    _test_derive_flag_lists_dedupes_and_sorts,
    _test_derive_flag_lists_omits_unclassified,
    _test_render_flag_array_indents_and_joins,
    _test_render_wrapper_substitutes_all_placeholders,
    _test_render_install_stamps_versions,
    _test_template_has_all_placeholders,
    _test_template_array_push_uses_printf,
]

def _test_impl(ctx):
    for t in _UNIT_TESTS:
        t(ctx)
    print("wrapper.axl: OK (%d tests)" % len(_UNIT_TESTS))
    return 0

wrapper_tests = task(
    name = "test-wrapper",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
