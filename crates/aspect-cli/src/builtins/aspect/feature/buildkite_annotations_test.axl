"""Snapshot tests for `feature/buildkite_annotations.axl`.

Run with:
  aspect dev test-bk-annotation-snapshots

Dry-run style — we don't actually invoke `buildkite-agent annotate`. Instead,
we call the per-kind renderers + the feature's `format_body` / `severity_for`
helpers directly and print what *would* be sent to BK for each scenario.

Coverage:
  - Each task kind (bazel_results, lint_results, delivery_results,
    format_results, gazelle_results)
  - Each terminal status (passed, failed)
  - Style selection edge cases: soft-lint passing with warnings, delivery
    all-skipped, delivery all-failed, soft-format passing with files.
"""

load("../lib/bazel_results.axl",
    bazel_init_results = "init_results",
    bazel_render_check_output = "render_check_output",
)
load("../lib/lint_results.axl",
    lint_init_results = "init_results",
    lint_accumulate = "accumulate",
    lint_render_check_output = "render_check_output",
)
load("../lib/delivery_results.axl",
    delivery_init_results = "init_results",
    delivery_add_result = "add_result",
    delivery_render_check_output = "render_check_output",
)
load("../lib/format_results.axl",
    format_init_results = "init_results",
    format_render_check_output = "render_check_output",
)
load("../lib/gazelle_results.axl",
    gazelle_init_results = "init_results",
    gazelle_render_check_output = "render_check_output",
)
load("./buildkite_annotations.axl", "format_body", "severity_for")


# ─── Shared fake metadata ─────────────────────────────────────────────────────

def _seed_metadata(r):
    r["invocation_id"]       = "bk-abc12345-def4-5678-9abc-def012345678"
    r["sink_invocation_id"]  = "sink-uuid-1234-5678-9abc"
    r["build_tool_version"]  = "9.0.1"
    r["build_command"]       = "build"
    r["start_time_ms"]       = 1744630000000
    r["finish_time_ms"]      = 1744630004500
    r["wall_time_ms"]        = 4500
    r["workspace_status"]    = {
        "BUILD_USER":      "aspect-runner",
        "BUILD_HOST":      "ip-10-0-86-10",
        "BUILD_TIMESTAMP": "1776727956",
    }
    r["metadata"] = {
        "BRANCH":             "main",
        "COMMIT_SHA":         "abc123def456789abcdef",
        "COMMIT_MESSAGE":     "feat: add buildkite annotations",
        "COMMIT_AUTHOR":      "Greg Magolan <greg@aspect.build>",
        "COMMIT_AUTHOR_NAME": "Greg Magolan",
        "USER":               "Greg Magolan",
        "CI_HOST":            "BUILDKITE",
        "VCS":                "GITHUB",
        "REPO_OWNER":         "aspect-build",
        "REPO_NAME":          "silo",
        "BUILD_NUMBER":       "49508",
        "RUN_TYPE":           "BRANCH_PUSH",
        "ASPECT_TASK_NAME":   "Test",
        "BUILD_URL":          "https://buildkite.com/aspect-build/silo-aws/builds/49508",
    }
    return r


# ─── Fixtures ─────────────────────────────────────────────────────────────────

def _make_build_passed():
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]    = 120
    r["actions_executed"] = 240
    r["actions_total"]    = 240
    return r


def _make_test_failed():
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]        = 60
    r["actions_executed"]     = 120
    r["actions_total"]        = 120
    r["passed_test_total"]    = 55
    r["failed_test_total"]    = 3
    r["flaky_test_total"]     = 2
    r["build_command"]        = "test"
    return r


def _make_build_failing_actions():
    """Build invocation in flight, BES has already reported a failed action.

    Mirrors the live `bazel_runner.axl` path that emits `status="failing"`
    when `failed_actions_total > 0` — used to drive the early-feedback red
    stripe before the bazel invocation completes.
    """
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]         = 60
    r["actions_executed"]      = 18
    r["actions_total"]         = 240
    r["failed_actions_total"]  = 1
    return r


def _make_test_failing_test_fails():
    """Test invocation in flight, BES has already reported a failed test."""
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]      = 60
    r["actions_executed"]   = 80
    r["actions_total"]      = 120
    r["failed_test_total"]  = 1
    r["passed_test_total"]  = 12
    r["build_command"]      = "test"
    return r


def _make_test_running_flaky_only():
    """Test invocation streaming events, BES has reported flakes but no real failures.

    `bazel_runner.axl` keeps the live status as "running" (not "failing")
    when only flakes are observed, so the stripe should be yellow rather
    than red.
    """
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]      = 60
    r["actions_executed"]   = 75
    r["actions_total"]      = 120
    r["passed_test_total"]  = 8
    r["flaky_test_total"]   = 2
    r["build_command"]      = "test"
    return r


def _make_test_passed_flaky_only():
    """Terminal `passed` with flakes — bazel exited 0 after retry."""
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]      = 60
    r["actions_executed"]   = 120
    r["actions_total"]      = 120
    r["passed_test_total"]  = 58
    r["flaky_test_total"]   = 2
    r["build_command"]      = "test"
    return r


def _make_test_failing_with_flaky():
    """Failures dominate flakes — `severity_for` should still pick `error`."""
    r = _seed_metadata(bazel_init_results())
    r["targets_total"]      = 60
    r["actions_executed"]   = 90
    r["actions_total"]      = 120
    r["passed_test_total"]  = 50
    r["failed_test_total"]  = 1
    r["flaky_test_total"]   = 2
    r["build_command"]      = "test"
    return r


def _make_lint_passed_clean():
    r = _seed_metadata(lint_init_results())
    r["target_pattern"] = "//..."
    r["strategy"]       = "hard"
    return r


def _make_lint_passed_with_warnings():
    r = _seed_metadata(lint_init_results())
    r["target_pattern"] = "//..."
    r["strategy"]       = "soft"
    lint_accumulate(r, [
        {"tool": "eslint", "file": "apps/web/src/a.ts", "line": 10, "rule_id": "no-console",   "severity": "warning", "message": "Unexpected console statement"},
        {"tool": "eslint", "file": "apps/web/src/b.ts", "line": 20, "rule_id": "prefer-const", "severity": "warning", "message": "Use const"},
    ])
    return r


def _make_lint_failed_errors():
    r = _seed_metadata(lint_init_results())
    r["target_pattern"] = "//..."
    r["strategy"]       = "hard"
    lint_accumulate(r, [
        {"tool": "eslint", "file": "apps/web/src/a.ts", "line": 10, "rule_id": "no-undef", "severity": "error",   "message": "'Foo' is not defined"},
        {"tool": "pylint", "file": "tools/x.py",        "line": 5,  "rule_id": "E0401",   "severity": "error",   "message": "Unable to import"},
        {"tool": "eslint", "file": "apps/web/src/b.ts", "line": 20, "rule_id": "no-console", "severity": "warning", "message": "Unexpected console"},
    ])
    return r


def _make_delivery_all_ok():
    r = _seed_metadata(delivery_init_results())
    r["target_pattern"] = "//apps/..."
    r["build_url"]      = "https://buildkite.com/aspect-build/silo-aws/builds/49508"
    delivery_add_result(r, "//apps/web:release", "ok", message = r["build_url"], output_sha = "11112222333344445555")
    delivery_add_result(r, "//apps/api:release", "ok", message = r["build_url"], output_sha = "22223333444455556666")
    return r


def _make_delivery_all_skipped():
    r = _seed_metadata(delivery_init_results())
    r["target_pattern"] = "//apps/..."
    prior = "https://buildkite.com/aspect-build/silo-aws/builds/49495"
    delivery_add_result(r, "//apps/web:release", "skip", message = prior, output_sha = "11112222333344445555")
    delivery_add_result(r, "//apps/api:release", "skip", message = prior, output_sha = "22223333444455556666")
    return r


def _make_delivery_mixed_warn():
    r = _seed_metadata(delivery_init_results())
    r["target_pattern"] = "//apps/..."
    r["build_url"]      = "https://buildkite.com/aspect-build/silo-aws/builds/49508"
    delivery_add_result(r, "//apps/web:release",    "ok",   message = r["build_url"], output_sha = "11112222333344445555")
    delivery_add_result(r, "//apps/legacy:release", "warn", message = "no entrypoint", output_sha = "22223333444455556666")
    return r


def _make_delivery_fail():
    r = _seed_metadata(delivery_init_results())
    r["target_pattern"] = "//apps/..."
    delivery_add_result(r, "//apps/web:release", "fail", message = "exit 1", output_sha = "11112222333344445555")
    return r


def _make_format_clean():
    r = _seed_metadata(format_init_results())
    r["scope"]            = "changed"
    r["formatter_target"] = "//tools/format"
    return r


def _make_format_files_need_format():
    r = _seed_metadata(format_init_results())
    r["scope"]            = "changed"
    r["formatter_target"] = "//tools/format"
    r["affected_files"]   = [
        "apps/web/src/auth/login.ts",
        "apps/web/src/utils/helpers.go",
        "tools/deploy/deploy.py",
    ]
    return r


def _make_format_soft_fail():
    """Files need formatting but --soft-fail; exits 0 → status=passed with affected_files → BK warning."""
    r = _seed_metadata(format_init_results())
    r["scope"]            = "changed"
    r["formatter_target"] = "//tools/format"
    r["soft_fail"]        = True
    r["affected_files"]   = [
        "apps/web/src/auth/login.ts",
        "apps/api/handler.go",
    ]
    return r


def _make_gazelle_clean():
    r = _seed_metadata(gazelle_init_results())
    r["gazelle_target"]  = "//tools/gazelle:gazelle"
    r["gazelle_command"] = ""
    r["check_mode"]      = True
    return r


def _make_gazelle_out_of_date():
    r = _seed_metadata(gazelle_init_results())
    r["gazelle_target"]  = "//tools/gazelle:gazelle"
    r["gazelle_command"] = ""
    r["check_mode"]      = True
    r["affected_files"]  = [
        "services/api/BUILD.bazel",
        "services/worker/BUILD.bazel",
        "tools/go/BUILD.bazel",
    ]
    return r


def _make_gazelle_fix_applied():
    """Fix mode applied changes; exits 0 → status=passed with affected_files → BK warning."""
    r = _seed_metadata(gazelle_init_results())
    r["gazelle_target"]  = "//tools/gazelle:gazelle"
    r["gazelle_command"] = ""
    r["check_mode"]      = False
    r["affected_files"]  = [
        "services/api/BUILD.bazel",
        "services/worker/BUILD.bazel",
    ]
    return r


# ─── Test harness ─────────────────────────────────────────────────────────────

def _bk_links():
    # Mirror the live wiring: ArtifactsTrait fields are surfaced into the
    # links dict by `_make_links` in the BK feature whenever the running
    # task uploaded artifacts via the ArtifactUpload feature. The snapshot
    # exercises that path so renderer regressions in the Artifacts row /
    # Artifacts detail block trip a visible diff.
    return {
        "ci_label":             "Buildkite",
        "ci_url":               "https://buildkite.com/aspect-build/silo-aws/builds/49508/steps/canvas?sid=s1",
        "aspect_url":           "https://app.aspect.build/invocations/sink-uuid-1234-5678-9abc",
        "results_base_url":     "https://app.aspect.build/",
        "artifacts_browse_url": "https://buildkite.com/organizations/aspect-build/pipelines/silo-aws/builds/49508/jobs/j1/artifacts",
        "artifact_urls":        {
            "testlogs": "https://buildkite.com/organizations/aspect-build/pipelines/silo-aws/builds/49508/jobs/j1/artifacts/aaaa-1111/testlogs.tar.zst",
            "profile":  "https://buildkite.com/organizations/aspect-build/pipelines/silo-aws/builds/49508/jobs/j1/artifacts/bbbb-2222/profile.json.gz",
            "bep":      "https://buildkite.com/organizations/aspect-build/pipelines/silo-aws/builds/49508/jobs/j1/artifacts/cccc-3333/bep.json",
        },
        "testlogs_label_urls":  {},
    }


def _render_ctx(targets, task_display_name):
    return {
        "triggered_by":      "Greg Magolan (BUILDKITE_BUILD_CREATOR)",
        "targets":           targets,
        "started_ms":        1744630000000,
        "ended_ms":          1744630004500,
        "progress":          "",
        "task_display_name": task_display_name,
    }


_RENDERERS = {
    "bazel_results":    bazel_render_check_output,
    "lint_results":     lint_render_check_output,
    "delivery_results": delivery_render_check_output,
    "format_results":   format_render_check_output,
    "gazelle_results":  gazelle_render_check_output,
}


def _test_impl(ctx):
    scenarios = [
        # (label,                                      kind,                results,                            status,  targets,        display)
        ("1. build-passed · bazel_results",            "bazel_results",     _make_build_passed(),               "passed", "//...",       "Build"),
        ("2. test-failed · bazel_results",             "bazel_results",     _make_test_failed(),                "failed", "//...",       "Test"),
        ("3. lint-passed-clean · lint_results",        "lint_results",      _make_lint_passed_clean(),          "passed", "//...",       "Lint"),
        ("4. lint-passed-with-warnings (soft)",        "lint_results",      _make_lint_passed_with_warnings(),  "passed", "//...",       "Lint"),
        ("5. lint-failed-errors · lint_results",       "lint_results",      _make_lint_failed_errors(),         "failed", "//...",       "Lint"),
        ("6. delivery-all-ok · delivery_results",      "delivery_results",  _make_delivery_all_ok(),            "passed", "//apps/...",  "Delivery"),
        ("7. delivery-all-skipped · delivery_results", "delivery_results",  _make_delivery_all_skipped(),       "passed", "//apps/...",  "Delivery"),
        ("8. delivery-mixed-warn · delivery_results",  "delivery_results",  _make_delivery_mixed_warn(),        "passed", "//apps/...",  "Delivery"),
        ("9. delivery-fail · delivery_results",        "delivery_results",  _make_delivery_fail(),              "failed", "//apps/...",  "Delivery"),
        # Running updates should pick the info style.
        ("10. lint-running · lint_results",             "lint_results",      _make_lint_passed_with_warnings(),  "running", "//...",      "Lint"),
        # Format scenarios — clean=success, files-failed=error, soft-fail=warning.
        ("11. format-clean · format_results",           "format_results",    _make_format_clean(),               "passed",  "",           "Format"),
        ("12. format-files-failed · format_results",    "format_results",    _make_format_files_need_format(),   "failed",  "",           "Format"),
        ("13. format-soft-fail · format_results",       "format_results",    _make_format_soft_fail(),           "passed",  "",           "Format"),
        # Gazelle scenarios — clean=success, out-of-date=error, fix-applied=warning.
        ("14. gazelle-clean · gazelle_results",         "gazelle_results",   _make_gazelle_clean(),              "passed",  "",           "Gazelle"),
        ("15. gazelle-out-of-date · gazelle_results",   "gazelle_results",   _make_gazelle_out_of_date(),        "failed",  "",           "Gazelle"),
        ("16. gazelle-fix-applied · gazelle_results",   "gazelle_results",   _make_gazelle_fix_applied(),        "passed",  "",           "Gazelle"),
        # Early-feedback `failing` scenarios — bazel_runner streams a failure
        # before invocation.wait() returns; BK should flip to red right away.
        ("17. build-failing-actions · bazel_results",   "bazel_results",     _make_build_failing_actions(),      "failing", "//...",       "Build"),
        ("18. test-failing-tests · bazel_results",      "bazel_results",     _make_test_failing_test_fails(),    "failing", "//...",       "Test"),
        # Flaky-only scenarios — no real failures yet, but flakes seen.
        # `bazel_runner.axl` keeps live status="running" (not "failing");
        # `severity_for` should pick warning/yellow at both running and passed.
        ("19. test-running-flaky-only · bazel_results", "bazel_results",     _make_test_running_flaky_only(),    "running", "//...",       "Test"),
        ("20. test-passed-flaky-only · bazel_results",  "bazel_results",     _make_test_passed_flaky_only(),     "passed",  "//...",       "Test"),
        # Mixed — real failure plus flakes. Failures dominate; stripe stays red.
        ("21. test-failing-with-flaky · bazel_results", "bazel_results",     _make_test_failing_with_flaky(),    "failing", "//...",       "Test"),
    ]

    sep = "=" * 70

    for (label, kind, results, status, targets, display) in scenarios:
        renderer = _RENDERERS[kind]
        rc = _render_ctx(targets, display)
        out = renderer(ctx, results, status, rc, _bk_links(), None, None)
        # Mirror the live wiring: include a `:aspect: task <code>key</code>`
        # pill so the snapshot exercises the flex-header path as well as the
        # body.
        task_label = ":aspect: task <code>%s</code>" % "local-test"
        body = format_body(out, kind, status, task_label = task_label)
        style = severity_for(kind, results, status)

        context_id = "aspect-%s-%s" % (display.lower(), "local-test")

        print(sep)
        print("SCENARIO: " + label)
        print(sep)
        print("buildkite-agent annotate --style %s --context %s --scope=job" % (style, context_id))
        print("─" * 70)
        # Show first 2500 chars of the formatted body — enough to see the
        # title/summary and the first chunk of the body without flooding.
        print(body[:2500])
        if len(body) > 2500:
            print("... [truncated, full length: %d chars]" % len(body))
        print("")

    print(sep)
    print("All " + str(len(scenarios)) + " BK annotation scenarios rendered without error (including format + gazelle).")
    return 0


bk_annotation_snapshot_tests = task(
    name = "test-bk-annotation-snapshots",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
