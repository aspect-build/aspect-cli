"""Snapshot tests for `feature/github_status_comments.axl`.

Run with:
  aspect dev test-pr-comment-snapshots

Dry-run style — we don't actually invoke the GitHub Issues API. We
construct artifact-payload-shaped entry dicts (matching what
`_publish_self` writes to the per-task task.json), pass them through
`_prepare_for_render` + `_bucket_entries` + `_render_body`, and print
the resulting Markdown body for each scenario.

Coverage:
  - All-running, mixed running + failed, all-passed clean,
    flake-only-warning, lint-warnings, format-diffs,
    delivery mixed-warn, aborted, all-failed, empty
  - Link availability variants (CI Run only, no Aspect, no Check, all)
  - Live phase + ProgressStyles round-trip via the artifact-shape dict
  - Failed-in-phase prefix
  - Tips aggregation: single-task, multi-task dedup + attribution,
    severity-sort with the `_MAX_SUBORDINATE_TIPS` cap on
    suggestion / info; plus inline `_check_collect_tip_rows`
    assertions on the aggregator's invariants (dedup,
    attribution-key sort, severity order, cap, silence_hint).
"""

load(
    "./github_status_comments.axl",
    "DEFAULT_BODY_TEMPLATE",
    "DEFAULT_STATUS_BADGES",
    "MARKER_FMT",
    "bucket_entries",
    "collect_tip_rows",
    "prepare_for_render",
    "render_body",
    "results_subset",
)
load(
    "./test_fixtures.axl",
    "make_build_failing_actions",
    "make_build_passed",
    "make_delivery_all_ok",
    "make_delivery_fail",
    "make_delivery_mixed_warn",
    "make_format_clean",
    "make_format_files_need_format",
    "make_gazelle_clean",
    "make_gazelle_fix_applied",
    "make_gazelle_out_of_date",
    "make_lint_failed_errors",
    "make_lint_passed_clean",
    "make_lint_passed_with_warnings",
    "make_test_failed",
    "make_test_failing_test_fails",
    "make_test_failing_with_flaky",
    "make_test_passed_flaky_only",
    "make_test_running_flaky_only",
)
load("../lib/bazel_results.axl", "compute_reproducer_command")

_DEFAULT_RUN_URL = "https://github.com/aspect-build/aspect-cli/actions/runs/25615893249"
_DEFAULT_ASPECT_URL = "https://app.aspect.build/build/sink-uuid-1234-5678-9abc"
_DEFAULT_CHECK_URL = "https://github.com/aspect-build/aspect-cli/runs/47921003"

# Pinned-in-time fixture timestamp so snapshot output is stable.
# Corresponds to `date -u -d "@1715326565"` → `Fri May 10 07:16:05 UTC 2024`.
_DEFAULT_START_MS = 1715326565000

# Mirror of each producer's `_body_text` so the fixture builds the
# same `progress.body` strings the live producers ship. Internal
# `_compact_for` / `_*_compact` helpers compute count strings; the
# narrative `_body_for` wraps them in a verb-prefixed phrase.

def _with_commands(data, repro = [], fix = []):
    """Decorate a fixture's `data` dict with explicit
    `repro_commands` + `fix_commands` lists. Each input is a list of
    `(command, description)` tuples (description usually `""`). Use
    in scenarios that need to assert the aggregator's repro / fix
    rendering — the producers normally append these at terminal-emit
    time, but the snapshot tests fabricate the artifact-payload
    shape directly so the inputs are spelled out here."""
    out = dict(data)
    out["repro_commands"] = [{"command": c, "description": d} for (c, d) in repro]
    out["fix_commands"] = [{"command": c, "description": d} for (c, d) in fix]
    return out

def _body_for(kind, status, data):
    """Mirror the producer's `progress.body` narrative form.

    Running emits ship the live phase narrative (`Bazel test running
    (12 tests run)` / `Linting`); terminal emits ship a verb-prefixed
    summary (`Bazel test complete (58/58 passed)` /
    `Lint failed (3 errors)`)."""
    compact = _compact_for(kind, status, data)

    # Live forms.
    if status == "running":
        if kind == "build" or kind == "test":
            base = "Bazel " + kind + " running..."
            return base + (" (" + compact + ")") if compact else base
        if kind == "lint":
            return ("Linting... (" + compact + ")") if compact else "Linting..."
        if kind == "format":
            return ("Formatting... (" + compact + ")") if compact else "Formatting..."
        if kind == "gazelle":
            return ("Running gazelle... (" + compact + ")") if compact else "Running gazelle..."
        if kind == "delivery":
            return ("Delivering... (" + compact + ")") if compact else "Delivering..."
        return ""

    # Terminal / live-non-running forms — verb-prefixed summary.
    verb_map = {
        "passed": "complete",
        "warning": "complete",
        "failing": "failing",
        "failed": "failed",
        "aborted": "aborted",
    }
    verb = verb_map.get(status, status)
    if kind == "build" or kind == "test":
        return "Bazel " + kind + " " + verb + ((" (" + compact + ")") if compact else "")
    title = {
        "lint": "Lint",
        "format": "Format",
        "gazelle": "Gazelle",
        "delivery": "Delivery",
    }.get(kind, kind)
    return title + " " + verb + ((" (" + compact + ")") if compact else "")

def _compact_for(kind, status, data):
    if kind == "build" or kind == "test":
        return _bazel_compact(kind, status, data)
    if kind == "lint":
        return _lint_compact(status, data)
    if kind == "format":
        return _format_compact(status, data)
    if kind == "gazelle":
        return _gazelle_compact(status, data)
    if kind == "delivery":
        return _delivery_compact(status, data)
    return ""

def _bazel_compact(command, status, data):
    bz = data.get("bazel", {}) or {}
    if status == "running":
        if command == "test":
            ran = bz.get("passed_test_total", 0) + bz.get("failed_test_total", 0)
            total = bz.get("targets_total", 0)
            if total > 0 and ran > 0:
                return "%d/%d tests run" % (ran, total)
        elif command == "build":
            n = bz.get("targets_total", 0)
            if n > 0:
                return "%d targets" % n
        return ""
    if status == "warning" or status == "passed":
        if command == "test":
            passed = bz.get("passed_test_total", 0)
            failed = bz.get("failed_test_total", 0)
            flaky = bz.get("flaky_test_total", 0)
            cached = bz.get("cached_test_total", 0)
            total = passed + failed
            if total == 0:
                return "no tests"
            text = "%d/%d passed" % (passed, total)
            extras = []
            if flaky > 0:
                extras.append("%d flaky" % flaky)
            if cached > 0:
                extras.append("%d cached" % cached)
            if extras:
                text = text + " · " + " · ".join(extras)
            return text
        n = bz.get("targets_total", 0)
        return ("%d built" % n) if n > 0 else "ok"
    if status == "failing" or status == "failed":
        if command == "test":
            f = bz.get("failed_test_total", 0)
            if f > 0:
                return "%d test%s failed" % (f, "s" if f != 1 else "")
            return ""

        # build/failed: detailed reads "Bazel build failed"; compact = ""
        # so the headline doesn't render the redundant "· build failed"
        # tail (mirrors bazel_runner.axl::_compact_text).
        return ""
    return ""

def _lint_compact(status, data):
    counts = (data.get("lint", {}) or {}).get("counts_by_severity", {}) or {}
    e = counts.get("error", 0)
    w = counts.get("warning", 0)
    if status == "failed" or status == "failing":
        return ("%d error%s" % (e, "s" if e != 1 else "")) if e > 0 else ""
    if status == "passed":
        return "clean"
    if status == "warning":
        return ("%d warning%s" % (w, "s" if w != 1 else "")) if w > 0 else ""
    if e > 0 or w > 0:
        bits = []
        if e > 0:
            bits.append("%d error%s" % (e, "s" if e != 1 else ""))
        if w > 0:
            bits.append("%d warning%s" % (w, "s" if w != 1 else ""))
        return " · ".join(bits)
    return ""

def _format_compact(status, data):
    n = len((data.get("format", {}) or {}).get("affected_files", []) or [])
    if status == "failed" or status == "failing":
        if n > 0:
            return "%d file%s need%s format" % (n, "s" if n != 1 else "", "" if n != 1 else "s")
        return ""
    if status == "passed":
        return "clean"
    if status == "warning" or status == "running":
        if n > 0:
            return "%d file%s differ%s" % (n, "s" if n != 1 else "", "" if n != 1 else "s")
        return ""
    return ""

def _gazelle_compact(status, data):
    n = len((data.get("gazelle", {}) or {}).get("affected_files", []) or [])
    if status == "failed" or status == "failing":
        return ("%d out of date" % n) if n > 0 else ""
    if status == "passed":
        return "clean"
    if status == "warning":
        if n > 0:
            return "%d update%s" % (n, "s" if n != 1 else "")
        return ""
    if status == "running":
        if n > 0:
            return "%d update%s pending" % (n, "s" if n != 1 else "")
        return ""
    return ""

def _delivery_compact(status, dr):
    counts = (dr.get("delivery", {}) or {}).get("counts", {}) or {}
    ok = counts.get("ok", 0)
    skip = counts.get("skip", 0)
    warn = counts.get("warn", 0)
    fail = counts.get("fail", 0)
    if status == "failed" or status == "failing":
        if fail > 0:
            return "%d delivery fail%s" % (fail, "s" if fail != 1 else "")
        return ""
    if status == "passed" or status == "warning":
        bits = []
        if ok:
            bits.append("%d delivered" % ok)
        if warn:
            bits.append("%d warn" % warn)
        if skip:
            bits.append("%d skipped" % skip)
        if bits:
            return " · ".join(bits)
        return "no deliveries" if status == "passed" else ""
    if status == "running":
        done = ok + skip + warn + fail
        total = (dr.get("delivery", {}) or {}).get("targets_total", 0) or 0
        if done > 0:
            if total > 0:
                return "%d/%d delivered" % (done, total)
            return "%d delivered" % done
    return ""

def _entry(
        name,
        key,
        job,
        kind,
        status,
        data,
        elapsed_ms,
        aspect_url = _DEFAULT_ASPECT_URL,
        bes_url = "",
        check_run_url = _DEFAULT_CHECK_URL,
        ci_run_url = _DEFAULT_RUN_URL,
        current_phase = "",
        current_phase_elapsed_ms = 0,
        progress = None,
        failed_in_phase = "",
        start_time_ms = _DEFAULT_START_MS,
        tips = None):
    """Build an artifact-payload-shaped entry. Mirrors what
    `_publish_self` writes to task.json so the test exercises the same
    on-wire shape sibling jobs would read.

    Emulates the producer-side composition: `body` is filled from
    `_body_for(kind, status, data)` matching what each real producer
    ships at task_update time. Pass an explicit `progress` dict to
    override (e.g. to test a specific shape)."""

    # Mirror the producer side: if the fixture's `data` doesn't carry
    # repro_commands, synthesize one the way bazel_runner does. Lets
    # existing fixtures exercise the "🔁 Reproduce" section without
    # spelling out the list shape.
    if not data.get("repro_commands"):
        repro, _ = compute_reproducer_command(data, name)
        if repro:
            data = dict(data)
            data["repro_commands"] = [{"command": repro, "description": ""}]
    payload = results_subset(
        data,
        elapsed_ms,
        aspect_url = aspect_url,
        bes_url = bes_url,
        check_run_url = check_run_url,
        current_phase = current_phase,
        current_phase_elapsed_ms = current_phase_elapsed_ms,
        progress_styles = None,
        failed_in_phase = failed_in_phase,
        start_time_ms = start_time_ms,
    )
    if progress != None:
        # Explicit override — scenario tests a specific progress shape.
        payload["progress"] = progress
    else:
        # Default: mirror what each producer ships — narrative `body`
        # text + empty `stream`.
        payload["progress"] = {
            "body": _body_for(kind, status, data),
            "stream": "",
        }
    payload["name"] = name
    payload["key"] = key
    payload["job"] = job
    payload["run_attempt"] = "1"
    payload["status"] = status
    payload["ci_run_url"] = ci_run_url
    if tips != None:
        payload["tips"] = tips
    return payload

def _check_collect_tip_rows(ctx):
    """Functional assertions for `_collect_tip_rows` — exercise the
    dedup, attribution, severity-sort, `_MAX_SUBORDINATE_TIPS` cap,
    and the multi-accumulator JINJA2 re-render logic without going
    through the full snapshot pipeline."""

    # Dedup + attribution: same id surfaced by two tasks merges into
    # one row with both task keys in alphabetical order.
    rows = collect_tip_rows(ctx, [
        {"key": "lint-task", "tips": [
            {"id": "x", "severity": "suggestion", "title": "T", "body": "B"},
        ]},
        {"key": "build-task", "tips": [
            {"id": "x", "severity": "suggestion", "title": "T", "body": "B"},
        ]},
    ])
    if len(rows) != 1:
        fail("collect_tip_rows dedup: expected 1 row, got %d" % len(rows))
    if rows[0]["task_keys"] != ["build-task", "lint-task"]:
        fail("collect_tip_rows attribution: expected [build-task, lint-task], got %r" % rows[0]["task_keys"])

    # Severity sort: critical first, then warning, then suggestion, then info.
    rows = collect_tip_rows(ctx, [{"key": "t1", "tips": [
        {"id": "i", "severity": "info", "title": "I", "body": ""},
        {"id": "c", "severity": "critical", "title": "C", "body": ""},
        {"id": "s", "severity": "suggestion", "title": "S", "body": ""},
        {"id": "w", "severity": "warning", "title": "W", "body": ""},
    ]}])
    ids = [r["id"] for r in rows]
    if ids != ["c", "w", "s", "i"]:
        fail("collect_tip_rows severity sort: expected [c, w, s, i], got %r" % ids)

    # Cap: suggestion + info combined capped at 5; critical + warning unbounded.
    big = (
        [{"id": "c%d" % i, "severity": "critical", "title": "C", "body": ""} for i in range(3)] +
        [{"id": "w%d" % i, "severity": "warning", "title": "W", "body": ""} for i in range(4)] +
        [{"id": "s%d" % i, "severity": "suggestion", "title": "S", "body": ""} for i in range(4)] +
        [{"id": "i%d" % i, "severity": "info", "title": "I", "body": ""} for i in range(4)]
    )
    rows = collect_tip_rows(ctx, [{"key": "t1", "tips": big}])
    critical_count = len([r for r in rows if r["severity_label"] == "Critical"])
    warning_count = len([r for r in rows if r["severity_label"] == "Warning"])
    subordinate_count = len([r for r in rows if r["severity_label"] in ("Tip", "Info")])
    if critical_count != 3:
        fail("collect_tip_rows cap: expected 3 critical, got %d" % critical_count)
    if warning_count != 4:
        fail("collect_tip_rows cap: expected 4 warning, got %d" % warning_count)
    if subordinate_count != 5:
        fail("collect_tip_rows cap: expected 5 subordinate (suggestion+info), got %d" % subordinate_count)

    # silence_hint: empty for critical, non-empty for non-critical.
    # The rendered tip carries this `<sub>...</sub>` line as its
    # silence-hint footer; an empty value suppresses the footer.
    rows = collect_tip_rows(ctx, [{"key": "t1", "tips": [
        {"id": "c", "severity": "critical", "title": "C", "body": ""},
        {"id": "s", "severity": "suggestion", "title": "S", "body": ""},
    ]}])
    by_id = {r["id"]: r for r in rows}
    if by_id["c"]["silence_hint"] != "":
        fail("collect_tip_rows: critical row must have empty silence_hint")
    if "silenced_tips" not in by_id["s"]["silence_hint"]:
        fail("collect_tip_rows: suggestion row must reference silenced_tips in silence_hint")

    # Multi-accumulator cross-task merge: two tasks each emit the
    # `add-github-token-scope` JINJA2 tip with distinct scopes and
    # endpoints. The merged row carries the union of each
    # accumulator (preserving first-seen order across tasks), and
    # the title + body are re-rendered via Jinja2 so the surfaced
    # text reflects the merged accumulator state (pluralized title,
    # full endpoint list in the body).
    title_tmpl = "Grant {% if scopes|length == 1 %}`{{ scopes[0] }}`{% else %}{{ scopes|length }} scopes{% endif %}"
    body_tmpl = "{{ endpoints|length }} calls fell back:\n{% for e in endpoints %}- {{ e }}\n{% endfor %}"
    rows = collect_tip_rows(ctx, [
        {"key": "build-task", "tips": [{
            "id": "add-github-token-scope",
            "severity": "warning",
            "title": "Grant `actions: read`",
            "body": "...",
            "type": "jinja2",
            "title_template": title_tmpl,
            "body_template": body_tmpl,
            "accumulators": {"scopes": ["actions: read"], "endpoints": ["/a/jobs"]},
        }]},
        {"key": "test-task", "tips": [{
            "id": "add-github-token-scope",
            "severity": "warning",
            "title": "Grant `pull-requests: read`",
            "body": "...",
            "type": "jinja2",
            "title_template": title_tmpl,
            "body_template": body_tmpl,
            "accumulators": {"scopes": ["pull-requests: read"], "endpoints": ["/b/files", "/c/files"]},
        }]},
    ])
    if len(rows) != 1:
        fail("multi-accumulator merge: expected 1 row, got %d" % len(rows))
    if "2 scopes" not in rows[0]["title"]:
        fail("multi-accumulator merge: title not re-rendered with plural form: %r" % rows[0]["title"])
    if "/a/jobs" not in rows[0]["body_quoted"] or "/b/files" not in rows[0]["body_quoted"] or "/c/files" not in rows[0]["body_quoted"]:
        fail("multi-accumulator merge: body missing an endpoint: %r" % rows[0]["body_quoted"])
    if "3 calls" not in rows[0]["body_quoted"]:
        fail("multi-accumulator merge: body not re-rendered with merged count: %r" % rows[0]["body_quoted"])
    if rows[0]["task_keys"] != ["build-task", "test-task"]:
        fail("multi-accumulator merge: task_keys merge wrong: %r" % rows[0]["task_keys"])

def _test_impl(ctx):
    sep = "=" * 70

    _check_collect_tip_rows(ctx)

    scenarios = [
        (
            "1. all-running (initial)",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "running",
                    make_build_passed(),
                    8000,
                ),
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "running",
                    make_test_failing_test_fails(),
                    12000,
                ),
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "running",
                    make_lint_passed_clean(),
                    4000,
                ),
            ],
        ),
        (
            "2. mixed running + one failed",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "failed",
                    make_build_failing_actions(),
                    42000,
                ),
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "running",
                    make_test_failing_test_fails(),
                    78000,
                ),
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "passed",
                    make_lint_passed_clean(),
                    24000,
                ),
            ],
        ),
        (
            "3. all-passed clean",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    60000,
                ),
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "passed",
                    make_test_passed_flaky_only(),
                    180000,
                ),
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "passed",
                    make_lint_passed_clean(),
                    24000,
                ),
                _entry(
                    "format",
                    "format-task",
                    "format-task",
                    "format",
                    "passed",
                    make_format_clean(),
                    14000,
                ),
                _entry(
                    "gazelle",
                    "gazelle-task",
                    "gazelle-task",
                    "gazelle",
                    "passed",
                    make_gazelle_clean(),
                    22000,
                ),
                _entry(
                    "delivery",
                    "delivery-task",
                    "delivery-task",
                    "delivery",
                    "passed",
                    make_delivery_all_ok(),
                    28000,
                ),
            ],
        ),
        (
            "4. warned with flake-only (warning sort)",
            [
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "warning",
                    make_test_passed_flaky_only(),
                    180000,
                ),
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    60000,
                ),
            ],
        ),
        (
            "5. lint warnings → warned (soft)",
            [
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "warning",
                    make_lint_passed_with_warnings(),
                    30000,
                ),
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    60000,
                ),
            ],
        ),
        (
            "6. format diffs → warned (soft-fail clean exit)",
            [
                _entry(
                    "format",
                    "format-task",
                    "format-task",
                    "format",
                    "warning",
                    make_format_files_need_format(),
                    14000,
                ),
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    60000,
                ),
            ],
