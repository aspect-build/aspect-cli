                ),
                _entry(
                    "delivery",
                    "delivery-task",
                    "delivery-task",
                    "delivery",
                    "failed",
                    make_delivery_fail(),
                    28000,
                ),
            ],
        ),
        (
            "10. empty (no entries)",
            [],
        ),

        # Each row in this scenario carries a different subset of
        # (CI Run, Aspect, Check) so the snapshot freezes the
        # graceful-degradation behaviour.
        (
            "11. mixed link availability",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    60000,
                ),  # all three links
                _entry(
                    "delivery",
                    "delivery-task",
                    "delivery-task",
                    "delivery",
                    "passed",
                    make_delivery_all_ok(),
                    28000,
                    aspect_url = "",
                ),  # no Aspect
                _entry(
                    "format",
                    "format-task",
                    "format-task",
                    "format",
                    "passed",
                    make_format_clean(),
                    14000,
                    check_run_url = "",
                ),  # no Check
                _entry(
                    "gazelle",
                    "gazelle-task",
                    "gazelle-task",
                    "gazelle",
                    "passed",
                    make_gazelle_fix_applied(),
                    22000,
                    aspect_url = "",
                    check_run_url = "",
                ),  # CI Run only
            ],
        ),

        # Phase + progress text round-trip — running rows compose
        # phase, kind detail, and producer-supplied progress.
        (
            "12. running with phase + progress",
            [
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "running",
                    make_test_running_flaky_only(),
                    78000,
                    current_phase = "test",
                    current_phase_elapsed_ms = 65000,
                    progress = {
                        "body": "Bazel test running... (12 tests run)",
                        "stream": "",
                    },
                ),
                _entry(
                    "delivery",
                    "delivery-task",
                    "delivery-task",
                    "delivery",
                    "running",
                    make_delivery_all_ok(),
                    3000,
                    current_phase = "resolve",
                    current_phase_elapsed_ms = 3000,
                    progress = {"body": "", "stream": ""},
                ),
                # `body` populated by an arbitrary producer string —
                # snapshot exercises the renderer's body-text path.
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "running",
                    make_lint_passed_clean(),
                    4000,
                    progress = {
                        "body": "Linting 482 files...",
                        "stream": "",
                    },
                ),
            ],
        ),

        # Failed-in-phase — the failed row carries the phase the task
        # was in when it died.
        (
            "13. failed in phase",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "failed",
                    make_build_failing_actions(),
                    42000,
                    failed_in_phase = "build",
                    progress = {
                        "body": "Bazel build failed (3 actions failed)",
                        "stream": "",
                    },
                ),
            ],
        ),

        # Test-failing-with-flaky — failures dominate flakes; should
        # render as failed (red) not warning (yellow).
        (
            "14. failing test with flakes (failures dominate)",
            [
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "failing",
                    make_test_failing_with_flaky(),
                    60000,
                ),
            ],
        ),

        # Live `warning` — non-fatal signal detected mid-flight. The
        # producer flips status to `warning` so BK / GHSC PR-comment all
        # paint yellow before the task terminates.
        (
            "15. live warning (lint warnings detected mid-build)",
            [
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "warning",
                    make_lint_passed_with_warnings(),
                    18000,
                    current_phase = "build",
                    current_phase_elapsed_ms = 12000,
                ),
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "warning",
                    make_test_running_flaky_only(),
                    45000,
                    current_phase = "test",
                    current_phase_elapsed_ms = 30000,
                ),
            ],
        ),

        # Per-kind running compacts — exercises the mid-flight text
        # for lint/format/gazelle/delivery.
        (
            "16. per-kind running compacts",
            [
                # No fixture for "format running with diffs" — reuse files-need
                # but keep status=running so it's a live `warning` row with
                # the "N files differ" compact.
                _entry(
                    "format",
                    "format-task",
                    "format-task",
                    "format",
                    "warning",
                    make_format_files_need_format(),
                    8000,
                    current_phase = "diff",
                ),
                _entry(
                    "gazelle",
                    "gazelle-task",
                    "gazelle-task",
                    "gazelle",
                    "warning",
                    make_gazelle_fix_applied(),
                    12000,
                    current_phase = "diff",
                ),
                _entry(
                    "delivery",
                    "delivery-task",
                    "delivery-task",
                    "delivery",
                    "running",
                    _delivery_partial(make_delivery_all_ok(), 12),
                    25000,
                    current_phase = "deliver",
                ),
            ],
        ),

        # Validates the aggregator's "🔁 Reproduce" (non-passing
        # entries only) and "🛠️ Fix" (every contributing entry,
        # including passing ones) sections plus the kind-aware
        # dedup-and-attribute join across tasks contributing identical
        # commands.
        (
            "17. repro & fix sections",
            [
                # Failed build — contributes a repro narrowed to the
                # failed labels.
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "failed",
                    _with_commands(
                        make_build_failing_actions(),
                        repro = [("aspect build -- //pkg:lib //pkg:bin", "")],
                    ),
                    42000,
                ),
                # Sibling task contributing the SAME repro command —
                # exercises dedup-and-attribute (one row, both task
                # keys listed).
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "failed",
                    _with_commands(
                        make_test_failed(),
                        repro = [("aspect build -- //pkg:lib //pkg:bin", "")],
                    ),
                    78000,
                ),
                # Passing format task that contributes a fix command
                # only — verifies the fix section includes passing
                # tasks while the repro section does not.
                _entry(
                    "format",
                    "format-task",
                    "format-task",
                    "format",
                    "passed",
                    _with_commands(
                        make_format_clean(),
                        fix = [("aspect format --check=false", "")],
                    ),
                    24000,
                ),
                # Warning lint task contributing both — appears in
                # repro (non-passing) and fix sections.
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "warning",
                    _with_commands(
                        make_lint_passed_with_warnings(),
                        repro = [("aspect lint --strategy=hold-the-line -- //...", "")],
                        fix = [("aspect lint --fix --strategy=hold-the-line -- //...", "")],
                    ),
                    16000,
                ),
            ],
        ),
        # ── Tips aggregation ─────────────────────────────────────────
        # Each scenario below populates the new `tips` field on the
        # per-task payload. The aggregator dedups by id, attributes
        # by task key, severity-sorts, and applies the
        # `_MAX_SUBORDINATE_TIPS` cap on suggestion / info tips.
        (
            "18. tips — single tip on one task",
            [
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "passed",
                    make_lint_passed_clean(),
                    16000,
                    tips = [{
                        "id": "add-github-token",
                        "severity": "suggestion",
                        "title": "Export `GITHUB_TOKEN` to free App quota",
                        "body": "Setting `GITHUB_TOKEN` routes supporting calls through the job-scoped token.",
                    }],
                ),
            ],
        ),
        (
            "19. tips — same id surfaced by multiple tasks (dedup + attribution)",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    8000,
                    tips = [{
                        "id": "add-github-token",
                        "severity": "suggestion",
                        "title": "Export `GITHUB_TOKEN` to free App quota",
                        "body": "Setting `GITHUB_TOKEN` routes supporting calls through the job-scoped token.",
                    }],
                ),
                _entry(
                    "test",
                    "test-task",
                    "test-task",
                    "test",
                    "passed",
                    make_test_passed_flaky_only(),
                    12000,
                    tips = [{
                        "id": "add-github-token",
                        "severity": "suggestion",
                        "title": "Export `GITHUB_TOKEN` to free App quota",
                        "body": "Setting `GITHUB_TOKEN` routes supporting calls through the job-scoped token.",
                    }],
                ),
                _entry(
                    "lint",
                    "lint-task",
                    "lint-task",
                    "lint",
                    "passed",
                    make_lint_passed_clean(),
                    4000,
                    tips = [{
                        "id": "add-github-token",
                        "severity": "suggestion",
                        "title": "Export `GITHUB_TOKEN` to free App quota",
                        "body": "Setting `GITHUB_TOKEN` routes supporting calls through the job-scoped token.",
                    }],
                ),
            ],
        ),
        (
            "20. tips — critical + warning render in full; suggestion / info capped at 5",
            [
                _entry(
                    "build",
                    "build-task",
                    "build-task",
                    "build",
                    "passed",
                    make_build_passed(),
                    8000,
                    tips = [
                        # 1 critical — always shown, no silence footer.
                        {
                            "id": "add-id-token-permission",
                            "severity": "critical",
                            "title": "Grant `id-token: write`",
                            "body": "Required for artifact uploads.",
                        },
                        # 2 warnings — always shown.
                        {
                            "id": "warn-a",
                            "severity": "warning",
                            "title": "Warning A",
                            "body": "Degraded behavior A.",
                        },
                        {
                            "id": "warn-b",
                            "severity": "warning",
                            "title": "Warning B",
                            "body": "Degraded behavior B.",
                        },
                        # 7 suggestion/info — but the section caps the
                        # subordinate tier at 5, so two should be dropped.
                        {"id": "sugg-1", "severity": "suggestion", "title": "Sugg 1", "body": "B1"},
                        {"id": "sugg-2", "severity": "suggestion", "title": "Sugg 2", "body": "B2"},
                        {"id": "sugg-3", "severity": "suggestion", "title": "Sugg 3", "body": "B3"},
                        {"id": "info-1", "severity": "info", "title": "Info 1", "body": "I1"},
                        {"id": "info-2", "severity": "info", "title": "Info 2", "body": "I2"},
                        {"id": "info-3", "severity": "info", "title": "Info 3", "body": "I3"},
                        {"id": "info-4", "severity": "info", "title": "Info 4", "body": "I4"},
                    ],
                ),
            ],
        ),
    ]

    for (label, raw_entries) in scenarios:
        prepared = prepare_for_render(raw_entries)
        sections = bucket_entries(prepared)
        marker = MARKER_FMT % 1234

        # Pinned-in-time formatted timestamp so snapshot output is
        # stable (matches `date -u -d "@_DEFAULT_START_MS / 1000"`).
        body = render_body(
            ctx,
            marker,
            prepared,
            "Fri May 10 07:16:05 UTC 2024",
            DEFAULT_BODY_TEMPLATE,
            DEFAULT_STATUS_BADGES,
            sections,
        )

        print(sep)
        print("SCENARIO: " + label)
        print(sep)
        print(body)
        print("")

    print(sep)
    print("All %d PR-comment scenarios rendered without error." % len(scenarios))
    return 0

def _aborted(data, reason):
    """Mark a fixture as aborted so it routes through the aborted badge."""
    data["bazel"]["aborted"] = True
    data["bazel"]["abort_reason"] = reason
    return data

def _delivery_partial(data, total):
    """Stash a `targets_total` denominator on a delivery fixture so the
    running compact renders `N/M delivered` rather than `N delivered`."""
    if "delivery" not in data:
        data["delivery"] = {}
    data["delivery"]["targets_total"] = total
    return data

pr_comment_snapshot_tests = task(
    name = "test-pr-comment-snapshots",
    group = ["dev"],
    implementation = _test_impl,
    args = {},
)
