"""
A default 'test' task that wraps a 'bazel test' command.
"""
load("./traits.axl", "BazelTrait", "HealthCheckTrait", "TaskLifecycleTrait", "GitHubStatusChecksTrait", "ArtifactsTrait")
load("./lib/bazel_runner.axl", "run_bazel_task")


def _impl(ctx: TaskContext) -> int:
    return run_bazel_task(ctx, command = "test")


test = task(
    implementation = _impl,
    traits = [
        BazelTrait,
        HealthCheckTrait,
        TaskLifecycleTrait,
        GitHubStatusChecksTrait,
        ArtifactsTrait,
    ],
    args = {
        # TODO: Support a long --pattern_file like bazel does (@./targets)
        # TODO: Support - (list from stdin)
        "target_pattern": args.positional(minimum = 1, maximum = 512, default = ["..."]),
        "bazel_flag": args.string_list(),
        "bazel_startup_flag": args.string_list(),
        "bes_backend": args.string_list(),
        "bes_header": args.string_list(),
        "cancel": args.boolean(default = False, description = "Cancel any running Bazel invocation before starting the test"),
        "output_base": args.string(default = "", description = "Bazel output base path to target a specific server instance"),
    },
)
