load("//bazel/rust:defs.bzl", "rust_binary", "rust_test")

rust_binary(
    name = "basil",
    srcs = glob(["src/**/*.rs"]),
    version_key = None,
    visibility = [
        "//crates/axl-runtime:__pkg__",
    ],
    deps = [
        "//crates/axl-proto",
        "@crates//:base64",
        "@crates//:prost",
    ],
)

rust_test(
    name = "test",
    crate = ":basil",
)
