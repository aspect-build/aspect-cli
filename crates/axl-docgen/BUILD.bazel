load("//bazel/release:release.bzl", "release")
load("//bazel/rust:defs.bzl", "rust_binary", "rust_test")
load("//bazel/rust:multi_platform_rust_binaries.bzl", "multi_platform_rust_binaries")

rust_binary(
    name = "axl-docgen",
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//:__pkg__"],
    deps = [
        "//crates/axl-runtime",
        "@crates//:anyhow",
        "@crates//:clap",
        "@crates//:markdown",
        "@crates//:mdast_util_to_markdown",
        "@crates//:regex",
        "@crates//:starlark",
        "@crates//:syntect",
        "@crates//:tokio",
    ],
)

rust_test(
    name = "test",
    size = "small",
    crate = ":axl-docgen",
)

multi_platform_rust_binaries(
    name = "bins",
    tags = ["no-macos"],
    target = ":axl-docgen",
)

release(
    name = "release",
    tags = ["no-macos"],
    targets = [":bins"],
)
