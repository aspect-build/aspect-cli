#!/usr/bin/env bash
#
# tools/bazel — Bazel wrapper that transparently routes Aspect-specific
# functionality through the `aspect` CLI without forcing developers to learn
# a new command name.
#
# Behavior:
#   - bazel <aspect-verb> [args...]     → exec aspect <verb> [args...]
#       (e.g. `bazel lint`, `bazel format`, `bazel delivery`, `bazel configure`)
#   - bazel <common-verb> [args...]     → exec aspect <verb> [rewritten args]
#       (build, test, run — bazel-native flags become --bazel-flag=<flag>;
#        aspect-native flags pass through unchanged)
#   - bazel <anything else>             → exec $BAZEL_REAL <args>
#       (query, info, clean, mod, version, …)
#
# Flag handling for common verbs:
#   Aspect-native flags (recognized by name in the explicit ASPECT_FLAGS list
#   below) pass through unchanged. Anything else flag-shaped is treated as a
#   Bazel flag and wrapped: `--bazel-flag=<flag>` if standalone or already in
#   --name=value form, or `--bazel-flag=--name=value` if written as `--name
#   value` (space-separated) and `name` appears in the Bazel value-taking
#   flag list. The same rewrite applies to flags BEFORE the verb, except
#   bazel startup flags become `--bazel-startup-flag=<flag>`, which aspect
#   accepts as a post-verb flag.
#
# Drop this script at `tools/bazel` in your workspace and make it executable
# (`chmod +x tools/bazel`). Bazelisk and recent Bazel releases will exec it
# instead of the real bazel binary when present, passing the resolved Bazel
# path via the BAZEL_REAL environment variable.
#
# Environment variables:
#   ASPECT_WRAPPER_VANILLA=1 Forward build/test/run straight to bazel without
#                            routing through aspect. Aspect-only verbs (lint,
#                            format, delivery, …) still route to aspect since
#                            those have no bazel equivalent. Useful for
#                            developers who prefer a vanilla `bazel build`
#                            local workflow while keeping aspect features
#                            available via `aspect <verb>` directly.
#   ASPECT_WRAPPER_TRACE=1   Always print the resolved command (in grey, on
#                            stderr), even when forwarding straight to bazel.
#                            By default the trace prints only when routing
#                            to aspect, since plain bazel forwarding is
#                            uninteresting.
#   ASPECT_WRAPPER_QUIET=1   Suppress the trace line entirely.
#
# Implicit env var (set by aspect, not by users):
#   ASPECT_CLI_RUNNING=1     Aspect sets this on every child bazel it spawns.
#                            When the wrapper sees it, it bypasses ALL routing
#                            and forwards straight to the real bazel,
#                            preventing aspect → tools/bazel → aspect → …
#                            recursion. Customers should never set this
#                            manually. See bazelisk's BAZELISK_SKIP_WRAPPER
#                            for the same pattern.
#
# Source of truth: https://github.com/aspect-build/aspect-cli/blob/main/tools/bazel

set -euo pipefail

# --- Anti-inception bypass ------------------------------------------------
#
# If aspect set ASPECT_CLI_RUNNING, we're being invoked as a CHILD of aspect.
# Skip every code path that would re-enter aspect and forward to the real
# bazel directly. Done before everything else so it costs nothing in the
# common case and can't be defeated by later config.
if [[ -n "${ASPECT_CLI_RUNNING:-}" ]]; then
    if [[ -n "${BAZEL_REAL:-}" && -x "$BAZEL_REAL" ]]; then
        exec "$BAZEL_REAL" "$@"
    fi
    # No BAZEL_REAL (aspect was invoked directly, not through Bazelisk).
    # Find the next bazel on PATH that isn't us.
    self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    while IFS= read -r candidate; do
        if [[ "$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")" != "$self" ]]; then
            exec "$candidate" "$@"
        fi
    done < <(command -v -a bazel 2>/dev/null || true)
    echo "ERROR: tools/bazel: ASPECT_CLI_RUNNING is set but no real bazel found on PATH" >&2
    exit 127
fi


