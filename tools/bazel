# Lookup tables for the membership checks below. We use space-padded strings
# rather than associative arrays so the wrapper runs on the bash 3.2 that
# macOS still ships at /bin/bash. The check is O(n) but n is small (the
# bazel value-flag list is ~370 entries) and bash's `case` pattern match
# is fast enough that it doesn't show up in any real profile.
#
# Membership test: `case " $TABLE " in *" $needle "*) hit ;; esac`
ASPECT_FLAGS_STR=" ${ASPECT_FLAGS[*]} "
BAZEL_VALUE_FLAGS_STR=" ${BAZEL_VALUE_FLAGS[*]} "

# --- Helpers --------------------------------------------------------------

# Print a grey trace line on stderr showing what the wrapper is about to exec.
#
# Usage: trace_exec <category> <argv...>
#
# <category> is "aspect" when routing to aspect (the interesting case — the
# wrapper rewrote something) or "bazel" when forwarding straight to bazel
# (uninteresting; would be visually noisy on `bazel info`, `bazel query`,
# etc.). The trace prints by default for the "aspect" category and is
# suppressed for "bazel" unless ASPECT_WRAPPER_TRACE=1 forces it on.
#
# Suppressed entirely when stderr is not a TTY (so $(...) capture and CI
# logs stay clean), unless ASPECT_WRAPPER_TRACE=1. Always suppressed when
# ASPECT_WRAPPER_QUIET is set.
trace_exec() {
    local category="$1"; shift
    [[ -n "${ASPECT_WRAPPER_QUIET:-}" ]] && return 0
    local force="${ASPECT_WRAPPER_TRACE:-}"
    # Pure bazel forwarding: silent unless explicitly forced.
    if [[ "$category" == "bazel" && -z "$force" ]]; then
        return 0
    fi
    # Aspect routing: silent under non-TTY stderr unless forced.
    if [[ -z "$force" && ! -t 2 ]]; then
        return 0
    fi
    local grey="" reset=""
    if [[ -t 2 || -n "$force" ]]; then
        grey=$'\033[38;5;244m'
        reset=$'\033[0m'
    fi
    # Quote each arg if it contains anything outside the shell-safe character
    # set, so the trace line could be copy-pasted back into a terminal.
    local quoted=""
    local a stripped
    for a in "$@"; do
        # Remove every safe character; whatever remains is "needs quoting".
        stripped="${a//[A-Za-z0-9._\/=:@,+-]/}"
        if [[ -z "$a" || -n "$stripped" ]]; then
            # shellcheck disable=SC2001
            quoted+=" '$(echo "$a" | sed "s/'/'\\\\''/g")'"
        else
            quoted+=" $a"
        fi
    done
    printf '%s[tools/bazel]%s%s\n' "$grey" "$quoted" "$reset" >&2
}

# Locate the real bazel binary. Bazelisk and modern bazel set BAZEL_REAL when
# they exec a wrapper. Fall back to PATH lookup with a recursion guard so we
# never re-enter this wrapper.
resolve_bazel_real() {
    if [[ -n "${BAZEL_REAL:-}" && -x "$BAZEL_REAL" ]]; then
        echo "$BAZEL_REAL"
        return
    fi
    local self
    self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    local candidate
    while IFS= read -r candidate; do
        if [[ "$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")" != "$self" ]]; then
            echo "$candidate"
            return
        fi
    done < <(command -v -a bazel 2>/dev/null || true)
    echo "ERROR: tools/bazel: cannot find a real bazel binary on PATH (and BAZEL_REAL is unset)" >&2
    exit 127
}

contains() {
    local needle="$1"
    shift
    local item
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

# Walk a flag list and classify each token into the OUT array. The caller
# names what to do with non-aspect flags (the WRAPPER_PREFIX, e.g.
# --bazel-flag= or --bazel-startup-flag=).
#
# Usage:  classify_flags <wrapper_prefix> <out_array_name> <args...>
#
# Writes the rewritten tokens to the global array named by <out_array_name>
# (the caller declares it; we append via `eval` because bash 3.2 has no
# nameref support — see https://wiki.bash-hackers.org/scripting/bashchanges).
#
# Behavior per token:
#   --                                → stop classifying; remainder passes through
#   non-flag (target, etc.)           → pass through
#   --name or --name=value where name
#     is a known aspect flag          → pass through unchanged
#   --name=value (otherwise)          → push "<prefix>--name=value"
#   --name where name is a known
#     bazel value-taking flag         → consume next token N, push
#                                       "<prefix>--name=N"
#   --name (otherwise)                → push "<prefix>--name"
classify_flags() {
    local prefix="$1"
    local out_name="$2"
    shift 2
    local tokens=("$@")
    local n=${#tokens[@]}
    local i=0 passthrough=0
    local t body name has_eq next_i emit
    while [[ $i -lt $n ]]; do
        t="${tokens[$i]}"
        if [[ $passthrough -eq 1 || "$t" != -* ]]; then
            eval "$out_name+=(\"\$t\")"; i=$((i + 1)); continue
        fi
        if [[ "$t" == "--" ]]; then
            passthrough=1
            eval "$out_name+=(\"\$t\")"; i=$((i + 1)); continue
        fi
        body="${t#--}"
        name="${body%%=*}"
        has_eq=0
        [[ "$body" == *=* ]] && has_eq=1

        # Aspect flag: pass through unchanged.
        case "$ASPECT_FLAGS_STR" in
            *" $name "*)
                eval "$out_name+=(\"\$t\")"; i=$((i + 1)); continue
                ;;
        esac
        # Bazel flag with =value: wrap as one token.
        if [[ $has_eq -eq 1 ]]; then
            emit="${prefix}${t}"
            eval "$out_name+=(\"\$emit\")"; i=$((i + 1)); continue
        fi
        # Bazel flag with space-value: consume next token, glue with =.
        case "$BAZEL_VALUE_FLAGS_STR" in
            *" $name "*)
                next_i=$((i + 1))
                if [[ $next_i -lt $n ]]; then
                    emit="${prefix}--${name}=${tokens[$next_i]}"
                    eval "$out_name+=(\"\$emit\")"; i=$((i + 2)); continue
                fi
                emit="${prefix}${t}"
                eval "$out_name+=(\"\$emit\")"; i=$((i + 1)); continue
                ;;
        esac
        # Bazel boolean or unknown flag: single token.
        emit="${prefix}${t}"
        eval "$out_name+=(\"\$emit\")"; i=$((i + 1))
    done
}

# --- Dispatch -------------------------------------------------------------

BAZEL_REAL_BIN="$(resolve_bazel_real)"

# Set of known verbs (aspect + bazel) used to disambiguate "is the next token
# the verb or is it the value of a space-separated flag?" If a token equals
# one of these and the preceding arg was a value-taking flag without `=`, we
# break and treat it as the verb rather than the value. Misclassifying a
# real flag-value as a verb would be a bug, but in practice values are paths,
# numbers, regexes, etc. — never one of these short, well-known verb names.
KNOWN_VERBS_STR=" aquery build canonicalize-flags clean configure coverage cquery delivery docs dump fetch format gazelle help info init license lint mobile-install mod outputs print_action query run shutdown test vendor version buildifier "

# Pre-verb walk. Anything flag-shaped is collected. Bare tokens (no leading
# `-`) are either the verb or the value of a preceding space-separated flag;
# we disambiguate by checking KNOWN_VERBS_STR. `--` before any verb is
# treated as "no verb" — forward the whole thing to bazel verbatim.
pre_verb=()
verb=""
verb_idx=-1
args=("$@")
n_args=${#args[@]}
prev_was_value_taking=0
i=0
while [[ $i -lt $n_args ]]; do
    arg="${args[$i]}"
    if [[ "$arg" == "--" ]]; then
        break
    fi
    if [[ "$arg" == -* ]]; then
        pre_verb+=("$arg")
        # Is this flag a value-taker that COULD consume the next non-flag arg?
        body="${arg#--}"
        name="${body%%=*}"
        if [[ "$body" == *=* ]]; then
            prev_was_value_taking=0
        else
            case "$BAZEL_VALUE_FLAGS_STR$ASPECT_FLAGS_STR" in
                *" $name "*) prev_was_value_taking=1 ;;
                *) prev_was_value_taking=0 ;;
            esac
        fi
        i=$((i + 1))
        continue
    fi
    # Bare token. If it's a known verb, OR if the previous arg wasn't a
    # value-taker, treat it as the verb. Otherwise consume it as the
    # previous flag's value and keep walking.
    is_known_verb=0
    case "$KNOWN_VERBS_STR" in
        *" $arg "*) is_known_verb=1 ;;
    esac
    if [[ $is_known_verb -eq 1 || $prev_was_value_taking -eq 0 ]]; then
        verb="$arg"
        verb_idx=$i
        break
    fi
    pre_verb+=("$arg")
    prev_was_value_taking=0
    i=$((i + 1))
done

# No verb: forward verbatim to bazel.
if [[ -z "$verb" ]]; then
    trace_exec bazel "$BAZEL_REAL_BIN" "$@"
    exec "$BAZEL_REAL_BIN" "$@"
fi

# Aspect-only verb: always route to aspect. Aspect is extensible — custom
# tasks defined in .axl files can have any name — so we can't safely assume
# unknown verbs are bazel commands. Pre-verb args route to either aspect
# (if recognized as aspect global flags) or as --bazel-startup-flag=.
if contains "$verb" "${ASPECT_VERBS[@]}"; then
    pre_for_aspect=()
    if [[ ${#pre_verb[@]} -gt 0 ]]; then
        classify_flags "--bazel-startup-flag=" pre_for_aspect "${pre_verb[@]}"
    fi
    post=("${@:$((verb_idx + 2))}")
    export BAZEL_REAL="$BAZEL_REAL_BIN"
    trace_exec aspect aspect "${pre_for_aspect[@]}" "$verb" "${post[@]}"
    exec aspect "${pre_for_aspect[@]}" "$verb" "${post[@]}"
fi

# Common verb under vanilla mode: forward to bazel without rewriting.
# Developers who prefer a vanilla `bazel build` workflow set
# ASPECT_WRAPPER_VANILLA=1 in their shell rc; aspect-only verbs above still
# route through aspect because there is no bazel equivalent.
if [[ -n "${ASPECT_WRAPPER_VANILLA:-}" ]] && contains "$verb" "${COMMON_VERBS[@]}"; then
    trace_exec bazel "$BAZEL_REAL_BIN" "$@"
    exec "$BAZEL_REAL_BIN" "$@"
fi

# Non-common verb: stays on vanilla bazel.
if ! contains "$verb" "${COMMON_VERBS[@]}"; then
    trace_exec bazel "$BAZEL_REAL_BIN" "$@"
    exec "$BAZEL_REAL_BIN" "$@"
fi

# Common verb: classify pre-verb and post-verb args.
pre_for_aspect=()
if [[ ${#pre_verb[@]} -gt 0 ]]; then
    classify_flags "--bazel-startup-flag=" pre_for_aspect "${pre_verb[@]}"
fi
post=("${@:$((verb_idx + 2))}")
post_rewritten=()
if [[ ${#post[@]} -gt 0 ]]; then
    classify_flags "--bazel-flag=" post_rewritten "${post[@]}"
fi

# Aspect accepts --bazel-startup-flag as a POST-verb flag. Move pre-verb
# startup-flag forwards into the post-verb position. Aspect global flags
# (--task-key, --timing, etc.) stay in pre-verb position where they belong.
pre_globals=()
pre_bazel_starts=()
for arg in "${pre_for_aspect[@]}"; do
    if [[ "$arg" == --bazel-startup-flag=* ]]; then
        pre_bazel_starts+=("$arg")
    else
        pre_globals+=("$arg")
    fi
done

export BAZEL_REAL="$BAZEL_REAL_BIN"
trace_exec aspect aspect "${pre_globals[@]}" "$verb" "${pre_bazel_starts[@]}" "${post_rewritten[@]}"
exec aspect "${pre_globals[@]}" "$verb" "${pre_bazel_starts[@]}" "${post_rewritten[@]}"
